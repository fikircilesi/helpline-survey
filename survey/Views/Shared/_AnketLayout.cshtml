<!DOCTYPE html>
<html lang="tr">
<head>
    <title>Aslana Survey Studio</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=0, minimal-ui">
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <link rel="icon" href="~/Content/img/aslana-favicon.png" type="image/png">
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:400,600" rel="stylesheet">

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/files/bower_components/bootstrap/dist/css/bootstrap.min.css"
          onerror="this.onerror=null;this.href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css'">

    <!-- Icon Fonts -->
    <link rel="stylesheet" href="~/files/assets/icon/feather/css/feather.css">
    <link rel="stylesheet" href="~/files/assets/icon/themify-icons/themify-icons.css">
    <link rel="stylesheet" href="~/files/assets/icon/icofont/css/icofont.css">
    <link rel="stylesheet" href="~/files/assets/icon/font-awesome/css/font-awesome.min.css">

    <!-- Tema CSS -->
    <link rel="stylesheet" href="~/files/assets/css/component.css">
    <link rel="stylesheet" href="~/files/assets/css/style.css">
    <link rel="stylesheet" href="~/css/studio-legacy.css" asp-append-version="true">
</head>

<body>
    <div class="main-body">
        <div class="page-wrapper">
            @RenderBody()

            <div class="text-center mt-4">
                <a href="@Url.Action("Giris","Home")">
                    <img src="~/Content/img/aslana-logo.png" width="112" alt="Aslana Survey Studio" />
                </a>
            </div>
        </div>
    </div>

    <!-- jQuery (TEK jQuery!) -->
    <script src="~/files/bower_components/jquery/dist/jquery.min.js"></script>

    <!-- !!! slimScroll mutlaka jQuery'den SONRA ve script.js'den ÖNCE -->
    <script src="~/files/bower_components/jquery-slimscroll/jquery.slimscroll.min.js"></script>

    <!-- Bootstrap JS (bundle=Popper dahil) -->
    <script src="~/files/bower_components/bootstrap/dist/js/bootstrap.bundle.min.js"
            onerror="this.onerror=null;this.src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js'"></script>

    <!-- Scrollbar (mCustomScrollbar kullanıyorsanız; değilse çıkarın) -->
    <script src="~/files/assets/js/jquery.mCustomScrollbar.concat.min.js"></script>

    <!-- Çekirdek tema JS (bunlar init yapar; gerekli pluginler yukarıda hazır olmalı) -->
    <script src="~/files/assets/js/pcoded.min.js"></script>
    <script src="~/files/assets/js/vartical-layout.min.js"></script>

    <!-- script.js bazen slimScroll/select2 vs bekleyebilir; o yüzden pluginlerden SONRA -->
    <script src="~/files/assets/js/script.js" asp-append-version="true"></script>

    <!-- Grafik/Plugin JS'leri (kullanıyorsanız) -->
    

    

    
    <!-- modal.js sorun çıkarıyorsa korumalı hale getirin (aşağıda snippet var) -->
    

    

    <!-- Masking -->
    

    <!-- i18n -->
    

    <!-- Nestable (kullanılan sayfalarda lazım; global yüklüyorsanız korumalı kullanın) -->
    
    <script src="~/js/studio-legacy.js" asp-append-version="true"></script>

    @* Sayfa özel scriptlerini burada isteğe bağlı render edin *@
    @RenderSection("Scripts", required: false)
</body>
</html>
