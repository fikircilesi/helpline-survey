<!DOCTYPE html>
<html lang="tr">
<head>
    <title>Evalio by Aslana</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=0, minimal-ui">
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <link rel="icon" href="~/files/assets/images/favicon.ico" type="image/x-icon">
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:400,600" rel="stylesheet">

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/files/bower_components/bootstrap/dist/css/bootstrap.min.css"
          onerror="this.onerror=null;this.href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css'">

    <!-- Icon Fonts -->
    <link rel="stylesheet" href="~/files/assets/icon/feather/css/feather.css">
    <link rel="stylesheet" href="~/files/assets/icon/themify-icons/themify-icons.css">
    <link rel="stylesheet" href="~/files/assets/icon/ion-icon/css/ionicons.min.css">
    <link rel="stylesheet" href="~/files/assets/icon/icofont/css/icofont.css">
    <link rel="stylesheet" href="~/files/assets/icon/typicons-icons/css/typicons.min.css">
    <link rel="stylesheet" href="~/files/assets/icon/material-design/css/material-design-iconic-font.min.css">
    <link rel="stylesheet" href="~/files/assets/icon/font-awesome/css/font-awesome.min.css">

    <!-- Plugins CSS -->
    <link rel="stylesheet" href="~/files/assets/css/jquery.mCustomScrollbar.css">
    <link rel="stylesheet" href="~/files/assets/css/component.css">
    <link rel="stylesheet" href="~/files/assets/css/sweetalert.css">
    <link rel="stylesheet" href="~/files/assets/pages/nestable/nestable.css">
    <link rel="stylesheet" href="~/files/bower_components/select2/dist/css/select2.min.css">
    <link rel="stylesheet" href="~/files/bower_components/bootstrap-multiselect/dist/css/bootstrap-multiselect.css">
    <link rel="stylesheet" href="~/files/bower_components/multiselect/css/multi-select.css">
    <link rel="stylesheet" href="~/files/bower_components/c3/c3.css">
    <link rel="stylesheet" href="~/files/bower_components/nvd3/build/nv.d3.css">

    <!-- Ana stil -->
    <link rel="stylesheet" href="~/files/assets/css/style.css">
</head>

<body>
    <div class="main-body">
        <div class="page-wrapper">
            @RenderBody()

            <div class="text-center mt-4">
                <a href="@Url.Action("Giris","Home")">
                    <img src="~/Content/img/evalio-mark.svg" width="54" alt="Evalio by Aslana" />
                </a>
            </div>
        </div>
    </div>

    <!-- jQuery (TEK jQuery!) -->
    <script src="~/files/bower_components/jquery/dist/jquery.min.js"></script>
    <script src="~/files/bower_components/jquery-ui/jquery-ui.min.js"></script>

    <!-- !!! slimScroll mutlaka jQuery'den SONRA ve script.js'den ÖNCE -->
    <script src="~/files/bower_components/jquery-slimscroll/jquery.slimscroll.min.js"></script>

    <!-- Bootstrap JS (bundle=Popper dahil) -->
    <script src="~/files/bower_components/bootstrap/dist/js/bootstrap.bundle.min.js"
            onerror="this.onerror=null;this.src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js'"></script>

    <!-- Scrollbar (mCustomScrollbar kullanıyorsanız; değilse çıkarın) -->
    <script src="~/files/assets/js/jquery.mCustomScrollbar.concat.min.js"></script>

    <!-- Çekirdek tema JS (bunlar init yapar; gerekli pluginler yukarıda hazır olmalı) -->
    <script src="~/files/assets/js/pcoded.min.js"></script>
    <script src="~/files/assets/js/vartical-layout.min.js"></script>

    <!-- script.js bazen slimScroll/select2 vs bekleyebilir; o yüzden pluginlerden SONRA -->
    <script src="~/files/assets/js/script.js" asp-append-version="true"></script>

    <!-- Grafik/Plugin JS'leri (kullanıyorsanız) -->
    <script src="~/files/bower_components/chart.js/dist/Chart.js"></script>
    <script src="~/files/assets/pages/widget/amchart/amcharts.js"></script>
    <script src="~/files/assets/pages/widget/amchart/serial.js"></script>
    <script src="~/files/assets/pages/widget/amchart/light.js"></script>

    <script src="~/files/bower_components/d3/d3.min.js"></script>
    <script src="~/files/bower_components/c3/c3.js"></script>
    <script src="~/files/bower_components/nvd3/build/nv.d3.js"></script>

    <script src="~/files/assets/js/sweetalert.js"></script>
    <script src="~/files/assets/js/classie.js"></script>
    <script src="~/files/assets/js/modalEffects.js"></script>
    <!-- modal.js sorun çıkarıyorsa korumalı hale getirin (aşağıda snippet var) -->
    <script src="~/files/assets/js/modal.js" asp-append-version="true"></script>

    <script src="~/files/bower_components/select2/dist/js/select2.full.min.js"></script>
    <script src="~/files/bower_components/bootstrap-multiselect/dist/js/bootstrap-multiselect.js"></script>
    <script src="~/files/bower_components/multiselect/js/jquery.multi-select.js"></script>
    <script src="~/files/assets/js/jquery.quicksearch.js"></script>

    <!-- Masking -->
    <script src="~/files/assets/pages/form-masking/inputmask.js"></script>
    <script src="~/files/assets/pages/form-masking/jquery.inputmask.js"></script>
    <script src="~/files/assets/pages/form-masking/autoNumeric.js"></script>
    <script src="~/files/assets/pages/form-masking/form-mask.js"></script>

    <!-- i18n -->
    <script src="~/files/bower_components/i18next/i18next.min.js"></script>
    <script src="~/files/bower_components/i18next-xhr-backend/i18nextXHRBackend.min.js"></script>
    <script src="~/files/bower_components/i18next-browser-languagedetector/i18nextBrowserLanguageDetector.min.js"></script>
    <script src="~/files/bower_components/jquery-i18next/jquery-i18next.min.js"></script>

    <!-- Nestable (kullanılan sayfalarda lazım; global yüklüyorsanız korumalı kullanın) -->
    <script src="~/files/assets/pages/nestable/jquery.nestable.js" asp-append-version="true"></script>
    <script src="~/files/assets/pages/nestable/custom-nestable.js" asp-append-version="true"></script>

    @* Sayfa özel scriptlerini burada isteğe bağlı render edin *@
    @RenderSection("Scripts", required: false)
</body>
</html>
