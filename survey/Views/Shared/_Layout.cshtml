<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <title>Survey by Aslana Teknoloji | Anket, Sınav ve Sertifika Platformu</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=0, minimal-ui" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- Favicon -->
    <link rel="icon" href="~/Content/img/aslana-favicon.png" type="image/png" />

    <!-- Fonts (tek satır yeterli) -->
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:400,600&display=swap" rel="stylesheet" />

    <!-- Core CSS (kritik olanlar) -->
    <link rel="stylesheet" href="~/files/bower_components/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/files/assets/icon/feather/css/feather.css" />
    <link rel="stylesheet" href="~/files/assets/icon/font-awesome/css/font-awesome.min.css" />
    <link rel="stylesheet" href="~/files/assets/icon/themify-icons/themify-icons.css" />
    <link rel="stylesheet" href="~/files/assets/css/style.css" />
    <link rel="stylesheet" href="~/files/assets/css/component.css" />
    <link rel="stylesheet" href="~/css/studio-legacy.css" asp-append-version="true" />

    <!-- Kaldırılanlar / varsayılan kapalı:
         - jquery.mCustomScrollbar.css
         - c3.css, nvd3.css, nestable.css, sweetalert.css (gerekli sayfada section ile)
         - icofont, ionicons, typicons, material-design (hepsi yerine feather+fa yeterli)
    -->
    <!-- Performans: ağır içeriklere görünürlük bazlı render -->
    <style>
        :root {
            --studio-sidebar-width: 272px;
            --studio-sidebar-collapsed-width: 84px;
            --studio-header-height: 64px;
        }

        /* Native scroll kullan, custom scrollbar kapalı */
        html, body {
            margin: 0;
            padding: 0;
            overscroll-behavior-y: none;
        }
        /* Büyük içerikli containerlarda boyama gecikmesini azaltır */
        .page-wrapper {
            content-visibility: auto;
            contain-intrinsic-size: 1000px 800px;
        }
        /* Header/Sidebar fix’lerinde GPU tepkisini yumuşatır */
        .pcoded-navbar, .pcoded-header {
            will-change: transform;
        }
        /* Preloader'ı istersen tamamen kapat */
        .theme-loader {
            display: none !important;
        }

        .pcoded-header,
        .pcoded-header .navbar-wrapper,
        .pcoded-header .navbar-logo {
            min-height: var(--studio-header-height);
            height: var(--studio-header-height);
        }

        .pcoded-header .navbar-logo {
            width: var(--studio-sidebar-width);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 18px;
            box-sizing: border-box;
            overflow: hidden;
        }

        .navbar-logo .studio-brand-link {
            min-width: 0;
            display: inline-flex !important;
            align-items: center;
            justify-content: flex-start;
            gap: 10px;
            flex: 1 1 auto;
            margin-left: 0;
            min-height: 50px;
            padding: 0;
            align-self: center;
            border: 0;
            border-radius: 0;
            background: transparent;
            color: #fff;
            text-decoration: none;
            box-shadow: none;
            overflow: hidden;
            box-sizing: border-box;
        }

        .navbar-logo .studio-brand-link:hover,
        .navbar-logo .studio-brand-link:focus {
            color: #fff;
            text-decoration: none;
        }

        .studio-brand-mark {
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex: 0 0 56px;
            width: 56px;
            height: 44px;
            margin-left: 0;
            border: 0;
            border-radius: 0;
            background: transparent;
            box-shadow: none;
            overflow: visible;
        }

        .studio-brand-mark::before {
            content: none;
        }

        .studio-brand-mark::after {
            content: none;
        }

        .studio-brand-sketch {
            position: relative;
            z-index: 1;
            display: block;
            width: 56px;
            height: 44px;
            color: #fff;
            overflow: visible;
            filter: drop-shadow(0 8px 14px rgba(0, 0, 0, .16));
        }

        .studio-brand-sketch path,
        .studio-brand-sketch line,
        .studio-brand-sketch rect,
        .studio-brand-sketch polyline {
            fill: none;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .studio-brand-sketch .survey-sheet,
        .studio-brand-sketch .survey-fold {
            stroke: rgba(255, 255, 255, .92);
            stroke-width: 3.1;
        }

        .studio-brand-sketch .survey-form-line {
            stroke: rgba(255, 255, 255, .82);
            stroke-width: 2.4;
        }

        .studio-brand-sketch .survey-box.mint {
            stroke: #7df4c7;
        }

        .studio-brand-sketch .survey-box.blue {
            stroke: #38bdf8;
        }

        .studio-brand-sketch .survey-box.coral {
            stroke: #fb7185;
        }

        .studio-brand-sketch .survey-check {
            stroke: url(#studioSurveyCheckGradient);
            stroke-width: 4.4;
        }

        .studio-brand-sketch .survey-check-shadow {
            stroke: rgba(251, 113, 133, .28);
            stroke-width: 7;
        }

        .studio-brand-copy {
            min-width: 0;
            max-width: 112px;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 0;
            line-height: 1;
            text-align: left;
            overflow: hidden;
        }

        .studio-brand-copy strong {
            display: block;
            margin: 0;
            color: #fff;
            font-size: 25px;
            font-weight: 850;
            letter-spacing: 0;
            white-space: nowrap;
            text-transform: lowercase;
        }

        .studio-brand-copy span {
            display: block;
            margin: 0;
            color: rgba(255, 255, 255, .74);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0;
            white-space: nowrap;
            text-transform: none !important;
        }

        .navbar-logo .mobile-menu,
        .navbar-logo .mobile-options {
            flex: 0 0 auto;
        }

        .studio-sidebar-inner {
            min-height: calc(100vh - var(--studio-header-height));
            display: flex;
            flex-direction: column;
            padding: 18px 14px;
        }

        .studio-menu-label {
            margin: 4px 10px 14px;
            color: rgba(255, 255, 255, .52);
            font-size: 14px;
            letter-spacing: .02em;
        }

        .studio-menu {
            flex: 1 1 auto;
            display: grid;
            align-content: start;
            gap: 8px;
            margin: 0;
            padding: 0;
            list-style: none;
        }

        .studio-menu details {
            margin: 0;
        }

        .studio-menu summary {
            list-style: none;
        }

        .studio-menu summary::-webkit-details-marker {
            display: none;
        }

        .studio-menu-link,
        .studio-menu-summary {
            min-height: 44px;
            display: grid;
            grid-template-columns: 34px minmax(0, 1fr) 16px;
            align-items: center;
            column-gap: 12px;
            padding: 5px 8px;
            border-radius: 8px;
            color: rgba(255, 255, 255, .86);
            cursor: pointer;
            transition: background .18s ease, color .18s ease;
        }

        .studio-menu-link:hover,
        .studio-menu-summary:hover,
        .studio-menu details[open] > .studio-menu-summary {
            color: #fff;
            background: rgba(255, 255, 255, .08);
        }

        .studio-menu-icon {
            width: 34px;
            height: 34px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            color: #fff;
            font-size: 16px;
        }

        .studio-menu-icon.blue { background: #2196f3; }
        .studio-menu-icon.rose { background: #ff7588; }
        .studio-menu-icon.green { background: #16d39a; }
        .studio-menu-icon.amber { background: #f6a609; }

        .studio-menu-text {
            min-width: 0;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            font-size: 14px;
            font-weight: 600;
        }

        .studio-menu-chevron {
            justify-self: end;
            transition: transform .18s ease;
        }

        .studio-menu details[open] .studio-menu-chevron {
            transform: rotate(90deg);
        }

        .studio-submenu {
            display: grid;
            gap: 4px;
            margin: 4px 0 8px 48px;
        }

        .studio-submenu a {
            min-height: 34px;
            display: flex;
            align-items: center;
            padding: 0 10px;
            border-radius: 7px;
            color: rgba(255, 255, 255, .68);
            font-size: 13px;
            font-weight: 600;
        }

        .studio-submenu a:hover {
            color: #fff;
            background: rgba(255, 255, 255, .08);
        }

        .pcoded-inner-navbar.main-menu {
            min-height: calc(100vh - 76px);
            display: flex;
            flex-direction: column;
        }

        .pcoded-left-item {
            flex: 1 1 auto;
        }

        .sidebar-account {
            margin-top: auto;
            padding: 14px 14px 18px;
            border-top: 1px solid rgba(255, 255, 255, 0.09);
        }

        .sidebar-user-card {
            background: rgba(255, 255, 255, 0.07);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 8px;
            padding: 12px;
            color: #fff;
        }

        .sidebar-user-main {
            display: flex;
            align-items: center;
            gap: 10px;
            min-width: 0;
        }

        .sidebar-user-main img {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            object-fit: cover;
            background: rgba(255, 255, 255, 0.18);
            flex: 0 0 auto;
        }

        .sidebar-user-name {
            display: block;
            max-width: 118px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            font-weight: 700;
            font-size: 13px;
            line-height: 1.2;
        }

        .sidebar-user-role {
            display: block;
            color: rgba(255, 255, 255, 0.62);
            font-size: 11px;
            margin-top: 2px;
        }

        .sidebar-user-actions {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 7px;
            margin-top: 12px;
        }

        .sidebar-user-actions.two-actions {
            grid-template-columns: repeat(2, 1fr);
        }

        body.studio-personel .sidebar-user-actions {
            grid-template-columns: repeat(2, 1fr);
        }

        body.studio-personel .sidebar-user-actions a[title="Ayarlar"] {
            display: none;
        }

        .sidebar-user-actions a {
            height: 32px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 7px;
            color: rgba(255, 255, 255, 0.82);
            background: rgba(255, 255, 255, 0.08);
            transition: background 0.18s ease, color 0.18s ease, transform 0.18s ease;
        }

        .sidebar-user-actions a:hover {
            color: #fff;
            background: rgba(123, 230, 190, 0.2);
            transform: translateY(-1px);
        }

        .settings-list-panel {
            width: min(100%, 980px);
            margin: 32px auto 0;
            overflow: hidden;
            border: 1px solid #dde6f1;
            border-radius: 8px;
            background: #fff;
            box-shadow: 0 18px 42px rgba(15, 23, 42, .07);
        }

        .settings-list-panel > div:not([class]) {
            min-height: 68px;
            display: flex;
            align-items: center;
            padding: 0 28px;
            background: linear-gradient(135deg, #142032 0%, #183f49 100%);
        }

        .settings-list-panel h4 {
            margin: 0;
            color: #fff;
            font-size: 20px;
            font-weight: 700;
            line-height: 1.2;
        }

        .settings-list-panel .panel-body {
            padding: 24px 28px 28px;
            overflow-x: auto;
        }

        .settings-list-panel .table {
            width: 100%;
            min-width: 720px;
            margin-bottom: 0;
            border: 1px solid #dde6f1;
            border-radius: 8px;
            overflow: hidden;
            background: #fff;
        }

        .settings-list-panel .table th,
        .settings-list-panel .table td {
            height: 54px;
            padding: 12px 18px;
            vertical-align: middle;
            border-color: #e8edf4;
            color: #102033;
            white-space: nowrap;
        }

        .settings-list-panel .table tr:first-child th,
        .settings-list-panel .table thead th,
        .settings-list-panel .table thead td {
            background: #f4f8fc;
            color: #102033;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: .01em;
            text-transform: uppercase;
        }

        .settings-list-panel .table a.fa {
            width: 34px;
            height: 34px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-right: 8px;
            border-radius: 8px;
            font-size: 13px;
            text-decoration: none;
        }

        .settings-list-panel .table a.fa-pencil {
            color: #0f3156;
            background: #eef5fb;
            border: 1px solid #d9e6f2;
        }

        .settings-list-panel .table a.fa-trash-o {
            color: #ef3d56;
            background: #fff2f4;
            border: 1px solid #ffd7dd;
        }

        .settings-list-panel .panel-body > .col-lg-9:empty {
            display: none;
        }

        .settings-list-panel .panel-body > .col-lg-3,
        .settings-list-panel .settings-list-actions {
            width: auto;
            float: none;
            display: flex;
            gap: 10px;
            align-items: center;
            margin-top: 14px;
            padding: 0;
        }

        .settings-list-panel .btn {
            min-width: 64px;
            height: 40px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 0 !important;
            border-radius: 8px !important;
            color: #fff !important;
            font-weight: 700;
            box-shadow: 0 8px 18px rgba(15, 23, 42, .12);
        }

        .settings-status-badge {
            min-height: 26px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0 10px;
            border: 1px solid #d7e2ee;
            border-radius: 999px;
            color: #526172;
            background: #f6f8fb;
            font-size: 12px;
            font-weight: 800;
            line-height: 1;
            white-space: nowrap;
        }

        .settings-status-badge.active {
            color: #047857;
            border-color: #bbf7d0;
            background: #ecfdf5;
        }

        .settings-status-badge.passive {
            color: #64748b;
            border-color: #dbe3ec;
            background: #f1f5f9;
        }

        .settings-status-badge.admin {
            color: #1d4ed8;
            border-color: #bfdbfe;
            background: #eff6ff;
        }

        .settings-status-badge.neutral {
            color: #475569;
            border-color: #d7e2ee;
            background: #f8fafc;
        }

        .settings-status-badge.warning {
            color: #b45309;
            border-color: #fde68a;
            background: #fffbeb;
        }

        .settings-user-list-panel > .col-lg-9 {
            display: none;
        }

        .settings-user-list-panel > .col-lg-3 {
            width: 100%;
            float: none;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0 28px;
            min-height: 68px;
            background: linear-gradient(135deg, #142032 0%, #183f49 100%);
        }

        .settings-user-list-panel > .col-lg-3 h4 {
            order: 1;
            flex: 1 1 auto;
        }

        .settings-user-list-panel > .col-lg-3 .btn {
            order: 2;
            margin: 0;
        }

        .settings-user-list-panel > .col-lg-12 {
            width: 100%;
            float: none;
            padding: 24px 28px 28px;
            overflow-x: auto !important;
        }

        .settings-user-list-panel .dataTables_wrapper {
            min-width: 760px;
        }

        .settings-user-list-panel .dataTables_length,
        .settings-user-list-panel .dataTables_filter {
            margin-bottom: 14px;
        }

        .settings-user-list-panel .dataTables_filter input,
        .settings-user-list-panel .dataTables_length select {
            min-height: 38px;
            border: 1px solid #d7e2ee;
            border-radius: 8px;
            color: #102033;
        }

        .settings-form-panel {
            width: min(100%, 980px);
            margin: 32px auto 0;
            overflow: hidden;
            border: 1px solid #dde6f1;
            border-radius: 8px;
            background: #fff;
            box-shadow: 0 18px 42px rgba(15, 23, 42, .07);
        }

        .settings-personel-form-panel {
            width: min(100%, 760px);
        }

        .settings-form-heading {
            min-height: 68px;
            display: flex;
            align-items: center;
            padding: 0 28px;
            background: linear-gradient(135deg, #142032 0%, #183f49 100%);
        }

        .settings-form-heading h4 {
            margin: 0;
            color: #fff;
            font-size: 20px;
            font-weight: 700;
            line-height: 1.2;
        }

        .settings-form-body {
            padding: 24px 28px 28px;
        }

        .settings-form-body .form-group {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 16px 20px;
            margin: 0;
        }

        .settings-form-body .form-group > div {
            width: 100%;
            float: none;
            min-width: 0;
            margin: 0;
            padding: 0;
        }

        .settings-form-body .form-group > div[hidden] {
            display: none !important;
        }

        .settings-form-body b,
        .settings-form-body h5,
        .settings-form-body .form-label {
            display: block;
            margin: 0 0 7px;
            color: #4a5b70;
            font-size: 12px;
            font-weight: 700;
            line-height: 1.25;
        }

        .settings-form-body .form-control {
            width: 100%;
            min-height: 42px;
            border: 1px solid #d7e2ee;
            border-radius: 8px;
            color: #102033;
            box-shadow: none;
        }

        .settings-form-body .checkbox-color {
            display: flex;
            align-items: center;
            gap: 8px;
            padding-top: 22px;
        }

        .settings-form-body .checkbox-color input {
            margin: 0;
        }

        .settings-form-body .checkbox-color .form-label {
            margin: 0;
        }

        .settings-form-actions {
            display: flex;
            gap: 10px;
            align-items: center;
            margin-top: 20px;
        }

        .settings-form-panel .btn {
            min-width: 64px;
            height: 40px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 0 !important;
            border-radius: 8px !important;
            color: #fff !important;
            font-weight: 700;
            box-shadow: 0 8px 18px rgba(15, 23, 42, .12);
        }

        @@media (max-width: 991.98px) {
            .settings-list-panel {
                width: 100%;
                margin-top: 16px;
            }

            .settings-list-panel > div:not([class]),
            .settings-user-list-panel > .col-lg-3 {
                padding: 0 18px;
            }

            .settings-list-panel .panel-body,
            .settings-user-list-panel > .col-lg-12,
            .settings-form-body {
                padding: 18px;
            }

            .settings-form-panel {
                width: 100%;
                margin-top: 16px;
            }

            .settings-form-heading {
                padding: 0 18px;
            }

            .settings-form-body .form-group {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 991.98px) {
            body.studio-mobile-menu-open {
                overflow: hidden;
            }

            #pcoded[theme-layout="vertical"] .pcoded-header {
                width: 0 !important;
                height: 0 !important;
                min-height: 0 !important;
                left: 0 !important;
                right: 0 !important;
                top: 0 !important;
                box-shadow: none !important;
                background: transparent !important;
                pointer-events: none;
                z-index: 1060;
            }

            #pcoded[theme-layout="vertical"] .pcoded-header .navbar-wrapper,
            #pcoded[theme-layout="vertical"] .pcoded-header .navbar-logo {
                width: 0 !important;
                max-width: 0 !important;
                height: 0 !important;
                min-height: 0 !important;
                overflow: visible;
                background: transparent !important;
            }

            #pcoded[theme-layout="vertical"] .pcoded-header .navbar-logo {
                padding: 0;
                gap: 0;
            }

            #pcoded[theme-layout="vertical"] .navbar-logo .studio-brand-link,
            #pcoded[theme-layout="vertical"] .navbar-logo .mobile-options {
                display: none !important;
            }

            #pcoded[theme-layout="vertical"] .navbar-logo .mobile-menu {
                width: 34px;
                height: 34px;
                display: inline-flex !important;
                align-items: center;
                justify-content: center;
                flex: 0 0 34px;
                position: fixed !important;
                top: 12px !important;
                left: 12px !important;
                z-index: 1062;
                border-radius: 8px;
                color: rgba(255, 255, 255, .88);
                background: #404e67;
                box-shadow: 0 10px 22px rgba(15, 23, 42, .18);
                pointer-events: auto;
            }

            #pcoded[theme-layout="vertical"] .pcoded-main-container {
                width: 100% !important;
                margin-left: 0 !important;
                margin-top: 0 !important;
            }

            #pcoded[theme-layout="vertical"] .pcoded-content {
                width: 100% !important;
                margin-left: 0 !important;
                overflow-x: hidden;
            }

            #pcoded[theme-layout="vertical"] .pcoded-navbar {
                position: fixed !important;
                top: 0 !important;
                left: 0 !important;
                margin-left: 0 !important;
                width: min(286px, calc(100vw - 36px)) !important;
                height: 100vh !important;
                min-height: 0 !important;
                max-height: 100vh !important;
                z-index: 1059;
                transform: translateX(-105%) !important;
                transition: transform .22s ease;
                overflow-y: auto;
                overflow-x: visible;
                background: #404e67;
                box-shadow: 18px 0 36px rgba(15, 23, 42, .24);
            }

            #pcoded.studio-mobile-menu-open[theme-layout="vertical"] .pcoded-navbar {
                transform: translateX(0) !important;
            }

            #pcoded[theme-layout="vertical"] .studio-sidebar-inner {
                min-height: 100vh;
                padding: 72px 14px 18px;
            }

            #pcoded[theme-layout="vertical"] .pcoded-overlay-box {
                position: fixed !important;
                inset: 0;
                z-index: 1058;
                pointer-events: none !important;
                opacity: 0 !important;
                visibility: hidden !important;
                background: rgba(15, 23, 42, .42);
                transition: opacity .18s ease, visibility .18s ease;
            }

            #pcoded.studio-mobile-menu-open[theme-layout="vertical"] .pcoded-overlay-box {
                pointer-events: auto !important;
                opacity: 1 !important;
                visibility: visible !important;
            }
