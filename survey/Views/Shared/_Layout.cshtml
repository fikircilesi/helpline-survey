<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <title>Aslana Survey Studio | Anket, Sınav ve Sertifika Platformu</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=0, minimal-ui" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- Favicon -->
    <link rel="icon" href="~/files/assets/images/favicon.ico" type="image/x-icon" />

    <!-- Fonts (tek satır yeterli) -->
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:400,600&display=swap" rel="stylesheet" />

    <!-- Core CSS (kritik olanlar) -->
    <link rel="stylesheet" href="~/files/bower_components/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/files/assets/icon/feather/css/feather.css" />
    <link rel="stylesheet" href="~/files/assets/icon/font-awesome/css/font-awesome.min.css" />
    <link rel="stylesheet" href="~/files/assets/icon/themify-icons/themify-icons.css" />
    <link rel="stylesheet" href="~/files/assets/css/style.css" />
    <link rel="stylesheet" href="~/files/assets/css/component.css" />
    <link rel="stylesheet" href="~/css/studio-legacy.css" asp-append-version="true" />

    <!-- Kaldırılanlar / varsayılan kapalı:
         - jquery.mCustomScrollbar.css
         - c3.css, nvd3.css, nestable.css, sweetalert.css (gerekli sayfada section ile)
         - icofont, ionicons, typicons, material-design (hepsi yerine feather+fa yeterli)
    -->
    <!-- Performans: ağır içeriklere görünürlük bazlı render -->
    <style>
        :root {
            --studio-sidebar-width: 272px;
            --studio-header-height: 64px;
        }

        /* Native scroll kullan, custom scrollbar kapalı */
        html, body {
            overscroll-behavior-y: none;
        }
        /* Büyük içerikli containerlarda boyama gecikmesini azaltır */
        .page-wrapper {
            content-visibility: auto;
            contain-intrinsic-size: 1000px 800px;
        }
        /* Header/Sidebar fix’lerinde GPU tepkisini yumuşatır */
        .pcoded-navbar, .pcoded-header {
            will-change: transform;
        }
        /* Preloader'ı istersen tamamen kapat */
        .theme-loader {
            display: none !important;
        }

        .pcoded-header,
        .pcoded-header .navbar-wrapper,
        .pcoded-header .navbar-logo {
            min-height: var(--studio-header-height);
            height: var(--studio-header-height);
        }

        .pcoded-header .navbar-logo {
            width: var(--studio-sidebar-width);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 18px;
        }

        .navbar-logo .brand-logo {
            width: 196px !important;
            max-width: 196px !important;
            height: 44px !important;
            object-fit: contain !important;
            object-position: left center;
            display: block !important;
        }

        .navbar-logo .studio-brand-link {
            min-width: 0;
            display: inline-flex !important;
            align-items: center;
            justify-content: flex-start;
            flex: 1 1 auto;
            margin-left: 8px;
            overflow: hidden;
        }

        .navbar-logo .mobile-menu,
        .navbar-logo .mobile-options {
            flex: 0 0 auto;
        }

        .studio-sidebar-inner {
            min-height: calc(100vh - var(--studio-header-height));
            display: flex;
            flex-direction: column;
            padding: 18px 14px;
        }

        .studio-menu-label {
            margin: 4px 10px 14px;
            color: rgba(255, 255, 255, .52);
            font-size: 14px;
            letter-spacing: .02em;
        }

        .studio-menu {
            flex: 1 1 auto;
            display: grid;
            align-content: start;
            gap: 8px;
            margin: 0;
            padding: 0;
            list-style: none;
        }

        .studio-menu details {
            margin: 0;
        }

        .studio-menu summary {
            list-style: none;
        }

        .studio-menu summary::-webkit-details-marker {
            display: none;
        }

        .studio-menu-link,
        .studio-menu-summary {
            min-height: 44px;
            display: grid;
            grid-template-columns: 34px minmax(0, 1fr) 16px;
            align-items: center;
            column-gap: 12px;
            padding: 5px 8px;
            border-radius: 8px;
            color: rgba(255, 255, 255, .86);
            cursor: pointer;
            transition: background .18s ease, color .18s ease;
        }

        .studio-menu-link:hover,
        .studio-menu-summary:hover,
        .studio-menu details[open] > .studio-menu-summary {
            color: #fff;
            background: rgba(255, 255, 255, .08);
        }

        .studio-menu-icon {
            width: 34px;
            height: 34px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            color: #fff;
            font-size: 16px;
        }

        .studio-menu-icon.blue { background: #2196f3; }
        .studio-menu-icon.rose { background: #ff7588; }
        .studio-menu-icon.green { background: #16d39a; }

        .studio-menu-text {
            min-width: 0;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            font-size: 14px;
            font-weight: 600;
        }

        .studio-menu-chevron {
            justify-self: end;
            transition: transform .18s ease;
        }

        .studio-menu details[open] .studio-menu-chevron {
            transform: rotate(90deg);
        }

        .studio-submenu {
            display: grid;
            gap: 4px;
            margin: 4px 0 8px 48px;
        }

        .studio-submenu a {
            min-height: 34px;
            display: flex;
            align-items: center;
            padding: 0 10px;
            border-radius: 7px;
            color: rgba(255, 255, 255, .68);
            font-size: 13px;
            font-weight: 600;
        }

        .studio-submenu a:hover {
            color: #fff;
            background: rgba(255, 255, 255, .08);
        }

        .pcoded-inner-navbar.main-menu {
            min-height: calc(100vh - 76px);
            display: flex;
            flex-direction: column;
        }

        .pcoded-left-item {
            flex: 1 1 auto;
        }

        .sidebar-account {
            margin-top: auto;
            padding: 14px 14px 18px;
            border-top: 1px solid rgba(255, 255, 255, 0.09);
        }

        .sidebar-user-card {
            background: rgba(255, 255, 255, 0.07);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 8px;
            padding: 12px;
            color: #fff;
        }

        .sidebar-user-main {
            display: flex;
            align-items: center;
            gap: 10px;
            min-width: 0;
        }

        .sidebar-user-main img {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            object-fit: cover;
            background: rgba(255, 255, 255, 0.18);
            flex: 0 0 auto;
        }

        .sidebar-user-name {
            display: block;
            max-width: 118px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            font-weight: 700;
            font-size: 13px;
            line-height: 1.2;
        }

        .sidebar-user-role {
            display: block;
            color: rgba(255, 255, 255, 0.62);
            font-size: 11px;
            margin-top: 2px;
        }

        .sidebar-user-actions {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 7px;
            margin-top: 12px;
        }

        .sidebar-user-actions a {
            height: 32px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 7px;
            color: rgba(255, 255, 255, 0.82);
            background: rgba(255, 255, 255, 0.08);
            transition: background 0.18s ease, color 0.18s ease, transform 0.18s ease;
        }

        .sidebar-user-actions a:hover {
            color: #fff;
            background: rgba(123, 230, 190, 0.2);
            transform: translateY(-1px);
        }

        @@media (min-width: 992px) {
            #pcoded[theme-layout="vertical"] .pcoded-overlay-box {
                pointer-events: none !important;
                opacity: 0 !important;
                visibility: hidden !important;
                z-index: -1 !important;
            }

            #pcoded[theme-layout="vertical"] .pcoded-navbar {
                width: var(--studio-sidebar-width) !important;
                top: var(--studio-header-height) !important;
                min-height: calc(100vh - var(--studio-header-height));
                transform: none !important;
                left: 0 !important;
                overflow: visible;
            }

            #pcoded[theme-layout="vertical"] .pcoded-navbar .main-menu,
            #pcoded[theme-layout="vertical"] .pcoded-navbar .pcoded-inner-navbar,
            #pcoded[theme-layout="vertical"] .pcoded-navbar .pcoded-left-item {
                width: 100% !important;
                max-width: none !important;
                min-width: 0 !important;
                margin-left: 0 !important;
                transform: none !important;
            }

            #pcoded[theme-layout="vertical"] .pcoded-navbar .pcoded-navigatio-lavel,
            #pcoded[theme-layout="vertical"] .pcoded-navbar .pcoded-item,
            #pcoded[theme-layout="vertical"] .pcoded-navbar .sidebar-account,
            #pcoded[theme-layout="vertical"] .pcoded-navbar .sidebar-user-card,
            #pcoded[theme-layout="vertical"] .pcoded-navbar .sidebar-user-name,
            #pcoded[theme-layout="vertical"] .pcoded-navbar .sidebar-user-role {
                display: block !important;
                opacity: 1 !important;
                visibility: visible !important;
                transform: none !important;
            }

            #pcoded[theme-layout="vertical"] .pcoded-main-container {
                width: calc(100% - var(--studio-sidebar-width)) !important;
                margin-left: var(--studio-sidebar-width) !important;
                margin-top: var(--studio-header-height) !important;
            }

            #pcoded[theme-layout="vertical"] .pcoded-content {
                width: 100% !important;
                margin-left: 0 !important;
                overflow-x: hidden;
            }

            #pcoded[theme-layout="vertical"] .pcoded-header .navbar-container {
                margin-left: var(--studio-sidebar-width) !important;
            }

            #pcoded[theme-layout="vertical"] .pcoded-navbar .pcoded-micon,
            #pcoded[theme-layout="vertical"] .pcoded-navbar .pcoded-mtext {
                opacity: 1 !important;
                position: static !important;
                visibility: visible !important;
                transform: none !important;
            }

            #pcoded[theme-layout="vertical"] .pcoded-navbar .pcoded-micon {
                display: inline-flex !important;
                width: 32px !important;
                min-width: 32px !important;
                height: 32px !important;
                margin: 0 !important;
                padding: 0 !important;
                align-items: center;
                justify-content: center;
                border-radius: 8px;
                color: #fff;
                flex: 0 0 32px;
            }

            #pcoded[theme-layout="vertical"] .pcoded-navbar .pcoded-mtext {
                display: block !important;
                min-width: 0;
                margin: 0 !important;
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            #pcoded[theme-layout="vertical"] .pcoded-navbar .pcoded-item > li > a {
                display: grid !important;
                grid-template-columns: 32px minmax(0, 1fr) 16px;
                align-items: center;
                column-gap: 12px;
                min-height: 44px;
                padding: 0 18px !important;
                color: rgba(255, 255, 255, .86) !important;
            }

            #pcoded[theme-layout="vertical"] .pcoded-navbar .pcoded-item > li.pcoded-hasmenu > a:after {
                position: static !important;
                grid-column: 3;
                justify-self: end;
                margin: 0 !important;
                transform: none !important;
            }

            #pcoded[theme-layout="vertical"] .pcoded-navbar .pcoded-item > li > a:hover,
            #pcoded[theme-layout="vertical"] .pcoded-navbar .pcoded-item > li.pcoded-trigger > a {
                color: #fff !important;
                background: rgba(255, 255, 255, .08);
            }

            #pcoded[theme-layout="vertical"] .pcoded-navbar .pcoded-submenu {
                padding-left: 48px;
            }

            #pcoded[theme-layout="vertical"] .pcoded-navbar .pcoded-submenu a {
                display: block !important;
                min-height: 36px;
                color: rgba(255, 255, 255, .72) !important;
            }

            #pcoded[theme-layout="vertical"] .pcoded-navbar .pcoded-submenu .pcoded-mtext {
                display: block !important;
            }
        }
    </style>

    @RenderSection("HeadExtra", required: false)
</head>

@{
    var profileName = Convert.ToString(Session["adi"]) ?? string.Empty;
    var profileImage = Convert.ToString(Session["resim"]);
    profileImage = string.IsNullOrWhiteSpace(profileImage)
        ? "avatar.png"
        : System.IO.Path.GetFileName(profileImage);
    var profileImageUrl = Url.Content("~/Content/Personel/" + profileImage);
    var fallbackProfileImageUrl = Url.Content("~/Content/Personel/avatar.png");
}

<body>
    <div id="pcoded" class="pcoded nocollapsed" theme-layout="vertical" vertical-placement="left" vertical-layout="wide" vertical-effect="shrink" vertical-nav-type="expanded" pcoded-device-type="desktop" vnavigation-view="view1" nav-type="st2" fream-type="theme1" layout-type="light">
        <div class="pcoded-overlay-box"></div>
        <div class="pcoded-container navbar-wrapper">

            <!-- HEADER -->
            <nav class="navbar header-navbar pcoded-header nocollapsed" pcoded-header-position="fixed" header-theme="theme1">
                <div class="navbar-wrapper">
                    <div class="navbar-logo" logo-theme="theme1">
                        <a class="mobile-menu" id="mobile-collapse" href="#!">
                            <i class="feather icon-menu"></i>
                        </a>
                        <a class="studio-brand-link" href="@Url.Action("Indexgosterge", "Home", new { idi = Session["id"] })">
                            <img class="img-fluid brand-logo" src="~/Content/img/evalio-logo.svg" alt="Aslana Survey Studio" />
                        </a>
                        <a class="mobile-options">
                            <i class="feather icon-more-horizontal"></i>
                        </a>
                    </div>

                    <div class="navbar-container">
                        <ul class="nav-left">
                            <li>
                                <a href="#!" onclick="toggleFullScreen()" class="waves-effect waves-light">
                                    <i class="full-screen feather icon-maximize"></i>
                                </a>
                            </li>
                        </ul>
                    </div>

                </div>
            </nav>
            <!-- /HEADER -->

            <div class="pcoded-main-container">
                <div class="pcoded-wrapper">

                    <!-- SIDEBAR (hafifletildi) -->
                    <nav class="pcoded-navbar" pcoded-navbar-position="fixed" pcoded-header-position="fixed" navbar-theme="theme1" active-item-theme="theme1" sub-item-theme="theme2" active-item-style="style0">
                        <div class="studio-sidebar-inner">
                            <div class="studio-menu-label">Menü</div>
                            <ul class="studio-menu">
                                <li>
                                    <a class="studio-menu-link" href="@Url.Action("Indexgosterge", "Home", new { idi = Session["id"] })">
                                        <span class="studio-menu-icon blue"><i class="feather icon-home"></i></span>
                                        <span class="studio-menu-text">Gösterge Paneli</span>
                                        <span></span>
                                    </a>
                                </li>
                                <li>
                                    <details>
                                        <summary class="studio-menu-summary">
                                            <span class="studio-menu-icon rose"><i class="feather icon-package"></i></span>
                                            <span class="studio-menu-text">Anket İşlemleri</span>
                                            <i class="studio-menu-chevron feather icon-chevron-right"></i>
                                        </summary>
                                        <div class="studio-submenu">
                                            <a title="Sihirbaz ile sınav, anket veya işe alım değerlendirmesi oluştur" href="@Url.Action("AssessmentWizard", "Home", new { id = Session["id"] })">Yeni Sihirbaz</a>
                                            <a title="Anket Yönetim İşlemleri" href="@Url.Action("AnketAdIndex", "Home", new { id = Session["id"] })">Anket Yönetimi</a>
                                        </div>
                                    </details>
                                </li>
                                <li>
                                    <details>
                                        <summary class="studio-menu-summary">
                                            <span class="studio-menu-icon green"><i class="feather icon-credit-card"></i></span>
                                            <span class="studio-menu-text">Raporlar</span>
                                            <i class="studio-menu-chevron feather icon-chevron-right"></i>
                                        </summary>
                                        <div class="studio-submenu">
                                            <a title="Raporlar" href="@Url.Action("AnketIndex", "Home", new { id = Session["id"] })">Anket Raporları</a>
                                        </div>
                                    </details>
                                </li>
                            </ul>
                            <div class="sidebar-account">
                                <div class="sidebar-user-card">
                                    <div class="sidebar-user-main">
                                        <img src="@profileImageUrl" alt="@profileName" onerror="this.onerror=null;this.src='@fallbackProfileImageUrl';" />
                                        <div>
                                            <span class="sidebar-user-name">@profileName</span>
                                            <span class="sidebar-user-role">Studio hesabı</span>
                                        </div>
                                    </div>
                                    <div class="sidebar-user-actions" aria-label="Hesap bağlantıları">
                                        <a title="Ayarlar" href="@Url.Action("Index", "Ayar", new { id = Session["id"] })">
                                            <i class="feather icon-settings"></i>
                                        </a>
                                        <a title="Hesabım" href="@Url.Action("UserEdit", "Home", new { id = Session["id"] })">
                                            <i class="feather icon-user"></i>
                                        </a>
                                        <a title="Çıkış" href="@Url.Action("GirisCikis", "Home", new { id = Session["id"] })">
                                            <i class="feather icon-log-out"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                        @* <div id="styleSelector"></div> *@
                    </nav>
                    <!-- /SIDEBAR -->
                    <!-- CONTENT -->
                    <div class="pcoded-content">
                        <div class="pcoded-inner-content">
                            <div class="main-body">
                                <div class="page-wrapper">
                                    @RenderBody()
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- /CONTENT -->

                </div>
            </div>

        </div>
    </div>


    <!-- JS -->
    <!-- 1. jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <!-- 2. Tema eklentileri: script.js bunlari hazir bekliyor -->
    <script src="~/files/bower_components/jquery-slimscroll/jquery.slimscroll.min.js"></script>
    <script src="~/files/assets/js/jquery.mCustomScrollbar.concat.min.js"></script>

    <!-- 3. Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- 4. DataTables -->
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>

    <!-- 5. Tema JS -->
    <script src="~/files/assets/js/pcoded.min.js"></script>
    <script src="~/files/assets/js/vartical-layout.min.js"></script>
    <script src="~/files/assets/js/script.js" asp-append-version="true"></script>
    <script src="~/js/studio-legacy.js" asp-append-version="true"></script>
    <script>
        (function () {
            function setAttrIfDifferent(element, name, value) {
                if (element.getAttribute(name) !== value) {
                    element.setAttribute(name, value);
                }
            }

            function studioDesktopLayout() {
                var pcoded = document.getElementById("pcoded");
                if (!pcoded || !window.matchMedia("(min-width: 992px)").matches) {
                    return;
                }

                setAttrIfDifferent(pcoded, "pcoded-device-type", "desktop");
                setAttrIfDifferent(pcoded, "vertical-nav-type", "expanded");
                setAttrIfDifferent(pcoded, "vertical-layout", "wide");
                pcoded.classList.add("nocollapsed");
                pcoded.classList.remove("iscollapsed");

                var header = document.querySelector(".pcoded-header");
                if (header) {
                    header.classList.add("nocollapsed");
                    header.classList.remove("iscollapsed");
                    setAttrIfDifferent(header, "pcoded-header-position", "fixed");
                }
            }

            window.addEventListener("load", studioDesktopLayout);
            window.addEventListener("resize", studioDesktopLayout);
            setTimeout(studioDesktopLayout, 100);
            setTimeout(studioDesktopLayout, 500);
            setTimeout(studioDesktopLayout, 1200);
        })();
    </script>

    <!-- Sayfa bazlı scriptler -->
    @RenderSection("Scripts", required: false)
</body>
</html>
