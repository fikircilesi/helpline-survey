    <script>
        (function () {
            function setAttrIfDifferent(element, name, value) {
                if (element.getAttribute(name) !== value) {
                    element.setAttribute(name, value);
                }
            }

            var storageKey = "studioSidebarCollapsed";
            var desktopQuery = window.matchMedia("(min-width: 992px)");

            function cssVar(name, fallback) {
                var value = getComputedStyle(document.documentElement).getPropertyValue(name).trim();
                return value || fallback;
            }

            function setImportantStyle(element, property, value) {
                if (!element) {
                    return;
                }

                if (element.style.getPropertyValue(property) !== value
                    || element.style.getPropertyPriority(property) !== "important") {
                    element.style.setProperty(property, value, "important");
                }
            }

            function clearInlineLayout(element, properties) {
                if (!element) {
                    return;
                }

                properties.forEach(function (property) {
                    element.style.removeProperty(property);
                });
            }

            function syncSidebarMetrics() {
                var pcoded = document.getElementById("pcoded");
                if (!pcoded) {
                    return;
                }

                var header = document.querySelector(".pcoded-header");
                var headerWrapper = document.querySelector(".pcoded-header .navbar-wrapper");
                var logo = document.querySelector(".pcoded-header .navbar-logo");
                var navbar = document.querySelector(".pcoded-navbar");
                var main = document.querySelector(".pcoded-main-container");
                var content = document.querySelector(".pcoded-content");
                var innerContent = document.querySelector(".pcoded-inner-content");
                var widthProperties = ["width", "max-width", "min-width", "flex-basis", "margin-left", "left", "right"];
                var navProperties = widthProperties.concat(["top", "height", "min-height", "max-height", "transform"]);

                if (!desktopQuery.matches) {
                    [header, headerWrapper, logo, main, content, innerContent].forEach(function (element) {
                        clearInlineLayout(element, widthProperties.concat(["height", "min-height", "margin-top", "padding-left"]));
                    });
                    clearInlineLayout(navbar, navProperties);
                    return;
                }

                var expandedWidth = cssVar("--studio-sidebar-width", "272px");
                var collapsedWidth = cssVar("--studio-sidebar-collapsed-width", "84px");
                var headerHeight = cssVar("--studio-header-height", "64px");
                var activeWidth = pcoded.classList.contains("studio-sidebar-collapsed")
                    ? collapsedWidth
                    : expandedWidth;

                [header, headerWrapper, logo].forEach(function (element) {
                    setImportantStyle(element, "width", activeWidth);
                    setImportantStyle(element, "max-width", activeWidth);
                    setImportantStyle(element, "flex-basis", activeWidth);
                });

                setImportantStyle(navbar, "width", activeWidth);
                setImportantStyle(navbar, "left", "0px");
                setImportantStyle(navbar, "top", headerHeight);
                setImportantStyle(navbar, "height", "calc(100vh - " + headerHeight + ")");
                setImportantStyle(navbar, "min-height", "calc(100vh - " + headerHeight + ")");
                setImportantStyle(navbar, "max-height", "calc(100vh - " + headerHeight + ")");
                setImportantStyle(navbar, "transform", "none");

                setImportantStyle(main, "width", "calc(100% - " + activeWidth + ")");
                setImportantStyle(main, "margin-left", activeWidth);
                setImportantStyle(main, "margin-top", "0px");
                setImportantStyle(content, "width", "100%");
                setImportantStyle(content, "margin-left", "0px");
                setImportantStyle(innerContent, "padding-left", "0px");
            }

            function setMenuToggleIcon(iconName) {
                var icon = document.querySelector("#mobile-collapse i");
                if (icon) {
                    icon.className = "feather " + iconName;
                }
            }

            function sidebarIsCollapsed() {
                var pcoded = document.getElementById("pcoded");
                return !!(pcoded && pcoded.classList.contains("studio-sidebar-collapsed"));
            }

            function closeSidebarDetails(except) {
                document.querySelectorAll(".studio-menu details[open]").forEach(function (item) {
                    if (item !== except) {
                        item.open = false;
                    }
                });
            }

            function applyDesktopSidebarState(collapsed) {
                var pcoded = document.getElementById("pcoded");
                if (!pcoded || !desktopQuery.matches) {
                    return;
                }

                document.body.classList.remove("studio-mobile-menu-open");
                pcoded.classList.remove("studio-mobile-menu-open");
                setAttrIfDifferent(pcoded, "pcoded-device-type", "desktop");
                setAttrIfDifferent(pcoded, "vertical-layout", "wide");
                setAttrIfDifferent(pcoded, "vertical-nav-type", collapsed ? "collapsed" : "expanded");
                pcoded.classList.toggle("studio-sidebar-collapsed", collapsed);
                pcoded.classList.toggle("iscollapsed", collapsed);
                pcoded.classList.toggle("nocollapsed", !collapsed);
                setMenuToggleIcon(collapsed ? "icon-chevrons-right" : "icon-chevrons-left");

                var header = document.querySelector(".pcoded-header");
                if (header) {
                    header.classList.toggle("iscollapsed", collapsed);
                    header.classList.toggle("nocollapsed", !collapsed);
                    setAttrIfDifferent(header, "pcoded-header-position", "fixed");
                }

                syncSidebarMetrics();
            }

            function setMobileMenu(open) {
                var pcoded = document.getElementById("pcoded");
                if (!pcoded || desktopQuery.matches) {
                    return;
                }

                setAttrIfDifferent(pcoded, "pcoded-device-type", "phone");
                setAttrIfDifferent(pcoded, "vertical-nav-type", "offcanvas");
                pcoded.classList.remove("studio-sidebar-collapsed", "iscollapsed", "nocollapsed");
                pcoded.classList.toggle("studio-mobile-menu-open", open);
                document.body.classList.toggle("studio-mobile-menu-open", open);
                setMenuToggleIcon(open ? "icon-x" : "icon-menu");

                var header = document.querySelector(".pcoded-header");
                if (header) {
                    header.classList.remove("iscollapsed", "nocollapsed");
                    setAttrIfDifferent(header, "pcoded-header-position", "fixed");
                }

                syncSidebarMetrics();
            }

            function studioDesktopLayout() {
                if (desktopQuery.matches) {
                    applyDesktopSidebarState(localStorage.getItem(storageKey) === "1");
                } else {
                    setMobileMenu(false);
                }
            }

            var toggle = document.getElementById("mobile-collapse");
            if (toggle) {
                toggle.addEventListener("click", function (event) {
                    event.preventDefault();
                    event.stopPropagation();
                    if (desktopQuery.matches) {
                        var pcoded = document.getElementById("pcoded");
                        var collapsed = !(pcoded && pcoded.classList.contains("studio-sidebar-collapsed"));
                        localStorage.setItem(storageKey, collapsed ? "1" : "0");
                        applyDesktopSidebarState(collapsed);
                    } else {
                        var isOpen = document.getElementById("pcoded")?.classList.contains("studio-mobile-menu-open");
                        setMobileMenu(!isOpen);
                    }
                }, true);
            }

            var overlay = document.querySelector(".pcoded-overlay-box");
            if (overlay) {
                overlay.addEventListener("click", function () {
                    setMobileMenu(false);
                });
            }

            document.querySelectorAll(".pcoded-navbar a[href]").forEach(function (link) {
                link.addEventListener("click", function () {
                    if (!desktopQuery.matches) {
                        setMobileMenu(false);
                    } else if (sidebarIsCollapsed()) {
                        closeSidebarDetails();
                    }
                });
            });

            document.querySelectorAll(".studio-menu details").forEach(function (details) {
                details.addEventListener("toggle", function () {
                    if (details.open) {
                        closeSidebarDetails(details);
                    }
                });

                details.addEventListener("mouseenter", function () {
                    if (desktopQuery.matches && sidebarIsCollapsed()) {
                        closeSidebarDetails(details);
                    }
                });

                details.addEventListener("mouseleave", function () {
                    if (desktopQuery.matches && sidebarIsCollapsed()) {
                        details.open = false;
                    }
                });
            });

            window.addEventListener("load", studioDesktopLayout);
            window.addEventListener("resize", studioDesktopLayout);
            ["#pcoded", ".pcoded-header", ".pcoded-navbar", ".pcoded-main-container"].forEach(function (selector) {
                var element = document.querySelector(selector);
                if (!element) {
                    return;
                }

                new MutationObserver(syncSidebarMetrics).observe(element, {
                    attributes: true,
                    attributeFilter: ["class", "style", "pcoded-device-type", "vertical-nav-type", "vertical-layout"]
                });
            });
            setTimeout(studioDesktopLayout, 100);
            setTimeout(studioDesktopLayout, 500);
            setTimeout(studioDesktopLayout, 1200);
            setTimeout(syncSidebarMetrics, 1800);
            setTimeout(syncSidebarMetrics, 2600);
        })();
    </script>

    <!-- Sayfa bazlı scriptler -->
    @RenderSection("Scripts", required: false)
</body>
</html>
