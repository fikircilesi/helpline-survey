@model survey.Models.CevapGrup

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    ViewData["DeleteEyebrow"] = "Seçenek grubu";
    ViewData["DeleteTitle"] = "Seçenek grubu silinsin mi?";
    ViewData["DeleteDescription"] = "Bu seçenek grubu bankadan kaldırılacak. İçindeki seçenekler sorularda kullanılıyorsa sistem silmeyi durdurur.";
    ViewData["DeleteItemLabel"] = "Seçenek grubu";
    ViewData["DeleteItemName"] = Model?.CevapGrupAdi;
    ViewData["DeleteWarning"] = "Bu işlem geri alınamaz. Önce bu grubu kullanan soru veya cevap bağlantılarını kaldırmanız gerekebilir.";
    ViewData["DeleteBackUrl"] = Url.Action("CevapGrupIndex", "Home");
    ViewData["DeleteSubmitText"] = "Grubu sil";
}

@await Html.PartialAsync("_DeleteConfirm")
