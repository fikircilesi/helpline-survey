@model survey.Models.AnketGrup

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    ViewData["DeleteEyebrow"] = "Çalışma kırılımı";
    ViewData["DeleteTitle"] = "Soru grubu bu çalışmadan kaldırılsın mı?";
    ViewData["DeleteDescription"] = "Bu işlem soru grubunu bankadan silmez; yalnızca seçili çalışmadaki bağlantıyı kaldırır.";
    ViewData["DeleteItemLabel"] = "Soru grubu";
    ViewData["DeleteItemName"] = Model?.SoruGrup?.SoruGrupAdi;
    ViewData["DeleteWarning"] = "Bu kırılıma ait katılım cevabı varsa bağlantı kaldırılmaz. Önce ilgili katılım verilerini temizleyin.";
    ViewData["DeleteBackUrl"] = Url.Action("AnketGrupIndex", "Home", new { id = ViewBag.id, adi = ViewBag.adi });
    ViewData["DeleteSubmitText"] = "Kırılımı kaldır";
    ViewData["DeleteHiddenFields"] = new[]
    {
        new System.Collections.Generic.KeyValuePair<string, string>("ank", Convert.ToString(ViewBag.id)),
        new System.Collections.Generic.KeyValuePair<string, string>("sr", Convert.ToString(Model?.SoruGrupId)),
        new System.Collections.Generic.KeyValuePair<string, string>("adi", Convert.ToString(ViewBag.adi))
    };
}

@await Html.PartialAsync("_DeleteConfirm")
