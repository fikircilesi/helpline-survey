@model survey.Models.Havuz
@using System.Linq

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var ids = ViewBag.id as System.Collections.IEnumerable;
    var idList = ids != null ? ids.Cast<object>().ToList() : new System.Collections.Generic.List<object>();
    var grupAdi = Model != null && Model.SoruGrup != null && !string.IsNullOrWhiteSpace(Model.SoruGrup.SoruGrupAdi)
        ? Model.SoruGrup.SoruGrupAdi
        : "Seçili soru grubu";
    var calismaAdi = Model != null && Model.Anket != null && !string.IsNullOrWhiteSpace(Model.Anket.AnketAdi)
        ? Model.Anket.AnketAdi
        : "Çalışma";
}

<div class="confirm-page">
    <section class="confirm-card">
        <div class="confirm-icon"><i class="fa fa-folder-open-o"></i></div>
        <span class="confirm-eyebrow">Grup verisi silme</span>
        <h1>@grupAdi</h1>
        <p>@calismaAdi içindeki bu soru grubuna ait katılım cevapları temizlenecek. Diğer soru gruplarındaki cevaplar korunur.</p>

        <div class="confirm-stats compact">
            <span><strong>@idList.Count</strong> cevap kaydı</span>
        </div>

        <div class="confirm-warning">
            <i class="fa fa-lock"></i>
            <span>Bu işlem geri alınamaz. Yalnızca seçili kırılımın katılım verileri silinir.</span>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            foreach (var id in idList)
            {
                <input type="hidden" name="ids" value="@id" />
            }
            <input type="hidden" name="ank" value="@ViewBag.ank" />

            <div class="confirm-actions">
                <a class="confirm-btn" href="@Url.Action("AnketHavuzIndex2", "Home", new { id = ViewBag.ank })">
                    <i class="fa fa-arrow-left"></i> Vazgeç
                </a>
                <button type="submit" class="confirm-btn danger">
                    <i class="fa fa-trash-o"></i> Grubu sıfırla
                </button>
            </div>
        }
    </section>
</div>

<style>
    .confirm-page { width: min(760px, calc(100% - 32px)); margin: 58px auto; color: #061a35; }
    .confirm-page * { box-sizing: border-box; }
    .confirm-card { border: 1px solid #ffd1d8; border-radius: 14px; background: linear-gradient(135deg, #fff, #fff8f9); box-shadow: 0 24px 60px rgba(154, 38, 62, .12); padding: 34px; }
    .confirm-icon { display: grid; place-items: center; width: 64px; height: 64px; border-radius: 18px; background: #fff0f2; color: #d9364f; font-size: 28px; margin-bottom: 18px; }
    .confirm-eyebrow { color: #d9364f; font-size: 12px; font-weight: 950; letter-spacing: .08em; text-transform: uppercase; }
    .confirm-card h1 { margin: 8px 0 10px; font-size: 34px; line-height: 1.18; font-weight: 950; letter-spacing: 0; }
    .confirm-card p { margin: 0; color: #53627a; font-size: 15px; line-height: 1.7; font-weight: 700; }
    .confirm-stats { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; margin: 24px 0; }
    .confirm-stats.compact { grid-template-columns: minmax(180px, 240px); }
    .confirm-stats span { border: 1px solid #dce7f6; border-radius: 12px; background: #fff; padding: 14px; color: #53627a; font-weight: 850; }
    .confirm-stats strong { display: block; color: #071832; font-size: 26px; margin-bottom: 4px; }
    .confirm-warning { display: flex; gap: 10px; align-items: center; border: 1px solid #ffd7a7; border-radius: 12px; background: #fffaf1; color: #7a4300; padding: 14px; font-weight: 850; }
    .confirm-actions { display: flex; justify-content: flex-end; gap: 12px; margin-top: 24px; }
    .confirm-btn { min-height: 44px; display: inline-flex; align-items: center; justify-content: center; gap: 8px; border: 1px solid #cfe0f6; border-radius: 10px; background: #fff; color: #071832; font-weight: 950; text-decoration: none; padding: 0 18px; }
    .confirm-btn.danger { border-color: #d9364f; background: #d9364f; color: #fff; }
    @@media (max-width: 720px) { .confirm-stats, .confirm-stats.compact { grid-template-columns: 1fr; } .confirm-actions { display: grid; } }
</style>
