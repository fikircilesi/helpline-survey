@model IEnumerable<survey.Models.Havuz>
@using System
@using System.Globalization
@using System.Linq

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var culture = new CultureInfo("tr-TR");
    var kayitlar = (Model ?? Enumerable.Empty<survey.Models.Havuz>()).ToList();
    var anketAdi = Convert.ToString(ViewBag.ankadi);
    if (string.IsNullOrWhiteSpace(anketAdi))
    {
        anketAdi = kayitlar.Select(x => x.Anket != null ? x.Anket.AnketAdi : null).FirstOrDefault(x => !string.IsNullOrWhiteSpace(x)) ?? "Çalışma";
    }
    var grupAdi = Convert.ToString(ViewBag.grupadi);
    if (string.IsNullOrWhiteSpace(grupAdi))
    {
        grupAdi = kayitlar.Select(x => x.SoruGrup != null ? x.SoruGrup.SoruGrupAdi : null).FirstOrDefault(x => !string.IsNullOrWhiteSpace(x)) ?? "Soru grubu";
    }
    var katilimciSayisi = kayitlar
        .Select(x => x.UserId.HasValue && x.UserId.Value != 1 ? "U" + x.UserId.Value : (x.Isimsiz.HasValue ? "A" + x.Isimsiz.Value : "Bilinmiyor"))
        .Distinct()
        .Count();
    Func<double?, string> number = value => value.HasValue ? value.Value.ToString("0.##", culture) : "0";
    Func<DateTime?, string> tarih = value => value.HasValue ? value.Value.ToString("dd.MM.yyyy HH:mm", culture) : "Tarih yok";
    Func<survey.Models.Havuz, string> katilimci = item =>
    {
        if (item.User != null && !string.IsNullOrWhiteSpace(item.User.UserAdi))
        {
            return item.User.UserAdi;
        }
        if (item.UserId.HasValue && item.UserId.Value != 1)
        {
            return "Kullanıcı #" + item.UserId.Value;
        }
        if (item.Isimsiz.HasValue)
        {
            return "Katılımcı #" + item.Isimsiz.Value;
        }
        return "Tanımsız katılımcı";
    };
}

<div class="answers-page">
    <section class="answers-hero">
        <div>
            <span class="answers-eyebrow">Grup kayıtları</span>
            <h1>@grupAdi</h1>
            <p>@anketAdi çalışmasında bu kırılıma ait cevap kayıtları. Eksik bağlantılı eski kayıtlar artık hata üretmeden güvenli şekilde gösterilir.</p>
            <div class="answers-chip-row">
                <span><i class="fa fa-database"></i> @kayitlar.Count kayıt</span>
                <span><i class="fa fa-users"></i> @katilimciSayisi katılımcı</span>
                <span><i class="fa fa-star"></i> @number(kayitlar.Sum(x => x.CevapPuan ?? 0)) toplam cevap puanı</span>
            </div>
        </div>
        <a class="answers-btn" href="@Url.Action("AnketHavuzIndex2", "Home", new { id = ViewBag.ank })">
            <i class="fa fa-arrow-left"></i> Gruplara dön
        </a>
    </section>

    <section class="answers-toolbar">
        <div class="answers-search">
            <i class="fa fa-search"></i>
            <input id="answersSearch" type="search" placeholder="Soru, cevap veya katılımcı ara" autocomplete="off" />
        </div>
    </section>

    @if (kayitlar.Any())
    {
        <section class="answers-table-card">
            <table class="answers-table">
                <thead>
                    <tr>
                        <th>Soru</th>
                        <th>Verilen cevap</th>
                        <th>Katılımcı</th>
                        <th>Puan</th>
                        <th>Kayıt tarihi</th>
                        <th>İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in kayitlar.OrderByDescending(x => x.KayitTar))
                    {
                        var soruAdi = item.Soru != null && !string.IsNullOrWhiteSpace(item.Soru.SoruAdi) ? item.Soru.SoruAdi : "Silinmiş veya bulunamayan soru";
                        var cevapAdi = item.Cevap != null && !string.IsNullOrWhiteSpace(item.Cevap.CevapAdi) ? item.Cevap.CevapAdi : "Cevap bilgisi yok";
                        var katilimciAdi = katilimci(item);
                        var search = (soruAdi + " " + cevapAdi + " " + katilimciAdi).ToLower(culture);
                        <tr data-answer-row data-search="@search">
                            <td>
                                <strong>@soruAdi</strong>
                            </td>
                            <td>@cevapAdi</td>
                            <td>@katilimciAdi</td>
                            <td><span class="score-pill">@number(item.CevapPuan)</span></td>
                            <td>@tarih(item.KayitTar)</td>
                            <td>
                                <a class="answers-icon danger" title="Bu cevap kaydını sil" href="@Url.Action("AnketHavuzDelete1", "Home", new { id = item.HavuzId, ank = ViewBag.ank, sor = item.SoruGrupId })">
                                    <i class="fa fa-trash-o"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    }
    else
    {
        <section class="answers-empty">
            <i class="fa fa-check-circle-o"></i>
            <strong>Bu grupta kayıt yok</strong>
            <span>Silinmiş veya boş bir kırılım açılmış olabilir.</span>
        </section>
    }

    <section class="answers-empty" id="answersEmpty" hidden>
        <i class="fa fa-search"></i>
        <strong>Sonuç bulunamadı</strong>
        <span>Arama metnini değiştirerek tekrar deneyin.</span>
    </section>
</div>

<style>
    .answers-page { width: min(1580px, calc(100% - 48px)); margin: 34px auto 60px; color: #061a35; }
    .answers-page * { box-sizing: border-box; }
    .answers-hero, .answers-toolbar, .answers-table-card, .answers-empty { border: 1px solid #d6e2f3; border-radius: 12px; background: rgba(255,255,255,.96); box-shadow: 0 20px 48px rgba(24,45,83,.08); }
    .answers-hero { display: flex; justify-content: space-between; align-items: flex-start; gap: 24px; padding: 34px; background: linear-gradient(130deg, rgba(225,253,246,.96), rgba(244,247,255,.9) 58%, rgba(255,248,229,.72)), #fff; }
    .answers-eyebrow { color: #255ef5; font-size: 12px; font-weight: 900; letter-spacing: .08em; text-transform: uppercase; }
    .answers-hero h1 { margin: 10px 0 8px; font-size: 38px; line-height: 1.14; font-weight: 950; letter-spacing: 0; }
    .answers-hero p { max-width: 820px; margin: 0; color: #53627a; font-size: 15px; line-height: 1.7; font-weight: 650; }
    .answers-chip-row { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 20px; }
    .answers-chip-row span, .score-pill { display: inline-flex; align-items: center; gap: 7px; border-radius: 999px; background: #eef5ff; color: #24436d; font-size: 12px; font-weight: 850; padding: 8px 11px; }
    .answers-chip-row i { color: #11a99b; }
    .answers-btn { min-height: 42px; display: inline-flex; align-items: center; justify-content: center; gap: 8px; border: 1px solid #cfe0f6; border-radius: 10px; background: #fff; color: #071832; font-weight: 900; text-decoration: none; padding: 0 16px; transition: transform .16s ease, box-shadow .16s ease; white-space: nowrap; }
    .answers-btn:hover, .answers-icon:hover { transform: translateY(-2px); box-shadow: 0 18px 38px rgba(19,42,80,.12); text-decoration: none; }
    .answers-toolbar { margin-top: 18px; padding: 16px; }
    .answers-search { position: relative; max-width: 560px; }
    .answers-search i { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #7890b0; }
    .answers-search input { width: 100%; min-height: 44px; border: 1px solid #d3dfef; border-radius: 10px; padding: 0 14px 0 40px; color: #071832; font-weight: 750; outline: none; }
    .answers-search input:focus { border-color: #3562f4; box-shadow: 0 0 0 3px rgba(53,98,244,.12); }
    .answers-table-card { margin-top: 18px; overflow-x: auto; }
    .answers-table { width: 100%; border-collapse: collapse; min-width: 1040px; }
    .answers-table th { background: #f6f9fd; color: #48607e; font-size: 12px; font-weight: 950; letter-spacing: .06em; text-transform: uppercase; padding: 15px 16px; border-bottom: 1px solid #dbe6f4; }
    .answers-table td { padding: 15px 16px; border-bottom: 1px solid #edf2f8; color: #10223f; font-weight: 700; vertical-align: middle; }
    .answers-table tr:hover td { background: #fbfdff; }
    .answers-table strong { display: block; max-width: 620px; color: #061a35; font-weight: 900; line-height: 1.45; }
    .answers-icon { width: 38px; height: 38px; display: inline-flex; align-items: center; justify-content: center; border: 1px solid #cfe0f6; border-radius: 10px; background: #fff; color: #1763df; transition: transform .16s ease, box-shadow .16s ease; }
    .answers-icon.danger { color: #d9364f; border-color: #ffd1d8; background: #fff7f8; }
    .answers-empty { display: grid; place-items: center; gap: 6px; margin-top: 18px; padding: 42px; color: #64748b; text-align: center; }
    .answers-empty i { color: #11a99b; font-size: 32px; }
    @@media (max-width: 1000px) { .answers-page { width: min(100% - 22px, 1580px); } .answers-hero { display: grid; grid-template-columns: 1fr; } }
</style>

<script>
    (function () {
        const input = document.getElementById('answersSearch');
        const rows = document.querySelectorAll('[data-answer-row]');
        const empty = document.getElementById('answersEmpty');
        function normalize(value) { return (value || '').toLocaleLowerCase('tr-TR').trim(); }
        function applySearch() {
            const term = normalize(input ? input.value : '');
            let visible = 0;
            rows.forEach(function (row) {
                const show = !term || normalize(row.dataset.search).indexOf(term) > -1;
                row.hidden = !show;
                if (show) visible += 1;
            });
            if (empty) empty.hidden = visible !== 0;
        }
        if (input) input.addEventListener('input', applySearch);
        applySearch();
    })();
</script>
