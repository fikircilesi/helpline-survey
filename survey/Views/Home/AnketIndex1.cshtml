@model IEnumerable<survey.Models.Havuz>
@using System
@using System.Collections.Generic
@using System.Globalization
@using System.Linq

@functions {
    public class ReportRow
    {
        public string Ad { get; set; }
        public string Alt { get; set; }
        public int Kisi { get; set; }
        public int Soru { get; set; }
        public double Puan { get; set; }
        public string Link { get; set; }
    }

    public class BreakdownBlock
    {
        public string Baslik { get; set; }
        public string Ikon { get; set; }
        public List<ReportRow> Satirlar { get; set; }
    }

    public string KatilimciAnahtari(survey.Models.Havuz kayit)
    {
        if (kayit?.User != null && kayit.UserId != null)
        {
            return "u:" + kayit.UserId.Value;
        }

        if (kayit?.Isimsiz != null)
        {
            return "k:" + kayit.Isimsiz.Value;
        }

        if (kayit?.UserId != null)
        {
            return "u:" + kayit.UserId.Value;
        }

        return "h:" + (kayit?.HavuzId ?? 0);
    }

    public List<survey.Models.Havuz> SonSoruCevaplari(IEnumerable<survey.Models.Havuz> kayitlar)
    {
        return (kayitlar ?? Enumerable.Empty<survey.Models.Havuz>())
            .Where(x => x.SoruID != null)
            .GroupBy(x => x.SoruID.Value)
            .Select(g => g
                .OrderByDescending(x => x.KayitTar ?? DateTime.MinValue)
                .ThenByDescending(x => x.HavuzId)
                .First())
            .ToList();
    }

    public double SoruPuani(survey.Models.Havuz kayit)
    {
        var puan = kayit?.SoruPuan ?? kayit?.Soru?.SoruPuan ?? 0;
        return puan > 0 ? puan : 1;
    }

    public double AnketCevapPuani(survey.Models.Havuz kayit)
    {
        var puan = kayit?.Cevap?.CevapPuan ?? kayit?.CevapPuan ?? 0;
        return Math.Max(0, Math.Min(5, puan));
    }

    public double KisiPuani(IEnumerable<survey.Models.Havuz> kayitlar, bool sinavMi)
    {
        var liste = SonSoruCevaplari(kayitlar);
        if (!liste.Any())
        {
            return 0;
        }

        if (sinavMi)
        {
            var toplam = liste.Sum(SoruPuani);
            var dogru = liste
                .Where(x => x.Cevap != null && x.Cevap.Dogru == true)
                .Sum(SoruPuani);

            return toplam <= 0 ? 0 : dogru / toplam * 100;
        }

        var toplamAgirlik = liste.Sum(SoruPuani);
        var agirlikliPuan = liste.Sum(x => AnketCevapPuani(x) * SoruPuani(x));

        return toplamAgirlik <= 0 ? 0 : agirlikliPuan / toplamAgirlik * 20;
    }

    public double OrtalamaPuan(IEnumerable<survey.Models.Havuz> kayitlar, bool sinavMi)
    {
        return (kayitlar ?? Enumerable.Empty<survey.Models.Havuz>())
            .GroupBy(KatilimciAnahtari)
            .Select(g => KisiPuani(g, sinavMi))
            .DefaultIfEmpty(0)
            .Average();
    }

    public int KisiSayisi(IEnumerable<survey.Models.Havuz> kayitlar)
    {
        return (kayitlar ?? Enumerable.Empty<survey.Models.Havuz>())
            .GroupBy(KatilimciAnahtari)
            .Count();
    }

    public string FormatScore(double value)
    {
        return Math.Max(0, Math.Min(100, value)).ToString("N2", new CultureInfo("tr-TR"));
    }

    public string FormatOne(double value)
    {
        return Math.Max(0, Math.Min(100, value)).ToString("N1", new CultureInfo("tr-TR"));
    }

    public string PercentWidth(double value)
    {
        return Math.Max(0, Math.Min(100, value)).ToString("0.##", CultureInfo.InvariantCulture) + "%";
    }

    public string SafeText(string value, string fallback = "Tanımsız")
    {
        return string.IsNullOrWhiteSpace(value) ? fallback : value;
    }

    public string YasEtiketi(int dogumYili)
    {
        var yas = DateTime.Today.Year - dogumYili;
        if (yas < 18)
        {
            return "18 yaş altı";
        }

        if (yas <= 24)
        {
            return "18-24 yaş";
        }

        if (yas <= 34)
        {
            return "25-34 yaş";
        }

        if (yas <= 44)
        {
            return "35-44 yaş";
        }

        if (yas <= 54)
        {
            return "45-54 yaş";
        }

        return "55+ yaş";
    }
}

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    var kayitlar = (Model ?? Enumerable.Empty<survey.Models.Havuz>()).ToList();
    var sinavMi = ViewBag.sinav == true;
    var calismaTuru = sinavMi ? "Sınav / eğitim" : "Anket";
    var anketAdi = Convert.ToString(ViewBag.adi ?? kayitlar.FirstOrDefault()?.Anket?.AnketAdi ?? "Çalışma raporu");
    var anketId = 0;
    int.TryParse(Convert.ToString(ViewBag.id), out anketId);

    Func<string, int?, string> detayLink = (action, idValue) =>
        idValue.HasValue && idValue.Value > 0
            ? Url.Action(action, "Home", new { id = idValue.Value, ank = anketId })
            : null;

    var katilimGruplari = kayitlar.GroupBy(KatilimciAnahtari).ToList();
    var toplamKatilim = katilimGruplari.Count;
    var toplamSoru = kayitlar
        .Where(x => x.SoruID != null)
        .Select(x => x.SoruID.Value)
        .Distinct()
        .Count();
    var toplamYanıt = katilimGruplari.Sum(g => SonSoruCevaplari(g).Count);
    var beklenenYanıt = Math.Max(1, toplamKatilim * Math.Max(1, toplamSoru));
    var tamamlama = toplamKatilim == 0 || toplamSoru == 0 ? 0 : toplamYanıt * 100.0 / beklenenYanıt;
    var genelPuan = OrtalamaPuan(kayitlar, sinavMi);
    var tanimli = katilimGruplari.Count(g => g.Any(x => x.User != null && !string.IsNullOrWhiteSpace(x.User.UserAdi)));
    var tanimsiz = Math.Max(0, toplamKatilim - tanimli);

    var genelLink = anketId > 0 ? Url.Action("AnketGenelIndex", "Home", new { id = anketId, ank = anketId }) : null;

    var soruRows = kayitlar
        .Where(x => x.SoruID != null && x.Soru != null)
        .GroupBy(x => new
        {
            Id = x.SoruID.Value,
            Ad = x.Soru.SoruAdi,
            Grup = x.SoruGrup?.SoruGrupAdi ?? x.Soru.SoruGrup?.SoruGrupAdi ?? "Grupsuz"
        })
        .Select(g => new ReportRow
        {
            Ad = SafeText(g.Key.Ad, "Soru"),
            Alt = SafeText(g.Key.Grup, "Grupsuz"),
            Kisi = KisiSayisi(g),
            Soru = 1,
            Puan = OrtalamaPuan(g, sinavMi),
            Link = detayLink("AnketSoruIndex", g.Key.Id)
        })
        .OrderBy(x => x.Puan)
        .ToList();

    var soruGrubuRows = kayitlar
        .Where(x => x.SoruGrupId != null || x.Soru?.SoruGrupId != null || x.SoruGrup != null || x.Soru?.SoruGrup != null)
        .GroupBy(x => new
        {
            Id = x.SoruGrupId ?? x.Soru?.SoruGrupId ?? 0,
            Ad = x.SoruGrup?.SoruGrupAdi ?? x.Soru?.SoruGrup?.SoruGrupAdi ?? "Grupsuz"
        })
        .Select(g => new ReportRow
        {
            Ad = SafeText(g.Key.Ad, "Grupsuz"),
            Alt = "Soru grubu",
            Kisi = KisiSayisi(g),
            Soru = g.Where(x => x.SoruID != null).Select(x => x.SoruID.Value).Distinct().Count(),
            Puan = OrtalamaPuan(g, sinavMi),
            Link = detayLink("AnketSoruGrupIndex", g.Key.Id)
        })
        .OrderByDescending(x => x.Puan)
        .ToList();

    var departmanRows = kayitlar
        .Where(x => x.User?.Departman != null)
        .GroupBy(x => new { Id = x.User.UserDepartman, Ad = x.User.Departman.DepartmanAdi })
        .Select(g => new ReportRow { Ad = SafeText(g.Key.Ad), Kisi = KisiSayisi(g), Soru = toplamSoru, Puan = OrtalamaPuan(g, sinavMi), Link = detayLink("AnketDepartmanIndex", g.Key.Id) })
        .OrderByDescending(x => x.Puan)
        .ToList();

    var cinsiyetRows = kayitlar
        .Where(x => x.User?.Cinsiyet != null)
        .GroupBy(x => new { Id = x.User.UserCinsiyet, Ad = x.User.Cinsiyet.CinsiyetAdi })
        .Select(g => new ReportRow { Ad = SafeText(g.Key.Ad), Kisi = KisiSayisi(g), Soru = toplamSoru, Puan = OrtalamaPuan(g, sinavMi), Link = detayLink("AnketCinsiyetIndex", g.Key.Id) })
        .OrderByDescending(x => x.Puan)
        .ToList();

    var egitimRows = kayitlar
        .Where(x => x.User?.Egitim != null)
        .GroupBy(x => new { Id = x.User.UserEgitim, Ad = x.User.Egitim.EgitimAdi })
        .Select(g => new ReportRow { Ad = SafeText(g.Key.Ad), Kisi = KisiSayisi(g), Soru = toplamSoru, Puan = OrtalamaPuan(g, sinavMi), Link = detayLink("AnketEgitimIndex", g.Key.Id) })
        .OrderByDescending(x => x.Puan)
        .ToList();

    var yasRows = kayitlar
        .Where(x => x.User?.UserDogumTar != null)
        .GroupBy(x => new { Yil = x.User.UserDogumTar.Value.Year, Ad = YasEtiketi(x.User.UserDogumTar.Value.Year) })
        .GroupBy(x => x.Key.Ad)
        .Select(g => new ReportRow
        {
            Ad = g.Key,
            Kisi = KisiSayisi(g.SelectMany(x => x)),
            Soru = toplamSoru,
            Puan = OrtalamaPuan(g.SelectMany(x => x), sinavMi)
        })
        .OrderByDescending(x => x.Puan)
        .ToList();

    var sehirRows = kayitlar
        .Where(x => x.User?.Sehir != null)
        .GroupBy(x => new { Id = x.User.UserSehir, Ad = x.User.Sehir.SehiarAdi })
        .Select(g => new ReportRow { Ad = SafeText(g.Key.Ad), Kisi = KisiSayisi(g), Soru = toplamSoru, Puan = OrtalamaPuan(g, sinavMi), Link = detayLink("AnketSehirIndex", g.Key.Id) })
        .OrderByDescending(x => x.Puan)
        .ToList();

    var subeRows = kayitlar
        .Where(x => x.User?.Sube != null)
        .GroupBy(x => new { Id = x.User.UserSube, Ad = x.User.Sube.SubeAdi })
        .Select(g => new ReportRow { Ad = SafeText(g.Key.Ad), Kisi = KisiSayisi(g), Soru = toplamSoru, Puan = OrtalamaPuan(g, sinavMi), Link = detayLink("AnketSubeIndex", g.Key.Id) })
        .OrderByDescending(x => x.Puan)
        .ToList();

    var unvanRows = kayitlar
        .Where(x => x.User?.Unvan != null)
        .GroupBy(x => new { Id = x.User.UserUnvan, Ad = x.User.Unvan.UnvanAdi })
        .Select(g => new ReportRow { Ad = SafeText(g.Key.Ad), Kisi = KisiSayisi(g), Soru = toplamSoru, Puan = OrtalamaPuan(g, sinavMi), Link = detayLink("AnketUnvanIndex", g.Key.Id) })
        .OrderByDescending(x => x.Puan)
        .ToList();

    var yakaRows = kayitlar
        .Where(x => x.User?.Yaka != null)
        .GroupBy(x => new { Id = x.User.UserYaka, Ad = x.User.Yaka.YakaAdi })
        .Select(g => new ReportRow { Ad = SafeText(g.Key.Ad), Kisi = KisiSayisi(g), Soru = toplamSoru, Puan = OrtalamaPuan(g, sinavMi), Link = detayLink("AnketYakaIndex", g.Key.Id) })
        .OrderByDescending(x => x.Puan)
        .ToList();

    var yoneticiRows = kayitlar
        .Where(x => x.User?.Yonetici != null)
        .GroupBy(x => new { Id = x.User.UserYoneticisi, Ad = x.User.Yonetici.YoneticiAdi })
        .Select(g => new ReportRow { Ad = SafeText(g.Key.Ad), Kisi = KisiSayisi(g), Soru = toplamSoru, Puan = OrtalamaPuan(g, sinavMi), Link = detayLink("AnketYoneticiIndex", g.Key.Id) })
        .OrderByDescending(x => x.Puan)
        .ToList();

    var kisiRows = katilimGruplari
        .Select(g =>
        {
            var user = g.FirstOrDefault(x => x.User != null)?.User;
            var firstRec = g.FirstOrDefault();
            var detayId = user?.UserId ?? firstRec?.Isimsiz ?? firstRec?.UserId;
            var profil = user == null
                ? "Tanımsız katılımcı"
                : string.Join(" / ", new[]
                    {
                        user.Departman?.DepartmanAdi,
                        user.Unvan?.UnvanAdi,
                        user.Sehir?.SehiarAdi
                    }
                    .Where(x => !string.IsNullOrWhiteSpace(x))
                    .DefaultIfEmpty("Profil bilgisi yok"));

            return new ReportRow
            {
                Ad = !string.IsNullOrWhiteSpace(user?.UserAdi)
                    ? user.UserAdi
                    : (firstRec?.Isimsiz != null ? "Katılımcı #" + firstRec.Isimsiz : "Tanımsız katılımcı"),
                Alt = profil,
                Kisi = SonSoruCevaplari(g).Count,
                Soru = toplamSoru,
                Puan = KisiPuani(g, sinavMi),
                Link = detayId != null ? Url.Action("AnketUserIndex", "Home", new { id = detayId.Value, ank = anketId }) : null
            };
        })
        .OrderByDescending(x => x.Puan)
        .ToList();

    var breakdowns = new List<BreakdownBlock>
    {
        new BreakdownBlock { Baslik = "Departman", Ikon = "fa-sitemap", Satirlar = departmanRows },
        new BreakdownBlock { Baslik = "Cinsiyet", Ikon = "fa-venus-mars", Satirlar = cinsiyetRows },
        new BreakdownBlock { Baslik = "Eğitim", Ikon = "fa-graduation-cap", Satirlar = egitimRows },
        new BreakdownBlock { Baslik = "Yaş", Ikon = "fa-calendar", Satirlar = yasRows },
        new BreakdownBlock { Baslik = "Şehir", Ikon = "fa-map-marker-alt", Satirlar = sehirRows },
        new BreakdownBlock { Baslik = "Şube", Ikon = "fa-building", Satirlar = subeRows },
        new BreakdownBlock { Baslik = "Unvan", Ikon = "fa-id-badge", Satirlar = unvanRows },
        new BreakdownBlock { Baslik = "Yaka", Ikon = "fa-layer-group", Satirlar = yakaRows },
        new BreakdownBlock { Baslik = "Yönetici", Ikon = "fa-user-tie", Satirlar = yoneticiRows }
    }
    .Where(x => x.Satirlar != null && x.Satirlar.Any())
    .ToList();

    var enIyiGrup = soruGrubuRows.OrderByDescending(x => x.Puan).FirstOrDefault();
    var enDusukGrup = soruGrubuRows.OrderBy(x => x.Puan).FirstOrDefault();
    var enIyiSoru = soruRows.OrderByDescending(x => x.Puan).FirstOrDefault();
    var enDusukSoru = soruRows.OrderBy(x => x.Puan).FirstOrDefault();
}

<div class="report-showcase">
    <section class="report-hero">
        <div>
            <span class="eyebrow">Evalio Studio</span>
            <h1>@anketAdi</h1>
            <p>@calismaTuru sonuçları tek ekranda; katılım, genel skor, soru kırılımları ve kişi bazlı performans birlikte okunur.</p>
            <div class="hero-chips">
                <span><i class="fa fa-poll"></i> @calismaTuru</span>
                <span><i class="fa fa-users"></i> @toplamKatilim katılımcı</span>
                <span><i class="fa fa-list-check"></i> @toplamSoru soru</span>
                <span><i class="fa fa-chart-line"></i> @FormatScore(genelPuan)%</span>
            </div>
        </div>
        <div class="hero-actions">
            @if (!sinavMi)
            {
                <a class="showcase-btn primary" target="_blank" href="@Url.Action("MemnuniyetRaporu", "Home", new { id = anketId })">
                    <i class="fa fa-file-pdf"></i> Memnuniyet Raporu
                </a>
            }
            @if (!string.IsNullOrWhiteSpace(genelLink))
            {
                <a class="showcase-btn" href="@genelLink">
                    <i class="fa fa-table"></i> Detay Rapor
                </a>
            }
            <a class="showcase-btn" href="@Url.Action("AnketIndex", "Home", new { id = anketId })">
                <i class="fa fa-layer-group"></i> Rapor Merkezi
            </a>
        </div>
    </section>

    <section class="metric-grid">
        <div class="metric-card">
            <span>Genel skor</span>
            <strong>@FormatScore(genelPuan)%</strong>
            <small>@(sinavMi ? "Doğru cevap başarısı" : "Memnuniyet ortalaması")</small>
        </div>
        <div class="metric-card">
            <span>Katılım</span>
            <strong>@toplamKatilim</strong>
            <small>@tanimli tanımlı, @tanimsiz tanımsız</small>
        </div>
        <div class="metric-card">
            <span>Yanıt kapsamı</span>
            <strong>@FormatScore(tamamlama)%</strong>
            <small>@toplamYanıt / @beklenenYanıt yanıt</small>
        </div>
        <div class="metric-card">
            <span>Soru grubu</span>
            <strong>@soruGrubuRows.Count</strong>
            <small>@toplamSoru soru raporlandı</small>
        </div>
    </section>

    <section class="visual-grid">
        <article class="score-panel">
            <div class="score-ring" style="--score:@PercentWidth(genelPuan)">
                <div>
                    <strong>@FormatOne(genelPuan)</strong>
                    <span>%</span>
                </div>
            </div>
            <div class="score-copy">
                <span>Genel görünüm</span>
                <h2>@(genelPuan >= 80 ? "Güçlü tablo" : genelPuan >= 60 ? "Geliştirilebilir alanlar var" : "Dikkat isteyen sonuç")</h2>
                <p>@(sinavMi ? "Sınav puanı doğru cevaplara göre ağırlıklı hesaplandı." : "Anket puanı cevap puanlarının 100 üzerinden normalize edilmiş ortalamasıdır.")</p>
            </div>
        </article>

        <article class="insight-board">
            <div class="insight-card positive">
                <span>En güçlü kırılım</span>
                <strong>@(enIyiGrup?.Ad ?? "Henüz yok")</strong>
                <small>@(enIyiGrup == null ? "Veri oluşmadı" : FormatScore(enIyiGrup.Puan) + "%")</small>
            </div>
            <div class="insight-card warning">
                <span>İyileştirme adayı</span>
                <strong>@(enDusukGrup?.Ad ?? "Henüz yok")</strong>
                <small>@(enDusukGrup == null ? "Veri oluşmadı" : FormatScore(enDusukGrup.Puan) + "%")</small>
            </div>
            <div class="insight-card blue">
                <span>En yüksek soru</span>
                <strong>@(enIyiSoru?.Ad ?? "Henüz yok")</strong>
                <small>@(enIyiSoru == null ? "Veri oluşmadı" : FormatScore(enIyiSoru.Puan) + "%")</small>
            </div>
            <div class="insight-card coral">
                <span>En düşük soru</span>
                <strong>@(enDusukSoru?.Ad ?? "Henüz yok")</strong>
                <small>@(enDusukSoru == null ? "Veri oluşmadı" : FormatScore(enDusukSoru.Puan) + "%")</small>
            </div>
        </article>
    </section>

    <section class="report-section">
        <div class="section-head">
            <div>
                <span>Rapor kırılımı</span>
                <h2>Soru grupları</h2>
            </div>
            <small>@soruGrubuRows.Count kırılım</small>
        </div>

        @if (soruGrubuRows.Any())
        {
            <div class="ranking-list">
                @foreach (var row in soruGrubuRows)
                {
                    <div class="ranking-row">
                        <div class="ranking-title">
                            <strong>@row.Ad</strong>
                            <span>@row.Soru soru · @row.Kisi katılımcı</span>
                        </div>
                        <div class="ranking-score">
                            <b>@FormatScore(row.Puan)%</b>
                            <div class="score-bar"><i style="width:@PercentWidth(row.Puan)"></i></div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(row.Link))
                        {
                            <a href="@row.Link" class="row-action" title="Detay">
                                <i class="fa fa-arrow-right"></i>
                            </a>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fa fa-circle-info"></i>
                Bu çalışma için soru grubu kırılımı bulunamadı.
            </div>
        }
    </section>

    <section class="report-section">
        <div class="section-head">
            <div>
                <span>Soru performansı</span>
                <h2>Tek tek sorular</h2>
            </div>
            <small>@soruRows.Count soru</small>
        </div>

        @if (soruRows.Any())
        {
            <div class="question-grid">
                @foreach (var row in soruRows)
                {
                    <a class="question-card" href="@(row.Link ?? "#")">
                        <div>
                            <span>@row.Alt</span>
                            <strong>@row.Ad</strong>
                        </div>
                        <div class="question-score">
                            <b>@FormatScore(row.Puan)%</b>
                            <div class="score-bar"><i style="width:@PercentWidth(row.Puan)"></i></div>
                        </div>
                    </a>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fa fa-circle-info"></i>
                Bu çalışma için soru sonucu oluşmadı.
            </div>
        }
    </section>

    <section class="report-section">
        <div class="section-head">
            <div>
                <span>Organizasyon kırılımları</span>
                <h2>Profil bazlı okumalar</h2>
            </div>
            <small>@breakdowns.Count aktif kırılım</small>
        </div>

        @if (breakdowns.Any())
        {
            <div class="breakdown-grid">
                @foreach (var block in breakdowns)
                {
                    <article class="breakdown-card">
                        <div class="breakdown-head">
                            <i class="fa @block.Ikon"></i>
                            <strong>@block.Baslik</strong>
                        </div>
                        @foreach (var row in block.Satirlar.Take(6))
                        {
                            <div class="mini-row">
                                <div>
                                    <strong>@row.Ad</strong>
                                    <span>@row.Kisi katılımcı</span>
                                </div>
                                <div>
                                    <b>@FormatScore(row.Puan)%</b>
                                    <div class="score-bar tiny"><i style="width:@PercentWidth(row.Puan)"></i></div>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(row.Link))
                                {
                                    <a href="@row.Link" title="Detay">
                                        <i class="fa fa-arrow-right"></i>
                                    </a>
                                }
                            </div>
                        }
                    </article>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fa fa-circle-info"></i>
                Bu çalışma katılım kodu ile tanımsız tamamlandığı için profil kırılımları boş olabilir.
            </div>
        }
    </section>

    <section class="report-section">
