                <span>Katılımcı görünümü</span>
                <h2>Kişiye göre sonuçlar</h2>
            </div>
            <small>@kisiRows.Count kayıt</small>
        </div>

        @if (kisiRows.Any())
        {
            <div class="person-list">
                @foreach (var row in kisiRows)
                {
                    <a class="person-card" href="@(row.Link ?? "#")">
                        <div class="person-avatar">@row.Ad.Substring(0, 1).ToUpper(new CultureInfo("tr-TR"))</div>
                        <div class="person-info">
                            <strong>@row.Ad</strong>
                            <span>@row.Alt</span>
                        </div>
                        <div class="person-progress">
                            <b>@FormatScore(row.Puan)%</b>
                            <small>@row.Kisi / @row.Soru cevap</small>
                        </div>
                    </a>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fa fa-circle-info"></i>
                Katılımcı sonucu henüz oluşmadı.
            </div>
        }
    </section>
</div>

