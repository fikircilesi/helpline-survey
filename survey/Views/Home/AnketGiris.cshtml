@model survey.Models.User
@{
    ViewBag.Title = "Giris";
    Layout = null;

}

<!DOCTYPE html>
<html>
<head>
    <title>Survey by Aslana Teknoloji</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=0, minimal-ui">
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="description" content="#">
    <meta name="keywords"
          content="Admin , Responsive, Landing, Bootstrap, App, Template, Mobile, iOS, Android, apple, creative app">
    <meta name="author" content="#">
    <!-- Favicon icon -->
    <link rel="icon" href="~/Content/img/aslana-favicon.png" type="image/png">
    <!-- Google font-->
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:400,600,800" rel="stylesheet">
    <!-- Required Fremwork -->
    <link rel="stylesheet" type="text/css" href="~/files/bower_components/bootstrap/dist/css/bootstrap.min.css">
    <!-- themify-icons line icon -->
    <link rel="stylesheet" type="text/css" href="~/files/assets/icon/themify-icons/themify-icons.css">
    <!-- ico font -->
    <link rel="stylesheet" type="text/css" href="~/files/assets/icon/icofont/css/icofont.css">
    <!-- Style.css -->
    <link rel="stylesheet" type="text/css" href="~/files/assets/css/style.css">
</head>
<body>
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true)

        <section class="login-block">
            <!-- Container-fluid starts -->
            <div class="container">
                <div class="row">
                    <div class="col-sm-12">
                        <!-- Authentication card start -->
                        <br />
                        <br />
                        <br />

                        <div class="md-float-material form-material">
                            <div class="text-center">
                                <img src="~/Content/img/aslana-logo.png" alt="Survey by Aslana Teknoloji">
                            </div>
                            <div class="auth-box card">
                                <div class="card-block">
                                    <div class="row m-b-20">
                                        <div class="col-md-12">
                                            <h3 class="text-center">Giriş</h3>
                                        </div>
                                    </div>
                                    <div class="mb-3 form-primary">
                                        <input name="objUser" type="text" class="form-control" required=""
                                               placeholder="Tc No" />
                                        <span class="form-bar"></span>
                                    </div>
                                    <div class="row m-t-30">
                                        <div class="d-grid">
                                            <button type="submit" class="btn btn-primary btn-md waves-effect waves-light text-center">
                                                Giriş
                                            </button>
                                        </div>
                                    </div>
                                    <div class="mb-3 form-primary">
                                        <input hidden name="objUser" class="form-control" value="" />
                                        <span class="form-bar"></span>
                                    </div>
                                    <div class="d-grid">

                                        <a class="btn btn-primary btn-md waves-effect waves-light text-center m-b-20" href="@Url.Action("AnketGirisIndex", "Home", new { kod = ViewBag.kod, user = Session["id"] })">Tanımsız Giriş</a>
                                    </div>
                                    <div style="color:red">
                                        @if (ViewBag.Uyari != null)
                                        {
                                            @ViewBag.Uyari
                                        }

                                    </div>
                                    <hr />
                                    <div class="row">
                                        <div class="col-md-10">
                                            <a href="@Url.Action("Giris", "Home")">
                                                <p class="text-inverse text-start m-b-0">&copy; Survey by Aslana Teknoloji</p>

                                            </a>

                                        </div>
                                        <div class="col-md-2">
                                            <a href="@Url.Action("Giris", "Home")">
                                                <img width="82" src="~/Content/img/aslana-logo.png" alt="Survey by Aslana Teknoloji" />
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- end of form -->
                    </div>
                    <!-- end of col-sm-12 -->
                </div>
                <!-- end of row -->
            </div>
            <!-- end of container-fluid -->
        </section>
    }

    <script type="text/javascript" src="~/files/bower_components/jquery/dist/jquery.min.js"></script>
    <script type="text/javascript" src="~/files/bower_components/jquery-ui/jquery-ui.min.js"></script>
    <script type="text/javascript" src="~/files/bower_components/popper.js/dist/umd/popper.min.js"></script>
    <script type="text/javascript" src="~/files/bower_components/bootstrap/dist/js/bootstrap.min.js"></script>
    <!-- jquery slimscroll js -->
    <script type="text/javascript" src="~/files/bower_components/jquery-slimscroll/jquery.slimscroll.js"></script>
    <!-- modernizr js -->
    <script type="text/javascript" src="~/files/bower_components/modernizr/modernizr.js"></script>
    <script type="text/javascript" src="~/files/bower_components/modernizr/feature-detects/css-scrollbars.js"></script>
    <!-- i18next.min.js -->
    <script type="text/javascript" src="~/files/bower_components/i18next/i18next.min.js"></script>
    <script type="text/javascript"
            src="~/files/bower_components/i18next-xhr-backend/i18nextXHRBackend.min.js"></script>
    <script type="text/javascript"
            src="~/files/bower_components/i18next-browser-languagedetector/i18nextBrowserLanguageDetector.min.js"></script>
    <script type="text/javascript" src="~/files/bower_components/jquery-i18next/jquery-i18next.min.js"></script>
    <script type="text/javascript" src="~/files/assets/js/common-pages.js"></script>

</body>
</html>

