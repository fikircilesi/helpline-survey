                            </button>
                        </div>
                        <div id="reportSummary" class="report-summary-grid"></div>
                        <div id="raporContainer"></div>
                    </div>


                    <!-- Genel -->
                    <div class="tab-pane" id="Genel"><div class="insight-board" id="insight1"></div></div>
                    <div class="tab-pane" id="Departman"><div class="insight-board" id="insight2"></div></div>
                    <div class="tab-pane" id="Cinsiyet"><div class="insight-board" id="insight3"></div></div>
                    <div class="tab-pane" id="Egitim"><div class="insight-board" id="insight4"></div></div>
                    <div class="tab-pane" id="Yas"><div class="insight-board" id="insight5"></div></div>
                    <div class="tab-pane" id="Sehir"><div class="insight-board" id="insight6"></div></div>
                    <div class="tab-pane" id="Sube"><div class="insight-board" id="insight7"></div></div>
                    <div class="tab-pane" id="Unvani"><div class="insight-board" id="insight8"></div></div>
                    <div class="tab-pane" id="Yaka"><div class="insight-board" id="insight9"></div></div>
                    <div class="tab-pane" id="Yonetici"><div class="insight-board" id="insight10"></div></div>
                    <div class="tab-pane" id="Soru"><div class="insight-board" id="insight11"></div></div>
                    <div class="tab-pane" id="Sorugrup"><div class="insight-board" id="insight12"></div></div>

                    <!-- Kişi Tablosu -->
                    <div class="tab-pane" id="Kisi">
                        <div class="person-table-head">
                            <div>
                                <h3>Kişiye Göre Detay</h3>
                                <p>Katılımcı bazında puan, departman ve diğer profil alanlarını tek tabloda inceleyin.</p>
                            </div>
                        </div>
                        <div class="person-table-shell">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover" id="Grid">
                                <thead>
                                    <!-- Başlık satırı -->
                                    <tr class="table-dark">
                                        <th>Adı Soyadı</th>
                                        <th>Departman</th>
                                        <th>Cinsiyet</th>
                                        <th>Eğitim</th>
                                        <th>Yaş</th>
                                        <th>Şehir</th>
                                        <th>Şube</th>
                                        <th>Ünvan</th>
                                        <th>Yaka</th>
                                        <th>Yönetici</th>
                                        <th>Puan</th>
                                    </tr>
                                    <!-- Arama satırı (Id için input yok) -->
                                    <tr>
                                        <th><input type="text" placeholder="Ara Adı Soyadı" /></th>
                                        <th><input type="text" placeholder="Ara Departman" /></th>
                                        <th><input type="text" placeholder="Ara Cinsiyet" /></th>
                                        <th><input type="text" placeholder="Ara Eğitim" /></th>
                                        <th><input type="text" placeholder="Ara Yaş" /></th>
                                        <th><input type="text" placeholder="Ara Şehir" /></th>
                                        <th><input type="text" placeholder="Ara Şube" /></th>
                                        <th><input type="text" placeholder="Ara Ünvan" /></th>
                                        <th><input type="text" placeholder="Ara Yaka" /></th>
                                        <th><input type="text" placeholder="Ara Yönetici" /></th>
                                        <th><input type="text" placeholder="Ara Puan" /></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in modelKayitlari.GroupBy(x => x.UserId.HasValue
                                        ? "u:" + x.UserId.Value
                                        : x.Isimsiz.HasValue
                                            ? "k:" + x.Isimsiz.Value
                                            : "h:" + x.HavuzId))
                                    {
                                        var ilkKayit = item
                                            .OrderByDescending(x => x.KayitTar ?? DateTime.MinValue)
                                            .ThenByDescending(x => x.HavuzId)
                                            .FirstOrDefault();
                                        var kullanici = ilkKayit?.User;
                                        var raporId = kullanici?.UserId ?? ilkKayit?.Isimsiz ?? ilkKayit?.UserId ?? ilkKayit?.HavuzId ?? 0;
                                        var katilimciAdi = !string.IsNullOrWhiteSpace(kullanici?.UserAdi)
                                            ? kullanici.UserAdi
                                            : ilkKayit?.Isimsiz.HasValue == true
                                                ? "Katılımcı #" + ilkKayit.Isimsiz.Value
                                                : "Tanımsız katılımcı";
                                        var departmanAdi = !string.IsNullOrWhiteSpace(kullanici?.Departman?.DepartmanAdi) ? kullanici.Departman.DepartmanAdi : "Tanımsız";
                                        var cinsiyetAdi = !string.IsNullOrWhiteSpace(kullanici?.Cinsiyet?.CinsiyetAdi) ? kullanici.Cinsiyet.CinsiyetAdi : "Tanımsız";
                                        var egitimAdi = !string.IsNullOrWhiteSpace(kullanici?.Egitim?.EgitimAdi) ? kullanici.Egitim.EgitimAdi : "Tanımsız";
                                        var sehirAdi = !string.IsNullOrWhiteSpace(kullanici?.Sehir?.SehiarAdi) ? kullanici.Sehir.SehiarAdi : "Tanımsız";
                                        var subeAdi = !string.IsNullOrWhiteSpace(kullanici?.Sube?.SubeAdi) ? kullanici.Sube.SubeAdi : "Tanımsız";
                                        var unvanAdi = !string.IsNullOrWhiteSpace(kullanici?.Unvan?.UnvanAdi) ? kullanici.Unvan.UnvanAdi : "Tanımsız";
                                        var yakaAdi = !string.IsNullOrWhiteSpace(kullanici?.Yaka?.YakaAdi) ? kullanici.Yaka.YakaAdi : "Tanımsız";
                                        var yoneticiAdi = !string.IsNullOrWhiteSpace(kullanici?.Yonetici?.YoneticiAdi) ? kullanici.Yonetici.YoneticiAdi : "Tanımsız";
                                        <tr>
                                            <!-- ID gizli olacak -->

                                            <td>
                                                <div class="avatar-name-cell">
                                                    @await Html.PartialAsync("_KatilimciAvatar", new survey.Models.KatilimciAvatarModel { Ad = katilimciAdi, Resim = kullanici?.UserResim, Cinsiyet = kullanici?.Cinsiyet?.CinsiyetAdi, Size = "sm" })
                                                    @if (raporId > 0)
                                                    {
                                                        <a href="@Url.Action("AnketUserIndex", "Home", new { id = raporId, ank = ViewBag.id })">
                                                            @katilimciAdi
                                                        </a>
                                                    }
                                                    else
                                                    {
                                                        <span>@katilimciAdi</span>
                                                    }
                                                </div>
                                            </td>
                                            <td>@departmanAdi</td>
                                            <td>@cinsiyetAdi</td>
                                            <td>@egitimAdi</td>
                                            <td>
                                                @{
                                                    var dogumTarihi = kullanici?.UserDogumTar;
                                                    if (dogumTarihi != null)
                                                    {
                                                        var yas = DateTime.Today.Year - dogumTarihi.Value.Year;
                                                        if (DateTime.Today < dogumTarihi.Value.AddYears(yas)) { yas--; }
                                                        @yas
                                                    }
                                                    else
                                                    {
                                                        <span>Tanımsız</span>
                                                    }
                                                }
                                            </td>
                                            <td>@sehirAdi</td>
                                            <td>@subeAdi</td>
                                            <td>@unvanAdi</td>
                                            <td>@yakaAdi</td>
                                            <td>@yoneticiAdi</td>
                                            <td>
                                                @if (ViewBag.sinav != true)
                                                {
                                                    var soru = item.Count();
                                                    var c5 = item.Count(x => x.CevapPuan == 5);
                                                    var c4 = item.Count(x => x.CevapPuan == 4);
                                                    var c3 = item.Count(x => x.CevapPuan == 3);
                                                    var c2 = item.Count(x => x.CevapPuan == 2);
                                                    var c1 = item.Count(x => x.CevapPuan == 1);

                                                    var d5 = (float)c5 * 5 / 5 * 100;
                                                    var d4 = (float)c4 * 4 / 5 * 100;
                                                    var d3 = (float)c3 * 3 / 5 * 100;
                                                    var d2 = (float)c2 * 2 / 5 * 100;
                                                    var d1 = (float)c1 * 1 / 5 * 100;

                                                    var p2 = d1 + d2 + d3 + d4 + d5;
                                                    var p1 = p2 / soru;
                                                    @String.Format("{0:n2}", p1)
                                                }
                                                else
                                                {
                                                    var cx = item.Where(x => x.Cevap != null && x.Cevap.Dogru == true);
                                                    var tp = cx.Sum(x => x.SoruPuan ?? 0);
                                                    @String.Format("{0:n2}", tp)
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        </div>
                    </div>
                </div> <!-- tab-content -->
            </div>
        </div>
    </div>
</div>
