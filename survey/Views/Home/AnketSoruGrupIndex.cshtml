            <p>@ViewBag.anketadi çalışmasının tüm sonuç kırılımları burada toparlandı. Kalabalık ünvan ve soru listeleri artık grafiği boğmadan, özet ve detay dengesiyle okunur.</p>
        </div>
        <a class="report-back" href="@Url.Action("AnketIndex1", "Home", new { id = ViewBag.ank })">
            <i class="fa fa-arrow-left"></i> Çalışmaya dön
        </a>
    </div>

