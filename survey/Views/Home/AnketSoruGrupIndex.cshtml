@model IEnumerable<survey.Models.Havuz>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var modelKayitlari = (Model ?? Enumerable.Empty<survey.Models.Havuz>()).ToList();
    var tanimli = modelKayitlari.Where(x => x.UserId != null).GroupBy(x => x.UserId).Count();
    var tanimsiz = modelKayitlari.Where(x => x.Isimsiz != null).Count();
    var toplamKatilim = tanimli + tanimsiz;
    var cevapKaydiSayisi = modelKayitlari.Count;
    var yoneticiAdlari = (ViewBag.baslik10 as System.Collections.Generic.IEnumerable<string> ?? Enumerable.Empty<string>()).ToList();
    var yoneticiResimDosyalari = (ViewBag.yoneticiResim10 as System.Collections.Generic.IEnumerable<string> ?? Enumerable.Empty<string>()).ToList();
    var yoneticiAvatarlar = yoneticiAdlari
        .Select((ad, index) =>
        {
            var resim = index < yoneticiResimDosyalari.Count ? yoneticiResimDosyalari[index] : string.Empty;
            var dosya = System.IO.Path.GetFileName(resim ?? string.Empty);
            return new
            {
                ad = ad ?? string.Empty,
                resim = string.IsNullOrWhiteSpace(dosya) ? string.Empty : Url.Content("~/Content/Yonetici/" + dosya)
            };
        })
        .GroupBy(x => x.ad)
        .Select(g => g.First())
        .ToList();
}

