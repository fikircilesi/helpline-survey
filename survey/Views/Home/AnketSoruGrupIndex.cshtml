<script>
    (function () {
        const workTitle = @Html.Raw(JsonConvert.SerializeObject(Convert.ToString(ViewBag.adi) ?? ""));
        const workSubtitle = @Html.Raw(JsonConvert.SerializeObject(Convert.ToString(ViewBag.anketadi) ?? ""));
        const participantTotals = {
            total: @toplamKatilim,
            defined: @tanimli,
            anonymous: @tanimsiz,
            answerRows: @cevapKaydiSayisi
        };

        const dimensions = [
            { id: 1, target: "insight1", tab: "#Genel", label: "Genel", labels: baslik1, scores: puan1, counts: adet1, note: "Çalışmanın genel skor dağılımı." },
            { id: 2, target: "insight2", tab: "#Departman", label: "Departman", labels: baslik2, scores: puan2, counts: adet2, note: "Departman bazında katılım ve ortalama puan." },
            { id: 3, target: "insight3", tab: "#Cinsiyet", label: "Cinsiyet", labels: baslik3, scores: puan3, counts: adet3, note: "Cinsiyet kırılımında sonuç dengesi." },
            { id: 4, target: "insight4", tab: "#Egitim", label: "Eğitim", labels: baslik4, scores: puan4, counts: adet4, note: "Eğitim seviyesine göre sonuç görünümü." },
            { id: 5, target: "insight5", tab: "#Yas", label: "Yaş", labels: baslik5, scores: puan5, counts: adet5, note: "Yaş gruplarında skor ve katılımcı yoğunluğu." },
            { id: 6, target: "insight6", tab: "#Sehir", label: "Şehir", labels: baslik6, scores: puan6, counts: adet6, note: "Şehir bazında karşılaştırmalı görünüm." },
            { id: 7, target: "insight7", tab: "#Sube", label: "Şube", labels: baslik7, scores: puan7, counts: adet7, note: "Şubelerin ortalama performansı ve katılımı." },
            { id: 8, target: "insight8", tab: "#Unvani", label: "Ünvan", labels: baslik8, scores: puan8, counts: adet8, note: "Çok uzun ünvan listeleri özetlenir, tüm detay tabloda aranır." },
            { id: 9, target: "insight9", tab: "#Yaka", label: "Yaka", labels: baslik9, scores: puan9, counts: adet9, note: "Yaka tipine göre sonuçların ayrımı." },
            { id: 10, target: "insight10", tab: "#Yonetici", label: "Yönetici", labels: baslik10, scores: puan10, counts: adet10, note: "Yönetici kırılımında ekiplerin genel görünümü." },
            { id: 11, target: "insight11", tab: "#Soru", label: "Soru", labels: baslik11, scores: puan11, counts: adet11, note: "Soruların ortalama başarı ve cevap yoğunluğu." },
            { id: 12, target: "insight12", tab: "#Sorugrup", label: "Soru Grup", labels: baslik12, scores: puan12, counts: adet12, note: "Soru gruplarının rapor başlığı bazında özeti." }
        ];
        let lastReportCards = [];
        const livePalette = [
            "#2ec4b6", "#4361ee", "#f59e0b", "#ef476f", "#06d6a0", "#118ab2",
            "#9b5de5", "#f15bb5", "#00bbf9", "#fb8500", "#4cc9f0", "#70e000"
        ];
        function avatarMapKey(value) {
            return String(value || "")
                .normalize("NFKC")
                .toLocaleLowerCase("tr-TR")
                .replace(/\s+/g, " ")
                .trim();
        }

        const managerAvatarMap = (Array.isArray(yoneticiAvatarlar) ? yoneticiAvatarlar : []).reduce(function (map, item) {
            const key = avatarMapKey(item.ad);
            if (key) {
                map[key] = item.resim || "";
            }
            return map;
        }, {});

        function escapeHtml(value) {
            return String(value ?? "").replace(/[&<>"']/g, function (char) {
                return {
                    "&": "&amp;",
                    "<": "&lt;",
                    ">": "&gt;",
                    "\"": "&quot;",
                    "'": "&#39;"
                }[char];
            });
        }

        function asNumber(value) {
            const numeric = Number(value);
            return Number.isFinite(numeric) ? numeric : 0;
        }

        function formatScore(value) {
            return asNumber(value).toLocaleString("tr-TR", {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            });
        }

        function formatCount(value) {
            return Math.round(asNumber(value)).toLocaleString("tr-TR");
        }

        function normalizeRows(dimension) {
            const labels = Array.isArray(dimension.labels) ? dimension.labels : [];
            const scores = Array.isArray(dimension.scores) ? dimension.scores : [];
            const counts = Array.isArray(dimension.counts) ? dimension.counts : [];

            return labels.map(function (label, index) {
                const name = String(label || "Tanımsız").trim() || "Tanımsız";
                const managerKey = avatarMapKey(name);
                const hasAvatar = dimension.id === 10;
                return {
                    name,
                    score: asNumber(scores[index]),
                    count: asNumber(counts[index]),
                    hasAvatar,
                    avatarUrl: hasAvatar ? (managerAvatarMap[managerKey] || "") : ""
                };
            }).filter(function (row) {
                return row.name || row.score || row.count;
            }).sort(function (a, b) {
                return (b.count - a.count) || (b.score - a.score) || a.name.localeCompare(b.name, "tr");
            });
        }

        function weightedScore(rows) {
            const totalCount = rows.reduce(function (sum, row) { return sum + row.count; }, 0);
            if (totalCount > 0) {
                return rows.reduce(function (sum, row) { return sum + (row.score * row.count); }, 0) / totalCount;
            }

            return rows.length
                ? rows.reduce(function (sum, row) { return sum + row.score; }, 0) / rows.length
                : 0;
        }

        function topRow(rows) {
            return rows.slice().sort(function (a, b) {
                return (b.score - a.score) || (b.count - a.count) || a.name.localeCompare(b.name, "tr");
            })[0] || null;
        }

        function buildBars(rows, limit) {
            const visible = rows.slice(0, limit);
            if (!visible.length) {
                return '<div class="chart-empty">Bu kırılım için gösterilecek veri yok.</div>';
            }

            const maxScore = Math.max(100, ...visible.map(function (row) { return row.score; }));
            return '<div class="bar-list">' + visible.map(function (row) {
                const width = Math.max(3, Math.min(100, (row.score / maxScore) * 100));
                return `
                    <div class="bar-row" title="${escapeHtml(row.name)}">
                        <div class="bar-label">${buildLabelContent(row, "sm")}</div>
                        <div class="bar-track"><div class="bar-fill" style="width:${width}%"></div></div>
                        <div class="bar-value">${formatScore(row.score)} <small>(${formatCount(row.count)})</small></div>
                    </div>`;
            }).join("") + "</div>";
        }

        function liveColor(index) {
            return livePalette[index % livePalette.length];
        }

        function liveVerticalGradient(index) {
            return `linear-gradient(180deg, ${liveColor(index)}, ${liveColor(index + 2)})`;
        }

        function liveChartLabel(rows) {
            if (rows.length <= 3) return "Pasta grafik";
            if (rows.length <= 9) return "Kolon grafik";
            return "Yo\u011fun liste \u00f6zeti";
        }

        function buildLiveAvatar(row, size) {
            if (!row?.hasAvatar) return "";
            const safeName = escapeHtml(row.name);
            const safeSrc = escapeHtml(row.avatarUrl || "");
            const photoClass = safeSrc ? " has-photo" : "";
            const image = safeSrc
                ? `<img src="${safeSrc}" alt="${safeName}" onerror="this.parentElement.classList.remove('has-photo'); this.remove();">`
                : "";

            return `
                <span class="katilimci-avatar ${size || "sm"} is-neutral${photoClass}"
                      title="${safeName}"
                      aria-label="${safeName}"
                      data-avatar-preview-open
                      data-avatar-name="${safeName}"
                      data-avatar-src="${safeSrc}"
                      data-avatar-tone="is-neutral"
                      data-avatar-icon="fa-user">
                    ${image}
                    <span class="katilimci-avatar-fallback">
                        <i class="fa fa-user" aria-hidden="true"></i>
                    </span>
                </span>`;
        }

        function buildLabelContent(row, size) {
            if (!row?.hasAvatar) return escapeHtml(row.name);
            return `
                <span class="live-avatar-name">
                    ${buildLiveAvatar(row, size || "sm")}
                    <span>${escapeHtml(row.name)}</span>
                </span>`;
        }

        function buildLiveChartLegend(rows, colorOffset) {
            return `
                <div class="live-chart-legend">
                    ${rows.map(function (row, index) {
                        return `
                            <div class="live-chart-legend-row">
                                <span class="live-chart-swatch" style="background:${liveColor(colorOffset + index)}"></span>
                                <span title="${escapeHtml(row.name)}">${buildLabelContent(row, "sm")}</span>
                                <strong>${formatScore(row.score)}</strong>
                            </div>`;
                    }).join("")}
                </div>`;
        }

        function buildLivePieVisual(rows, colorOffset) {
            const values = rows.map(function (row) { return Math.max(0, row.count); });
            const total = values.reduce(function (sum, value) { return sum + value; }, 0);
            const safeValues = total > 0 ? values : rows.map(function () { return 1; });
            const safeTotal = safeValues.reduce(function (sum, value) { return sum + value; }, 0);
            let angle = 0;

            const slices = rows.length === 1
                ? `<circle cx="110" cy="110" r="86" fill="${liveColor(colorOffset)}"></circle>`
                : rows.map(function (row, index) {
                    const sliceAngle = (safeValues[index] / safeTotal) * 360;
                    const start = angle;
                    const end = angle + sliceAngle;
                    angle = end;
                    return `<path d="${pieSlicePath(110, 110, 86, start, end)}" fill="${liveColor(colorOffset + index)}"></path>`;
                }).join("");

            return `
                <div class="live-pie-layout">
                    <svg class="live-pie-svg" viewBox="0 0 220 220" role="img" aria-label="Pasta grafik">
                        <circle cx="110" cy="110" r="94" fill="#edf3fb"></circle>
                        ${slices}
                        <circle cx="110" cy="110" r="43" fill="#ffffff"></circle>
                        <text x="110" y="105" text-anchor="middle" fill="#122033" font-size="23" font-weight="900">${formatCount(rows.length)}</text>
                        <text x="110" y="125" text-anchor="middle" fill="#66758c" font-size="10" font-weight="800">kay&#305;t</text>
                    </svg>
                    ${buildLiveChartLegend(rows, colorOffset)}
                </div>`;
        }

        function buildLiveColumnVisual(rows, colorOffset) {
            return `
                <div class="live-column-chart">
                    ${rows.map(function (row, index) {
                        const height = Math.max(6, Math.min(100, row.score));
                        return `
                            <div class="live-column-item">
                                <div class="live-column-track">
                                    <div class="live-column-value">${formatScore(row.score)}</div>
                                    <div class="live-column-fill" style="height:${height}%; background:${liveVerticalGradient(colorOffset + index)}"></div>
                                </div>
                                <div class="live-column-label" title="${escapeHtml(row.name)}">${buildLabelContent(row, "sm")}</div>
                            </div>`;
                    }).join("")}
                </div>`;
        }

        function buildLiveDensityVisual(rows, colorOffset, compact) {
            const visible = rows.slice(0, compact ? 5 : 8);
            return `
                <div class="live-density-grid">
                    ${visible.map(function (row, index) {
                        return `
                            <div class="live-density-card" style="--accent:${liveColor(colorOffset + index)}">
                                <span title="${escapeHtml(row.name)}">${buildLabelContent(row, compact ? "sm" : "md")}</span>
                                <strong>${formatScore(row.score)}</strong>
                                <small>${formatCount(row.count)} ki&#351;i</small>
                            </div>`;
                    }).join("")}
                </div>`;
        }

        function buildAdaptiveLiveChart(rows, options) {
            const settings = options || {};
            const compact = settings.compact === true;
            const colorOffset = settings.colorOffset || 0;

            if (!rows.length) {
                return '<div class="chart-empty">Bu k\u0131r\u0131l\u0131m i\u00e7in g\u00f6sterilecek veri yok.</div>';
            }

            if (rows.length <= 3) {
                return `<div class="live-chart-summary">${buildLivePieVisual(rows, colorOffset)}</div>`;
            }

            if (rows.length <= 9 && !compact) {
                return `<div class="live-chart-summary">${buildLiveColumnVisual(rows, colorOffset)}</div>`;
            }

            if (rows.length <= 6) {
                return `<div class="live-chart-summary">${buildLiveColumnVisual(rows, colorOffset)}</div>`;
            }

            return `<div class="live-chart-summary">${buildLiveDensityVisual(rows, colorOffset, compact)}</div>`;
        }

        function buildTable(dimension, rows) {
            if (!rows.length) {
                return '<div class="chart-empty">Tabloya aktarılacak veri bulunamadı.</div>';
            }

            return `
                <input id="dimSearch${dimension.id}" class="dim-search" type="search" placeholder="${escapeHtml(dimension.label)} içinde ara">
                <div class="insight-table-wrap">
                    <table class="insight-table">
                        <thead>
                            <tr>
                                <th>${escapeHtml(dimension.label)}</th>
                                <th>Ortalama</th>
                                <th>Kişi</th>
                                <th>Dağılım</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${rows.map(function (row) {
                                const width = Math.max(3, Math.min(100, row.score));
                                return `
                                    <tr data-label="${escapeHtml(row.name.toLocaleLowerCase("tr-TR"))}">
                                        <td>${buildLabelContent(row, "sm")}</td>
                                        <td><strong>${formatScore(row.score)}</strong></td>
                                        <td>${formatCount(row.count)}</td>
                                        <td><div class="mini-track"><div class="mini-fill" style="width:${width}%"></div></div></td>
                                    </tr>`;
                            }).join("")}
                        </tbody>
                    </table>
                </div>`;
        }

        function bindTableFilter(dimension) {
            const input = document.getElementById(`dimSearch${dimension.id}`);
            if (!input) return;

            input.addEventListener("input", function () {
                const query = this.value.trim().toLocaleLowerCase("tr-TR");
                document.querySelectorAll(`#${dimension.target} tbody tr`).forEach(function (row) {
                    row.style.display = row.dataset.label.includes(query) ? "" : "none";
                });
            });
        }

        function renderDimension(dimension) {
            const target = document.getElementById(dimension.target);
            if (!target) return;

            const rows = normalizeRows(dimension);
            const totalCount = rows.reduce(function (sum, row) { return sum + row.count; }, 0);
            const weighted = weightedScore(rows);
            const leader = topRow(rows);
            const visualLimit = rows.length > 18 ? 12 : rows.length;
            const visualLabel = liveChartLabel(rows);

            target.innerHTML = `
                <div class="insight-head">
                    <div>
                        <h3>${escapeHtml(dimension.label)} Analizi</h3>
                        <p>${escapeHtml(dimension.note)} Grafik alanı en anlamlı kayıtlarla sınırlı, tam liste aramalı tabloda.</p>
                    </div>
                </div>
                <div class="insight-kpis">
                    <div class="insight-metric"><span>Kırılım</span><strong>${formatCount(rows.length)}</strong></div>
                    <div class="insight-metric"><span>Ortalama puan</span><strong>${formatScore(weighted)}</strong></div>
                    <div class="insight-metric"><span>Kişi sayısı</span><strong>${formatCount(totalCount)}</strong></div>
                    <div class="insight-metric"><span>En yüksek</span><strong title="${escapeHtml(leader?.name || "-")}">${escapeHtml(leader ? leader.name : "-")}</strong></div>
                </div>
                <div class="insight-layout">
                    <div class="chart-panel">
                        <div class="panel-title">
                            <h4>Öne çıkan ${visualLimit} kayıt</h4>
                            <small>Puan / kişi</small>
                        </div>
                        ${buildAdaptiveLiveChart(rows, { colorOffset: dimension.id * 3 })}
                    </div>
                    <div class="table-panel">
                        <div class="panel-title">
                            <h4>Tüm detay</h4>
                            <small>${formatCount(rows.length)} satır</small>
                        </div>
                        ${buildTable(dimension, rows)}
                    </div>
                </div>`;

            bindTableFilter(dimension);
        }

        function renderSummaryCards(reportRows) {
            const best = reportRows.slice().sort(function (a, b) { return b.average - a.average; })[0];
            const widest = reportRows.slice().sort(function (a, b) { return b.categoryCount - a.categoryCount; })[0];
            const bestLabel = best?.dimension?.label || "-";
            const widestLabel = widest?.dimension?.label || "-";

            document.getElementById("reportSummary").innerHTML = `
                <div class="summary-card"><span>Katılım</span><strong>${formatCount(participantTotals.total)}</strong></div>
                <div class="summary-card"><span>Cevap satırı</span><strong>${formatCount(participantTotals.answerRows)}</strong></div>
                <div class="summary-card"><span>En yüksek kırılım</span><strong>${escapeHtml(bestLabel)}</strong><small>${best ? formatScore(best.average) + " ort." : ""}</small></div>
                <div class="summary-card"><span>En yoğun liste</span><strong>${escapeHtml(widestLabel)}</strong><small>${widest ? formatCount(widest.categoryCount) + " kırılım" : ""}</small></div>`;
        }

        function buildReportCardGrid(cards, includeDetailButton, barLimit) {
            const limit = barLimit || 5;
            return `
                <div class="report-card-grid">
                    ${cards.map(function (card) {
                        const detailButton = includeDetailButton
                            ? `<button type="button" class="dimension-link" data-tab="${card.dimension.tab}">Detay</button>`
                            : "";

                        return `
                            <section class="dimension-card">
                                <div class="dimension-card-head">
                                    <div>
                                        <h4>${escapeHtml(card.dimension.label)}</h4>
                                        <small>${formatCount(card.categoryCount)} kırılım · ${formatCount(card.totalCount)} kişi · ${formatScore(card.average)} ort.</small>
                                    </div>
                                    ${detailButton}
                                </div>
                                ${buildAdaptiveLiveChart(card.rows, { compact: true, colorOffset: card.dimension.id * 3 })}
                            </section>`;
                    }).join("")}
                </div>`;
        }

        function renderReportDashboard() {
            const container = document.getElementById("raporContainer");
            if (!container) return;

            const cards = dimensions.filter(function (dimension) {
                return dimension.id !== 1;
            }).map(function (dimension) {
                const rows = normalizeRows(dimension);
                return {
                    dimension,
                    rows,
                    average: weightedScore(rows),
                    categoryCount: rows.length,
                    totalCount: rows.reduce(function (sum, row) { return sum + row.count; }, 0)
                };
            });
            lastReportCards = cards;

            renderSummaryCards(cards);
            container.innerHTML = buildReportCardGrid(cards, true, 5);

            container.querySelectorAll("[data-tab]").forEach(function (button) {
                button.addEventListener("click", function () {
                    const link = document.querySelector(`.report-tabs a[href="${this.dataset.tab}"]`);
                    if (link) link.click();
                });
            });
        }

        function renderAll() {
            dimensions.forEach(renderDimension);
            renderReportDashboard();
        }

        const pdfPalette = [
            "#2ec4b6", "#4361ee", "#f59e0b", "#ef476f", "#06d6a0", "#118ab2",
            "#9b5de5", "#f15bb5", "#00bbf9", "#fb8500", "#4cc9f0", "#70e000"
        ];

        function truncateText(value, limit) {
            const text = String(value ?? "").trim();
            if (!limit || text.length <= limit) return text;
            return text.slice(0, Math.max(0, limit - 3)) + "...";
        }

        function pdfColor(index) {
            return pdfPalette[index % pdfPalette.length];
        }

        function pdfGradient(index) {
            return `linear-gradient(90deg, ${pdfColor(index)}, ${pdfColor(index + 2)})`;
        }

        function pdfVerticalGradient(index) {
            return `linear-gradient(180deg, ${pdfColor(index)}, ${pdfColor(index + 2)})`;
        }

        function lowestRow(rows) {
            return rows.slice().sort(function (a, b) {
                return (a.score - b.score) || (b.count - a.count) || a.name.localeCompare(b.name, "tr");
            })[0] || null;
        }

        function densestRow(rows) {
            return rows.slice().sort(function (a, b) {
                return (b.count - a.count) || (b.score - a.score) || a.name.localeCompare(b.name, "tr");
            })[0] || null;
        }

        function getPdfCards() {
            return dimensions.map(function (dimension) {
                const rows = normalizeRows(dimension);
                return {
                    dimension,
                    rows,
                    average: weightedScore(rows),
                    categoryCount: rows.length,
                    totalCount: rows.reduce(function (sum, row) { return sum + row.count; }, 0)
                };
            }).filter(function (card) {
                return card.rows.length || card.dimension.id === 1;
            });
        }

        function buildPdfKpi(label, value, note) {
            return `
                <div class="pdf-kpi-card">
                    <span>${escapeHtml(label)}</span>
                    <strong title="${escapeHtml(value)}">${escapeHtml(value)}</strong>
                    ${note ? `<small>${escapeHtml(note)}</small>` : ""}
                </div>`;
        }

        function buildPdfBars(rows, limit, colorOffset) {
            const visible = rows.slice(0, limit);
            if (!visible.length) {
                return '<div class="chart-empty">Bu bölüm için gösterilecek veri yok.</div>';
            }

            return `
                <div class="pdf-bars">
                    ${visible.map(function (row, index) {
                        const width = Math.max(4, Math.min(100, row.score));
                        return `
                            <div class="pdf-bar-row">
                                <div class="pdf-bar-rank">${index + 1}</div>
                                <div class="pdf-bar-label" title="${escapeHtml(row.name)}">${escapeHtml(truncateText(row.name, 54))}</div>
                                <div class="pdf-bar-track">
                                    <div class="pdf-bar-fill" style="width:${width}%; background:${pdfGradient(colorOffset + index)}"></div>
                                </div>
                                <div class="pdf-bar-score">${formatScore(row.score)}</div>
                                <div class="pdf-bar-count">${formatCount(row.count)}</div>
                            </div>`;
                    }).join("")}
                </div>`;
        }

        function buildPdfMiniBars(rows, colorOffset) {
            const visible = rows.slice(0, 3);
            if (!visible.length) return "";

            return `
                <div class="pdf-overview-bars">
                    ${visible.map(function (row, index) {
                        const width = Math.max(4, Math.min(100, row.score));
                        return `
                            <div class="pdf-overview-row">
                                <span title="${escapeHtml(row.name)}">${escapeHtml(truncateText(row.name, 26))}</span>
                                <div class="pdf-detail-track">
                                    <div class="pdf-detail-fill" style="width:${width}%; background:${pdfGradient(colorOffset + index)}"></div>
                                </div>
                                <strong>${formatScore(row.score)}</strong>
                            </div>`;
                    }).join("")}
                </div>`;
        }

        function piePoint(cx, cy, radius, angle) {
            const radians = (angle - 90) * Math.PI / 180;
            return {
                x: cx + radius * Math.cos(radians),
                y: cy + radius * Math.sin(radians)
            };
        }

        function pieSlicePath(cx, cy, radius, startAngle, endAngle) {
            const start = piePoint(cx, cy, radius, startAngle);
            const end = piePoint(cx, cy, radius, endAngle);
            const largeArc = endAngle - startAngle > 180 ? 1 : 0;
            return [
                `M ${cx} ${cy}`,
                `L ${start.x.toFixed(2)} ${start.y.toFixed(2)}`,
                `A ${radius} ${radius} 0 ${largeArc} 1 ${end.x.toFixed(2)} ${end.y.toFixed(2)}`,
                "Z"
            ].join(" ");
        }

        function buildPdfChartLegend(rows, colorOffset) {
            return `
                <div class="pdf-chart-legend">
                    ${rows.map(function (row, index) {
                        return `
                            <div class="pdf-chart-legend-row">
                                <span class="pdf-chart-swatch" style="background:${pdfColor(colorOffset + index)}"></span>
                                <span title="${escapeHtml(row.name)}">${escapeHtml(truncateText(row.name, 34))}</span>
                                <strong>${formatScore(row.score)}</strong>
                            </div>`;
                    }).join("")}
                </div>`;
        }

        function buildPdfPieVisual(rows, colorOffset) {
            const values = rows.map(function (row) { return Math.max(0, row.count); });
            const total = values.reduce(function (sum, value) { return sum + value; }, 0);
            const safeValues = total > 0 ? values : rows.map(function () { return 1; });
            const safeTotal = safeValues.reduce(function (sum, value) { return sum + value; }, 0);
            let angle = 0;

            const slices = rows.length === 1
                ? `<circle cx="110" cy="110" r="86" fill="${pdfColor(colorOffset)}"></circle>`
                : rows.map(function (row, index) {
                    const sliceAngle = (safeValues[index] / safeTotal) * 360;
                    const start = angle;
                    const end = angle + sliceAngle;
                    angle = end;
                    return `<path d="${pieSlicePath(110, 110, 86, start, end)}" fill="${pdfColor(colorOffset + index)}"></path>`;
                }).join("");

            return `
                <div class="pdf-pie-layout">
                    <svg class="pdf-pie-svg" viewBox="0 0 220 220" role="img" aria-label="Pasta grafik">
                        <circle cx="110" cy="110" r="92" fill="#eef4fb"></circle>
                        ${slices}
                        <circle cx="110" cy="110" r="40" fill="#fff"></circle>
                        <text x="110" y="105" text-anchor="middle" fill="#122033" font-size="22" font-weight="900">${formatCount(rows.length)}</text>
                        <text x="110" y="124" text-anchor="middle" fill="#66758c" font-size="10" font-weight="800">kayıt</text>
                    </svg>
                    ${buildPdfChartLegend(rows, colorOffset)}
                </div>`;
        }

        function buildPdfColumnVisual(rows, colorOffset) {
            return `
                <div class="pdf-column-chart">
                    ${rows.map(function (row, index) {
                        const height = Math.max(6, Math.min(100, row.score));
                        return `
                            <div class="pdf-column-item">
                                <div class="pdf-column-track">
                                    <div class="pdf-column-value">${formatScore(row.score)}</div>
                                    <div class="pdf-column-fill" style="height:${height}%; background:${pdfVerticalGradient(colorOffset + index)}"></div>
                                </div>
                                <div class="pdf-column-label" title="${escapeHtml(row.name)}">${escapeHtml(truncateText(row.name, 18))}</div>
                            </div>`;
                    }).join("")}
                </div>`;
        }

        function buildPdfSmallBarVisual(rows, colorOffset) {
            return `
                <div class="pdf-small-bar-chart">
                    ${rows.map(function (row, index) {
                        const width = Math.max(4, Math.min(100, row.score));
                        return `
                            <div class="pdf-small-bar-row">
                                <div class="pdf-small-bar-label" title="${escapeHtml(row.name)}">${escapeHtml(truncateText(row.name, 30))}</div>
                                <div class="pdf-small-bar-track">
                                    <div class="pdf-small-bar-fill" style="width:${width}%; background:${pdfGradient(colorOffset + index)}"></div>
                                </div>
                                <div class="pdf-small-bar-score">${formatScore(row.score)}</div>
                            </div>`;
                    }).join("")}
                </div>`;
        }

        function buildPdfSmallDataVisual(card, rows, colorOffset) {
            if (!rows.length || rows.length > 10) return "";

            const chartType = rows.length <= 3
                ? "Pasta grafiği"
                : rows.length <= 6
                    ? "Kolon grafiği"
                    : "Bar grafiği";
            const chartMarkup = rows.length <= 3
                ? buildPdfPieVisual(rows, colorOffset)
                : rows.length <= 6
                    ? buildPdfColumnVisual(rows, colorOffset)
                    : buildPdfSmallBarVisual(rows, colorOffset);

            return `
                <div class="pdf-small-data-visual">
                    <div class="pdf-panel-title">
                        <h3>${escapeHtml(card.dimension.label)} görsel özet</h3>
                        <small>${chartType} · ${formatCount(rows.length)} kayıt</small>
                    </div>
                    ${chartMarkup}
                </div>`;
        }

        function buildPdfCover(cards) {
            const best = cards.slice().sort(function (a, b) { return b.average - a.average; })[0];
            const dense = cards.slice().sort(function (a, b) { return b.categoryCount - a.categoryCount; })[0];
            const reportDate = new Date().toLocaleDateString("tr-TR", {
                day: "2-digit",
                month: "2-digit",
                year: "numeric"
            });

            return `
                <section class="pdf-slide-page pdf-cover-page">
                    <div class="pdf-cover-meta">
                        ${escapeHtml(reportDate)}<br>
                        Survey by Aslana Teknoloji
                    </div>
                    <div class="pdf-cover-title">
                        <span class="pdf-cover-kicker">Sunum raporu</span>
                        <h1>${escapeHtml(workTitle || "Analiz Raporu")}</h1>
                        <p>${escapeHtml(workSubtitle || "Katılım, başarı ve kırılım analizleri renkli grafikler ve detay tablolarla sunuma hazırlandı.")}</p>
                    </div>
                    <div class="pdf-cover-stats">
                        <div class="pdf-cover-stat"><span>Toplam katılım</span><strong>${formatCount(participantTotals.total)}</strong><small>Tanımlı ve anonim toplamı</small></div>
                        <div class="pdf-cover-stat"><span>Cevap satırı</span><strong>${formatCount(participantTotals.answerRows)}</strong><small>Rapora giren kayıt</small></div>
                        <div class="pdf-cover-stat"><span>En yüksek kırılım</span><strong>${escapeHtml(best ? best.dimension.label : "-")}</strong><small>${best ? formatScore(best.average) + " ortalama" : ""}</small></div>
                        <div class="pdf-cover-stat"><span>En yoğun liste</span><strong>${escapeHtml(dense ? dense.dimension.label : "-")}</strong><small>${dense ? formatCount(dense.categoryCount) + " kırılım" : ""}</small></div>
                    </div>
                </section>`;
        }

        function buildPdfExecutivePage(cards) {
            const best = cards.slice().sort(function (a, b) { return b.average - a.average; })[0];
            const low = cards.slice().sort(function (a, b) { return a.average - b.average; })[0];
            const dense = cards.slice().sort(function (a, b) { return b.categoryCount - a.categoryCount; })[0];

            return `
                <section class="pdf-slide-page">
                    <div class="pdf-slide-header">
                        <div>
                            <span class="pdf-slide-kicker">Yönetici özeti</span>
                            <h2>Raporun genel resmi</h2>
                            <p>Bu sayfa tüm kırılımları hızlıca okumak için hazırlanmıştır. Devamındaki sayfalarda her başlık ayrı grafik ve tam detay listesiyle verilir.</p>
                        </div>
                        <div class="pdf-slide-number">01</div>
                    </div>
                    <div class="pdf-kpi-grid">
                        ${buildPdfKpi("Toplam katılım", formatCount(participantTotals.total), "Tanımlı + anonim")}
                        ${buildPdfKpi("Tanımlı katılım", formatCount(participantTotals.defined), "Personel kaydı eşleşen")}
                        ${buildPdfKpi("Tanımsız katılım", formatCount(participantTotals.anonymous), "Kodla takip edilen")}
                        ${buildPdfKpi("Cevap satırı", formatCount(participantTotals.answerRows), "Hesaplamaya giren satır")}
                    </div>
                    <div class="pdf-kpi-grid">
                        ${buildPdfKpi("En yüksek ortalama", best ? best.dimension.label : "-", best ? formatScore(best.average) + " puan" : "")}
                        ${buildPdfKpi("En düşük ortalama", low ? low.dimension.label : "-", low ? formatScore(low.average) + " puan" : "")}
                        ${buildPdfKpi("En yoğun kırılım", dense ? dense.dimension.label : "-", dense ? formatCount(dense.categoryCount) + " satır" : "")}
                        ${buildPdfKpi("Analiz başlığı", formatCount(cards.length), "PDF içinde detaylı")}
                    </div>
                    <div class="pdf-overview-grid">
                        ${cards.filter(function (card) { return card.dimension.id !== 1; }).slice(0, 6).map(function (card, index) {
                            return `
                                <div class="pdf-overview-card">
                                    <h3>${escapeHtml(card.dimension.label)}</h3>
                                    <p>${formatCount(card.categoryCount)} kırılım · ${formatCount(card.totalCount)} kişi · ${formatScore(card.average)} ort.</p>
                                    ${buildPdfMiniBars(card.rows, index * 2)}
                                </div>`;
                        }).join("")}
                    </div>
                </section>`;
        }

        function buildPdfDimensionPage(card, index) {
            const rows = card.rows;
            const hasSmallDataVisual = rows.length > 0 && rows.length <= 10;
            const useTwoColumnList = rows.length > 10;
            const hasLongLabels = rows.some(function (row) { return String(row.name || "").length > 52; });
            const firstPageLimit = hasSmallDataVisual ? rows.length : hasLongLabels ? 34 : 52;
            const nextPageLimit = hasLongLabels ? 40 : 60;
            const firstRows = rows.slice(0, firstPageLimit);
            const remainingChunks = chunkRows(rows.slice(firstPageLimit), nextPageLimit);
            const pageCount = 1 + remainingChunks.length;
            const pageLabel = pageCount > 1 ? `1/${formatCount(pageCount)}` : String(index + 2).padStart(2, "0");
            const pageBody = hasSmallDataVisual
                ? `
                    <div class="pdf-small-data-layout ${rows.length <= 3 ? "pdf-small-data-layout-pie" : "pdf-small-data-layout-chart"}">
                        ${buildPdfSmallDataVisual(card, firstRows, index * 5)}
                        ${buildPdfTablePanel(card, firstRows, 0, index * 5, rows.length, "Tam liste", { hideGraph: true, className: "pdf-table-readable" })}
                    </div>`
                : useTwoColumnList
                    ? buildPdfTwoColumnTablePanel(card, firstRows, 0, index * 5, rows.length, "Tam liste")
                    : buildPdfTablePanel(card, firstRows, 0, index * 5, rows.length, "Tam liste", { className: "pdf-table-readable" });
            const pages = [`
                <section class="pdf-slide-page pdf-combined-page">
                    <div class="pdf-slide-header">
                        <div>
                            <span class="pdf-slide-kicker">${escapeHtml(card.dimension.label)} tam liste</span>
                            <h2>${escapeHtml(card.dimension.label)} tam liste</h2>
                            <p>${escapeHtml(card.dimension.note)} ${hasSmallDataVisual ? "Az kayıtlı listelerde sayfa dengesi için görsel özet ve tam liste birlikte verilir." : "Kırılım özeti üst kartlarda, tüm kayıtlar alttaki tabloda verilir."}</p>
                        </div>
                        <div class="pdf-slide-number">${pageLabel}</div>
                    </div>
                    <div class="pdf-kpi-grid pdf-combined-kpis">
                        ${buildPdfKpi("Kırılım", formatCount(card.categoryCount), "Ayrı analiz satırı")}
                        ${buildPdfKpi("Ortalama puan", formatScore(card.average), "Ağırlıklı ortalama")}
                        ${buildPdfKpi("Kişi sayısı", formatCount(card.totalCount), "Bu kırılımdaki toplam")}
                        ${buildPdfKpi("Tam liste", formatCount(rows.length), pageCount > 1 ? formatCount(pageCount) + " sayfa" : "Tek sayfa")}
                    </div>
                    ${pageBody}
                </section>`];

            remainingChunks.forEach(function (chunk, chunkIndex) {
                const startIndex = firstPageLimit + (chunkIndex * nextPageLimit);
                pages.push(`
                    <section class="pdf-slide-page pdf-list-page">
                        <div class="pdf-slide-header">
                            <div>
                                <span class="pdf-slide-kicker">${escapeHtml(card.dimension.label)} tam liste</span>
                                <h2>${escapeHtml(card.dimension.label)} tam liste devamı</h2>
                                <p>${formatCount(startIndex + 1)}-${formatCount(startIndex + chunk.length)} arası kayıtlar. Tam liste korunması için kalan satırlar devam sayfasına taşındı.</p>
                            </div>
                            <div class="pdf-slide-number">${formatCount(chunkIndex + 2)}/${formatCount(pageCount)}</div>
                        </div>
                        ${useTwoColumnList
                            ? buildPdfTwoColumnTablePanel(card, chunk, startIndex, index * 5, rows.length, "Tam liste devamı")
                            : buildPdfTablePanel(card, chunk, startIndex, index * 5, rows.length, "Tam liste devamı", { className: "pdf-table-readable" })}
                    </section>`);
            });

            return pages.join("");
        }

        function chunkRows(rows, size) {
            const chunks = [];
            for (let index = 0; index < rows.length; index += size) {
                chunks.push(rows.slice(index, index + size));
            }
            return chunks;
        }

        function buildPdfDetailRows(rows, startIndex, colorOffset, options) {
            const hideGraph = !!options?.hideGraph;
            return rows.map(function (row, index) {
                const width = Math.max(4, Math.min(100, row.score));
                return `
                    <tr>
                        <td>${formatCount(startIndex + index + 1)}</td>
                        <td>${escapeHtml(row.name)}</td>
                        <td>${formatScore(row.score)}</td>
                        <td>${formatCount(row.count)}</td>
                        ${hideGraph ? "" : `<td><div class="pdf-detail-track"><div class="pdf-detail-fill" style="width:${width}%; background:${pdfGradient(colorOffset + index)}"></div></div></td>`}
                    </tr>`;
            }).join("");
        }

        function buildPdfDetailTable(card, rows, startIndex, colorOffset, options) {
            const hideGraph = !!options?.hideGraph;
            return `
                <table class="pdf-detail-table">
                    <colgroup>
                        <col style="width:46px">
                        <col>
                        <col style="width:90px">
                        <col style="width:72px">
                        ${hideGraph ? "" : '<col style="width:220px">'}
                    </colgroup>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>${escapeHtml(card.dimension.label)}</th>
                            <th>Puan</th>
                            <th>Kişi</th>
                            ${hideGraph ? "" : "<th>Grafik</th>"}
                        </tr>
                    </thead>
                    <tbody>
                        ${buildPdfDetailRows(rows, startIndex, colorOffset, { hideGraph })}
                    </tbody>
                </table>`;
        }

        function buildPdfTablePanel(card, rows, startIndex, colorOffset, totalRows, title, options) {
            if (!rows.length) {
                return '<div class="chart-empty">Bu bölüm için gösterilecek veri yok.</div>';
            }

            const className = options?.className ? " " + options.className : "";
            return `
                <div class="pdf-table-panel pdf-combined-table${className}">
                    <div class="pdf-panel-title">
                        <h3>${escapeHtml(card.dimension.label)} ${escapeHtml(title || "tam liste")}</h3>
                        <small>${formatCount(startIndex + 1)}-${formatCount(startIndex + rows.length)} / ${formatCount(totalRows)} kayıt</small>
                    </div>
                    ${buildPdfDetailTable(card, rows, startIndex, colorOffset, options)}
                </div>`;
        }

        function buildPdfTwoColumnTablePanel(card, rows, startIndex, colorOffset, totalRows, title) {
            if (!rows.length) {
                return '<div class="chart-empty">Bu bölüm için gösterilecek veri yok.</div>';
            }

            const splitIndex = Math.ceil(rows.length / 2);
            const leftRows = rows.slice(0, splitIndex);
            const rightRows = rows.slice(splitIndex);

            return `
                <div class="pdf-table-panel pdf-two-column-table pdf-table-readable">
                    <div class="pdf-panel-title">
                        <h3>${escapeHtml(card.dimension.label)} ${escapeHtml(title || "tam liste")}</h3>
                        <small>${formatCount(startIndex + 1)}-${formatCount(startIndex + rows.length)} / ${formatCount(totalRows)} kayıt</small>
                    </div>
                    <div class="pdf-two-column-grid">
                        <div>${buildPdfDetailTable(card, leftRows, startIndex, colorOffset, { hideGraph: true })}</div>
                        <div>${rightRows.length ? buildPdfDetailTable(card, rightRows, startIndex + splitIndex, colorOffset + splitIndex, { hideGraph: true }) : ""}</div>
                    </div>
                </div>`;
        }

        function buildPdfDocument(cards) {
            const pages = [buildPdfCover(cards), buildPdfExecutivePage(cards)];
            cards.forEach(function (card, index) {
                pages.push(buildPdfDimensionPage(card, index));
            });
            return pages.join("");
        }

        document.addEventListener("DOMContentLoaded", renderAll);

        function getJsPdfConstructor() {
            if (window.jspdf && window.jspdf.jsPDF) return window.jspdf.jsPDF;
            return window.jsPDF || null;
        }

        function getPdfPageSize(pdf, dimension, fallback) {
            const pageSize = pdf?.internal?.pageSize;
            if (!pageSize) return fallback;

            const getter = dimension === "width" ? "getWidth" : "getHeight";
            return typeof pageSize[getter] === "function"
                ? pageSize[getter]()
                : pageSize[dimension] || fallback;
        }

        function waitForPdfLayout() {
            return new Promise(function (resolve) {
                requestAnimationFrame(function () {
                    requestAnimationFrame(resolve);
                });
            });
        }

        async function savePdfSlides(pdfCards) {
            const JsPdfConstructor = getJsPdfConstructor();
            if (typeof html2canvas === "undefined" || !JsPdfConstructor) return;

            const source = document.createElement("div");
            source.innerHTML = buildPdfDocument(pdfCards);
            const sourcePages = Array.from(source.querySelectorAll(".pdf-slide-page"));
            if (!sourcePages.length) return;

            const wrapper = document.createElement("div");
            wrapper.className = "pdf-page-shell";
            wrapper.setAttribute("aria-hidden", "true");
            wrapper.innerHTML = '<section class="pdf-report-export"></section>';
            document.body.appendChild(wrapper);

            const exportRoot = wrapper.querySelector(".pdf-report-export");
            const pdf = new JsPdfConstructor("landscape", "pt", "a4");
            const pageWidth = getPdfPageSize(pdf, "width", 841.89);
            const pageHeight = getPdfPageSize(pdf, "height", 595.28);

            try {
                for (let index = 0; index < sourcePages.length; index += 1) {
                    exportRoot.innerHTML = "";
                    exportRoot.appendChild(sourcePages[index].cloneNode(true));
                    await waitForPdfLayout();

                    const pageNode = exportRoot.querySelector(".pdf-slide-page");
                    const canvas = await html2canvas(pageNode, {
                        scale: 2,
                        useCORS: true,
                        backgroundColor: "#ffffff",
                        width: 1120,
                        height: 792,
                        windowWidth: 1120,
                        windowHeight: 792,
                        scrollX: 0,
                        scrollY: 0
                    });

                    if (index > 0) pdf.addPage("a4", "landscape");
                    pdf.addImage(canvas.toDataURL("image/jpeg", 0.98), "JPEG", 0, 0, pageWidth, pageHeight);
                }

                pdf.save(`${workTitle || "Rapor"}-detayli-analiz.pdf`);
            } finally {
                if (wrapper.parentNode) wrapper.parentNode.removeChild(wrapper);
            }
        }

        window.downloadPDF = async function () {
            if (typeof html2canvas === "undefined" || !getJsPdfConstructor()) return;
            if (!lastReportCards.length) renderReportDashboard();

            const pdfCards = getPdfCards();
            await savePdfSlides(pdfCards);
        };
    })();
</script>

@section Scripts {
    <script>
$(function () {
    // Dil değerini Session'dan al (yoksa 'tr')
    var dil = '@(Session["Dil"] as string ?? "tr")'.toLowerCase();

    var table = $('#Grid').DataTable({
        responsive: true,
        orderCellsTop: true,
        fixedHeader: true,
        pageLength: 10,
        lengthMenu: [
            [10, 25, 50, 100, 500, -1],
            [10, 25, 50, 100, 500, dil === 'en' ? 'All' : 'Tümü']
        ],
        // İstersen varsayılan sıralamayı kapat:
        // order: [],
        // veya bir kolona göre sırala:
        // order: [[0, 'asc']],
        language: {
            url: dil === 'en'
                ? '@Url.Content("~/Scripts/en.json")'
                : '@Url.Content("~/Scripts/tr.json")'
        },
        drawCallback: function () {
            var api = this.api();
            if (api.rows({ page: 'current' }).data().length === 0) {
                $('#Grid tbody td')
                    .addClass('text-light text-center fst-italic')
                    .css('background-color', '#1a1a1a')
                    .text(dil === 'en' ? 'No data available in table' : 'Tabloda veri yok');
            }
        }
    });

    // Kolon bazlı arama – ikinci header satırındaki inputlarla birebir
    $('#Grid thead tr:eq(1) th').each(function (i) {
        var $input = $('input', this);
        if (!$input.length) return;

        $input.on('keyup change', function () {
            if (table.column(i).search() !== this.value) {
                table.column(i).search(this.value).draw();
            }
        });
    });
});
    </script>
}
