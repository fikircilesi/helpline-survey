</style>

<div class="page-body workspace-page">
    <section class="workspace-hero">
        <div>
            <div class="workspace-kicker">
                <i class="ti-dashboard"></i>
                Survey by Aslana Teknoloji çalışma alanı
            </div>
            <h1 class="workspace-title">Merhaba @kullaniciAdi, bugün neyi yayına alıyoruz?</h1>
            <p class="workspace-subtitle">
                Sihirbazdan sınav, anket, eğitim veya aday değerlendirmesi hazırlayın; ödeme ve kredi adımı tamamlandığında yayın akışını buradan yönetin.
            </p>
        </div>
        <div class="workspace-actions">
            <div class="wizard-launcher">
                <span class="launch-spark one"></span>
                <span class="launch-spark two"></span>
                <span class="launch-spark three"></span>
                <a class="workspace-btn primary wizard-cta" href="@Url.Action("AssessmentWizard", "Home")">
                    <i class="ti-wand"></i>
                    <span>Yeni Sihirbaz</span>
                </a>
            </div>
        </div>
    </section>

    <section class="workspace-section studio-zone">
        <div class="section-head">
            <div>
                <h2 class="section-title"><i class="ti-palette"></i> Çalışma Stüdyosu</h2>
                <p class="section-note">Günlük akış sihirbaz üzerinden ilerler; soru bankası ve bakım araçları gerektiğinde kullanılır.</p>
            </div>
        </div>

        <div class="management-grid">
            <a class="management-link" href="@Url.Action("AssessmentWizard", "Home")">
                <i class="ti-wand"></i>
                <span>
                    <strong>Yeni Çalışma Oluştur</strong>
                    <span>Sınav, anket veya değerlendirme sihirbazı</span>
                </span>
            </a>
            <a class="management-link" href="@Url.Action("AnketAdIndex", "Home", new { id = Session["id"] })">
                <i class="ti-clipboard"></i>
                <span>
                    <strong>Çalışma Tanımları</strong>
                    <span>Yayın, süre ve sertifika ayarları</span>
                </span>
            </a>
            <a class="management-link" href="@Url.Action("SoruIndex", "Home")">
                <i class="ti-help-alt"></i>
                <span>
                    <strong>Soru Bankası</strong>
                    <span>Sorular ve puan yapısı</span>
                </span>
            </a>
            <a class="management-link" href="@Url.Action("SoruGrupIndex", "Home")">
                <i class="ti-layers"></i>
                <span>
                    <strong>Bölüm / Kategori Bankası</strong>
                    <span>Soru grupları ve sıralama</span>
                </span>
            </a>
            <a class="management-link" href="@Url.Action("CevapIndex", "Home")">
                <i class="ti-check-box"></i>
                <span>
                    <strong>Seçenek Bankası</strong>
                    <span>Anket puanı ve doğru cevap bilgisi</span>
                </span>
            </a>
            <a class="management-link" href="@Url.Action("CevapGrupIndex", "Home")">
                <i class="ti-view-list"></i>
                <span>
                    <strong>Gelişmiş Seçenek Grupları</strong>
                    <span>Manuel soru bankası eşleşmeleri</span>
                </span>
            </a>
            <a class="management-link danger" href="@Url.Action("AnketHavuzIndex", "Home", new { id = Session["id"] })">
                <i class="ti-trash"></i>
                <span>
                    <strong>Katılım Verilerini Temizle</strong>
                    <span>Cevap ve sonuç kayıtları</span>
                </span>
            </a>
            <a class="management-link danger" href="@Url.Action("AnketZamanIndex", "Home", new { id = Session["id"] })">
                <i class="ti-timer"></i>
                <span>
                    <strong>Süre Kayıtlarını Sıfırla</strong>
                    <span>Sınav zaman takibi</span>
                </span>
            </a>
        </div>
    </section>

    <section class="workspace-section works-zone">
        <div class="section-head">
            <div>
                <h2 class="section-title"><i class="ti-briefcase"></i> Çalışmalarım</h2>
                <p class="section-note">@katilimSayisi cevaplı katılım, @sureKayitSayisi süre kaydı sistemde takip ediliyor.</p>
            </div>
            <div class="works-summary">
                <span><i class="ti-signal"></i> @aktifSayisi yayında</span>
                <span><i class="ti-pencil-alt"></i> @taslakSayisi taslak</span>
                <span><i class="ti-user"></i> @katilimSayisi cevaplı</span>
                <span><i class="ti-timer"></i> @sureKayitSayisi süre kaydı</span>
            </div>
        </div>

        @if (!anketler.Any())
        {
            <div class="empty-state">
                <div>
                    <i class="ti-wand"></i>
                    <h3>İlk çalışmanızı oluşturun</h3>
                    <p>Sürükle-bırak sihirbaz ile sınav, anket veya işe alım değerlendirmesi hazırlayıp yayın akışına taşıyın.</p>
                    <a class="workspace-btn primary" href="@Url.Action("AssessmentWizard", "Home")">Sihirbazı Aç</a>
                </div>
            </div>
        }
        else
        {
            <div class="assessment-grid">
                @foreach (var item in anketler.OrderByDescending(x => x.AnketId))
                {
                    var soruGruplari = anketGruplari.Where(x => x.AnketId == item.AnketId).ToList();
                    var soruSayisi = (from detay in soruGruplari
                                      join soru in sorular on detay.SoruGrupId equals soru.SoruGrupId
                                      select soru.SoruId).Distinct().Count();
                    if (soruSayisi == 0)
                    {
                        soruSayisi = havuzSoruSayisiMap.ContainsKey(item.AnketId)
                            ? havuzSoruSayisiMap[item.AnketId]
                            : 0;
                    }
                    var katilim = cevapliKatilimMap.ContainsKey(item.AnketId) ? cevapliKatilimMap[item.AnketId] : 0;
                    var sureKaydi = sureKayitMap.ContainsKey(item.AnketId) ? sureKayitMap[item.AnketId] : 0;
                    var durumClass = item.Pasif == true ? "draft" : "live";
                    var durumText = item.Pasif == true ? "Taslak" : "Yayında";
                    var tipText = item.Sinav == true ? "Sınav" : "Anket";
                    var tipClass = item.Sinav == true ? "exam" : "survey";
                    var tipIcon = item.Sinav == true ? "ti-ruler-pencil" : "ti-clipboard";
                    var katilimToken = katilimTokenMap.ContainsKey(item.AnketId) ? katilimTokenMap[item.AnketId] : "";
                    var publicLinkEnabled = item.Pasif != true && !string.IsNullOrWhiteSpace(katilimToken);
                    var paylasimUrl = Url.Action("Katilim", "Home", new { token = katilimToken }, Context.Request.Scheme);
                    var qrUrl = Url.Action("KatilimQr", "Home", new { token = katilimToken });
                    var katilimYontemi = katilimYontemiMap.ContainsKey(item.AnketId) ? katilimYontemiMap[item.AnketId] : "HerkeseAcik";
                    var katilimYontemiText = katilimYontemi == "Kayitli"
                        ? "Kayıtlı kişiler"
                        : katilimYontemi == "KisiyeOzel"
                            ? "Kişiye özel"
                            : katilimYontemi == "BilgiFormu"
                                ? "Bilgi formu"
                                : "Herkese açık";
                    var shareSubtitle = katilimYontemi == "Kayitli" || katilimYontemi == "KisiyeOzel"
                        ? "Bu bağlantı kayıtlı katılımcılara özeldir. Giriş yapan uygun kişilerin sonuçları kendi profiline işlenir."
                        : katilimYontemi == "BilgiFormu"
                            ? "Bu bağlantı bilgi formu ile açılır; katılımcıdan ad soyad ve TC / numara veya e-posta alınır."
                            : "Bu bağlantı herkese açıktır; giriş yapan kayıtlı kişiler kendi profiliyle, diğerleri katılım koduyla izlenir.";

                    <article class="assessment-card @tipClass @durumClass">
                        <div class="assessment-top">
                            <div class="assessment-title-row">
                                <span class="assessment-type-icon"><i class="@tipIcon"></i></span>
                                <h3 class="assessment-name">@item.AnketAdi</h3>
                            </div>
                            <span class="status-badge @durumClass">@durumText</span>
                        </div>

                        <div class="assessment-meta">
                            <div class="meta-box">
                                <strong>@soruGruplari.Count(x => x.SoruGrupId != null)</strong>
                                <span>Grup</span>
                            </div>
                            <div class="meta-box">
                                <strong>@soruSayisi</strong>
                                <span>Soru</span>
                            </div>
                            <div class="meta-box">
                                <strong>@katilim</strong>
                                <span>Cevaplı</span>
                            </div>
                        </div>

                        <div class="assessment-tags">
                            <span class="tag-pill type">@tipText</span>
                            @if (item.Sonuc == true)
                            {
                                <span class="tag-pill result">Sonuç açık</span>
                            }
                            @if (item.SertifikaNotu != null)
                            {
                                <span class="tag-pill cert">Sertifika @item.SertifikaNotu+</span>
                            }
                            @if (item.Zaman != null)
                            {
                                <span class="tag-pill time">@item.Zaman dk</span>
                            }
                            @if (sureKaydi > 0)
                            {
                                <span class="tag-pill time">@sureKaydi süre kaydı</span>
                            }
                            <span class="tag-pill audience js-audience-label">@katilimYontemiText</span>
                            <span class="tag-pill @(publicLinkEnabled ? "open" : "closed")">@(publicLinkEnabled ? "Link hazır" : "Link kapalı")</span>
                        </div>

                        <div class="assessment-actions">
                            <a class="mini-btn questions" href="@Url.Action("AnketSoruYonetim", "Home", new { id = item.AnketId, returnUrl = workspaceReturnUrl })">
                                <i class="ti-write"></i>
                                Sorular
                            </a>
                            <a class="mini-btn" href="@Url.Action("AnketGrupIndex", "Home", new { id = item.AnketId, adi = item.AnketAdi, returnUrl = workspaceReturnUrl })">
                                <i class="ti-view-list"></i>
                                Rapor Başlıkları
                            </a>
                            <a class="mini-btn answer-key" href="@Url.Action("DogruCevapEditor", "Home", new { id = item.AnketId, returnUrl = workspaceReturnUrl })">
                                <i class="ti-check"></i>
                                Doğru Cevap
                            </a>
                            <a class="mini-btn" href="@Url.Action("AnketIndex1", "Home", new { id = item.AnketId, returnUrl = workspaceReturnUrl })">
                                <i class="ti-bar-chart"></i>
                                Rapor
                            </a>
                            <a class="mini-btn" href="@Url.Action("AnketAdEdit", "Home", new { id = item.AnketId, returnUrl = workspaceReturnUrl })">
                                <i class="ti-settings"></i>
                                Ayarlar
                            </a>
                            <a class="mini-btn" href="@Url.Action("SertifikaWizard", "Home", new { id = item.AnketId, returnUrl = workspaceReturnUrl })">
                                <i class="ti-cup"></i>
                                Sertifika
                            </a>
                            @if (publicLinkEnabled)
                            {
                                <button class="mini-btn share js-share"
                                        type="button"
                                        data-anket-id="@item.AnketId"
                                        data-share-url="@paylasimUrl"
                                        data-qr-url="@qrUrl"
                                        data-share-title="@item.AnketAdi"
                                        data-katilim-yontemi="@katilimYontemi"
                                        data-share-subtitle="@shareSubtitle">
                                    <i class="ti-share"></i>
                                    Paylaş
                                </button>
                            }
                            else
                            {
                                <button class="mini-btn" type="button" disabled>
                                    <i class="ti-share"></i>
                                    Paylaşım Kapalı
                                </button>
                            }
                            <button class="mini-btn danger js-delete-work"
                                    type="button"
                                    data-delete-id="@item.AnketId"
                                    data-delete-title="@item.AnketAdi">
                                <i class="ti-trash"></i>
                                Sil
                            </button>
                        </div>
                    </article>
                }
            </div>
        }
    </section>
</div>

<div class="share-modal" id="shareModal" hidden>
    <div class="share-dialog" role="dialog" aria-modal="true" aria-labelledby="shareModalTitle">
        @Html.AntiForgeryToken()
        <div class="share-dialog-head">
            <div>
                <h3 id="shareModalTitle">Paylaşım Bağlantısı</h3>
                <p id="shareModalSubtitle">Bu link veya QR kod çalışma ayarlarındaki katılım yöntemine göre çalışır.</p>
            </div>
            <button class="share-close" type="button" id="shareModalClose" aria-label="Kapat">
                <span aria-hidden="true">x</span>
            </button>
        </div>

        <div class="share-access-panel">
            <div class="share-access-head">
                <span>Katılım yöntemi</span>
                <span class="share-access-current" id="shareAccessCurrent">Herkese açık</span>
            </div>
            <div class="share-access-options" role="group" aria-label="Katılım yöntemi">
                <button class="share-access-option" type="button" data-share-method="HerkeseAcik">Herkese açık</button>
                <button class="share-access-option" type="button" data-share-method="BilgiFormu">Bilgi formu</button>
                <button class="share-access-option" type="button" data-share-method="Kayitli">Kayıtlı kişiler</button>
                <button class="share-access-option" type="button" data-share-method="KisiyeOzel">Kişiye özel</button>
            </div>
        </div>

        <div class="share-url-row">
            <input id="shareUrlInput" type="text" readonly />
            <button class="mini-btn share" type="button" id="shareCopyButton">
                <i class="ti-files"></i>
                Kopyala
            </button>
        </div>

        <div class="share-platform-grid" aria-label="Paylasim kanallari">
            <button class="share-platform-btn primary" type="button" id="shareNativeButton">
                <i class="ti-share"></i>
                Paylas
            </button>
            <button class="share-platform-btn" type="button" data-share-platform="whatsapp">
                <i class="ti-mobile"></i>
                WhatsApp
            </button>
            <button class="share-platform-btn" type="button" data-share-platform="telegram">
                <i class="ti-location-arrow"></i>
                Telegram
            </button>
            <button class="share-platform-btn" type="button" data-share-platform="teams">
                <i class="ti-comments"></i>
                Teams
            </button>
            <button class="share-platform-btn" type="button" data-share-platform="mail">
                <i class="ti-email"></i>
                E-posta
            </button>
            <button class="share-platform-btn" type="button" data-share-platform="sms">
                <i class="ti-comment"></i>
                SMS
            </button>
        </div>

        <div class="share-qr-box" id="shareQrBox">
            <img id="shareQrImage" alt="Katılım QR kodu" />
        </div>
        <div class="share-feedback" id="shareFeedback" aria-live="polite"></div>
    </div>
</div>

<div class="share-modal" id="deleteWorkModal" hidden>
    <div class="share-dialog delete-dialog" role="dialog" aria-modal="true" aria-labelledby="deleteWorkTitle">
        @Html.AntiForgeryToken()
        <div class="share-dialog-head">
            <div>
                <h3 id="deleteWorkTitle">Çalışmayı Sil</h3>
                <p id="deleteWorkSubtitle">Silmeden önce bağlı kayıtları kontrol ediyoruz.</p>
            </div>
            <button class="share-close" type="button" id="deleteWorkClose" aria-label="Kapat">
                <span aria-hidden="true">x</span>
            </button>
        </div>

        <div class="delete-warning" id="deleteWorkWarning">
            <i class="ti-alert"></i>
            <div id="deleteWorkWarningText">
                Bu işlem çalışmayı ve bağlı kayıtları kalıcı olarak siler.
            </div>
        </div>

        <div class="delete-stats" id="deleteWorkStats"></div>

        <ul class="delete-impact" id="deleteWorkImpact"></ul>

        <div id="deleteWorkPeopleBlock" hidden>
            <p>Bu çalışmada kayıtlı katılım bulundu. Silme onaylanırsa bu cevaplar raporlardan da kalkar.</p>
            <div class="delete-people" id="deleteWorkPeople"></div>
        </div>

        <div class="share-feedback" id="deleteWorkFeedback" aria-live="polite"></div>

        <div class="delete-actions">
            <button class="delete-cancel" type="button" id="deleteWorkCancel">Vazgeç</button>
            <button class="delete-confirm" type="button" id="deleteWorkConfirm">
                <i class="ti-trash"></i>
                Çalışmayı Sil
            </button>
        </div>
    </div>
</div>

<script>
    (function () {
        const modal = document.getElementById("shareModal");
        const deleteModal = document.getElementById("deleteWorkModal");

        if (modal && modal.parentElement !== document.body) {
            document.body.appendChild(modal);
        }

        if (deleteModal && deleteModal.parentElement !== document.body) {
            document.body.appendChild(deleteModal);
        }

        const title = document.getElementById("shareModalTitle");
        const subtitle = document.getElementById("shareModalSubtitle");
        const input = document.getElementById("shareUrlInput");
        const qrBox = document.getElementById("shareQrBox");
        const qrImage = document.getElementById("shareQrImage");
        const feedback = document.getElementById("shareFeedback");
        const copyButton = document.getElementById("shareCopyButton");
        const closeButton = document.getElementById("shareModalClose");
        const nativeShareButton = document.getElementById("shareNativeButton");
        const platformButtons = document.querySelectorAll("[data-share-platform]");
        const accessCurrent = document.getElementById("shareAccessCurrent");
        const accessButtons = document.querySelectorAll("[data-share-method]");
        const accessUpdateUrl = "@Url.Action("KatilimYontemiGuncelle", "Home")";
        const deleteSummaryUrl = "@Url.Action("AnketSilmeOzeti", "Home")";
        const deleteWorkUrl = "@Url.Action("AnketSil", "Home")";
        const antiForgeryToken = modal.querySelector("input[name='__RequestVerificationToken']")?.value || "";
        const deleteAntiForgeryToken = deleteModal.querySelector("input[name='__RequestVerificationToken']")?.value || antiForgeryToken;
        const deleteTitle = document.getElementById("deleteWorkTitle");
        const deleteSubtitle = document.getElementById("deleteWorkSubtitle");
        const deleteWarningText = document.getElementById("deleteWorkWarningText");
        const deleteStats = document.getElementById("deleteWorkStats");
        const deleteImpact = document.getElementById("deleteWorkImpact");
        const deletePeopleBlock = document.getElementById("deleteWorkPeopleBlock");
        const deletePeople = document.getElementById("deleteWorkPeople");
        const deleteFeedback = document.getElementById("deleteWorkFeedback");
        const deleteCloseButton = document.getElementById("deleteWorkClose");
        const deleteCancelButton = document.getElementById("deleteWorkCancel");
        const deleteConfirmButton = document.getElementById("deleteWorkConfirm");
        const accessInfo = {
            HerkeseAcik: {
                label: "Herkese açık",
                subtitle: "Bu bağlantı herkese açıktır; giriş yapan kayıtlı kişiler kendi profiliyle, diğerleri katılım koduyla izlenir."
            },
            BilgiFormu: {
                label: "Bilgi formu",
                subtitle: "Bu bağlantı bilgi formu ile açılır; katılımcıdan ad soyad ve TC / numara veya e-posta alınır."
            },
            Kayitli: {
                label: "Kayıtlı kişiler",
                subtitle: "Bu bağlantı kayıtlı katılımcılara özeldir. Giriş yapan uygun kişilerin sonuçları kendi profiline işlenir."
            },
            KisiyeOzel: {
                label: "Kişiye özel",
                subtitle: "Bu bağlantı kayıtlı katılımcılara özeldir. Giriş yapan uygun kişilerin sonuçları kendi profiline işlenir."
            }
        };
        let currentShareTitle = "";
        let currentShareButton = null;
        let currentAnketId = "";
        let currentAccessMethod = "HerkeseAcik";
        let currentDeleteId = "";

        function normalizeAccessMethod(value) {
            return accessInfo[value] ? value : "HerkeseAcik";
        }

        function renderAccessMethod(value) {
            currentAccessMethod = normalizeAccessMethod(value);
            const info = accessInfo[currentAccessMethod];
            accessCurrent.textContent = info.label;
            subtitle.textContent = info.subtitle;

            accessButtons.forEach(function (button) {
                const active = button.dataset.shareMethod === currentAccessMethod;
                button.classList.toggle("is-active", active);
                button.setAttribute("aria-pressed", active ? "true" : "false");
            });
        }

        function setAccessButtonsBusy(isBusy) {
            accessButtons.forEach(function (button) {
                button.disabled = isBusy;
            });
        }

        function updateCurrentCardAccess(value, label, subtitleText) {
            if (!currentShareButton) return;

            currentShareButton.dataset.katilimYontemi = value;
            currentShareButton.dataset.shareSubtitle = subtitleText;

            const card = currentShareButton.closest(".assessment-card");
            const audience = card ? card.querySelector(".js-audience-label") : null;
            if (audience) {
                audience.textContent = label;
            }
        }

        async function saveAccessMethod(value) {
            const nextMethod = normalizeAccessMethod(value);
            if (!currentAnketId || nextMethod === currentAccessMethod) {
                renderAccessMethod(nextMethod);
                return;
            }

            const body = new URLSearchParams();
            body.set("__RequestVerificationToken", antiForgeryToken);
            body.set("anketId", currentAnketId);
            body.set("katilimYontemi", nextMethod);

            setAccessButtonsBusy(true);
            feedback.textContent = "Kaydediliyor...";

            try {
                const response = await fetch(accessUpdateUrl, {
                    method: "POST",
                    credentials: "same-origin",
                    headers: { "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8" },
                    body: body.toString()
                });
                const result = await response.json();
                if (!response.ok || !result.success) {
                    feedback.textContent = result.message || "Katılım yöntemi kaydedilemedi.";
                    return;
                }

                const savedMethod = normalizeAccessMethod(result.katilimYontemi || nextMethod);
                const info = accessInfo[savedMethod];
                renderAccessMethod(savedMethod);
                updateCurrentCardAccess(savedMethod, result.label || info.label, result.subtitle || info.subtitle);
                feedback.textContent = "Katılım yöntemi kaydedildi.";
            } catch {
                feedback.textContent = "Katılım yöntemi kaydedilemedi.";
            } finally {
                setAccessButtonsBusy(false);
            }
        }

        function openShareModal(button) {
            const shareUrl = button.dataset.shareUrl || "";
            const qrUrl = button.dataset.qrUrl || "";
            const shareTitle = button.dataset.shareTitle || "Çalışma";
            const accessMethod = normalizeAccessMethod(button.dataset.katilimYontemi || "");

            currentShareButton = button;
            currentAnketId = button.dataset.anketId || "";
            currentShareTitle = shareTitle;
            title.textContent = shareTitle;
            input.value = shareUrl;
            qrImage.src = qrUrl || "";
            qrBox.style.display = qrUrl ? "grid" : "none";
            qrImage.style.display = qrUrl ? "block" : "none";
            feedback.textContent = "";
            renderAccessMethod(accessMethod);
            modal.hidden = false;
            input.select();
        }

        async function copyShareUrl() {
            const value = input.value;
            if (!value) return;

            try {
                if (navigator.clipboard && window.isSecureContext) {
                    await navigator.clipboard.writeText(value);
                } else {
                    input.select();
                    document.execCommand("copy");
                }
                feedback.textContent = "Bağlantı kopyalandı.";
            } catch {
                feedback.textContent = "Bağlantıyı elle kopyalayabilirsiniz.";
            }
        }

        function platformShareUrl(platform, shareUrl, shareTitle) {
            const encodedUrl = encodeURIComponent(shareUrl);
            const encodedTitle = encodeURIComponent(shareTitle || "Survey by Aslana Teknoloji");
            const encodedText = encodeURIComponent((shareTitle || "Survey by Aslana Teknoloji") + " " + shareUrl);

            switch (platform) {
                case "whatsapp":
                    return "https://wa.me/?text=" + encodedText;
                case "telegram":
                    return "https://t.me/share/url?url=" + encodedUrl + "&text=" + encodedTitle;
                case "teams":
                    return "https://teams.microsoft.com/share?href=" + encodedUrl + "&msgText=" + encodedTitle;
                case "mail":
                    return "mailto:?subject=" + encodedTitle + "&body=" + encodedText;
                case "sms":
                    return "sms:?&body=" + encodedText;
                default:
                    return "";
            }
        }

        async function nativeShare() {
            const value = input.value;
            if (!value) return;

            if (navigator.share) {
                try {
                    await navigator.share({
                        title: currentShareTitle || "Survey by Aslana Teknoloji",
                        text: currentShareTitle || "Survey by Aslana Teknoloji",
                        url: value
                    });
                    feedback.textContent = "Paylasim penceresi acildi.";
                    return;
                } catch (error) {
                    if (error && error.name === "AbortError") {
                        feedback.textContent = "";
                        return;
                    }
                }
            }

            await copyShareUrl();
            feedback.textContent = "Bu cihazda genel paylasim desteklenmiyor; baglanti kopyalandi.";
        }

        function openPlatformShare(platform) {
            const value = input.value;
            if (!value) return;

            const targetUrl = platformShareUrl(platform, value, currentShareTitle);
            if (!targetUrl) return;

            if (targetUrl.startsWith("mailto:") || targetUrl.startsWith("sms:")) {
                window.location.href = targetUrl;
            } else {
                window.open(targetUrl, "_blank", "noopener,noreferrer");
            }
            feedback.textContent = "Paylasim kanali acildi.";
        }

        function deleteStatTemplate(value, label) {
            return "<div class=\"delete-stat\"><strong>" + value + "</strong><span>" + label + "</span></div>";
        }

        function renderDeleteSummary(result) {
            const katilimVar = Number(result.katilimKaydi || 0) > 0;
            deleteTitle.textContent = (result.anketAdi || "Çalışma") + " silinsin mi?";
            deleteSubtitle.textContent = katilimVar
                ? "Bu çalışmada katılım var; cevap kayıtları ve rapor sonuçları da silinecek."
                : "Katılım yok; çalışma ve bağlı hazırlık kayıtları silinecek.";
            deleteWarningText.textContent = katilimVar
                ? "Bu işlem geri alınamaz. Katılımcı cevapları, süre takipleri ve rapor çıktıları bu çalışma için temizlenir."
                : "Bu işlem geri alınamaz. Henüz katılım olmadığı için sadece çalışma kurulumu ve bağlı hazırlık kayıtları silinir.";

            deleteStats.innerHTML = [
                deleteStatTemplate(result.katilimciSayisi || 0, "Katılımcı"),
                deleteStatTemplate(result.katilimKaydi || 0, "Cevap kaydı"),
                deleteStatTemplate(result.raporBasligi || 0, "Rapor başlığı"),
                deleteStatTemplate(result.soru || 0, "Soru")
            ].join("");

            const kalemler = Array.isArray(result.kalemler) ? result.kalemler : [];
            deleteImpact.innerHTML = kalemler.length
                ? kalemler.map(function (item) {
                    return "<li><span>" + item.label + "</span><b>" + item.count + "</b></li>";
                }).join("")
                : "<li><span>Silinecek bağlı kayıt bulunmadı</span><b>0</b></li>";

            const people = Array.isArray(result.katilimcilar) ? result.katilimcilar : [];
            const fazla = Number(result.katilimciFazla || 0);
            deletePeopleBlock.hidden = people.length === 0 && fazla === 0;
            deletePeople.innerHTML = people.map(function (name) {
                return "<span class=\"delete-person\">" + name + "</span>";
            }).join("");

            if (fazla > 0) {
                deletePeople.innerHTML += "<span class=\"delete-person\">+" + fazla + " kişi daha</span>";
            }

            deleteFeedback.textContent = "";
            deleteConfirmButton.disabled = false;
        }

        async function openDeleteModal(button) {
            currentDeleteId = button.dataset.deleteId || "";
            deleteTitle.textContent = (button.dataset.deleteTitle || "Çalışma") + " silinsin mi?";
            deleteSubtitle.textContent = "Bağlı kayıtlar kontrol ediliyor...";
            deleteWarningText.textContent = "Lütfen bekleyin; bu çalışma için silinecek kayıtları hazırlıyoruz.";
            deleteStats.innerHTML = "";
            deleteImpact.innerHTML = "";
            deletePeople.innerHTML = "";
            deletePeopleBlock.hidden = true;
            deleteFeedback.textContent = "";
            deleteConfirmButton.disabled = true;
            deleteModal.hidden = false;

            try {
                const response = await fetch(deleteSummaryUrl + "?id=" + encodeURIComponent(currentDeleteId), {
                    method: "GET",
                    credentials: "same-origin"
                });
                const result = await response.json();
                if (!response.ok || !result.success) {
                    deleteFeedback.textContent = result.message || "Silme özeti hazırlanamadı.";
                    return;
                }

                renderDeleteSummary(result);
            } catch {
                deleteFeedback.textContent = "Silme özeti hazırlanamadı.";
            }
        }

        function closeDeleteModal() {
            deleteModal.hidden = true;
            currentDeleteId = "";
        }

        async function confirmDeleteWork() {
            if (!currentDeleteId) return;

            const body = new URLSearchParams();
            body.set("__RequestVerificationToken", deleteAntiForgeryToken);
            body.set("id", currentDeleteId);

            deleteConfirmButton.disabled = true;
            deleteFeedback.textContent = "Siliniyor...";

            try {
                const response = await fetch(deleteWorkUrl, {
                    method: "POST",
                    credentials: "same-origin",
                    headers: { "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8" },
                    body: body.toString()
                });
                const result = await response.json();
                if (!response.ok || !result.success) {
                    deleteFeedback.textContent = result.message || "Silme işlemi tamamlanamadı.";
                    deleteConfirmButton.disabled = false;
                    return;
                }

                deleteFeedback.textContent = result.message || "Çalışma silindi.";
                window.setTimeout(function () {
                    window.location.reload();
                }, 450);
            } catch {
                deleteFeedback.textContent = "Silme işlemi tamamlanamadı.";
                deleteConfirmButton.disabled = false;
            }
        }

        function closeShareModal() {
            modal.hidden = true;
            qrBox.style.display = "none";
            qrImage.removeAttribute("src");
        }

        document.querySelectorAll(".js-share").forEach(function (button) {
            button.addEventListener("click", function () {
                openShareModal(button);
            });
        });
        document.querySelectorAll(".js-delete-work").forEach(function (button) {
            button.addEventListener("click", function () {
                openDeleteModal(button);
            });
        });

        nativeShareButton.addEventListener("click", nativeShare);
        platformButtons.forEach(function (button) {
            button.addEventListener("click", function () {
                openPlatformShare(button.dataset.sharePlatform || "");
            });
        });
        accessButtons.forEach(function (button) {
            button.addEventListener("click", function () {
                saveAccessMethod(button.dataset.shareMethod || "");
            });
        });
        copyButton.addEventListener("click", copyShareUrl);
        closeButton.addEventListener("click", closeShareModal);
        deleteCloseButton.addEventListener("click", closeDeleteModal);
        deleteCancelButton.addEventListener("click", closeDeleteModal);
        deleteConfirmButton.addEventListener("click", confirmDeleteWork);
        modal.addEventListener("click", function (event) {
            if (event.target === modal) {
                closeShareModal();
            }
        });
        deleteModal.addEventListener("click", function (event) {
            if (event.target === deleteModal) {
                closeDeleteModal();
            }
        });
        document.addEventListener("keydown", function (event) {
            if (event.key === "Escape" && !modal.hidden) {
                closeShareModal();
            }
            if (event.key === "Escape" && !deleteModal.hidden) {
                closeDeleteModal();
            }
        });
    })();
</script>
