@model survey.Models.Tumcontroller
@{
    ViewBag.Title = "Çalışma Alanım";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var anketler = (Model.Ank ?? Enumerable.Empty<survey.Models.Anket>()).ToList();
    var anketGruplari = (Model.AnkGrp ?? Enumerable.Empty<survey.Models.AnketGrup>()).ToList();
    var sorular = (Model.Sor ?? Enumerable.Empty<survey.Models.Soru>()).ToList();
    var aktifSayisi = anketler.Count(x => x.Pasif != true);
    var taslakSayisi = anketler.Count(x => x.Pasif == true);
    var katilimSayisi = ViewBag.KatilimSayisi == null ? 0 : Convert.ToInt32(ViewBag.KatilimSayisi);
    var cevapliKatilimMap = ViewBag.CevapliKatilimMap as System.Collections.Generic.Dictionary<int, int>
        ?? new System.Collections.Generic.Dictionary<int, int>();
    var havuzSoruSayisiMap = ViewBag.HavuzSoruSayisiMap as System.Collections.Generic.Dictionary<int, int>
        ?? new System.Collections.Generic.Dictionary<int, int>();
    var katilimTokenMap = ViewBag.KatilimTokenMap as System.Collections.Generic.Dictionary<int, string>
        ?? new System.Collections.Generic.Dictionary<int, string>();
    var katilimYontemiMap = ViewBag.KatilimYontemiMap as System.Collections.Generic.Dictionary<int, string>
        ?? new System.Collections.Generic.Dictionary<int, string>();
    var sureKayitMap = ViewBag.SureKayitMap as System.Collections.Generic.Dictionary<int, int>
        ?? new System.Collections.Generic.Dictionary<int, int>();
    var sureKayitSayisi = ViewBag.SureKayitSayisi == null ? 0 : Convert.ToInt32(ViewBag.SureKayitSayisi);
    var kullaniciAdi = (Session["adi"] as string) ?? "Çalışma Alanım";
    var workspaceReturnUrl = Context.Request.Path.ToString() + Context.Request.QueryString.ToString();
}

<style>
    .workspace-page {
        color: #142033;
    }

    .workspace-hero {
        position: relative;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: center;
        gap: 22px;
        padding: 32px 28px;
        margin-bottom: 18px;
        border-radius: 8px;
        color: #fff;
        background:
            linear-gradient(130deg, rgba(9, 17, 31, .98) 0%, rgba(18, 46, 62, .96) 48%, rgba(13, 32, 47, .98) 100%),
            #0b1220;
        border: 1px solid rgba(255, 255, 255, .10);
        box-shadow: 0 20px 52px rgba(21, 34, 50, .18);
        overflow: hidden;
        isolation: isolate;
    }

    .workspace-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
            linear-gradient(112deg, transparent 0 35%, rgba(141, 240, 199, .18) 42%, transparent 50%),
            linear-gradient(72deg, transparent 0 58%, rgba(255, 228, 108, .16) 64%, transparent 70%),
            linear-gradient(138deg, transparent 0 72%, rgba(255, 143, 178, .14) 78%, transparent 84%);
        background-size: 520px 100%, 420px 100%, 460px 100%;
        animation: heroColorTracks 9s linear infinite;
        opacity: .95;
        z-index: -2;
    }

    .workspace-hero::after {
        content: "";
        position: absolute;
        inset: 0;
        background-image:
            repeating-linear-gradient(90deg, rgba(255, 255, 255, .055) 0 1px, transparent 1px 46px),
            repeating-linear-gradient(0deg, rgba(255, 255, 255, .04) 0 1px, transparent 1px 38px);
        opacity: .46;
        z-index: -1;
    }

    .workspace-hero > div {
        position: relative;
        z-index: 1;
    }

    .workspace-kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        min-height: 30px;
        padding: 0 11px;
        margin-bottom: 14px;
        border: 1px solid rgba(255, 255, 255, .22);
        border-radius: 999px;
        color: rgba(255, 255, 255, .78);
        background: rgba(255, 255, 255, .08);
        font-weight: 700;
        font-size: 12px;
    }

    .workspace-title {
        margin: 0;
        color: #fff;
        font-size: 32px;
        font-weight: 900;
        line-height: 1.18;
    }

    .workspace-subtitle {
        max-width: 760px;
        margin: 10px 0 0;
        color: rgba(255, 255, 255, .72);
        font-size: 15px;
        line-height: 1.6;
    }

    .workspace-actions {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 10px;
        flex-wrap: wrap;
        min-width: 270px;
        min-height: 126px;
    }

    .wizard-launcher {
        position: relative;
        display: grid;
        place-items: center;
        width: 250px;
        min-height: 126px;
        isolation: isolate;
    }

    .wizard-launcher::before {
        content: "";
        position: absolute;
        inset: 8px 6px;
        border-radius: 18px;
        background:
            conic-gradient(from 90deg, rgba(141, 240, 199, .24), rgba(53, 98, 244, .24), rgba(255, 207, 99, .22), rgba(255, 111, 145, .22), rgba(141, 240, 199, .24));
        opacity: .9;
        filter: blur(12px);
        animation: launchAura 7s linear infinite;
        z-index: -2;
    }

    .wizard-launcher::after {
        content: "";
        position: absolute;
        width: 190px;
        height: 58px;
        border: 1px solid rgba(255, 255, 255, .18);
        border-radius: 16px;
        transform: rotate(-7deg);
        opacity: .58;
        z-index: -1;
    }

    .workspace-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        min-height: 44px;
        padding: 0 16px;
        border: 1px solid rgba(255, 255, 255, .24);
        border-radius: 8px;
        color: #fff;
        background: rgba(255, 255, 255, .1);
        font-weight: 800;
        font-size: 13px;
        transition: transform .18s ease, background .18s ease;
    }

    .workspace-btn:hover {
        color: #fff;
        transform: translateY(-1px);
        background: rgba(255, 255, 255, .18);
    }

    .workspace-btn.primary {
        color: #0b1220;
        border-color: transparent;
        background: #8df0c7;
        box-shadow: 0 16px 34px rgba(56, 211, 159, .24);
    }

    .workspace-btn.primary:hover {
        color: #0b1220;
    }

    .workspace-btn.primary.wizard-cta {
        position: relative;
        min-height: 52px;
        padding: 0 22px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, .45);
        border-radius: 12px;
        background: linear-gradient(120deg, #8df0c7, #86f7ff, #ffe46c, #ff8fb2, #8df0c7);
        background-size: 260% 260%;
        box-shadow:
            0 18px 36px rgba(20, 184, 166, .30),
            0 0 0 7px rgba(255, 255, 255, .06);
        animation: ctaGradient 5.5s ease-in-out infinite, ctaBreath 2.4s ease-in-out infinite;
    }

    .workspace-btn.primary.wizard-cta i,
    .workspace-btn.primary.wizard-cta span {
        position: relative;
        z-index: 2;
    }

    .workspace-btn.primary.wizard-cta i {
        animation: wandFlick 1.8s ease-in-out infinite;
    }

    .workspace-btn.primary.wizard-cta::before {
        content: "";
        position: absolute;
        top: -60%;
        bottom: -60%;
        left: -34%;
        width: 32px;
        background: rgba(255, 255, 255, .58);
        transform: rotate(22deg);
        animation: ctaSweep 2.8s ease-in-out infinite;
        z-index: 1;
    }

    .workspace-btn.primary.wizard-cta:hover {
        transform: translateY(-3px) scale(1.03);
        box-shadow:
            0 24px 46px rgba(34, 211, 238, .28),
            0 0 0 9px rgba(141, 240, 199, .10);
    }

    .launch-spark {
        position: absolute;
        width: 9px;
        height: 9px;
        border-radius: 3px;
        background: #fff;
        box-shadow: 0 0 12px currentColor;
        transform: rotate(45deg);
        opacity: .8;
        pointer-events: none;
    }

    .launch-spark.one {
        top: 22px;
        right: 42px;
        color: #86f7ff;
        animation: sparkJump 2.8s ease-in-out infinite;
    }

    .launch-spark.two {
        bottom: 20px;
        left: 46px;
        color: #ffe46c;
        animation: sparkJump 3.2s ease-in-out .4s infinite;
    }

    .launch-spark.three {
        top: 38px;
        left: 28px;
        color: #ff8fb2;
        animation: sparkJump 2.6s ease-in-out .8s infinite;
    }

    @@keyframes ctaGradient {
        0%, 100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
    }

    @@keyframes ctaBreath {
        0%, 100% { transform: translateY(0) scale(1); }
        50% { transform: translateY(-2px) scale(1.015); }
    }

    @@keyframes ctaSweep {
        0% { left: -36%; opacity: 0; }
        28% { opacity: .58; }
        58%, 100% { left: 126%; opacity: 0; }
    }

    @@keyframes wandFlick {
        0%, 100% { transform: rotate(0deg); }
        45% { transform: rotate(-12deg) translateY(-1px); }
        70% { transform: rotate(8deg); }
    }

    @@keyframes sparkJump {
        0%, 100% { transform: rotate(45deg) translate(0, 0) scale(.78); opacity: .45; }
        45% { transform: rotate(45deg) translate(7px, -9px) scale(1.08); opacity: 1; }
    }

    @@keyframes launchAura {
        to { transform: rotate(360deg); }
    }

    @@keyframes heroColorTracks {
        0% { background-position: -260px 0, 180px 0, 420px 0; }
        100% { background-position: 520px 0, -420px 0, -120px 0; }
    }

    .workspace-section {
        margin-top: 10px;
    }

    .studio-zone,
    .works-zone {
        position: relative;
    }

    .studio-zone .section-title,
    .works-zone .section-title {
        display: inline-flex;
        align-items: center;
        gap: 9px;
    }

    .section-title i {
        display: inline-grid;
        place-items: center;
        width: 28px;
        height: 28px;
        border-radius: 8px;
        color: #0b1220;
        background: #e9fff6;
        font-size: 14px;
    }

    .section-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 12px;
    }

    .section-title {
        margin: 0;
        color: #101827;
        font-size: 20px;
        font-weight: 900;
    }

    .section-note {
        margin: 4px 0 0;
        color: #667085;
        font-size: 13px;
    }

    .works-summary {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: flex-end;
    }

    .works-summary span {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        min-height: 32px;
        padding: 0 11px;
        border: 1px solid #dce7f5;
        border-radius: 999px;
        color: #31506f;
        background: #fff;
        font-size: 12px;
        font-weight: 900;
        box-shadow: 0 8px 18px rgba(20, 32, 51, .05);
    }

    .works-summary span:nth-child(1) i { color: #16845b; }
    .works-summary span:nth-child(2) i { color: #c98909; }
    .works-summary span:nth-child(3) i { color: #1d67e8; }

    .assessment-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
    }

    .assessment-card {
        position: relative;
        display: grid;
        min-height: 236px;
        padding: 18px;
        border: 1px solid var(--work-border, #e8edf5);
        border-radius: 8px;
        background:
            linear-gradient(180deg, var(--work-tint, rgba(29, 103, 232, .05)), rgba(255, 255, 255, 0) 38%),
            #fff;
        box-shadow: 0 12px 28px rgba(20, 32, 51, .06);
        overflow: hidden;
        transition: transform .16s ease, box-shadow .16s ease, border-color .16s ease;
    }

    .assessment-card::before {
        content: "";
        position: absolute;
        inset: 0 0 auto;
        height: 5px;
        background: linear-gradient(90deg, var(--work-accent, #1d67e8), var(--work-accent-2, #00a9a5));
    }

    .assessment-card::after {
        content: "";
        position: absolute;
        right: -42px;
        top: -42px;
        width: 126px;
        height: 126px;
        border-radius: 999px;
        background: var(--work-orb, rgba(29, 103, 232, .08));
        pointer-events: none;
    }

    .assessment-card:hover {
        transform: translateY(-2px);
        border-color: var(--work-hover, #cbd5e1);
        box-shadow: 0 18px 38px rgba(20, 32, 51, .10);
    }

    .assessment-card.exam {
        --work-accent: #1d67e8;
        --work-accent-2: #00a9a5;
        --work-tint: rgba(29, 103, 232, .07);
        --work-orb: rgba(0, 169, 165, .12);
        --work-border: #d9e7ff;
        --work-hover: #adc8fb;
        --work-icon-bg: #e8f0ff;
        --work-icon-color: #1d4ed8;
    }

    .assessment-card.survey {
        --work-accent: #c98909;
        --work-accent-2: #d93662;
        --work-tint: rgba(201, 137, 9, .08);
        --work-orb: rgba(217, 54, 98, .10);
        --work-border: #f1dfb6;
        --work-hover: #e9c56d;
        --work-icon-bg: #fff2ce;
        --work-icon-color: #9a6500;
    }

    .assessment-card.draft {
        --work-accent: #f26b4f;
        --work-accent-2: #c98909;
        --work-tint: rgba(242, 107, 79, .07);
        --work-orb: rgba(242, 107, 79, .10);
    }

    .assessment-top {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
    }

    .assessment-title-row {
        display: grid;
        grid-template-columns: 42px minmax(0, 1fr);
        gap: 11px;
        align-items: center;
        min-width: 0;
    }

    .assessment-type-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 42px;
        height: 42px;
        border-radius: 10px;
        color: var(--work-icon-color, #1d4ed8);
        background: var(--work-icon-bg, #e8f0ff);
        font-size: 18px;
        box-shadow: 0 10px 18px rgba(20, 32, 51, .08);
    }

    .assessment-name {
        margin: 0;
        color: #101827;
        font-size: 17px;
        font-weight: 900;
        line-height: 1.35;
        text-transform: uppercase;
    }

    .status-badge {
        position: relative;
        z-index: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 26px;
        padding: 0 10px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 900;
        white-space: nowrap;
    }

    .status-badge.live {
        color: #08724f;
        background: #ddf8ea;
    }

    .status-badge.draft {
        color: #9a3412;
        background: #ffedd5;
    }

    .assessment-meta {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 8px;
        margin: 18px 0;
    }

    .meta-box {
        min-height: 62px;
        padding: 10px;
        border-radius: 8px;
        border: 1px solid rgba(226, 232, 240, .86);
        background: rgba(248, 251, 255, .86);
    }

    .meta-box:nth-child(1) { background: #eef8ff; }
    .meta-box:nth-child(2) { background: #f0fff8; }
    .meta-box:nth-child(3) { background: #fff7ed; }

    .meta-box strong {
        display: block;
        color: #101827;
        font-size: 18px;
        line-height: 1;
    }

    .meta-box span {
        display: block;
        margin-top: 7px;
        color: #667085;
        font-size: 11px;
        font-weight: 800;
    }

    .assessment-tags {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 7px;
        margin-bottom: 16px;
    }

    .tag-pill {
        display: inline-flex;
        align-items: center;
        min-height: 26px;
        padding: 0 9px;
        border: 1px solid transparent;
        border-radius: 999px;
        color: #344054;
        background: #eef2f7;
        font-size: 11px;
        font-weight: 800;
    }

    .tag-pill.type {
        color: var(--work-icon-color, #1d4ed8);
        border-color: var(--work-border, #d9e7ff);
        background: var(--work-icon-bg, #e8f0ff);
    }

    .tag-pill.result {
        color: #0b4b77;
        border-color: #c7e8f8;
        background: #eef9ff;
    }

    .tag-pill.cert {
        color: #8a5b00;
        border-color: #f3d48a;
        background: #fff7d8;
    }

    .tag-pill.time {
        color: #5f3ab0;
        border-color: #d7c4ff;
        background: #f3edff;
    }

    .tag-pill.audience {
        color: #31506f;
        border-color: #dce7f5;
        background: #f3f8ff;
    }

    .tag-pill.open {
        color: #08724f;
        background: #ddf8ea;
    }

    .tag-pill.closed {
        color: #9a3412;
        background: #ffedd5;
    }

    .assessment-actions {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        margin-top: auto;
    }

    .mini-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        min-height: 38px;
        border: 1px solid #d9e1ec;
        border-radius: 8px;
        color: #344054;
        background: #fff;
        font-size: 12px;
        font-weight: 900;
        cursor: pointer;
    }

    .mini-btn:hover {
        color: #101827;
        background: #f7fafc;
    }

    .assessment-actions .mini-btn:nth-child(1) {
        color: #1d4ed8;
        border-color: #c7d9ff;
        background: #f1f6ff;
    }

    .assessment-actions .mini-btn:nth-child(2) {
        color: #08724f;
        border-color: #bdebd7;
        background: #f0fff8;
    }

    .assessment-actions .mini-btn:nth-child(3) {
        color: #8a5b00;
        border-color: #f3d48a;
        background: #fff9e8;
    }

    .assessment-actions .mini-btn:nth-child(4) {
        color: #5f3ab0;
        border-color: #d7c4ff;
        background: #f6f1ff;
    }

    .assessment-actions .mini-btn:nth-child(5) {
        color: #0b4b77;
        border-color: #c7e8f8;
        background: #eef9ff;
    }

    .mini-btn:disabled {
        color: #98a2b3;
        border-color: #e8edf5;
        background: #f7fafc;
        cursor: not-allowed;
    }

    .mini-btn.publish {
        color: #0b1220;
        border-color: transparent;
        background: #8df0c7;
    }

    .mini-btn.share {
        color: #0b4b77;
        border-color: #c7e8f8;
        background: #eef9ff;
    }

    .mini-btn.questions {
        color: #075985;
        border-color: #bae6fd;
        background: #ecfeff;
    }

    .mini-btn.answer-key {
        color: #08724f;
        border-color: #bdebd7;
        background: #f0fff8;
    }

    .mini-btn.danger {
        color: #b42318;
        border-color: #fecaca;
        background: #fff1f2;
    }

    .mini-btn.danger:hover {
        color: #7f1d1d;
        border-color: #fda4af;
        background: #ffe4e6;
    }

    .share-modal[hidden] {
        display: none;
    }

    .share-modal {
        position: fixed;
        inset: 0;
        z-index: 5000;
        display: block;
        padding: 0;
        overflow: hidden;
        background: rgba(15, 23, 42, .48);
    }

    .share-dialog {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: min(560px, 100%);
        max-height: calc(100vh - 44px);
        overflow-y: auto;
        padding: 22px;
        border-radius: 8px;
        background: #fff;
        box-shadow: 0 24px 70px rgba(15, 23, 42, .25);
    }

    .delete-dialog {
        width: min(720px, 100%);
    }

    .share-dialog-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 14px;
    }

    .share-dialog h3 {
        margin: 0;
        color: #101827;
        font-size: 18px;
        font-weight: 900;
        line-height: 1.35;
    }

    .share-dialog p {
        margin: 6px 0 0;
        color: #667085;
        font-size: 13px;
        line-height: 1.5;
    }

    .delete-warning {
        display: flex;
        gap: 12px;
        align-items: flex-start;
        margin: 14px 0;
        padding: 14px;
        border: 1px solid #fed7aa;
        border-radius: 8px;
        color: #7c2d12;
        background: #fff7ed;
        font-size: 13px;
        line-height: 1.5;
    }

    .delete-warning i {
        width: 32px;
        height: 32px;
        display: inline-grid;
        place-items: center;
        flex: 0 0 auto;
        border-radius: 8px;
        color: #fff;
        background: #f97316;
    }

    .delete-stats {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 10px;
        margin: 14px 0;
    }

    .delete-stat {
        padding: 12px;
        border: 1px solid #d9e1ec;
        border-radius: 8px;
        background: #f8fafc;
    }

    .delete-stat strong {
        display: block;
        color: #0b1220;
        font-size: 22px;
        line-height: 1.1;
    }

    .delete-stat span {
        display: block;
        margin-top: 5px;
        color: #667085;
        font-size: 12px;
        font-weight: 800;
    }

    .delete-impact {
        display: grid;
        gap: 8px;
        margin: 12px 0;
        padding: 0;
        list-style: none;
    }

    .delete-impact li {
        display: flex;
        justify-content: space-between;
        gap: 14px;
        padding: 10px 12px;
        border: 1px solid #e4eaf3;
        border-radius: 8px;
        background: #fff;
        color: #344054;
        font-size: 13px;
        font-weight: 800;
    }

    .delete-impact b {
        color: #0b1220;
        white-space: nowrap;
    }

    .delete-people {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 10px;
    }

    .delete-person {
        display: inline-flex;
        align-items: center;
        min-height: 30px;
        padding: 0 10px;
        border-radius: 999px;
        color: #0b4b77;
        background: #eef9ff;
        border: 1px solid #c7e8f8;
        font-size: 12px;
        font-weight: 900;
    }

    .delete-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 16px;
    }

    .delete-confirm {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        min-height: 42px;
        padding: 0 16px;
        border: 1px solid transparent;
        border-radius: 8px;
        color: #fff;
        background: #dc2626;
        font-size: 13px;
        font-weight: 900;
    }

    .delete-confirm:disabled {
        opacity: .65;
        cursor: wait;
    }

    .delete-cancel {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 42px;
        padding: 0 16px;
        border: 1px solid #d9e1ec;
        border-radius: 8px;
        color: #344054;
        background: #fff;
        font-size: 13px;
        font-weight: 900;
    }

    .share-access-panel {
        margin: 10px 0 14px;
        padding: 10px;
        border: 1px solid #d9e1ec;
        border-radius: 8px;
        background: #f8fafc;
    }

    .share-access-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 8px;
        color: #344054;
        font-size: 12px;
        font-weight: 900;
    }

    .share-access-current {
        color: #0b4b77;
    }

    .share-access-options {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px;
    }

    .share-access-option {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 38px;
        padding: 0 10px;
        border: 1px solid #d9e1ec;
        border-radius: 8px;
        color: #172033;
        background: #fff;
        font-size: 12px;
        font-weight: 900;
        cursor: pointer;
    }

    .share-access-option:hover {
        border-color: #9fb2cf;
        background: #f4f8ff;
    }

    .share-access-option.is-active {
        color: #075985;
        border-color: #7dd3fc;
        background: #ecfeff;
        box-shadow: inset 0 0 0 1px rgba(14, 165, 233, .18);
    }

    .share-access-option[disabled] {
        opacity: .7;
        cursor: progress;
    }

    .share-close {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        border: 1px solid #e8edf5;
        border-radius: 8px;
        color: #344054;
        background: #fff;
        font-size: 18px;
        font-weight: 900;
        line-height: 1;
        cursor: pointer;
    }

    .share-url-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 8px;
        margin: 14px 0;
    }

    .share-url-row input {
        min-width: 0;
        height: 42px;
        padding: 0 12px;
        border: 1px solid #d9e1ec;
        border-radius: 8px;
        color: #344054;
        background: #f8fafc;
        font-size: 13px;
    }

    .share-qr-box {
        display: grid;
        place-items: center;
        min-height: 230px;
        border: 1px dashed #cbd5e1;
        border-radius: 8px;
        background: #f8fafc;
    }

    .share-qr-box img {
        width: 210px;
        height: 210px;
    }

    .share-platform-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 8px;
        margin: 10px 0 14px;
    }

    .share-platform-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        min-height: 40px;
        padding: 0 10px;
        border: 1px solid #d9e1ec;
        border-radius: 8px;
        color: #172033;
        background: #fff;
        font-size: 13px;
        font-weight: 900;
        cursor: pointer;
    }

    .share-platform-btn:hover {
        color: #0b1220;
        border-color: #b9c7dc;
        background: #f8fbff;
    }

    .share-platform-btn.primary {
        color: #fff;
        border-color: transparent;
        background: linear-gradient(135deg, #172033, #4f46e5);
    }

    .share-platform-btn i {
        font-size: 15px;
    }

    .share-feedback {
        min-height: 18px;
        margin-top: 10px;
        color: #08724f;
        font-size: 12px;
        font-weight: 800;
    }

    @@media (max-width: 620px) {
        .share-dialog {
            width: calc(100vw - 28px);
            max-height: calc(100vh - 28px);
            padding: 18px;
        }

        .share-platform-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .share-access-options {
            grid-template-columns: 1fr;
        }

        .delete-stats {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .delete-actions {
            display: grid;
            grid-template-columns: 1fr;
        }
    }

    .management-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 10px;
        margin-bottom: 18px;
    }

    .management-link {
        position: relative;
        display: grid;
        grid-template-columns: 38px minmax(0, 1fr);
        align-items: center;
        gap: 12px;
        min-height: 74px;
        padding: 14px;
        border: 1px solid #e8edf5;
        border-radius: 8px;
        color: #101827;
        background: #fff;
        box-shadow: 0 10px 24px rgba(20, 32, 51, .05);
        overflow: hidden;
        transition: transform .16s ease, box-shadow .16s ease, border-color .16s ease;
    }

    .management-link::before {
        content: "";
        position: absolute;
        inset: 0 auto 0 0;
        width: 5px;
        background: var(--studio-accent, #19a7ce);
    }

    .management-link::after {
        content: "";
        position: absolute;
        right: -28px;
        top: -28px;
        width: 90px;
        height: 90px;
        border-radius: 999px;
        background: var(--studio-soft, rgba(25, 167, 206, .12));
        pointer-events: none;
    }

    .management-link:hover {
        color: #101827;
        border-color: var(--studio-border, #cbd5e1);
        background: var(--studio-bg, #f8fbff);
        transform: translateY(-2px);
        box-shadow: 0 16px 34px rgba(20, 32, 51, .10);
    }

    .management-link i {
        position: relative;
        z-index: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 38px;
        height: 38px;
        border-radius: 8px;
        color: var(--studio-ink, #0b1220);
        background: var(--studio-icon, #eef2f7);
        font-size: 17px;
        box-shadow: 0 8px 18px var(--studio-shadow, rgba(20, 32, 51, .06));
    }

    .management-link > span {
        position: relative;
        z-index: 1;
    }

    .management-link strong {
        display: block;
        overflow: hidden;
        color: #101827;
        font-size: 13px;
        font-weight: 900;
        line-height: 1.25;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .management-link span {
        display: block;
        margin-top: 3px;
        color: #667085;
        font-size: 11px;
        font-weight: 800;
        line-height: 1.25;
    }

    .management-link.danger i {
        color: #7f1d1d;
        background: #fee2e2;
    }

    .management-link:nth-child(1) {
        --studio-accent: #1d67e8;
        --studio-soft: rgba(29, 103, 232, .12);
        --studio-bg: #f6f9ff;
        --studio-border: #bdd2fb;
        --studio-icon: #e8f0ff;
        --studio-ink: #1d4ed8;
        --studio-shadow: rgba(29, 103, 232, .14);
    }

    .management-link:nth-child(2) {
        --studio-accent: #00a9a5;
        --studio-soft: rgba(0, 169, 165, .13);
        --studio-bg: #f1fffd;
        --studio-border: #a9ece6;
        --studio-icon: #defaf7;
        --studio-ink: #087b76;
        --studio-shadow: rgba(0, 169, 165, .14);
    }

    .management-link:nth-child(3) {
        --studio-accent: #c98909;
        --studio-soft: rgba(201, 137, 9, .13);
        --studio-bg: #fffaf0;
        --studio-border: #f3d48a;
        --studio-icon: #fff2ce;
        --studio-ink: #9a6500;
        --studio-shadow: rgba(201, 137, 9, .15);
    }

    .management-link:nth-child(4) {
        --studio-accent: #6f42c1;
        --studio-soft: rgba(111, 66, 193, .12);
        --studio-bg: #fbf8ff;
        --studio-border: #d7c4ff;
        --studio-icon: #f0e8ff;
        --studio-ink: #5f3ab0;
        --studio-shadow: rgba(111, 66, 193, .14);
    }

    .management-link:nth-child(5) {
        --studio-accent: #16845b;
        --studio-soft: rgba(22, 132, 91, .13);
        --studio-bg: #f3fff9;
        --studio-border: #bdebd7;
        --studio-icon: #e2f8ee;
        --studio-ink: #08724f;
        --studio-shadow: rgba(22, 132, 91, .14);
    }

    .management-link:nth-child(6) {
        --studio-accent: #3347b9;
        --studio-soft: rgba(51, 71, 185, .12);
        --studio-bg: #f7f8ff;
        --studio-border: #c9d1ff;
        --studio-icon: #e9ecff;
        --studio-ink: #3140a0;
        --studio-shadow: rgba(51, 71, 185, .14);
    }

    .management-link.danger {
        --studio-accent: #e05252;
        --studio-soft: rgba(224, 82, 82, .12);
        --studio-bg: #fff7f7;
        --studio-border: #ffc9c9;
        --studio-icon: #fee2e2;
        --studio-ink: #7f1d1d;
        --studio-shadow: rgba(224, 82, 82, .13);
    }

    .empty-state {
        display: grid;
        place-items: center;
        min-height: 260px;
        padding: 32px;
        border: 1px dashed #cbd5e1;
        border-radius: 8px;
        background: #fff;
        text-align: center;
    }

    .empty-state i {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 56px;
        height: 56px;
        margin-bottom: 16px;
        border-radius: 8px;
        color: #0b1220;
        background: #8df0c7;
        font-size: 25px;
    }

    .empty-state h3 {
        margin: 0;
        color: #101827;
