</style>

<div class="page-body workspace-page">
    <section class="workspace-hero">
        <div>
            <div class="workspace-kicker">
                <i class="ti-dashboard"></i>
                Aslana Survey Studio çalışma alanı
            </div>
            <h1 class="workspace-title">Merhaba @kullaniciAdi, bugün neyi yayına alıyoruz?</h1>
            <p class="workspace-subtitle">
                Sihirbazdan sınav, anket, eğitim veya aday değerlendirmesi hazırlayın; ödeme ve kredi adımı tamamlandığında yayın akışını buradan yönetin.
            </p>
        </div>
        <div class="workspace-actions">
            <div class="wizard-launcher">
                <span class="launch-spark one"></span>
                <span class="launch-spark two"></span>
                <span class="launch-spark three"></span>
                <a class="workspace-btn primary wizard-cta" href="@Url.Action("AssessmentWizard", "Home")">
                    <i class="ti-wand"></i>
                    <span>Yeni Sihirbaz</span>
                </a>
            </div>
        </div>
    </section>

    <section class="workspace-section studio-zone">
        <div class="section-head">
            <div>
                <h2 class="section-title"><i class="ti-palette"></i> Çalışma Stüdyosu</h2>
                <p class="section-note">Günlük akış sihirbaz üzerinden ilerler; soru bankası ve bakım araçları gerektiğinde kullanılır.</p>
            </div>
        </div>

        <div class="management-grid">
            <a class="management-link" href="@Url.Action("AssessmentWizard", "Home")">
                <i class="ti-wand"></i>
                <span>
                    <strong>Yeni Çalışma Oluştur</strong>
                    <span>Sınav, anket veya değerlendirme sihirbazı</span>
                </span>
            </a>
            <a class="management-link" href="@Url.Action("AnketAdIndex", "Home", new { id = Session["id"] })">
                <i class="ti-clipboard"></i>
                <span>
                    <strong>Çalışma Tanımları</strong>
                    <span>Yayın, süre ve sertifika ayarları</span>
                </span>
            </a>
            <a class="management-link" href="@Url.Action("SoruIndex", "Home")">
                <i class="ti-help-alt"></i>
                <span>
                    <strong>Soru Bankası</strong>
                    <span>Sorular ve puan yapısı</span>
                </span>
            </a>
            <a class="management-link" href="@Url.Action("SoruGrupIndex", "Home")">
                <i class="ti-layers"></i>
                <span>
                    <strong>Bölüm / Kategori Bankası</strong>
                    <span>Soru grupları ve sıralama</span>
                </span>
            </a>
            <a class="management-link" href="@Url.Action("CevapIndex", "Home")">
                <i class="ti-check-box"></i>
                <span>
                    <strong>Seçenek Bankası</strong>
                    <span>Anket puanı ve doğru cevap bilgisi</span>
                </span>
            </a>
            <a class="management-link" href="@Url.Action("CevapGrupIndex", "Home")">
                <i class="ti-view-list"></i>
                <span>
                    <strong>Gelişmiş Seçenek Grupları</strong>
                    <span>Manuel soru bankası eşleşmeleri</span>
                </span>
            </a>
            <a class="management-link danger" href="@Url.Action("AnketHavuzIndex", "Home", new { id = Session["id"] })">
                <i class="ti-trash"></i>
                <span>
                    <strong>Katılım Verilerini Temizle</strong>
                    <span>Cevap ve sonuç kayıtları</span>
                </span>
            </a>
            <a class="management-link danger" href="@Url.Action("AnketZamanIndex", "Home", new { id = Session["id"] })">
                <i class="ti-timer"></i>
                <span>
                    <strong>Süre Kayıtlarını Sıfırla</strong>
                    <span>Sınav zaman takibi</span>
                </span>
            </a>
        </div>
    </section>

    <section class="workspace-section works-zone">
        <div class="section-head">
            <div>
                <h2 class="section-title"><i class="ti-briefcase"></i> Çalışmalarım</h2>
                <p class="section-note">@katilimSayisi katılımcı kaydı sistemde takip ediliyor.</p>
            </div>
            <div class="works-summary">
                <span><i class="ti-signal"></i> @aktifSayisi yayında</span>
                <span><i class="ti-pencil-alt"></i> @taslakSayisi taslak</span>
                <span><i class="ti-user"></i> @katilimSayisi katılım</span>
            </div>
        </div>

        @if (!anketler.Any())
        {
            <div class="empty-state">
                <div>
                    <i class="ti-wand"></i>
                    <h3>İlk çalışmanızı oluşturun</h3>
                    <p>Sürükle-bırak sihirbaz ile sınav, anket veya işe alım değerlendirmesi hazırlayıp yayın akışına taşıyın.</p>
                    <a class="workspace-btn primary" href="@Url.Action("AssessmentWizard", "Home")">Sihirbazı Aç</a>
                </div>
            </div>
        }
        else
        {
            <div class="assessment-grid">
                @foreach (var item in anketler.OrderByDescending(x => x.AnketId))
                {
                    var itemHavuz = havuz.Where(x => x.AnketId == item.AnketId).ToList();
                    var soruGruplari = anketGruplari.Where(x => x.AnketId == item.AnketId).ToList();
                    var soruSayisi = (from detay in soruGruplari
                                      join soru in sorular on detay.SoruGrupId equals soru.SoruGrupId
                                      select soru.SoruId).Distinct().Count();
                    if (soruSayisi == 0)
                    {
                        soruSayisi = itemHavuz
                            .Where(x => x.SoruID != null)
                            .Select(x => x.SoruID)
                            .Distinct()
                            .Count();
                    }
                    var kayitliKatilim = itemHavuz.Where(x => x.UserId != null && x.UserId != 1).Select(x => x.UserId).Distinct().Count();
                    var anonimKatilim = itemHavuz.Where(x => x.UserId == null && x.Isimsiz != null).Select(x => x.Isimsiz).Distinct().Count();
                    var katilim = kayitliKatilim + anonimKatilim;
                    var durumClass = item.Pasif == true ? "draft" : "live";
                    var durumText = item.Pasif == true ? "Taslak" : "Yayında";
                    var tipText = item.Sinav == true ? "Sınav" : "Anket";
                    var tipClass = item.Sinav == true ? "exam" : "survey";
                    var tipIcon = item.Sinav == true ? "ti-ruler-pencil" : "ti-clipboard";
                    var katilimToken = katilimTokenMap.ContainsKey(item.AnketId) ? katilimTokenMap[item.AnketId] : "";
                    var publicLinkEnabled = item.Pasif != true && !string.IsNullOrWhiteSpace(katilimToken);
                    var paylasimUrl = Url.Action("Katilim", "Home", new { token = katilimToken }, Context.Request.Scheme);
                    var qrUrl = Url.Action("KatilimQr", "Home", new { token = katilimToken });
                    var katilimYontemi = katilimYontemiMap.ContainsKey(item.AnketId) ? katilimYontemiMap[item.AnketId] : "HerkeseAcik";
                    var katilimYontemiText = katilimYontemi == "Kayitli"
                        ? "Kayitli kisiler"
                        : katilimYontemi == "KisiyeOzel"
                            ? "Kisiye ozel"
                            : katilimYontemi == "BilgiFormu"
                                ? "Bilgi formu"
                                : "Herkese acik";
                    var shareSubtitle = katilimYontemi == "Kayitli" || katilimYontemi == "KisiyeOzel"
                        ? "Bu baglanti kayitli katilimcilara ozeldir. Giris yapan uygun kisilerin sonuclari kendi profiline islenir."
                        : katilimYontemi == "BilgiFormu"
                            ? "Bu baglanti genel katilima aciktir; kayitli olmayan kisiler kod ile takip edilir."
                            : "Bu baglanti herkese aciktir; giris yapan kayitli kisiler kendi profiliyle, digerleri katilim koduyla izlenir.";

                    <article class="assessment-card @tipClass @durumClass">
                        <div class="assessment-top">
                            <div class="assessment-title-row">
                                <span class="assessment-type-icon"><i class="@tipIcon"></i></span>
                                <h3 class="assessment-name">@item.AnketAdi</h3>
                            </div>
                            <span class="status-badge @durumClass">@durumText</span>
                        </div>

                        <div class="assessment-meta">
                            <div class="meta-box">
                                <strong>@soruGruplari.Count(x => x.SoruGrupId != null)</strong>
                                <span>Grup</span>
                            </div>
                            <div class="meta-box">
                                <strong>@soruSayisi</strong>
                                <span>Soru</span>
                            </div>
                            <div class="meta-box">
                                <strong>@katilim</strong>
                                <span>Katılım</span>
                            </div>
                        </div>

                        <div class="assessment-tags">
                            <span class="tag-pill type">@tipText</span>
                            @if (item.Sonuc == true)
                            {
                                <span class="tag-pill result">Sonuç açık</span>
                            }
                            @if (item.SertifikaNotu != null)
                            {
                                <span class="tag-pill cert">Sertifika @item.SertifikaNotu+</span>
                            }
                            @if (item.Zaman != null)
                            {
                                <span class="tag-pill time">@item.Zaman dk</span>
                            }
                            <span class="tag-pill audience">@katilimYontemiText</span>
                            <span class="tag-pill @(publicLinkEnabled ? "open" : "closed")">@(publicLinkEnabled ? "Link hazır" : "Link kapalı")</span>
                        </div>

                        <div class="assessment-actions">
                            <a class="mini-btn" href="@Url.Action("AnketGrupIndex", "Home", new { id = item.AnketId, adi = item.AnketAdi })">
                                <i class="ti-pencil"></i>
                                Düzenle
                            </a>
                            <a class="mini-btn" href="@Url.Action("DogruCevapEditor", "Home", new { id = item.AnketId })">
                                <i class="ti-check"></i>
                                Doğru Cevap
                            </a>
                            <a class="mini-btn" href="@Url.Action("AnketIndex1", "Home", new { id = item.AnketId })">
                                <i class="ti-bar-chart"></i>
                                Rapor
                            </a>
                            <a class="mini-btn" href="@Url.Action("AnketAdEdit", "Home", new { id = item.AnketId })">
                                <i class="ti-settings"></i>
                                Ayarlar
                            </a>
                            <a class="mini-btn" href="@Url.Action("SertifikaWizard", "Home", new { id = item.AnketId })">
                                <i class="ti-cup"></i>
                                Sertifika
                            </a>
                            @if (publicLinkEnabled)
                            {
                                <button class="mini-btn share js-share"
                                        type="button"
                                        data-share-url="@paylasimUrl"
                                        data-qr-url="@qrUrl"
                                        data-share-title="@item.AnketAdi"
                                        data-share-subtitle="@shareSubtitle">
                                    <i class="ti-share"></i>
                                    Paylaş
                                </button>
                            }
                            else
                            {
                                <button class="mini-btn" type="button" disabled>
                                    <i class="ti-share"></i>
                                    Paylaşım Kapalı
                                </button>
                            }
                        </div>
                    </article>
                }
            </div>
        }
    </section>
</div>

<div class="share-modal" id="shareModal" hidden>
    <div class="share-dialog" role="dialog" aria-modal="true" aria-labelledby="shareModalTitle">
        <div class="share-dialog-head">
            <div>
                <h3 id="shareModalTitle">Paylaşım Bağlantısı</h3>
                <p id="shareModalSubtitle">Bu link veya QR kod çalışma ayarlarındaki katılım yöntemine göre çalışır.</p>
            </div>
            <button class="share-close" type="button" id="shareModalClose" aria-label="Kapat">
                <span aria-hidden="true">x</span>
            </button>
        </div>

        <div class="share-url-row">
            <input id="shareUrlInput" type="text" readonly />
            <button class="mini-btn share" type="button" id="shareCopyButton">
                <i class="ti-files"></i>
                Kopyala
            </button>
        </div>

        <div class="share-platform-grid" aria-label="Paylasim kanallari">
            <button class="share-platform-btn primary" type="button" id="shareNativeButton">
                <i class="ti-share"></i>
                Paylas
            </button>
            <button class="share-platform-btn" type="button" data-share-platform="whatsapp">
                <i class="ti-mobile"></i>
                WhatsApp
            </button>
            <button class="share-platform-btn" type="button" data-share-platform="telegram">
                <i class="ti-location-arrow"></i>
                Telegram
            </button>
            <button class="share-platform-btn" type="button" data-share-platform="teams">
                <i class="ti-comments"></i>
                Teams
            </button>
            <button class="share-platform-btn" type="button" data-share-platform="mail">
                <i class="ti-email"></i>
                E-posta
            </button>
            <button class="share-platform-btn" type="button" data-share-platform="sms">
                <i class="ti-comment"></i>
                SMS
            </button>
        </div>

        <div class="share-qr-box" id="shareQrBox">
            <img id="shareQrImage" alt="Katılım QR kodu" />
        </div>
        <div class="share-feedback" id="shareFeedback" aria-live="polite"></div>
    </div>
</div>

<script>
    (function () {
        const modal = document.getElementById("shareModal");
        const title = document.getElementById("shareModalTitle");
        const subtitle = document.getElementById("shareModalSubtitle");
        const input = document.getElementById("shareUrlInput");
        const qrBox = document.getElementById("shareQrBox");
        const qrImage = document.getElementById("shareQrImage");
        const feedback = document.getElementById("shareFeedback");
        const copyButton = document.getElementById("shareCopyButton");
        const closeButton = document.getElementById("shareModalClose");
        const nativeShareButton = document.getElementById("shareNativeButton");
        const platformButtons = document.querySelectorAll("[data-share-platform]");
        let currentShareTitle = "";

        function openShareModal(button) {
            const shareUrl = button.dataset.shareUrl || "";
            const qrUrl = button.dataset.qrUrl || "";
            const shareTitle = button.dataset.shareTitle || "Çalışma";
            const shareSubtitle = button.dataset.shareSubtitle || "Bu bağlantıyı veya QR kodu kendi biriminizle paylaşabilirsiniz.";

            currentShareTitle = shareTitle;
            title.textContent = shareTitle;
            subtitle.textContent = shareSubtitle;
            input.value = shareUrl;
            qrImage.src = qrUrl || "";
            qrBox.style.display = qrUrl ? "grid" : "none";
            qrImage.style.display = qrUrl ? "block" : "none";
            feedback.textContent = "";
            modal.hidden = false;
            input.select();
        }

        async function copyShareUrl() {
            const value = input.value;
            if (!value) return;

            try {
                if (navigator.clipboard && window.isSecureContext) {
                    await navigator.clipboard.writeText(value);
                } else {
                    input.select();
                    document.execCommand("copy");
                }
                feedback.textContent = "Bağlantı kopyalandı.";
            } catch {
                feedback.textContent = "Bağlantıyı elle kopyalayabilirsiniz.";
            }
        }

        function platformShareUrl(platform, shareUrl, shareTitle) {
            const encodedUrl = encodeURIComponent(shareUrl);
            const encodedTitle = encodeURIComponent(shareTitle || "Aslana Survey Studio");
            const encodedText = encodeURIComponent((shareTitle || "Aslana Survey Studio") + " " + shareUrl);

            switch (platform) {
                case "whatsapp":
                    return "https://wa.me/?text=" + encodedText;
                case "telegram":
                    return "https://t.me/share/url?url=" + encodedUrl + "&text=" + encodedTitle;
                case "teams":
                    return "https://teams.microsoft.com/share?href=" + encodedUrl + "&msgText=" + encodedTitle;
                case "mail":
                    return "mailto:?subject=" + encodedTitle + "&body=" + encodedText;
                case "sms":
                    return "sms:?&body=" + encodedText;
                default:
                    return "";
            }
        }

        async function nativeShare() {
            const value = input.value;
            if (!value) return;

            if (navigator.share) {
                try {
                    await navigator.share({
                        title: currentShareTitle || "Aslana Survey Studio",
                        text: currentShareTitle || "Aslana Survey Studio",
                        url: value
                    });
                    feedback.textContent = "Paylasim penceresi acildi.";
                    return;
                } catch (error) {
                    if (error && error.name === "AbortError") {
                        feedback.textContent = "";
                        return;
                    }
                }
            }

            await copyShareUrl();
            feedback.textContent = "Bu cihazda genel paylasim desteklenmiyor; baglanti kopyalandi.";
        }

        function openPlatformShare(platform) {
            const value = input.value;
            if (!value) return;

            const targetUrl = platformShareUrl(platform, value, currentShareTitle);
            if (!targetUrl) return;

            if (targetUrl.startsWith("mailto:") || targetUrl.startsWith("sms:")) {
                window.location.href = targetUrl;
            } else {
                window.open(targetUrl, "_blank", "noopener,noreferrer");
            }
            feedback.textContent = "Paylasim kanali acildi.";
        }

        function closeShareModal() {
            modal.hidden = true;
            qrBox.style.display = "none";
            qrImage.removeAttribute("src");
        }

        document.querySelectorAll(".js-share").forEach(function (button) {
            button.addEventListener("click", function () {
                openShareModal(button);
            });
        });

        nativeShareButton.addEventListener("click", nativeShare);
        platformButtons.forEach(function (button) {
            button.addEventListener("click", function () {
                openPlatformShare(button.dataset.sharePlatform || "");
            });
        });
        copyButton.addEventListener("click", copyShareUrl);
        closeButton.addEventListener("click", closeShareModal);
        modal.addEventListener("click", function (event) {
            if (event.target === modal) {
                closeShareModal();
            }
        });
        document.addEventListener("keydown", function (event) {
            if (event.key === "Escape" && !modal.hidden) {
                closeShareModal();
            }
        });
    })();
</script>
