    }

    @@media (max-width: 1200px) {
        .assessment-grid,
        .management-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 900px) {
        .workspace-hero,
        .section-head {
            grid-template-columns: 1fr;
            flex-direction: column;
            align-items: flex-start;
        }

        .workspace-actions {
            justify-content: flex-start;
            min-width: 0;
            min-height: 96px;
        }

        .works-summary {
            justify-content: flex-start;
        }

        .wizard-launcher {
            width: min(100%, 250px);
            min-height: 96px;
        }

        .assessment-grid,
        .management-grid {
