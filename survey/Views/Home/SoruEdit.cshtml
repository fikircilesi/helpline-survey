@model survey.Models.Soru

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    @Html.HiddenFor(model => model.SoruId)

    <div class="panel">
        <div>
            <h4>Soru Düzenle</h4>
        </div>
        <div class="panel-body">

            <div class="col-md-10">
                <h5>Soru Adı</h5>
                @Html.EditorFor(model => model.SoruAdi, new { htmlAttributes = new { @class = "form-control", @Required = "", @maxlength = "250" } })
                @Html.ValidationMessageFor(model => model.SoruAdi, "", new { @class = "text-danger" })
            </div>
            <div class="col-md-10">
                <h5>Bölüm / Kategori</h5>
                @Html.DropDownListFor(m => m.SoruGrupId, (List<SelectListItem>)ViewBag.Sor, "Seçim", new { @class = "form-control", @Required = "" })
                @Html.ValidationMessageFor(model => model.SoruGrupId, "", new { @class = "text-danger" })
            </div>
            <div class="col-md-10">
                <h5>Seçenek Grubu</h5>
                @Html.DropDownListFor(m => m.CevapGrupId, (List<SelectListItem>)ViewBag.Cev, "Seçim", new { @class = "form-control", @Required = "" })
                @Html.ValidationMessageFor(model => model.CevapGrupId, "", new { @class = "text-danger" })
            </div>
            <div class="col-md-10">
                <h5>Sıra</h5>
                @Html.EditorFor(model => model.SoruSira, new { htmlAttributes = new { @class = "form-control", @Required = "", @maxlength = "2" } })
                @Html.ValidationMessageFor(model => model.SoruSira, "", new { @class = "text-danger" })
            </div>
            <div class="col-md-10">
                <h5>Puan</h5>
                @Html.EditorFor(model => model.SoruPuan, new { htmlAttributes = new { @class = "form-control", @Required = "", @maxlength = "3" } })
                @Html.ValidationMessageFor(model => model.SoruPuan, "", new { @class = "text-danger" })
            </div>


            <div class="col-lg-9"></div>
            <div class="col-lg-3">
                <a style="background-color:green; color:white" class="btn btn-default" href="@Url.Action("SoruIndex", "Home")">Geri</a>
                <input type="submit" style="background-color:blue; color:white" class="btn btn-default" value="Kayıt" />
            </div>
        </div>
    </div>
}
