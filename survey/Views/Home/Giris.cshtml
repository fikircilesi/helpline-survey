                    <form class="auth-form @(loginActive ? "is-active" : "")" data-panel="login" action="@Url.Action("Giris", "Home")" method="post" autocomplete="on">
                        @Html.AntiForgeryToken()
                        <h2 class="auth-title">Hoş geldiniz</h2>
                        <p class="auth-copy">Çalışma alanınıza güvenli şekilde giriş yapın.</p>

                        @if (ViewBag.Uyari != null)
                        {
                            <div class="alert-line" id="loginAlert">@ViewBag.Uyari</div>
                        }

                        <a class="google-btn" href="@Url.Action("GoogleGiris", "Home")">
                            <span class="google-mark">G</span>
                            Google ile devam et
                        </a>
                        <div class="or-line"><span>veya</span></div>

                        <div class="form-field">
                            <label for="objUser">Kullanıcı adı veya e-posta</label>
                            <input id="objUser" name="objUser" type="text" required maxlength="80" placeholder="ornek.kullanici veya mail@firma.com">
                        </div>
                        <div class="form-field password-field">
                            <label for="objUser1">Şifre</label>
                            <input id="objUser1" name="objUser1" type="password" required maxlength="50" placeholder="Şifrenizi yazın">
                            <button type="button" class="password-toggle" data-toggle-password="objUser1" aria-label="Şifreyi göster" title="Şifreyi göster">
                                <i class="ti-eye"></i>
                            </button>
                        </div>
                        @if (recaptchaAktif)
                        {
                            <div class="recaptcha-box">
                                <div id="loginRecaptcha" class="g-recaptcha" data-sitekey="@recaptchaSiteKey"></div>
                            </div>
                        }
                        else if (!captchaAtlandi)
                        {
                            <div class="captcha-box">
                                <div class="captcha-question">@captchaSoru</div>
                                <div class="form-field" style="margin-bottom:0">
                                    <label for="loginCaptcha">Güvenlik cevabı</label>
                                    <input id="loginCaptcha" name="guvenlikCevabi" type="number" required placeholder="Sonuç">
                                </div>
                            </div>
                        }
                        <button type="submit" class="submit-btn">
                            <i class="ti-lock"></i>
                            Panele Gir
                        </button>
                        <div class="form-foot">
                            <a href="/Ayar/SifremiUnuttum/">Şifremi unuttum</a>
                            <button type="button" class="text-btn" data-open-panel="register">Yeni hesap aç</button>
                        </div>
                    </form>

                    <form class="auth-form @(registerActive ? "is-active" : "")" data-panel="register" action="@Url.Action("KayitOl", "Home")" method="post" autocomplete="on">
                        @Html.AntiForgeryToken()
                        <h2 class="auth-title">Çalışma alanı açın</h2>
                        <p class="auth-copy">Taslak oluşturmak ücretsiz. Yayına alma ve sertifika adımları paket yapısına bağlanır.</p>

                        @if (ViewBag.RegisterError != null)
                        {
                            <div class="alert-line">@ViewBag.RegisterError</div>
                        }

                        <a class="google-btn" href="@Url.Action("GoogleGiris", "Home")">
                            <span class="google-mark">G</span>
                            Google ile hızlı kayıt
                        </a>
                        <div class="or-line"><span>veya</span></div>

                        <div class="field-grid">
                            <div class="form-field">
                                <label for="fullName">Ad soyad</label>
                                <input id="fullName" name="fullName" type="text" required maxlength="50" placeholder="Aydın Aslan">
                            </div>
                            <div class="form-field">
                                <label for="companyName">Firma</label>
                                <input id="companyName" name="companyName" type="text" required maxlength="100" placeholder="Elvan Gıda">
                            </div>
                        </div>
                        <div class="field-grid">
                            <div class="form-field">
                                <label for="email">E-posta</label>
                                <input id="email" name="email" type="email" required maxlength="50" placeholder="mail@firma.com">
                            </div>
                            <div class="form-field">
                                <label for="phone">Telefon</label>
                                <input id="phone" name="phone" type="tel" maxlength="30" placeholder="05xx xxx xx xx">
                            </div>
                        </div>
                        <div class="form-field">
                            <label for="username">Kullanıcı adı</label>
                            <input id="username" name="username" type="text" required maxlength="50" placeholder="firma.admin">
                        </div>
                        <div class="field-grid">
                            <div class="form-field password-field">
                                <label for="password">Şifre</label>
                                <input id="password" name="password" type="password" required minlength="6" maxlength="50" placeholder="En az 6 karakter">
                                <button type="button" class="password-toggle" data-toggle-password="password" aria-label="Şifreyi göster" title="Şifreyi göster">
                                    <i class="ti-eye"></i>
                                </button>
                                <span class="field-hint">En az 6 karakter, bir harf ve bir rakam. Boşluk kullanmayın.</span>
                            </div>
                            <div class="form-field password-field">
                                <label for="passwordConfirm">Şifre tekrar</label>
                                <input id="passwordConfirm" name="passwordConfirm" type="password" required minlength="6" maxlength="50" placeholder="Tekrar yazın">
                                <button type="button" class="password-toggle" data-toggle-password="passwordConfirm" aria-label="Şifreyi göster" title="Şifreyi göster">
                                    <i class="ti-eye"></i>
                                </button>
                            </div>
                        </div>
                        <div class="captcha-box">
                            <div class="captcha-question">@captchaSoru</div>
                            <div class="form-field" style="margin-bottom:0">
                                <label for="registerCaptcha">Güvenlik cevabı</label>
                                <input id="registerCaptcha" name="guvenlikCevabi" type="number" required placeholder="Sonuç">
                            </div>
                        </div>
                        <button type="submit" class="submit-btn">
                            <i class="ti-check"></i>
                            Hesabı Oluştur
                        </button>
                        <p class="legal-note">
                            Kayıtla birlikte <strong>KVKK Aydınlatma</strong>, <strong>Gizlilik Politikası</strong>, <strong>Kullanım Koşulları</strong> ve ödeme sırasında gösterilecek satış metinlerini okuduğunuzu kabul edersiniz.
                        </p>
                        <div class="form-foot">
                            <span>Zaten hesabınız var mı?</span>
                            <button type="button" class="text-btn" data-open-panel="login">Girişe dön</button>
                        </div>
                    </form>

                    <form class="auth-form @(verifyActive ? "is-active" : "")" data-panel="verify" action="@Url.Action("KayitOnayla", "Home")" method="post" autocomplete="on">
                        @Html.AntiForgeryToken()
                        <h2 class="auth-title">E-posta kodunu onaylayın</h2>
