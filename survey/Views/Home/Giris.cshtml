    <script type="text/javascript" src="~/files/bower_components/jquery/dist/jquery.min.js"></script>
    <script type="text/javascript" src="~/files/bower_components/popper.js/dist/umd/popper.min.js"></script>
    <script type="text/javascript" src="~/files/bower_components/bootstrap/dist/js/bootstrap.min.js"></script>
    <script>
        function setLoginAlert(message) {
            let alert = document.getElementById('loginAlert');
            if (!alert) {
                const authCopy = document.querySelector('[data-panel="login"] .auth-copy');
                alert = document.createElement('div');
                alert.className = 'alert-line';
                alert.id = 'loginAlert';
                if (authCopy) authCopy.insertAdjacentElement('afterend', alert);
            }

            alert.textContent = message;
            alert.style.display = '';
        }

        function setLoginSubmitState(enabled) {
            const submitButton = document.querySelector('[data-panel="login"] .submit-btn');
            if (submitButton && document.getElementById('loginRecaptcha')) {
                submitButton.disabled = !enabled;
            }
        }

        let loginRecaptchaWidgetId = null;

        window.onLoginRecaptchaReady = function () {
            if (!window.grecaptcha || loginRecaptchaWidgetId !== null) return;

            const recaptcha = document.getElementById('loginRecaptcha');
            if (!recaptcha) return;

            setLoginSubmitState(false);
            loginRecaptchaWidgetId = window.grecaptcha.render(recaptcha, {
                sitekey: recaptcha.dataset.sitekey,
                callback: window.onLoginRecaptchaVerified,
                'expired-callback': window.onLoginRecaptchaExpired,
                'error-callback': window.onLoginRecaptchaError
            });
        };

        window.onLoginRecaptchaVerified = function () {
            const alert = document.getElementById('loginAlert');
            if (alert) alert.style.display = 'none';
            setLoginSubmitState(true);
        };

        window.onLoginRecaptchaExpired = function () {
            setLoginSubmitState(false);
            setLoginAlert('reCAPTCHA süresi doldu. Lütfen kutuyu tekrar işaretleyin.');
        };

        window.onLoginRecaptchaError = function () {
            setLoginSubmitState(false);
            setLoginAlert('reCAPTCHA yüklenemedi. Sayfayı yenileyip tekrar deneyin.');
        };

        (function () {
            const root = document.querySelector('.studio-entry');
            const tabButtons = Array.from(document.querySelectorAll('[data-panel-tab]'));
            const forms = Array.from(document.querySelectorAll('[data-panel]'));
            const accessPanel = document.getElementById('accessPanel');

            function setPanel(name) {
                tabButtons.forEach(button => button.classList.toggle('is-active', button.dataset.panelTab === name));
                forms.forEach(form => form.classList.toggle('is-active', form.dataset.panel === name));
                root.dataset.activePanel = name;

                if (accessPanel && window.matchMedia('(max-width: 1080px)').matches) {
                    accessPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            }

            document.querySelectorAll('[data-open-panel]').forEach(button => {
                button.addEventListener('click', () => setPanel(button.dataset.openPanel));
            });

            document.querySelectorAll('[data-assistant-panel]').forEach(button => {
                button.addEventListener('click', () => setPanel(button.dataset.assistantPanel));
            });

            tabButtons.forEach(button => {
                button.addEventListener('click', () => setPanel(button.dataset.panelTab));
            });

            const assistant = document.getElementById('surveyAssistant');
            const assistantClose = document.querySelector('[data-assistant-close]');
            const assistantOpen = document.querySelector('[data-assistant-open]');

            if (assistant && assistantClose && assistantOpen) {
                assistantClose.addEventListener('click', () => assistant.classList.add('is-collapsed'));
                assistantOpen.addEventListener('click', () => assistant.classList.remove('is-collapsed'));
            }

            const loginForm = document.querySelector('[data-panel="login"]');
            if (loginForm) {
                if (loginForm.querySelector('.g-recaptcha')) {
                    setLoginSubmitState(false);
                }

                loginForm.addEventListener('submit', event => {
                    const recaptchaBox = loginForm.querySelector('.g-recaptcha');
                    if (!recaptchaBox) return;

                    if (!window.grecaptcha || loginRecaptchaWidgetId === null) {
                        event.preventDefault();
                        setLoginAlert('reCAPTCHA henüz hazır değil. Sayfayı yenileyip tekrar deneyin.');
                        return;
                    }

                    if (!window.grecaptcha.getResponse(loginRecaptchaWidgetId)) {
                        event.preventDefault();
                        setLoginAlert('Ben robot değilim kutusunu işaretleyin.');
                    }
                });
            }

            document.querySelectorAll('[data-toggle-password]').forEach(button => {
                button.addEventListener('click', () => {
                    const input = document.getElementById(button.dataset.togglePassword);
                    if (!input) return;

                    const show = input.type === 'password';
                    input.type = show ? 'text' : 'password';
                    button.classList.toggle('is-visible', show);
                    button.setAttribute('aria-label', show ? 'Şifreyi gizle' : 'Şifreyi göster');
                    button.setAttribute('title', show ? 'Şifreyi gizle' : 'Şifreyi göster');
                });
            });
        })();
    </script>
</body>
</html>
