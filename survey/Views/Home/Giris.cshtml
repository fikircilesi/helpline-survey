        .donut-ring strong {
            color: #172033;
            font-size: 16px;
            font-weight: 900;
        }

        .legend-list {
            display: grid;
            gap: 6px;
        }

        .legend-list span {
            display: grid;
            grid-template-columns: 9px 1fr;
            gap: 6px;
            align-items: center;
            color: #475569;
            font-size: 9px;
            font-weight: 850;
        }

        .legend-list span::before {
            width: 9px;
            height: 9px;
            border-radius: 3px;
            background: var(--dot, var(--teal));
            content: "";
        }

        .line-chart {
            position: relative;
            min-height: 100px;
            margin: 10px;
            background:
                repeating-linear-gradient(0deg, transparent 0 23px, rgba(132, 151, 176, .16) 23px 24px),
                repeating-linear-gradient(90deg, transparent 0 43px, rgba(132, 151, 176, .12) 43px 44px);
        }

        .line-chart svg {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
        }

        .bubble-chart {
            position: relative;
            min-height: 102px;
        }

        .bubble-chart span {
            position: absolute;
            left: var(--x, 20%);
            top: var(--y, 20%);
            display: grid;
            place-items: center;
            width: var(--s, 34px);
            height: var(--s, 34px);
            border-radius: 50%;
            color: #fff;
            background: linear-gradient(135deg, var(--c1, var(--teal)), var(--c2, var(--indigo)));
            font-size: 9px;
            font-weight: 900;
            box-shadow: 0 12px 24px rgba(49, 73, 118, .18);
        }

        .map-chart {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
            padding: 11px;
        }

        .map-tile {
            min-height: 38px;
            border-radius: 8px;
            background: linear-gradient(135deg, var(--c1, rgba(21, 184, 166, .18)), var(--c2, rgba(66, 87, 232, .15)));
            box-shadow: inset 0 0 0 1px rgba(132, 151, 176, .18);
        }

        .heat-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 6px;
            padding: 12px;
        }

        .heat-grid span {
            min-height: 28px;
            border-radius: 7px;
            background: color-mix(in srgb, var(--heat, #15b8a6) var(--mix, 50%), white);
            box-shadow: inset 0 0 0 1px rgba(132, 151, 176, .12);
        }

        .flow-chart {
            display: grid;
            grid-template-columns: 1fr 26px 1fr 26px 1fr;
            align-items: center;
            gap: 5px;
            padding: 14px 10px;
        }

        .flow-box {
            min-height: 68px;
            border-radius: 8px;
            background: linear-gradient(135deg, rgba(255, 255, 255, .96), rgba(239, 246, 255, .90));
            box-shadow: inset 0 0 0 1px rgba(132, 151, 176, .18);
            padding: 8px;
            color: #172033;
            font-size: 9px;
            font-weight: 900;
        }

        .flow-arrow {
            height: 3px;
            border-radius: 999px;
            background: linear-gradient(90deg, var(--teal), var(--indigo));
        }

        @@keyframes showcaseGlide {
            0%, 7% {
                transform: translateX(0);
            }

            11%, 18% {
                transform: translateX(-266px);
            }

            22%, 29% {
                transform: translateX(-532px);
            }

            33%, 40% {
                transform: translateX(-798px);
            }

            44%, 51% {
                transform: translateX(-1064px);
            }

            55%, 62% {
                transform: translateX(-1330px);
            }

            66%, 73% {
                transform: translateX(-1596px);
            }

            77%, 84% {
                transform: translateX(-1862px);
            }

            88%, 95% {
                transform: translateX(-2128px);
            }

            100% {
                transform: translateX(0);
            }
        }

        .hero-actions {
