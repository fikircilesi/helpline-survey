@model survey.Models.Personel
@{
    ViewBag.Title = "Evalio Studio by Aslana";
    Layout = null;

    var activePanel = (ViewBag.ActiveAuthPanel as string) ?? "login";
    var registerActive = string.Equals(activePanel, "register", StringComparison.OrdinalIgnoreCase);
    var verifyActive = string.Equals(activePanel, "verify", StringComparison.OrdinalIgnoreCase);
    var participantActive = string.Equals(activePanel, "participant", StringComparison.OrdinalIgnoreCase);
    var loginActive = !registerActive && !verifyActive && !participantActive;
    var captchaSoru = (ViewBag.CaptchaSoru as string) ?? "?";
    var verifyEmail = (ViewBag.VerifyEmail as string) ?? string.Empty;
    var recaptchaAktif = ViewBag.RecaptchaAktif is bool recaptchaValue && recaptchaValue;
    var recaptchaSiteKey = (ViewBag.RecaptchaSiteKey as string) ?? string.Empty;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <title>Evalio Studio by Aslana | Sınav, Anket ve Sertifika Platformu</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=0, minimal-ui">
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="description" content="Sınav, anket, eğitim ve sertifika yayınlama platformu">
    <link rel="icon" href="~/files/assets/images/favicon.ico" type="image/x-icon">
    <link rel="stylesheet" type="text/css" href="~/files/bower_components/bootstrap/dist/css/bootstrap.min.css">
    <link rel="stylesheet" type="text/css" href="~/files/assets/icon/themify-icons/themify-icons.css">
    <link rel="stylesheet" type="text/css" href="~/files/assets/icon/icofont/css/icofont.css">
    <style>
        :root {
            --ink: #152033;
            --muted: #667085;
            --soft: #f4f8ff;
            --line: #dce6f2;
            --panel: #ffffff;
            --teal: #15b8a6;
            --indigo: #4257e8;
            --amber: #ffb84d;
            --coral: #ff6b5d;
            --green: #22c55e;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            color: var(--ink);
            font-family: "Segoe UI", Arial, sans-serif;
            background: #f6faff;
        }

        a,
        a:hover {
            text-decoration: none;
        }

        .studio-entry {
            position: relative;
            min-height: 100vh;
            overflow: hidden;
            background:
                linear-gradient(135deg, rgba(21, 184, 166, .11) 0 16%, transparent 16% 100%),
                linear-gradient(155deg, transparent 0 54%, rgba(66, 87, 232, .10) 54% 100%),
                repeating-linear-gradient(90deg, rgba(21, 32, 51, .035) 0 1px, transparent 1px 76px),
                repeating-linear-gradient(0deg, rgba(21, 32, 51, .03) 0 1px, transparent 1px 76px),
                linear-gradient(180deg, #ffffff 0%, #f7fbff 48%, #edf5ff 100%);
        }

        .studio-entry::before {
            content: "";
            position: absolute;
            inset: auto 0 0;
            height: 12px;
            background: linear-gradient(90deg, var(--teal), var(--indigo), var(--amber), var(--coral));
        }

        .entry-shell {
            position: relative;
            z-index: 1;
            width: min(1180px, calc(100% - 36px));
            min-height: 100vh;
            margin: 0 auto;
            display: grid;
            grid-template-rows: auto 1fr;
            gap: 28px;
            padding: 24px 0 42px;
        }

        .entry-nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 18px;
        }

        .brand-lockup {
            display: inline-flex;
            align-items: center;
            min-width: 0;
        }

        .brand-lockup img {
            width: 226px;
            max-width: 64vw;
            height: auto;
            display: block;
        }

        .nav-actions {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 10px;
            flex-wrap: wrap;
        }

        .nav-link-btn,
        .primary-top,
        .text-btn,
        .submit-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            border-radius: 8px;
            font-weight: 800;
            transition: transform .16s ease, box-shadow .16s ease, background .16s ease, border-color .16s ease;
        }

        .nav-link-btn {
            min-height: 42px;
            padding: 0 15px;
            color: #1f2d44;
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .78);
        }

        .nav-link-btn:hover {
            color: #142033;
            border-color: rgba(66, 87, 232, .36);
            background: #fff;
            transform: translateY(-1px);
        }

        .primary-top {
            min-height: 42px;
            padding: 0 16px;
            border: 0;
            color: #fff;
            background: #152033;
            box-shadow: 0 12px 26px rgba(21, 32, 51, .18);
            cursor: pointer;
        }

        .primary-top:hover {
            transform: translateY(-1px);
            box-shadow: 0 16px 32px rgba(21, 32, 51, .22);
        }

        .entry-main {
            display: grid;
            grid-template-columns: minmax(0, 1fr) 430px;
            align-items: center;
            gap: 44px;
        }

        .story-panel {
            min-width: 0;
        }

        .eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 9px;
            margin-bottom: 18px;
            padding: 8px 12px;
            color: #174a43;
            border: 1px solid rgba(21, 184, 166, .28);
            border-radius: 999px;
            background: rgba(21, 184, 166, .10);
            font-size: 13px;
            font-weight: 800;
        }

        .eyebrow i {
            color: var(--teal);
        }

        .hero-title {
            max-width: 720px;
            margin: 0;
            color: #121b2d;
            font-size: 52px;
            line-height: 1.04;
            font-weight: 900;
            letter-spacing: 0;
        }

        .hero-title span {
            color: var(--indigo);
        }

        .hero-text {
            max-width: 620px;
            margin: 18px 0 0;
            color: #536174;
            font-size: 17px;
            line-height: 1.72;
            font-weight: 500;
        }

        .hero-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 11px;
            margin-top: 28px;
        }

        .hero-actions .primary-top,
        .hero-actions .nav-link-btn {
            min-height: 50px;
            padding: 0 20px;
            font-size: 14px;
        }

        .confidence-row {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 10px;
            max-width: 660px;
            margin-top: 30px;
        }

        .confidence-item {
            min-height: 78px;
            padding: 14px;
            border: 1px solid var(--line);
            border-radius: 8px;
            background: rgba(255, 255, 255, .72);
        }

        .confidence-item i {
            color: var(--indigo);
            font-size: 18px;
        }

        .confidence-item strong {
            display: block;
            margin-top: 8px;
            color: #19253a;
            font-size: 13px;
        }

        .confidence-item span {
            display: block;
            margin-top: 4px;
            color: #69778b;
            font-size: 12px;
            line-height: 1.35;
        }

        .studio-preview {
            max-width: 650px;
            margin-top: 30px;
            border: 1px solid rgba(66, 87, 232, .18);
            border-radius: 8px;
            background: rgba(255, 255, 255, .86);
            box-shadow: 0 22px 60px rgba(49, 73, 118, .14);
            overflow: hidden;
        }

        .preview-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 14px 16px;
            border-bottom: 1px solid #e5edf7;
            background: #fff;
        }

        .preview-title {
            display: flex;
            align-items: center;
            gap: 10px;
            min-width: 0;
            color: #182338;
            font-weight: 900;
        }

        .preview-title i {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 30px;
            height: 30px;
            flex: 0 0 30px;
            border-radius: 8px;
            color: #fff;
            background: var(--teal);
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            min-height: 30px;
            padding: 0 11px;
            color: #17663b;
            border-radius: 999px;
            background: rgba(34, 197, 94, .12);
            font-size: 12px;
            font-weight: 900;
            white-space: nowrap;
        }

        .preview-body {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
            padding: 16px;
        }

        .workflow-list,
        .report-list {
            display: grid;
            gap: 10px;
        }

        .workflow-step,
        .report-line {
            min-height: 54px;
            padding: 12px;
            border: 1px solid #e3ebf6;
            border-radius: 8px;
            background: #fbfdff;
        }

        .workflow-step {
            display: grid;
            grid-template-columns: 34px 1fr;
            align-items: center;
            gap: 10px;
        }

        .step-no {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 34px;
            height: 34px;
            border-radius: 8px;
            color: #fff;
            background: var(--indigo);
            font-weight: 900;
        }

        .workflow-step strong,
        .report-line strong {
            display: block;
            color: #1c2840;
            font-size: 13px;
        }

        .workflow-step span,
        .report-line span {
            display: block;
            margin-top: 3px;
            color: #6b7789;
            font-size: 12px;
        }

        .report-line {
            position: relative;
            overflow: hidden;
        }

        .report-line::after {
            content: "";
            display: block;
            width: var(--bar, 70%);
            height: 6px;
            margin-top: 10px;
            border-radius: 999px;
            background: linear-gradient(90deg, var(--teal), var(--amber));
        }

        .access-panel {
            align-self: center;
            border: 1px solid rgba(132, 151, 176, .30);
            border-radius: 8px;
            background: var(--panel);
            box-shadow: 0 28px 80px rgba(49, 73, 118, .18);
            overflow: hidden;
        }

        .panel-head {
            padding: 18px 18px 0;
        }

        .mode-tabs {
            display: flex;
            gap: 6px;
            padding: 5px;
            border: 1px solid #e2eaf5;
            border-radius: 8px;
            background: #f5f8fc;
        }

        .mode-tabs button {
            flex: 1 1 0;
            min-width: 0;
            min-height: 42px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            border: 0;
            border-radius: 6px;
            color: #667085;
            background: transparent;
            font-size: 13px;
            font-weight: 900;
            line-height: 1;
            white-space: nowrap;
            cursor: pointer;
            transition: background .16s ease, color .16s ease, box-shadow .16s ease;
        }

        .mode-tabs button i {
            font-size: 15px;
            line-height: 1;
        }

        .mode-tabs button.is-active {
            color: #fff;
            background: #152033;
            box-shadow: 0 10px 22px rgba(21, 32, 51, .18);
        }

        .auth-form {
            display: none;
            padding: 20px;
        }

        .auth-form.is-active {
            display: block;
        }

        .auth-title {
            margin: 0 0 5px;
            color: #142033;
            font-size: 24px;
            font-weight: 900;
        }

        .auth-copy {
            margin: 0 0 18px;
            color: #687789;
            line-height: 1.55;
            font-size: 13px;
        }

        .field-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .form-field {
            margin-bottom: 12px;
        }

        .form-field label {
            display: block;
            margin-bottom: 7px;
            color: #344054;
            font-size: 12px;
            font-weight: 900;
        }

        .form-field input {
            width: 100%;
            min-height: 46px;
            border: 1px solid #d9e3f0;
            border-radius: 8px;
            outline: none;
            padding: 0 13px;
            color: #172033;
            background: #fbfdff;
            transition: border-color .16s ease, background .16s ease, box-shadow .16s ease;
        }

        .form-field input:focus {
            border-color: rgba(66, 87, 232, .68);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(66, 87, 232, .11);
        }

        .form-field input::placeholder {
            color: #9aa8ba;
        }

        .password-field {
            position: relative;
        }

        .password-field input {
            padding-right: 48px;
        }

        .password-toggle {
            position: absolute;
            right: 8px;
            bottom: 8px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 32px;
            height: 32px;
            border: 0;
            border-radius: 6px;
            color: #5b667a;
            background: transparent;
            cursor: pointer;
        }

        .password-toggle:hover,
        .password-toggle.is-visible {
            color: var(--indigo);
            background: rgba(66, 87, 232, .08);
        }

        .google-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            width: 100%;
            min-height: 48px;
            margin: 4px 0 14px;
            border: 1px solid #d9e3f0;
            border-radius: 8px;
            color: #182338;
            background: #fff;
            font-weight: 900;
            box-shadow: 0 10px 24px rgba(49, 73, 118, .08);
            transition: transform .16s ease, border-color .16s ease, box-shadow .16s ease;
        }

        .google-btn:hover {
            color: #182338;
            border-color: rgba(66, 87, 232, .36);
            transform: translateY(-1px);
            box-shadow: 0 14px 28px rgba(49, 73, 118, .12);
        }

        .google-mark {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 24px;
            height: 24px;
            border-radius: 50%;
            color: #fff;
            background: linear-gradient(135deg, #4285f4, #34a853 46%, #fbbc05 72%, #ea4335);
            font-weight: 900;
            font-family: Arial, sans-serif;
        }

        .or-line {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            align-items: center;
            gap: 10px;
            margin: 2px 0 14px;
            color: #98a2b3;
            font-size: 11px;
            font-weight: 900;
            text-transform: uppercase;
        }

        .or-line::before,
        .or-line::after {
            content: "";
            height: 1px;
            background: #e5edf7;
        }

        .captcha-box {
            display: grid;
            grid-template-columns: 112px minmax(0, 1fr);
            gap: 10px;
            align-items: end;
            margin-bottom: 12px;
        }

        .captcha-question {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 46px;
            border: 1px solid rgba(21, 184, 166, .26);
            border-radius: 8px;
            color: #126b62;
            background: rgba(21, 184, 166, .10);
            font-weight: 900;
        }

        .recaptcha-box {
            display: flex;
            justify-content: center;
            min-height: 78px;
            margin: 4px 0 12px;
            padding: 8px;
            border: 1px solid var(--line);
            border-radius: 8px;
            background: #fbfdff;
            overflow: hidden;
        }

        .submit-btn {
            width: 100%;
            min-height: 50px;
            margin-top: 4px;
            border: 0;
            color: #fff;
            background: linear-gradient(135deg, #152033, #4257e8);
            box-shadow: 0 16px 34px rgba(66, 87, 232, .20);
            cursor: pointer;
        }

        .submit-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 20px 40px rgba(66, 87, 232, .24);
        }

        .form-foot {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin-top: 14px;
            color: #687789;
            font-size: 12px;
            flex-wrap: wrap;
        }

        .form-foot a {
            color: var(--indigo);
            font-weight: 900;
        }

        .text-btn {
            min-height: 36px;
            padding: 0 12px;
            color: var(--indigo);
            border: 1px solid rgba(66, 87, 232, .18);
            background: rgba(66, 87, 232, .07);
            cursor: pointer;
            font-size: 12px;
        }

        .text-btn:hover {
            background: rgba(66, 87, 232, .12);
        }

        .alert-line {
            margin-bottom: 14px;
            padding: 11px 12px;
            border: 1px solid rgba(255, 107, 93, .30);
            border-radius: 8px;
            color: #9c2f25;
            background: rgba(255, 107, 93, .10);
            font-size: 13px;
            font-weight: 800;
        }

        .alert-line.success {
            border-color: rgba(34, 197, 94, .30);
            color: #17663b;
            background: rgba(34, 197, 94, .10);
        }

        .panel-footer {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 1px;
            border-top: 1px solid #e5edf7;
            background: #e5edf7;
        }

        .mini-proof {
            min-height: 76px;
            padding: 13px;
            background: #fbfdff;
        }

        .mini-proof i {
            color: var(--teal);
            font-size: 18px;
        }

        .mini-proof span {
            display: block;
            margin-top: 8px;
            color: #617084;
            font-size: 12px;
            line-height: 1.35;
        }

        @@media (max-width: 1080px) {
            .entry-main {
                grid-template-columns: 1fr;
                gap: 28px;
            }

            .access-panel {
                order: -1;
                width: min(560px, 100%);
            }
        }

        @@media (max-width: 760px) {
            .entry-shell {
                width: min(100% - 22px, 1180px);
                padding-top: 16px;
            }

            .entry-nav {
                align-items: flex-start;
                flex-direction: column;
            }

            .nav-actions {
                width: 100%;
                justify-content: flex-start;
            }

            .nav-link-btn,
            .primary-top {
                width: 100%;
            }

            .hero-title {
                font-size: 38px;
            }

            .hero-text {
                font-size: 16px;
            }

            .confidence-row,
            .preview-body,
            .field-grid,
            .panel-footer,
            .captcha-box {
                grid-template-columns: 1fr;
            }

            .studio-preview {
                margin-top: 22px;
            }
        }

        @@media (max-width: 430px) {
            .panel-head {
                padding: 14px 14px 0;
            }

            .mode-tabs {
                gap: 4px;
                padding: 4px;
            }

            .mode-tabs button {
                min-height: 38px;
                gap: 5px;
                font-size: 12px;
            }

            .mode-tabs button i {
                font-size: 14px;
            }
        }
    </style>
    @if (recaptchaAktif)
    {
        <script src="https://www.google.com/recaptcha/api.js" async defer></script>
    }
</head>

<body>
    <main class="studio-entry" data-active-panel="@activePanel">
        <div class="entry-shell">
            <nav class="entry-nav">
                <a class="brand-lockup" href="@Url.Action("Giris", "Home")" aria-label="Evalio Studio ana sayfa">
                    <img src="@Url.Content("~/Content/img/evalio-logo-dark.svg")" alt="Evalio Studio by Aslana">
                </a>
                <div class="nav-actions">
                    <a class="nav-link-btn" href="@Url.Action("AnketGiris", "Home")">
                        <i class="ti-user"></i>
                        Katılımcı Girişi
                    </a>
                    <button type="button" class="nav-link-btn" data-open-panel="participant">
                        <i class="ti-search"></i>
                        Katılım Kodum Var
                    </button>
                    <button type="button" class="primary-top" data-open-panel="register">
                        <i class="ti-plus"></i>
                        Ücretsiz Başla
                    </button>
                </div>
            </nav>

            <section class="entry-main">
                <div class="story-panel">
                    <div class="eyebrow">
                        <i class="ti-shield"></i>
                        Güvenli sınav, anket ve sertifika stüdyosu
                    </div>
                    <h1 class="hero-title">
                        Değerlendirme süreçlerinizi <span>tek, sakin ve güvenli</span> bir ekrandan yönetin.
                    </h1>
                    <p class="hero-text">
                        Evalio Studio; İK, eğitim, kalite ve işe alım ekipleri için sınav oluşturma, anket yayınlama, sonuç izleme ve sertifika süreçlerini sade bir çalışma alanında toplar.
                    </p>
                    <div class="hero-actions">
                        <button type="button" class="primary-top" data-open-panel="register">
                            <i class="ti-rocket"></i>
                            Çalışma Alanı Aç
                        </button>
                        <button type="button" class="nav-link-btn" data-open-panel="login">
                            <i class="ti-lock"></i>
                            Hesabımla Giriş Yap
                        </button>
                        <button type="button" class="nav-link-btn" data-open-panel="participant">
                            <i class="ti-search"></i>
                            Katılım Koduyla Takip Et
                        </button>
                    </div>

                    <div class="confidence-row" aria-label="Güven veren özellikler">
                        <div class="confidence-item">
                            <i class="ti-check-box"></i>
                            <strong>Kontrollü yayın</strong>
                            <span>Taslak, önizleme ve yayın adımları ayrıdır.</span>
                        </div>
                        <div class="confidence-item">
                            <i class="ti-bar-chart"></i>
                            <strong>Net raporlar</strong>
                            <span>Katılım, puan ve sonuçlar tek panelde izlenir.</span>
                        </div>
                        <div class="confidence-item">
                            <i class="ti-id-badge"></i>
                            <strong>Sertifika akışı</strong>
                            <span>Başarı koşuluna bağlı sertifika yapısı hazırdır.</span>
                        </div>
                    </div>

                    <div class="studio-preview" aria-label="Evalio Studio çalışma alanı önizlemesi">
                        <div class="preview-top">
                            <div class="preview-title">
                                <i class="ti-layout"></i>
                                Gıda Güvenliği Sınavı
                            </div>
                            <span class="status-pill">
                                <i class="ti-check"></i>
                                Yayına hazır
                            </span>
                        </div>
                        <div class="preview-body">
                            <div class="workflow-list">
                                <div class="workflow-step">
                                    <span class="step-no">1</span>
                                    <div>
                                        <strong>Soruları içe aktar</strong>
                                        <span>Word veya Excel metninden hızlı kurulum</span>
                                    </div>
                                </div>
                                <div class="workflow-step">
                                    <span class="step-no">2</span>
                                    <div>
                                        <strong>Doğru cevapları belirle</strong>
                                        <span>Puanlama toplamı otomatik dengelenir</span>
                                    </div>
                                </div>
                                <div class="workflow-step">
                                    <span class="step-no">3</span>
                                    <div>
                                        <strong>Linki paylaş</strong>
                                        <span>Katılımcı ve rapor akışı hazır olur</span>
                                    </div>
                                </div>
                            </div>
                            <div class="report-list">
                                <div class="report-line" style="--bar:86%">
                                    <strong>Katılım</strong>
                                    <span>86 kişi tamamladı</span>
                                </div>
                                <div class="report-line" style="--bar:74%">
                                    <strong>Başarı</strong>
                                    <span>Ortalama 74 puan</span>
                                </div>
                                <div class="report-line" style="--bar:92%">
                                    <strong>Yayın sağlığı</strong>
                                    <span>Formlar ve cevaplar eşleşti</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <aside class="access-panel" id="accessPanel">
                    <div class="panel-head">
                        <div class="mode-tabs" role="tablist" aria-label="Giriş seçenekleri">
                            <button type="button" class="@(loginActive ? "is-active" : "")" data-panel-tab="login">
                                <i class="ti-lock"></i><span>Panel</span>
                            </button>
                            <button type="button" class="@(registerActive ? "is-active" : "")" data-panel-tab="register">
                                <i class="ti-user"></i><span>Üyelik</span>
                            </button>
                            <button type="button" class="@(verifyActive ? "is-active" : "")" data-panel-tab="verify">
                                <i class="ti-check-box"></i><span>Onay</span>
                            </button>
                            <button type="button" class="@(participantActive ? "is-active" : "")" data-panel-tab="participant">
                                <i class="ti-search"></i><span>Katılım</span>
                            </button>
                        </div>
                    </div>

                    <form class="auth-form @(loginActive ? "is-active" : "")" data-panel="login" action="@Url.Action("Giris", "Home")" method="post" autocomplete="on">
                        @Html.AntiForgeryToken()
                        <h2 class="auth-title">Hoş geldiniz</h2>
                        <p class="auth-copy">Çalışma alanınıza güvenli şekilde giriş yapın.</p>

                        @if (ViewBag.Uyari != null)
                        {
                            <div class="alert-line" id="loginAlert">@ViewBag.Uyari</div>
                        }

                        <a class="google-btn" href="@Url.Action("GoogleGiris", "Home")">
                            <span class="google-mark">G</span>
                            Google ile devam et
                        </a>
                        <div class="or-line"><span>veya</span></div>

                        <div class="form-field">
                            <label for="objUser">Kullanıcı adı</label>
                            <input id="objUser" name="objUser" type="text" required maxlength="50" placeholder="ornek.kullanici">
                        </div>
                        <div class="form-field password-field">
                            <label for="objUser1">Şifre</label>
                            <input id="objUser1" name="objUser1" type="password" required maxlength="50" placeholder="Şifrenizi yazın">
                            <button type="button" class="password-toggle" data-toggle-password="objUser1" aria-label="Şifreyi göster" title="Şifreyi göster">
                                <i class="ti-eye"></i>
                            </button>
                        </div>
                        @if (recaptchaAktif)
                        {
                            <div class="recaptcha-box">
                                <div class="g-recaptcha"
                                     data-sitekey="@recaptchaSiteKey"
                                     data-callback="onLoginRecaptchaVerified"
                                     data-expired-callback="onLoginRecaptchaExpired"
                                     data-error-callback="onLoginRecaptchaExpired"></div>
                            </div>
                        }
                        else
                        {
                            <div class="captcha-box">
                                <div class="captcha-question">@captchaSoru</div>
                                <div class="form-field" style="margin-bottom:0">
                                    <label for="loginCaptcha">Güvenlik cevabı</label>
                                    <input id="loginCaptcha" name="guvenlikCevabi" type="number" required placeholder="Sonuç">
                                </div>
                            </div>
                        }
                        <button type="submit" class="submit-btn">
                            <i class="ti-lock"></i>
                            Panele Gir
                        </button>
                        <div class="form-foot">
                            <a href="/Ayar/SifremiUnuttum/">Şifremi unuttum</a>
                            <button type="button" class="text-btn" data-open-panel="register">Yeni hesap aç</button>
                        </div>
                    </form>

                    <form class="auth-form @(registerActive ? "is-active" : "")" data-panel="register" action="@Url.Action("KayitOl", "Home")" method="post" autocomplete="on">
                        @Html.AntiForgeryToken()
                        <h2 class="auth-title">Çalışma alanı açın</h2>
                        <p class="auth-copy">Taslak oluşturmak ücretsiz. Yayına alma ve sertifika adımları paket yapısına bağlanır.</p>

                        @if (ViewBag.RegisterError != null)
                        {
                            <div class="alert-line">@ViewBag.RegisterError</div>
                        }

                        <a class="google-btn" href="@Url.Action("GoogleGiris", "Home")">
                            <span class="google-mark">G</span>
                            Google ile hızlı kayıt
                        </a>
                        <div class="or-line"><span>veya</span></div>

                        <div class="field-grid">
                            <div class="form-field">
                                <label for="fullName">Ad soyad</label>
                                <input id="fullName" name="fullName" type="text" required maxlength="50" placeholder="Aydın Aslan">
                            </div>
                            <div class="form-field">
                                <label for="companyName">Firma</label>
                                <input id="companyName" name="companyName" type="text" required maxlength="100" placeholder="Elvan Gıda">
                            </div>
                        </div>
                        <div class="field-grid">
                            <div class="form-field">
                                <label for="email">E-posta</label>
                                <input id="email" name="email" type="email" required maxlength="50" placeholder="mail@firma.com">
                            </div>
                            <div class="form-field">
                                <label for="phone">Telefon</label>
                                <input id="phone" name="phone" type="tel" maxlength="30" placeholder="05xx xxx xx xx">
                            </div>
                        </div>
                        <div class="form-field">
                            <label for="username">Kullanıcı adı</label>
                            <input id="username" name="username" type="text" required maxlength="50" placeholder="firma.admin">
                        </div>
                        <div class="field-grid">
                            <div class="form-field password-field">
                                <label for="password">Şifre</label>
                                <input id="password" name="password" type="password" required maxlength="50" placeholder="En az 6 karakter">
                                <button type="button" class="password-toggle" data-toggle-password="password" aria-label="Şifreyi göster" title="Şifreyi göster">
                                    <i class="ti-eye"></i>
                                </button>
                            </div>
                            <div class="form-field password-field">
                                <label for="passwordConfirm">Şifre tekrar</label>
                                <input id="passwordConfirm" name="passwordConfirm" type="password" required maxlength="50" placeholder="Tekrar yazın">
                                <button type="button" class="password-toggle" data-toggle-password="passwordConfirm" aria-label="Şifreyi göster" title="Şifreyi göster">
                                    <i class="ti-eye"></i>
                                </button>
                            </div>
                        </div>
                        <div class="captcha-box">
                            <div class="captcha-question">@captchaSoru</div>
                            <div class="form-field" style="margin-bottom:0">
                                <label for="registerCaptcha">Güvenlik cevabı</label>
                                <input id="registerCaptcha" name="guvenlikCevabi" type="number" required placeholder="Sonuç">
                            </div>
                        </div>
                        <button type="submit" class="submit-btn">
                            <i class="ti-check"></i>
                            Hesabı Oluştur
                        </button>
                        <div class="form-foot">
                            <span>Zaten hesabınız var mı?</span>
                            <button type="button" class="text-btn" data-open-panel="login">Girişe dön</button>
                        </div>
                    </form>

                    <form class="auth-form @(verifyActive ? "is-active" : "")" data-panel="verify" action="@Url.Action("KayitOnayla", "Home")" method="post" autocomplete="on">
                        @Html.AntiForgeryToken()
                        <h2 class="auth-title">E-posta kodunu onaylayın</h2>
                        <p class="auth-copy">Mail adresinize gelen 6 haneli kodu yazın; onaydan sonra çalışma alanınız açılacak.</p>

                        @if (ViewBag.RegisterSuccess != null)
                        {
                            <div class="alert-line success">@ViewBag.RegisterSuccess</div>
                        }
                        @if (ViewBag.VerifyError != null)
                        {
                            <div class="alert-line">@ViewBag.VerifyError</div>
                        }

                        <div class="form-field">
                            <label for="verifyEmail">E-posta</label>
                            <input id="verifyEmail" name="email" type="email" required maxlength="50" value="@verifyEmail" placeholder="mail@firma.com">
                        </div>
                        <div class="form-field">
                            <label for="onayKodu">Doğrulama kodu</label>
                            <input id="onayKodu" name="onayKodu" type="text" required maxlength="6" inputmode="numeric" placeholder="000000">
                        </div>
                        <div class="captcha-box">
                            <div class="captcha-question">@captchaSoru</div>
                            <div class="form-field" style="margin-bottom:0">
                                <label for="verifyCaptcha">Güvenlik cevabı</label>
                                <input id="verifyCaptcha" name="guvenlikCevabi" type="number" required placeholder="Sonuç">
                            </div>
                        </div>
                        <button type="submit" class="submit-btn">
                            <i class="ti-check"></i>
                            Hesabı Aktifleştir
                        </button>
                        <div class="form-foot">
                            <span>Kod gelmediyse spam klasörünü kontrol edin.</span>
                            <button type="button" class="text-btn" data-open-panel="login">Girişe dön</button>
                        </div>
                    </form>

                    <form class="auth-form @(participantActive ? "is-active" : "")" data-panel="participant" action="@Url.Action("KatilimKoduSorgula", "Home")" method="post" autocomplete="on">
                        @Html.AntiForgeryToken()
                        <h2 class="auth-title">Katılımınızı takip edin</h2>
                        <p class="auth-copy">Sınav, eğitim, anket ve sertifika durumunuzu görmek için size verilen katılım kodunu yazın.</p>

                        @if (ViewBag.KatilimSorguError != null)
                        {
                            <div class="alert-line">@ViewBag.KatilimSorguError</div>
                        }

                        <div class="form-field">
                            <label for="katilimKodu">Katılım kodu</label>
                            <input id="katilimKodu" name="katilimKodu" type="text" required maxlength="9" inputmode="numeric" placeholder="Örn. 317109290">
                        </div>
                        <button type="submit" class="submit-btn">
                            <i class="ti-search"></i>
                            Katılım Alanımı Aç
                        </button>
                        <div class="form-foot">
                            <span>Kod, katılım sayfanızın üst kısmında görünür.</span>
                            <button type="button" class="text-btn" data-open-panel="login">Girişe dön</button>
                        </div>
                    </form>

                    <div class="panel-footer">
                        <div class="mini-proof">
                            <i class="ti-shield"></i>
                            <span>Güvenli oturum</span>
                        </div>
                        <div class="mini-proof">
                            <i class="ti-layout"></i>
                            <span>Sade stüdyo akışı</span>
                        </div>
                        <div class="mini-proof">
                            <i class="ti-bar-chart"></i>
                            <span>Anlık raporlar</span>
                        </div>
                    </div>
                </aside>
            </section>
        </div>
    </main>

    <script type="text/javascript" src="~/files/bower_components/jquery/dist/jquery.min.js"></script>
    <script type="text/javascript" src="~/files/bower_components/popper.js/dist/umd/popper.min.js"></script>
    <script type="text/javascript" src="~/files/bower_components/bootstrap/dist/js/bootstrap.min.js"></script>
    <script>
        function setLoginAlert(message) {
            let alert = document.getElementById('loginAlert');
            if (!alert) {
                const authCopy = document.querySelector('[data-panel="login"] .auth-copy');
                alert = document.createElement('div');
                alert.className = 'alert-line';
                alert.id = 'loginAlert';
                if (authCopy) authCopy.insertAdjacentElement('afterend', alert);
            }

            alert.textContent = message;
            alert.style.display = '';
        }

        window.onLoginRecaptchaVerified = function () {
            const alert = document.getElementById('loginAlert');
            if (alert) alert.style.display = 'none';
        };

        window.onLoginRecaptchaExpired = function () {
            setLoginAlert('reCAPTCHA süresi doldu. Lütfen kutuyu tekrar işaretleyin.');
        };

        (function () {
            const root = document.querySelector('.studio-entry');
            const tabButtons = Array.from(document.querySelectorAll('[data-panel-tab]'));
            const forms = Array.from(document.querySelectorAll('[data-panel]'));
            const accessPanel = document.getElementById('accessPanel');

            function setPanel(name) {
                tabButtons.forEach(button => button.classList.toggle('is-active', button.dataset.panelTab === name));
                forms.forEach(form => form.classList.toggle('is-active', form.dataset.panel === name));
                root.dataset.activePanel = name;

                if (accessPanel && window.matchMedia('(max-width: 1080px)').matches) {
                    accessPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            }

            document.querySelectorAll('[data-open-panel]').forEach(button => {
                button.addEventListener('click', () => setPanel(button.dataset.openPanel));
            });

            tabButtons.forEach(button => {
                button.addEventListener('click', () => setPanel(button.dataset.panelTab));
            });

            const loginForm = document.querySelector('[data-panel="login"]');
            if (loginForm) {
                loginForm.addEventListener('submit', event => {
                    const recaptchaBox = loginForm.querySelector('.g-recaptcha');
                    if (!recaptchaBox || !window.grecaptcha) return;

                    if (!window.grecaptcha.getResponse()) {
                        event.preventDefault();
                        setLoginAlert('Ben robot değilim kutusunu işaretleyin.');
                    }
                });
            }

            document.querySelectorAll('[data-toggle-password]').forEach(button => {
                button.addEventListener('click', () => {
                    const input = document.getElementById(button.dataset.togglePassword);
                    if (!input) return;

                    const show = input.type === 'password';
                    input.type = show ? 'text' : 'password';
                    button.classList.toggle('is-visible', show);
                    button.setAttribute('aria-label', show ? 'Şifreyi gizle' : 'Şifreyi göster');
                    button.setAttribute('title', show ? 'Şifreyi gizle' : 'Şifreyi göster');
                });
            });
        })();
    </script>
</body>
</html>
