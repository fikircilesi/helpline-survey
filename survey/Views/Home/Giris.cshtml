                        </div>
                    </form>

                    <form class="auth-form @(participantActive ? "is-active" : "")" data-panel="participant" action="@Url.Action("KatilimKoduSorgula", "Home")" method="post" autocomplete="on">
                        @Html.AntiForgeryToken()
                        <h2 class="auth-title">Katılımınızı takip edin</h2>
                        <p class="auth-copy">Sınav, eğitim, anket ve sertifika durumunuzu görmek için size verilen katılım kodunu yazın.</p>

                        @if (ViewBag.KatilimSorguError != null)
                        {
                            <div class="alert-line">@ViewBag.KatilimSorguError</div>
                        }

                        <div class="form-field">
                            <label for="katilimKodu">Katılım kodu</label>
                            <input id="katilimKodu" name="katilimKodu" type="text" required maxlength="9" inputmode="numeric" placeholder="Örn. 317109290">
                        </div>
                        <button type="submit" class="submit-btn">
                            <i class="ti-search"></i>
                            Katılım Alanımı Aç
                        </button>
                        <div class="form-foot">
                            <span>Kod, katılım sayfanızın üst kısmında görünür.</span>
                            <button type="button" class="text-btn" data-open-panel="login">Girişe dön</button>
                        </div>
                    </form>

                    <div class="panel-footer">
                        <div class="mini-proof">
                            <i class="ti-shield"></i>
                            <span>KVKK ve gizlilik</span>
                        </div>
                        <div class="mini-proof">
                            <i class="ti-credit-card"></i>
                            <span>Tami ödeme altyapısı</span>
                        </div>
                        <div class="mini-proof">
                            <i class="ti-briefcase"></i>
                            <span>Ltd. şirket güvencesi</span>
                        </div>
                    </div>
                </aside>
                    <section class="side-product-tour" aria-label="Survey ürün turu">
                        <div class="side-product-head">
                            <div>
                                <strong>Kullanıcı sayısı büyüdükçe sistem sizinle birlikte büyür.</strong>
                                <span>Ücretsiz başlayın; rapor, ekip, dışa aktarım ve marka kontrolü gerektiğinde paketinizi yükseltin.</span>
                            </div>
                            <i class="ti-stats-up"></i>
                        </div>
                        <div class="side-shot-stack" aria-label="Survey rapor ekranları">
                            <div class="side-shot">
                                <div class="side-shot-title"><span>Departman analizi</span><i class="ti-bar-chart"></i></div>
                                <div class="side-shot-grid"><span></span><span></span><span></span></div>
                                <div class="side-shot-bars"><span style="--w:86%"></span><span style="--w:62%"></span></div>
                            </div>
                            <div class="side-shot">
                                <div class="side-shot-title"><span>Soru bazlı sonuç</span><i class="ti-check-box"></i></div>
                                <div class="side-shot-grid"><span></span><span></span><span></span></div>
                                <div class="side-shot-bars"><span style="--w:74%"></span><span style="--w:91%"></span></div>
                            </div>
                            <div class="side-shot">
                                <div class="side-shot-title"><span>Konu grubu başarısı</span><i class="ti-layers"></i></div>
                                <div class="side-shot-grid"><span></span><span></span><span></span></div>
                                <div class="side-shot-bars"><span style="--w:69%"></span><span style="--w:82%"></span></div>
                            </div>
                        </div>
                        <div class="tour-step-list">
                            <div class="tour-step">
                                <i class="ti-pencil-alt"></i>
                                <span><strong>Soru bankası kurulur</strong><span>Excel, Word veya AI destekli içerikle hızlı başlangıç yapılır.</span></span>
                            </div>
                            <div class="tour-step">
                                <i class="ti-world"></i>
                                <span><strong>Katılım linki paylaşılır</strong><span>Kodlu giriş, hedef kitle ve süre kuralları tek yerden yönetilir.</span></span>
                            </div>
                            <div class="tour-step">
                                <i class="ti-cup"></i>
                                <span><strong>Başarı belgelenir</strong><span>Puan ve tamamlama koşuluna göre sertifika akışı hazırlanır.</span></span>
                            </div>
                            <div class="tour-step">
                                <i class="ti-bar-chart"></i>
                                <span><strong>Yönetim rapor alır</strong><span>Departman, soru, grup ve kişi bazında karar verilecek veri oluşur.</span></span>
                            </div>
                        </div>
                    </section>
                </div>
            </section>
        </div>
    </main>

    <div class="assistant-widget is-collapsed" id="surveyAssistant" aria-live="polite">
        <div class="assistant-card">
            <div class="assistant-head">
                <span class="assistant-avatar"><i class="ti-headphone-alt"></i></span>
                        <span class="assistant-title">
                            <strong>Aslana ekibine yazın</strong>
                    <span>Mesajınız info@aslana.com.tr adresine iletilir; yanıt için e-posta adresinizi rica ederiz.</span>
                        </span>
                <button type="button" class="assistant-close" data-assistant-close aria-label="Mesaj kutusunu küçült" title="Mesaj kutusunu küçült">
                    <i class="ti-close"></i>
                </button>
            </div>
            <div class="assistant-body">
                <form class="assistant-contact-form" data-contact-form action="@Url.Action("IletisimMesajiGonder", "Home")" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="konusmaId" data-contact-conversation value="">
                    <div class="assistant-thread" data-contact-thread>
                        <p class="assistant-message">
                            Buraya yazdığınız mesaj doğrudan Aslana ekibine düşer. O anda yazışamazsak yanıtımız size e-posta ile ulaşsın diye adresinizi rica ediyoruz.
                        </p>
                    </div>
                    <div class="assistant-field">
                        <label for="contactName">Ad soyad</label>
                        <input id="contactName" name="adSoyad" type="text" maxlength="80" autocomplete="name" placeholder="Adınız">
                    </div>
                    <div class="assistant-field">
                        <label for="contactEmail">E-posta (yanıt için gerekli)</label>
                        <input id="contactEmail" name="email" type="email" required maxlength="120" autocomplete="email" placeholder="Size dönüş yapacağımız e-posta">
                    </div>
                    <div class="assistant-field">
                        <label for="contactMessage">Mesajınız</label>
                        <textarea id="contactMessage" name="mesaj" required maxlength="1500" placeholder="Nasıl yardımcı olalım?"></textarea>
                    </div>
                    <button type="submit" class="assistant-submit">
                        <i class="ti-email"></i>
                        Mesajı Gönder
                    </button>
                    <p class="assistant-note">Canlı yanıt veremezsek dönüş bu e-posta adresine gelir.</p>
                    <div class="assistant-status" data-contact-status aria-live="polite"></div>
                </form>
            </div>
        </div>
        <button type="button" class="assistant-launcher" data-assistant-open aria-label="Aslana ekibine mesaj yaz">
            <i class="ti-headphone-alt"></i>
            Aslana ekibine yazın
        </button>
    </div>

    <script type="text/javascript" src="~/files/bower_components/jquery/dist/jquery.min.js"></script>
    <script type="text/javascript" src="~/files/bower_components/popper.js/dist/umd/popper.min.js"></script>
    <script type="text/javascript" src="~/files/bower_components/bootstrap/dist/js/bootstrap.min.js"></script>
    <script>
        function setLoginAlert(message) {
            let alert = document.getElementById('loginAlert');
            if (!alert) {
                const authCopy = document.querySelector('[data-panel="login"] .auth-copy');
                alert = document.createElement('div');
                alert.className = 'alert-line';
                alert.id = 'loginAlert';
                if (authCopy) authCopy.insertAdjacentElement('afterend', alert);
            }

            alert.textContent = message;
            alert.style.display = '';
        }

        function setLoginSubmitState(enabled) {
            const submitButton = document.querySelector('[data-panel="login"] .submit-btn');
            if (submitButton && document.getElementById('loginRecaptcha')) {
                submitButton.disabled = !enabled;
            }
        }

        let loginRecaptchaWidgetId = null;

        window.onLoginRecaptchaReady = function () {
            if (!window.grecaptcha || loginRecaptchaWidgetId !== null) return;

            const recaptcha = document.getElementById('loginRecaptcha');
            if (!recaptcha) return;

            setLoginSubmitState(false);
            loginRecaptchaWidgetId = window.grecaptcha.render(recaptcha, {
                sitekey: recaptcha.dataset.sitekey,
                callback: window.onLoginRecaptchaVerified,
                'expired-callback': window.onLoginRecaptchaExpired,
                'error-callback': window.onLoginRecaptchaError
            });
        };

        window.onLoginRecaptchaVerified = function () {
            const alert = document.getElementById('loginAlert');
            if (alert) alert.style.display = 'none';
            setLoginSubmitState(true);
        };

        window.onLoginRecaptchaExpired = function () {
            setLoginSubmitState(false);
            setLoginAlert('reCAPTCHA süresi doldu. Lütfen kutuyu tekrar işaretleyin.');
        };

        window.onLoginRecaptchaError = function () {
            setLoginSubmitState(false);
            setLoginAlert('reCAPTCHA yüklenemedi. Sayfayı yenileyip tekrar deneyin.');
        };

        (function () {
            const root = document.querySelector('.studio-entry');
            const tabButtons = Array.from(document.querySelectorAll('[data-panel-tab]'));
            const forms = Array.from(document.querySelectorAll('[data-panel]'));
            const accessPanel = document.getElementById('accessPanel');

            function setPanel(name) {
                tabButtons.forEach(button => button.classList.toggle('is-active', button.dataset.panelTab === name));
                forms.forEach(form => form.classList.toggle('is-active', form.dataset.panel === name));
                root.dataset.activePanel = name;

                if (accessPanel && window.matchMedia('(max-width: 1080px)').matches) {
                    accessPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            }

            document.querySelectorAll('[data-open-panel]').forEach(button => {
                button.addEventListener('click', () => setPanel(button.dataset.openPanel));
            });

            document.querySelectorAll('[data-assistant-panel]').forEach(button => {
                button.addEventListener('click', () => setPanel(button.dataset.assistantPanel));
            });

            tabButtons.forEach(button => {
                button.addEventListener('click', () => setPanel(button.dataset.panelTab));
            });

            const assistant = document.getElementById('surveyAssistant');
            const assistantClose = document.querySelector('[data-assistant-close]');
            const assistantOpen = document.querySelector('[data-assistant-open]');

            if (assistant && assistantClose && assistantOpen) {
                assistantClose.addEventListener('click', () => assistant.classList.add('is-collapsed'));
                assistantOpen.addEventListener('click', () => assistant.classList.remove('is-collapsed'));
            }

            const contactForm = document.querySelector('[data-contact-form]');
            const contactThread = document.querySelector('[data-contact-thread]');
            const contactStatus = document.querySelector('[data-contact-status]');
            const contactConversationInput = document.querySelector('[data-contact-conversation]');
            const contactPollUrl = '@Url.Action("IletisimMesajlariniGetir", "Home")';
            const contactStorageKey = 'survey.aslana.contactConversation';
            let contactConversationId = '';
            let lastContactMessageId = 0;
            let contactPollTimer = null;
            let contactPollErrorShown = false;

            function contactTimeLabel() {
                return new Date().toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit' });
            }

            function flashContactStatus(message) {
                if (!contactStatus) return;

                contactStatus.textContent = message || '';
                if (!message) return;

                window.setTimeout(() => {
                    if (contactStatus.textContent === message) {
                        contactStatus.textContent = '';
                    }
                }, 1500);
            }

            function addContactBubble(message, type) {
                if (!contactThread || !message) return;

                const bubble = document.createElement('p');
                bubble.className = 'assistant-message' + (type ? ' ' + type : '');

                const body = document.createElement('span');
                body.textContent = message;
                bubble.appendChild(body);

                if (type === 'is-user' || type === 'is-admin') {
                    const time = document.createElement('small');
                    time.textContent = contactTimeLabel();
                    bubble.appendChild(time);
                }

                contactThread.appendChild(bubble);
                contactThread.scrollTop = contactThread.scrollHeight;
            }

            function saveContactState() {
                if (!contactConversationId) return;

                try {
                    const emailInput = contactForm ? contactForm.querySelector('[name="email"]') : null;
                    const nameInput = contactForm ? contactForm.querySelector('[name="adSoyad"]') : null;
                    window.localStorage.setItem(contactStorageKey, JSON.stringify({
                        conversationId: contactConversationId,
                        email: emailInput ? emailInput.value.trim() : '',
                        name: nameInput ? nameInput.value.trim() : '',
                        savedAt: Date.now()
                    }));
                } catch (error) {
                }
            }

            function restoreContactState() {
                try {
                    const raw = window.localStorage.getItem(contactStorageKey);
                    if (!raw) return;

                    const saved = JSON.parse(raw);
                    if (!saved || !saved.conversationId) return;

                    contactConversationId = saved.conversationId;
                    lastContactMessageId = 0;
                    if (contactConversationInput) contactConversationInput.value = contactConversationId;

                    const emailInput = contactForm ? contactForm.querySelector('[name="email"]') : null;
                    const nameInput = contactForm ? contactForm.querySelector('[name="adSoyad"]') : null;
                    if (emailInput && saved.email && !emailInput.value) emailInput.value = saved.email;
                    if (nameInput && saved.name && !nameInput.value) nameInput.value = saved.name;
                } catch (error) {
                }
            }

            function startContactPolling() {
                if (!contactConversationId || contactPollTimer) return;

                contactPollTimer = window.setInterval(loadContactReplies, 3500);
                loadContactReplies();
            }

            async function loadContactReplies() {
                if (!contactConversationId) return;

                try {
                    const url = `${contactPollUrl}?konusmaId=${encodeURIComponent(contactConversationId)}&sonMesajId=${lastContactMessageId}`;
                    const response = await fetch(url, {
                        credentials: 'same-origin',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });
                    const result = await response.json();
                    if (!result.success || !Array.isArray(result.messages)) {
                        if (!contactPollErrorShown && result.message) {
                            contactPollErrorShown = true;
                            addContactBubble(result.message, 'is-system');
                        }
                        return;
                    }

                    contactPollErrorShown = false;
                    result.messages.forEach(item => {
                        lastContactMessageId = Math.max(lastContactMessageId, item.id || 0);
                        if (item.kimden === 'yonetici') {
                            addContactBubble(item.mesaj, 'is-admin');
                        } else if (item.kimden === 'ziyaretci') {
                            addContactBubble(item.mesaj, 'is-user');
                        }
                    });
                    saveContactState();
                } catch (error) {
                }
            }

            if (contactForm) {
                const contactEmailInput = contactForm.querySelector('[name="email"]');
                const contactNameInput = contactForm.querySelector('[name="adSoyad"]');
                restoreContactState();
                if (contactConversationId) {
                    startContactPolling();
                }

                if (contactEmailInput) {
                    contactEmailInput.addEventListener('invalid', () => {
                        contactEmailInput.setCustomValidity('Size dönüş yapabilmemiz için e-posta adresinizi rica ediyoruz.');
                        addContactBubble('Size dönüş yapabilmemiz için e-posta adresinizi rica ediyoruz.', 'is-system');
                    });
                    contactEmailInput.addEventListener('input', () => {
                        contactEmailInput.setCustomValidity('');
                        saveContactState();
                    });
                }

                if (contactNameInput) {
                    contactNameInput.addEventListener('input', saveContactState);
                }

                contactForm.addEventListener('submit', async event => {
                    event.preventDefault();

                    const submitButton = contactForm.querySelector('.assistant-submit');
                    const emailInput = contactForm.querySelector('[name="email"]');
                    const messageInput = contactForm.querySelector('[name="mesaj"]');
                    const email = emailInput ? emailInput.value.trim() : '';
                    const message = messageInput ? messageInput.value.trim() : '';

                    if (!email) {
                        addContactBubble('Size dönüş yapabilmemiz için e-posta adresinizi rica ediyoruz.', 'is-system');
                        if (emailInput) emailInput.focus();
                        return;
                    }

                    if (!message) {
                        addContactBubble('Lütfen kısa da olsa mesajınızı yazın.', 'is-system');
                        return;
                    }

                    addContactBubble(message, 'is-user');
                    if (contactStatus) contactStatus.textContent = 'Mesaj gönderiliyor...';
                    if (submitButton) submitButton.disabled = true;
                    let statusHandled = false;

                    try {
                        const response = await fetch(contactForm.action, {
                            method: 'POST',
                            body: new FormData(contactForm),
                            credentials: 'same-origin',
                            headers: { 'X-Requested-With': 'XMLHttpRequest' }
                        });

                        const result = await response.json();
                        if (!result.success) {
                            addContactBubble(result.message || 'Mesaj durumunu alamadık.', 'is-system');
                        } else {
                            flashContactStatus('Gönderildi');
                            statusHandled = true;
                        }

                        if (result.conversationId) {
                            contactConversationId = result.conversationId;
                            if (contactConversationInput) contactConversationInput.value = result.conversationId;
                            saveContactState();
                        }
                        if (result.messageId) {
                            lastContactMessageId = Math.max(lastContactMessageId, result.messageId);
                        }
                        if (result.success) {
                            startContactPolling();
                        }
                        if (result.success && messageInput) {
                            messageInput.value = '';
                        }
                    } catch (error) {
                        addContactBubble('Mesaj şu anda gönderilemedi. info@aslana.com.tr adresine doğrudan yazabilirsiniz.', 'is-system');
                    } finally {
                        if (!statusHandled && contactStatus) contactStatus.textContent = '';
                        if (submitButton) submitButton.disabled = false;
                    }
                });
            }

            const loginForm = document.querySelector('[data-panel="login"]');
            if (loginForm) {
                if (loginForm.querySelector('.g-recaptcha')) {
                    setLoginSubmitState(false);
                }

                loginForm.addEventListener('submit', event => {
                    const recaptchaBox = loginForm.querySelector('.g-recaptcha');
                    if (!recaptchaBox) return;

                    if (!window.grecaptcha || loginRecaptchaWidgetId === null) {
                        event.preventDefault();
                        setLoginAlert('reCAPTCHA henüz hazır değil. Sayfayı yenileyip tekrar deneyin.');
                        return;
                    }

                    if (!window.grecaptcha.getResponse(loginRecaptchaWidgetId)) {
                        event.preventDefault();
                        setLoginAlert('Ben robot değilim kutusunu işaretleyin.');
                    }
                });
            }

            document.querySelectorAll('[data-toggle-password]').forEach(button => {
                button.addEventListener('click', () => {
                    const input = document.getElementById(button.dataset.togglePassword);
                    if (!input) return;

                    const show = input.type === 'password';
                    input.type = show ? 'text' : 'password';
                    button.classList.toggle('is-visible', show);
                    button.setAttribute('aria-label', show ? 'Şifreyi gizle' : 'Şifreyi göster');
                    button.setAttribute('title', show ? 'Şifreyi gizle' : 'Şifreyi göster');
                });
            });
        })();
    </script>
</body>
</html>
