@model survey.Models.Personel
@{
    ViewBag.Title = "Survey by Aslana Teknoloji";
    Layout = null;

    var activePanel = (ViewBag.ActiveAuthPanel as string) ?? "login";
    var registerActive = string.Equals(activePanel, "register", StringComparison.OrdinalIgnoreCase);
    var verifyActive = string.Equals(activePanel, "verify", StringComparison.OrdinalIgnoreCase);
    var participantActive = string.Equals(activePanel, "participant", StringComparison.OrdinalIgnoreCase);
    var loginActive = !registerActive && !verifyActive && !participantActive;
    var captchaSoru = (ViewBag.CaptchaSoru as string) ?? "?";
    var verifyEmail = (ViewBag.VerifyEmail as string) ?? string.Empty;
    var recaptchaAktif = ViewBag.RecaptchaAktif is bool recaptchaValue && recaptchaValue;
    var captchaAtlandi = ViewBag.CaptchaAtlandi is bool captchaAtlandiValue && captchaAtlandiValue;
    var recaptchaSiteKey = (ViewBag.RecaptchaSiteKey as string) ?? string.Empty;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <title>Survey by Aslana Teknoloji | Sınav, Anket ve Sertifika Platformu</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=0, minimal-ui">
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="description" content="Sınav, anket, eğitim ve sertifika yayınlama platformu">
    <link rel="icon" href="~/Content/img/aslana-favicon.png" type="image/png">
    <link rel="stylesheet" type="text/css" href="~/files/bower_components/bootstrap/dist/css/bootstrap.min.css">
    <link rel="stylesheet" type="text/css" href="~/files/assets/icon/themify-icons/themify-icons.css">
    <link rel="stylesheet" type="text/css" href="~/files/assets/icon/icofont/css/icofont.css">
    <style>
        :root {
            --ink: #152033;
            --muted: #667085;
            --soft: #f4f8ff;
            --line: #dce6f2;
            --panel: #ffffff;
            --teal: #15b8a6;
            --cyan: #28c7d9;
            --indigo: #4257e8;
            --violet: #7c3aed;
            --amber: #ffb84d;
            --coral: #ff6b5d;
            --rose: #ff4f8b;
            --green: #22c55e;
            --navy: #10192c;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            color: var(--ink);
            font-family: "Segoe UI", Arial, sans-serif;
            background: #f6faff;
        }

        a,
        a:hover {
            text-decoration: none;
        }

        .studio-entry {
            position: relative;
            min-height: 100vh;
            overflow: hidden;
            background:
                linear-gradient(132deg, rgba(21, 184, 166, .22) 0 17%, transparent 17% 100%),
                linear-gradient(151deg, transparent 0 48%, rgba(66, 87, 232, .11) 48% 70%, rgba(255, 184, 77, .18) 70% 100%),
                linear-gradient(22deg, transparent 0 62%, rgba(255, 79, 139, .12) 62% 100%),
                repeating-linear-gradient(90deg, rgba(16, 25, 44, .04) 0 1px, transparent 1px 76px),
                repeating-linear-gradient(0deg, rgba(16, 25, 44, .035) 0 1px, transparent 1px 76px),
                linear-gradient(180deg, #ffffff 0%, #f7fbff 46%, #eef7ff 100%);
        }

        .studio-entry::before {
            content: "";
            position: absolute;
            inset: auto 0 0;
            height: 12px;
            background: linear-gradient(90deg, var(--teal), var(--cyan), var(--indigo), var(--violet), var(--rose), var(--amber));
        }

        .studio-entry::after {
            content: "";
            position: absolute;
            top: 86px;
            right: -16%;
            width: 72%;
            height: 78%;
            clip-path: polygon(20% 0, 100% 13%, 84% 100%, 0 78%);
            background:
                linear-gradient(135deg, rgba(40, 199, 217, .16), rgba(124, 58, 237, .10) 42%, rgba(255, 184, 77, .16)),
                repeating-linear-gradient(90deg, rgba(66, 87, 232, .06) 0 1px, transparent 1px 58px);
            pointer-events: none;
        }

        .entry-shell {
            position: relative;
            z-index: 1;
            width: min(1180px, calc(100% - 36px));
            min-height: 100vh;
            margin: 0 auto;
            display: grid;
            grid-template-rows: auto 1fr;
            gap: 28px;
            padding: 24px 0 42px;
        }

        .entry-shell::before {
            content: "";
            position: absolute;
            top: 84px;
            left: -96px;
            width: 390px;
            height: 300px;
            clip-path: polygon(0 14%, 88% 0, 100% 64%, 23% 100%);
            background: linear-gradient(135deg, rgba(125, 244, 199, .38), rgba(56, 189, 248, .18), rgba(255, 107, 93, .10));
            filter: blur(1px);
            pointer-events: none;
            z-index: -1;
        }

        .entry-nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 18px;
        }

        .brand-lockup {
            display: inline-flex;
            align-items: center;
            gap: 14px;
            min-width: 0;
            padding: 10px 18px 10px 14px;
            color: #fff;
            border: 1px solid rgba(255, 255, 255, .16);
            border-radius: 18px;
            background:
                linear-gradient(135deg, rgba(255, 255, 255, .12), transparent 38%),
                linear-gradient(135deg, #121a2b 0%, #26384f 54%, #24325f 100%);
            box-shadow: 0 18px 42px rgba(21, 32, 51, .22), inset 0 0 0 1px rgba(125, 244, 199, .08);
            transition: transform .16s ease, box-shadow .16s ease, border-color .16s ease;
        }

        .brand-lockup:hover {
            color: #fff;
            border-color: rgba(125, 244, 199, .38);
            box-shadow: 0 22px 50px rgba(21, 32, 51, .24);
            transform: translateY(-1px);
        }

        .brand-mark {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex: 0 0 72px;
            width: 72px;
            height: 54px;
        }

        .brand-logo-sketch {
            display: block;
            width: 72px;
            height: 54px;
            overflow: visible;
            filter: drop-shadow(0 10px 18px rgba(0, 0, 0, .2));
        }

        .brand-logo-sketch path,
        .brand-logo-sketch line,
        .brand-logo-sketch rect {
            fill: none;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .brand-logo-sketch .survey-sheet,
        .brand-logo-sketch .survey-fold {
            stroke: rgba(255, 255, 255, .94);
            stroke-width: 3.2;
        }

        .brand-logo-sketch .survey-form-line {
            stroke: rgba(255, 255, 255, .82);
            stroke-width: 2.5;
        }

        .brand-logo-sketch .survey-box.mint {
            stroke: #7df4c7;
        }

        .brand-logo-sketch .survey-box.blue {
            stroke: #38bdf8;
        }

        .brand-logo-sketch .survey-box.coral {
            stroke: #fb7185;
        }

        .brand-logo-sketch .survey-check-shadow {
            stroke: rgba(251, 113, 133, .26);
            stroke-width: 7;
        }

        .brand-logo-sketch .survey-check {
            stroke: url(#entrySurveyCheckGradient);
            stroke-width: 4.5;
        }

        .brand-copy {
            min-width: 0;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            justify-content: center;
            line-height: 1;
            text-align: left;
        }

        .brand-copy strong {
            display: block;
            margin: 0;
            color: #fff;
            font-size: 36px;
            font-weight: 850;
            letter-spacing: 0;
            text-transform: lowercase;
            white-space: nowrap;
        }

        .brand-copy span {
            display: block;
            margin: 3px 0 0;
            color: rgba(255, 255, 255, .76);
            font-size: 15px;
            font-weight: 600;
            letter-spacing: 0;
            white-space: nowrap;
        }

        .brand-lockup img {
            width: 226px;
            max-width: 64vw;
            height: auto;
            display: block;
        }

        .nav-actions {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 10px;
            flex-wrap: wrap;
        }

        .nav-link-btn,
        .primary-top,
        .text-btn,
        .submit-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            border-radius: 8px;
            font-weight: 800;
            transition: transform .16s ease, box-shadow .16s ease, background .16s ease, border-color .16s ease;
        }

        .nav-link-btn {
            min-height: 42px;
            padding: 0 15px;
            color: #1f2d44;
            border: 1px solid rgba(151, 167, 195, .42);
            background: rgba(255, 255, 255, .82);
            box-shadow: 0 12px 26px rgba(49, 73, 118, .08);
        }

        .nav-link-btn:hover {
            color: #142033;
            border-color: rgba(66, 87, 232, .36);
            background: #fff;
            transform: translateY(-1px);
        }

        .primary-top {
            min-height: 42px;
            padding: 0 16px;
            border: 0;
            color: #fff;
            background: linear-gradient(135deg, var(--navy), #2d3be8 58%, #16b8a6);
            box-shadow: 0 14px 30px rgba(66, 87, 232, .24);
            cursor: pointer;
        }

        .primary-top:hover {
            transform: translateY(-1px);
            box-shadow: 0 16px 32px rgba(21, 32, 51, .22);
        }

        .entry-main {
            display: grid;
            grid-template-columns: minmax(0, 1fr) 430px;
            align-items: start;
            gap: 44px;
        }

        .story-panel {
            min-width: 0;
        }

        .eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 9px;
            margin-bottom: 18px;
            padding: 8px 12px;
            color: #0c4a45;
            border: 1px solid rgba(21, 184, 166, .34);
            border-radius: 999px;
            background: linear-gradient(90deg, rgba(21, 184, 166, .14), rgba(56, 189, 248, .12), rgba(255, 184, 77, .13));
            font-size: 13px;
            font-weight: 800;
            box-shadow: 0 12px 28px rgba(21, 184, 166, .10);
        }

        .eyebrow i {
            color: var(--teal);
        }

        .hero-title {
            max-width: 720px;
            margin: 0;
            color: #121b2d;
            font-size: 52px;
            line-height: 1.04;
            font-weight: 900;
            letter-spacing: 0;
        }

        .hero-title span {
            color: transparent;
            background: linear-gradient(90deg, var(--indigo), var(--violet), var(--teal), var(--coral));
            -webkit-background-clip: text;
            background-clip: text;
        }

        .hero-text {
            max-width: 620px;
            margin: 18px 0 0;
            color: #536174;
            font-size: 17px;
            line-height: 1.72;
            font-weight: 500;
        }

        .trust-ribbon {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 10px;
            max-width: 760px;
            margin-top: 22px;
        }

        .trust-item {
            display: grid;
            grid-template-columns: 38px 1fr;
            gap: 10px;
            min-height: 88px;
            padding: 13px;
            border: 1px solid rgba(132, 151, 176, .28);
            border-radius: 8px;
            background:
                linear-gradient(135deg, rgba(255, 255, 255, .88), rgba(255, 255, 255, .68)),
                linear-gradient(135deg, rgba(21, 184, 166, .12), rgba(66, 87, 232, .10));
            box-shadow: 0 16px 36px rgba(49, 73, 118, .10);
        }

        .trust-item:nth-child(2) {
            background:
                linear-gradient(135deg, rgba(255, 255, 255, .88), rgba(255, 255, 255, .68)),
                linear-gradient(135deg, rgba(124, 58, 237, .12), rgba(255, 184, 77, .13));
        }

        .trust-item:nth-child(3) {
            background:
                linear-gradient(135deg, rgba(255, 255, 255, .88), rgba(255, 255, 255, .68)),
                linear-gradient(135deg, rgba(255, 107, 93, .12), rgba(21, 184, 166, .12));
        }

        .trust-mark {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 38px;
            height: 38px;
            border-radius: 8px;
            color: #fff;
            background: linear-gradient(135deg, var(--teal), var(--cyan));
            box-shadow: 0 12px 24px rgba(21, 184, 166, .22);
        }

        .trust-item:nth-child(2) .trust-mark {
            background: linear-gradient(135deg, #4c2f91, var(--violet));
            box-shadow: 0 12px 24px rgba(124, 58, 237, .22);
        }

        .trust-item:nth-child(3) .trust-mark {
            background: linear-gradient(135deg, var(--coral), var(--amber));
            box-shadow: 0 12px 24px rgba(255, 107, 93, .20);
        }

        .trust-copy strong {
            display: block;
            color: #142033;
            font-size: 13px;
            font-weight: 900;
        }

        .trust-copy span {
            display: block;
            margin-top: 4px;
            color: #637288;
            font-size: 12px;
            line-height: 1.42;
        }

        .company-proof {
            display: grid;
            grid-template-columns: minmax(0, .95fr) minmax(0, 1.35fr);
            gap: 12px;
            max-width: 760px;
            margin-top: 14px;
            padding: 14px;
            border: 1px solid rgba(132, 151, 176, .30);
            border-radius: 8px;
            background:
                linear-gradient(135deg, rgba(255, 255, 255, .94), rgba(255, 255, 255, .72)),
                linear-gradient(135deg, rgba(21, 184, 166, .18), rgba(66, 87, 232, .12), rgba(255, 184, 77, .16));
            box-shadow: 0 18px 44px rgba(49, 73, 118, .12);
        }

        .company-proof-main {
            display: grid;
            gap: 8px;
            align-content: start;
            min-width: 0;
        }

        .company-proof-label {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            width: max-content;
            max-width: 100%;
            min-height: 28px;
            padding: 0 10px;
            border-radius: 999px;
            color: #0f766e;
            background: rgba(21, 184, 166, .12);
            font-size: 10px;
            font-weight: 900;
            text-transform: uppercase;
        }

        .company-proof-main strong {
            color: #172033;
            font-size: 17px;
            font-weight: 900;
            line-height: 1.2;
        }

        .company-proof-main p {
            margin: 0;
            color: #52637a;
            font-size: 12px;
            line-height: 1.48;
        }

        .company-proof-links {
            display: flex;
            flex-wrap: wrap;
            gap: 7px;
            margin-top: 2px;
        }

        .company-proof-links a {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            min-height: 28px;
            padding: 0 9px;
            border: 1px solid rgba(132, 151, 176, .30);
            border-radius: 999px;
            color: #26344c;
            background: rgba(255, 255, 255, .78);
            font-size: 10px;
            font-weight: 900;
            text-decoration: none;
            white-space: nowrap;
        }

        .company-proof-links a:hover {
            color: #0f172a;
            border-color: rgba(66, 87, 232, .34);
            box-shadow: 0 10px 20px rgba(66, 87, 232, .10);
        }

        .company-proof-details {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 8px;
            min-width: 0;
        }

        .company-detail {
            min-height: 58px;
            padding: 9px 10px;
            border: 1px solid rgba(132, 151, 176, .25);
            border-radius: 8px;
            background:
                linear-gradient(135deg, rgba(255, 255, 255, .90), rgba(246, 249, 255, .88));
        }

        .company-detail small {
            display: block;
            color: #65748a;
            font-size: 10px;
            font-weight: 900;
            letter-spacing: .02em;
            text-transform: uppercase;
        }

        .company-detail span {
            display: block;
            margin-top: 5px;
            color: #162137;
            font-size: 11px;
            font-weight: 850;
            line-height: 1.34;
            overflow-wrap: anywhere;
        }

        .legal-dock {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            max-width: 760px;
            margin-top: 14px;
        }

        .legal-chip {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            min-height: 30px;
            padding: 0 10px;
            border: 1px solid rgba(132, 151, 176, .28);
            border-radius: 999px;
            color: #314057;
            background: rgba(255, 255, 255, .78);
            box-shadow: 0 10px 24px rgba(49, 73, 118, .08);
            font-size: 11px;
            font-weight: 900;
            white-space: nowrap;
            text-decoration: none;
        }

        .legal-chip i {
            color: var(--teal);
        }

        .legal-chip:hover {
            color: #0f172a;
            border-color: rgba(66, 87, 232, .34);
            background: rgba(255, 255, 255, .94);
            box-shadow: 0 12px 28px rgba(49, 73, 118, .12);
        }

        .app-showcase {
            position: relative;
            max-width: 760px;
            margin-top: 18px;
            min-height: 374px;
            padding: 16px;
            border: 1px solid rgba(132, 151, 176, .26);
            border-radius: 8px;
            background:
                linear-gradient(135deg, rgba(255, 255, 255, .90), rgba(255, 255, 255, .62)),
                linear-gradient(118deg, rgba(21, 184, 166, .18), rgba(66, 87, 232, .11) 38%, rgba(255, 107, 93, .12) 66%, rgba(255, 184, 77, .18)),
                repeating-linear-gradient(90deg, rgba(66, 87, 232, .055) 0 1px, transparent 1px 48px);
            box-shadow: 0 20px 54px rgba(49, 73, 118, .12);
            overflow: hidden;
        }

        .showcase-track {
            display: flex;
            gap: 12px;
            width: max-content;
            animation: showcaseGlide 44s cubic-bezier(.77, 0, .18, 1) infinite;
            will-change: transform;
        }

        .showcase-head {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 16px;
            margin-bottom: 14px;
        }

        .showcase-kicker {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            min-height: 26px;
            padding: 0 10px;
            border-radius: 999px;
            color: #0f766e;
            background: rgba(21, 184, 166, .12);
            font-size: 10px;
            font-weight: 900;
            text-transform: uppercase;
        }

        .showcase-head strong {
            display: block;
            margin-top: 6px;
            color: #142033;
            font-size: 22px;
            line-height: 1.1;
            font-weight: 900;
        }

        .showcase-head span:not(.showcase-kicker) {
            display: block;
            margin-top: 5px;
            color: #607088;
            font-size: 12px;
            line-height: 1.45;
            font-weight: 750;
        }

        .showcase-count {
            display: grid;
            place-items: center;
            flex: 0 0 82px;
            min-height: 66px;
            border: 1px solid rgba(66, 87, 232, .22);
            border-radius: 8px;
            color: #4338ca;
            background: rgba(66, 87, 232, .08);
            text-align: center;
        }

        .showcase-count strong {
            margin: 0;
            color: #172033;
            font-size: 22px;
            line-height: 1;
        }

        .showcase-count span {
            margin: 4px 0 0;
            color: #64748b;
            font-size: 9px;
            font-weight: 900;
            text-transform: uppercase;
        }

        .app-showcase:hover .showcase-track {
            animation-play-state: paused;
        }

        .report-shot {
            position: relative;
            flex: 0 0 254px;
            min-height: 260px;
            border: 1px solid rgba(132, 151, 176, .30);
            border-radius: 8px;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, .98), rgba(247, 251, 255, .98));
            box-shadow: 0 16px 34px rgba(49, 73, 118, .12);
            overflow: hidden;
            transition: transform .22s ease, box-shadow .22s ease, border-color .22s ease;
        }

        .report-shot:hover {
            border-color: rgba(66, 87, 232, .42);
            box-shadow: 0 20px 48px rgba(49, 73, 118, .18);
            transform: translateY(-3px);
        }

        .report-badge {
            position: absolute;
            top: 12px;
            left: 12px;
            z-index: 1;
            min-height: 24px;
            padding: 0 9px;
            border-radius: 999px;
            color: #fff;
            background: linear-gradient(135deg, rgba(23, 32, 51, .92), rgba(66, 87, 232, .88));
            box-shadow: 0 12px 24px rgba(23, 32, 51, .16);
            font-size: 10px;
            font-weight: 900;
            line-height: 24px;
        }

        .report-visual {
            position: relative;
            min-height: 158px;
            padding: 42px 13px 13px;
            background:
                linear-gradient(135deg, rgba(240, 253, 250, .86), rgba(239, 246, 255, .78)),
                linear-gradient(120deg, rgba(21, 184, 166, .18), rgba(66, 87, 232, .12), rgba(255, 184, 77, .16));
            overflow: hidden;
        }

        .report-visual::after {
            position: absolute;
            right: -28px;
            bottom: -38px;
            width: 122px;
            height: 122px;
            border: 18px solid rgba(255, 255, 255, .46);
            border-radius: 50%;
            content: "";
        }

        .report-shot figcaption {
            display: grid;
            gap: 4px;
            min-height: 102px;
            padding: 13px 14px 14px;
            border-top: 1px solid rgba(132, 151, 176, .22);
            background:
                linear-gradient(135deg, rgba(255, 255, 255, .98), rgba(246, 249, 255, .98));
        }

        .report-shot figcaption strong {
            display: block;
            color: #172033;
            font-size: 14px;
            font-weight: 900;
            line-height: 1.16;
        }

        .report-shot figcaption span {
            color: #516178;
            font-size: 11px;
            font-weight: 750;
            line-height: 1.35;
        }

        .chart-shell {
            position: relative;
            z-index: 1;
            min-height: 102px;
            border: 1px solid rgba(132, 151, 176, .22);
            border-radius: 8px;
            background: rgba(255, 255, 255, .80);
            box-shadow: 0 14px 30px rgba(49, 73, 118, .12);
        }

        .metric-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 6px;
            padding: 10px;
        }

        .metric-grid span,
        .mini-metric {
            min-height: 42px;
            padding: 7px;
            border-radius: 8px;
            background: #fff;
            box-shadow: inset 0 0 0 1px rgba(132, 151, 176, .18);
        }

        .metric-grid b,
        .mini-metric b {
            display: block;
            color: #172033;
            font-size: 15px;
            line-height: 1;
        }

        .metric-grid em,
        .mini-metric em {
            display: block;
            margin-top: 4px;
            color: #667085;
            font-size: 8px;
            font-style: normal;
            font-weight: 850;
        }

        .bar-chart,
        .rank-chart,
        .question-chart {
            display: grid;
            gap: 7px;
            padding: 11px;
        }

        .bar-chart span,
        .rank-chart span,
        .question-chart span {
            display: block;
            width: var(--w, 70%);
            height: 9px;
            border-radius: 999px;
            background: linear-gradient(90deg, var(--c1, var(--teal)), var(--c2, var(--indigo)));
            box-shadow: 0 6px 12px rgba(49, 73, 118, .10);
