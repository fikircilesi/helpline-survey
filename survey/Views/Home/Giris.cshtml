        .rank-chart {
            padding-top: 14px;
        }

        .rank-chart span {
            height: 12px;
        }

        .stack-chart {
            display: grid;
            gap: 8px;
            padding: 12px;
        }

        .stack-row {
            display: grid;
            grid-template-columns: 42px 1fr 24px;
            align-items: center;
            gap: 7px;
            color: #344054;
            font-size: 8px;
            font-weight: 900;
        }

        .stack-row i {
            display: block;
            height: 8px;
            border-radius: 999px;
            background: #e8eef8;
            overflow: hidden;
        }

        .stack-row i::before {
            display: block;
            width: var(--w, 70%);
            height: 100%;
            border-radius: inherit;
            background: linear-gradient(90deg, var(--c1, var(--teal)), var(--c2, var(--amber)));
            content: "";
        }

        .donut-chart {
            display: grid;
            grid-template-columns: 88px 1fr;
            gap: 10px;
            align-items: center;
            padding: 11px;
        }

        .donut-ring {
            display: grid;
            place-items: center;
            width: 82px;
            height: 82px;
            border-radius: 50%;
            background:
                radial-gradient(circle, #fff 0 45%, transparent 46%),
                conic-gradient(var(--teal) 0 42%, var(--indigo) 42% 69%, var(--coral) 69% 86%, var(--amber) 86% 100%);
            box-shadow: 0 12px 22px rgba(49, 73, 118, .12);
