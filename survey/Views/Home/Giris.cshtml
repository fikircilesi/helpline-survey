            object-fit: cover;
            object-position: top left;
            box-shadow: 0 16px 34px rgba(49, 73, 118, .14);
        }

        .certificate-mockup,
        .report-mockup {
            min-height: 136px;
            border: 1px solid rgba(132, 151, 176, .28);
            border-radius: 8px;
            background: #fff;
            box-shadow: 0 16px 34px rgba(49, 73, 118, .14);
            overflow: hidden;
        }

        .certificate-mockup {
            padding: 10px;
            background:
                linear-gradient(135deg, #fffdf8, #f8fbff);
        }

        .certificate-border {
            position: relative;
            min-height: 116px;
            padding: 16px 18px 13px;
            border: 2px solid rgba(21, 184, 166, .64);
            background:
                linear-gradient(90deg, rgba(21, 184, 166, .18) 0 7px, transparent 7px calc(100% - 7px), rgba(21, 184, 166, .18) calc(100% - 7px)),
                linear-gradient(180deg, rgba(255, 255, 255, .96), rgba(255, 251, 241, .88));
            text-align: center;
        }

        .certificate-ribbon {
            position: absolute;
            top: -10px;
            left: 50%;
            transform: translateX(-50%);
            min-height: 20px;
            padding: 0 10px;
            border-radius: 999px;
            color: #fff;
            background: linear-gradient(135deg, var(--navy), var(--indigo));
            font-size: 9px;
            font-weight: 900;
            line-height: 20px;
            letter-spacing: 0;
        }

        .certificate-border strong {
            display: block;
            color: #172033;
            font-size: 16px;
            font-weight: 900;
            line-height: 1.1;
        }

        .certificate-border small {
            display: block;
            margin-top: 4px;
            color: #667085;
            font-size: 9px;
            font-weight: 850;
        }

        .certificate-name {
            display: inline-flex;
            justify-content: center;
            min-width: 142px;
            margin-top: 12px;
            padding-bottom: 4px;
            border-bottom: 1px solid rgba(23, 32, 51, .26);
            color: #172033;
            font-size: 12px;
            font-weight: 900;
        }

        .certificate-lines {
            display: grid;
            justify-content: center;
            gap: 4px;
            margin-top: 10px;
        }

        .certificate-lines span {
            display: block;
            width: 190px;
            height: 5px;
            border-radius: 999px;
            background: linear-gradient(90deg, rgba(66, 87, 232, .20), rgba(21, 184, 166, .22));
        }

        .certificate-lines span:nth-child(2) {
            width: 132px;
            justify-self: center;
        }

        .report-mockup {
            padding: 12px;
            background: linear-gradient(180deg, #ffffff, #f7fbff);
        }

        .report-toolbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 10px;
        }

        .report-toolbar strong {
            color: #172033;
            font-size: 11px;
            font-weight: 900;
        }

        .report-toolbar span {
            min-height: 20px;
            padding: 0 8px;
            border-radius: 999px;
            color: #0f766e;
            background: rgba(21, 184, 166, .12);
            font-size: 9px;
            font-weight: 900;
            line-height: 20px;
        }

        .report-kpis {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 7px;
        }

        .report-kpis div {
            min-height: 44px;
            padding: 8px;
            border: 1px solid rgba(132, 151, 176, .24);
            border-radius: 8px;
            background: #fff;
        }

        .report-kpis strong,
        .report-kpis span {
            display: block;
        }

        .report-kpis strong {
            color: #172033;
            font-size: 16px;
            line-height: 1;
            font-weight: 900;
        }

        .report-kpis span {
            margin-top: 4px;
            color: #667085;
            font-size: 8px;
            font-weight: 850;
        }

        .report-chart {
            display: grid;
            gap: 7px;
            margin-top: 12px;
        }

        .report-chart span {
            display: block;
            height: 8px;
            width: var(--w, 70%);
            border-radius: 999px;
            background: linear-gradient(90deg, var(--teal), var(--indigo), var(--amber));
        }

        .report-chart span:nth-child(2) {
            background: linear-gradient(90deg, var(--indigo), var(--violet), var(--rose));
        }

        .report-chart span:nth-child(3) {
            background: linear-gradient(90deg, var(--coral), var(--amber), var(--teal));
        }

        .side-column {
            display: grid;
            gap: 14px;
            min-width: 0;
            margin-top: 92px;
        }

        .side-column .access-panel {
            margin-top: 0;
        }

        .side-product-tour {
            padding: 16px;
            border: 1px solid rgba(132, 151, 176, .30);
            border-radius: 8px;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, .95), rgba(255, 255, 255, .82)),
                linear-gradient(135deg, rgba(21, 184, 166, .12), rgba(66, 87, 232, .12), rgba(255, 184, 77, .14));
            box-shadow: 0 24px 70px rgba(49, 73, 118, .16);
            overflow: hidden;
        }

        .side-product-head {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 14px;
            margin-bottom: 12px;
        }

        .side-product-head strong {
            display: block;
            color: #142033;
            font-size: 18px;
            line-height: 1.18;
            font-weight: 900;
        }

        .side-product-head span {
            display: block;
            margin-top: 5px;
            color: #64748b;
            font-size: 12px;
            line-height: 1.42;
        }

        .side-product-head i {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 38px;
            height: 38px;
            flex: 0 0 38px;
            border-radius: 8px;
            color: #fff;
            background: linear-gradient(135deg, var(--coral), var(--amber));
            box-shadow: 0 14px 28px rgba(255, 107, 93, .20);
        }

        .side-shot-stack {
            position: relative;
            min-height: 178px;
            margin: 8px 0 14px;
        }

        .side-shot {
            position: absolute;
            display: block;
            width: 78%;
            height: 118px;
            padding: 10px;
            border: 1px solid rgba(132, 151, 176, .30);
            border-radius: 8px;
            background: linear-gradient(180deg, #ffffff, #f7fbff);
            box-shadow: 0 18px 42px rgba(49, 73, 118, .18);
            overflow: hidden;
        }

        .side-shot:nth-child(1) {
            top: 0;
            left: 0;
            transform: rotate(-2deg);
        }

        .side-shot:nth-child(2) {
            top: 38px;
            right: 0;
            transform: rotate(2deg);
        }

        .side-shot:nth-child(3) {
            top: 82px;
            left: 34px;
            transform: rotate(-1deg);
        }

        .side-shot-title {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
            margin-bottom: 8px;
            color: #172033;
            font-size: 10px;
            font-weight: 900;
        }

        .side-shot-title i {
            color: var(--teal);
        }

        .side-shot-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 6px;
            margin-bottom: 8px;
        }

        .side-shot-grid span {
            height: 28px;
            border-radius: 7px;
            background: linear-gradient(135deg, rgba(21, 184, 166, .16), rgba(66, 87, 232, .12));
        }

        .side-shot-bars {
            display: grid;
            gap: 5px;
        }

        .side-shot-bars span {
            display: block;
            width: var(--w, 74%);
            height: 6px;
            border-radius: 999px;
            background: linear-gradient(90deg, var(--teal), var(--indigo), var(--amber));
        }

        .tour-step-list {
            display: grid;
            gap: 8px;
        }

        .tour-step {
            display: grid;
            grid-template-columns: 34px 1fr;
            gap: 10px;
            min-height: 58px;
            padding: 10px;
            border: 1px solid rgba(132, 151, 176, .26);
            border-radius: 8px;
            background: rgba(255, 255, 255, .78);
        }

        .tour-step i {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 34px;
            height: 34px;
            border-radius: 8px;
            color: #fff;
            background: linear-gradient(135deg, var(--teal), var(--indigo));
        }

        .tour-step:nth-child(2) i {
            background: linear-gradient(135deg, var(--violet), var(--rose));
        }

        .tour-step:nth-child(3) i {
            background: linear-gradient(135deg, var(--coral), var(--amber));
        }

        .tour-step:nth-child(4) i {
            background: linear-gradient(135deg, var(--indigo), var(--cyan));
        }

        .tour-step strong {
            display: block;
            color: #172033;
            font-size: 12px;
            font-weight: 900;
        }

        .tour-step > span {
            display: block;
            min-width: 0;
        }

        .tour-step > span > span {
            display: block;
            margin-top: 3px;
            color: #64748b;
            font-size: 11px;
            line-height: 1.35;
        }

        .access-panel {
            position: relative;
            align-self: start;
            margin-top: 92px;
            border: 1px solid rgba(132, 151, 176, .34);
            border-radius: 8px;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, .96), rgba(255, 255, 255, .90)),
                linear-gradient(145deg, rgba(21, 184, 166, .10), rgba(66, 87, 232, .10), rgba(255, 184, 77, .10));
            box-shadow: 0 30px 90px rgba(49, 73, 118, .22);
            overflow: hidden;
        }

        .access-panel::before {
            content: "";
            position: absolute;
            inset: 0 0 auto;
            height: 5px;
            background: linear-gradient(90deg, var(--teal), var(--cyan), var(--indigo), var(--violet), var(--rose), var(--amber));
        }

        .panel-head {
            padding: 18px 18px 0;
        }

        .panel-trust-strip {
            display: grid;
            grid-template-columns: 38px 1fr;
            gap: 10px;
            margin-bottom: 12px;
            padding: 12px;
            border: 1px solid rgba(21, 184, 166, .22);
            border-radius: 8px;
            background:
                linear-gradient(135deg, rgba(21, 184, 166, .10), rgba(66, 87, 232, .08), rgba(255, 184, 77, .10)),
                rgba(255, 255, 255, .88);
        }

        .panel-trust-strip i {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 38px;
            height: 38px;
            border-radius: 8px;
            color: #fff;
            background: linear-gradient(135deg, var(--teal), var(--indigo));
        }

        .panel-trust-strip strong {
            display: block;
            color: #142033;
            font-size: 13px;
            font-weight: 900;
        }

        .panel-trust-strip span {
            display: block;
            margin-top: 4px;
            color: #64748b;
            font-size: 12px;
            line-height: 1.35;
        }

        .mode-tabs {
            display: flex;
            gap: 6px;
            padding: 5px;
            border: 1px solid #e2eaf5;
            border-radius: 8px;
            background: #f5f8fc;
        }

        .mode-tabs button {
            flex: 1 1 0;
            min-width: 0;
            min-height: 42px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            border: 0;
            border-radius: 6px;
            color: #667085;
            background: transparent;
            font-size: 13px;
            font-weight: 900;
            line-height: 1;
            white-space: nowrap;
            cursor: pointer;
            transition: background .16s ease, color .16s ease, box-shadow .16s ease;
        }

        .mode-tabs button i {
            font-size: 15px;
            line-height: 1;
        }

        .mode-tabs button.is-active {
            color: #fff;
            background: linear-gradient(135deg, var(--navy), var(--indigo));
            box-shadow: 0 10px 22px rgba(66, 87, 232, .22);
        }

        .auth-form {
            display: none;
            padding: 20px;
        }

        .auth-form.is-active {
            display: block;
        }

        .auth-title {
            margin: 0 0 5px;
            color: #142033;
            font-size: 24px;
            font-weight: 900;
        }

        .auth-copy {
            margin: 0 0 18px;
            color: #687789;
            line-height: 1.55;
            font-size: 13px;
        }

        .field-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .form-field {
            margin-bottom: 12px;
        }

        .form-field label {
            display: block;
            margin-bottom: 7px;
            color: #344054;
            font-size: 12px;
            font-weight: 900;
        }

        .form-field input {
            width: 100%;
            min-height: 46px;
            border: 1px solid #d8e4f2;
            border-radius: 8px;
            outline: none;
            padding: 0 13px;
            color: #172033;
            background: rgba(255, 255, 255, .86);
            transition: border-color .16s ease, background .16s ease, box-shadow .16s ease;
        }

        .form-field input:focus {
            border-color: rgba(66, 87, 232, .68);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(66, 87, 232, .11);
        }

        .form-field input::placeholder {
            color: #9aa8ba;
        }

        .field-hint {
            display: block;
            margin-top: 6px;
            color: #667085;
            font-size: 11px;
            line-height: 1.38;
            font-weight: 750;
        }

        .password-field {
            position: relative;
        }

        .password-field input {
            padding-right: 48px;
        }

        .password-toggle {
            position: absolute;
            right: 8px;
            bottom: 8px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 32px;
            height: 32px;
            border: 0;
            border-radius: 6px;
            color: #5b667a;
            background: transparent;
            cursor: pointer;
        }

        .password-toggle:hover,
        .password-toggle.is-visible {
            color: var(--indigo);
            background: rgba(66, 87, 232, .08);
        }

        .google-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            width: 100%;
            min-height: 48px;
            margin: 4px 0 14px;
            border: 1px solid #d9e3f0;
            border-radius: 8px;
            color: #182338;
            background: #fff;
            font-weight: 900;
            box-shadow: 0 10px 24px rgba(49, 73, 118, .08);
            transition: transform .16s ease, border-color .16s ease, box-shadow .16s ease;
        }

        .google-btn:hover {
            color: #182338;
            border-color: rgba(66, 87, 232, .36);
            transform: translateY(-1px);
            box-shadow: 0 14px 28px rgba(49, 73, 118, .12);
        }

        .google-mark {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 24px;
            height: 24px;
            border-radius: 50%;
            color: #fff;
            background: linear-gradient(135deg, #4285f4, #34a853 46%, #fbbc05 72%, #ea4335);
            font-weight: 900;
            font-family: Arial, sans-serif;
        }

        .or-line {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            align-items: center;
            gap: 10px;
            margin: 2px 0 14px;
            color: #98a2b3;
            font-size: 11px;
            font-weight: 900;
            text-transform: uppercase;
        }

        .or-line::before,
        .or-line::after {
            content: "";
            height: 1px;
            background: #e5edf7;
        }

        .captcha-box {
            display: grid;
            grid-template-columns: 112px minmax(0, 1fr);
            gap: 10px;
            align-items: end;
            margin-bottom: 12px;
        }

        .captcha-question {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 46px;
            border: 1px solid rgba(21, 184, 166, .26);
            border-radius: 8px;
            color: #126b62;
            background: rgba(21, 184, 166, .10);
            font-weight: 900;
        }

        .recaptcha-box {
            display: flex;
            justify-content: center;
            min-height: 78px;
            margin: 4px 0 12px;
            padding: 8px;
            border: 1px solid var(--line);
            border-radius: 8px;
            background: #fbfdff;
            overflow: hidden;
        }

        .submit-btn {
            width: 100%;
            min-height: 50px;
            margin-top: 4px;
            border: 0;
            color: #fff;
            background: linear-gradient(135deg, var(--navy), var(--indigo) 48%, var(--teal));
            box-shadow: 0 18px 38px rgba(66, 87, 232, .24);
            cursor: pointer;
        }

        .submit-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 20px 40px rgba(66, 87, 232, .24);
        }

        .submit-btn:disabled {
            opacity: .58;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        .form-foot {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin-top: 14px;
            color: #687789;
            font-size: 12px;
            flex-wrap: wrap;
        }

        .form-foot a {
            color: var(--indigo);
            font-weight: 900;
        }

        .legal-note {
            margin: 12px 0 0;
            color: #667085;
            font-size: 11px;
            line-height: 1.45;
        }

        .legal-note strong {
            color: #26354d;
        }

        .text-btn {
            min-height: 36px;
            padding: 0 12px;
            color: var(--indigo);
            border: 1px solid rgba(66, 87, 232, .18);
            background: rgba(66, 87, 232, .07);
            cursor: pointer;
            font-size: 12px;
        }

        .text-btn:hover {
            background: rgba(66, 87, 232, .12);
        }

        .alert-line {
            margin-bottom: 14px;
            padding: 11px 12px;
            border: 1px solid rgba(255, 107, 93, .30);
            border-radius: 8px;
            color: #9c2f25;
            background: rgba(255, 107, 93, .10);
            font-size: 13px;
            font-weight: 800;
        }

        .alert-line.success {
            border-color: rgba(34, 197, 94, .30);
            color: #17663b;
            background: rgba(34, 197, 94, .10);
        }

        .panel-footer {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 1px;
            border-top: 1px solid #e5edf7;
            background: #e5edf7;
        }

        .mini-proof {
            min-height: 76px;
            padding: 13px;
            background: rgba(255, 255, 255, .88);
        }

        .mini-proof i {
            color: var(--teal);
            font-size: 18px;
        }

        .mini-proof:nth-child(2) i {
            color: var(--violet);
        }

        .mini-proof:nth-child(3) i {
            color: var(--coral);
        }

        .mini-proof span {
            display: block;
            margin-top: 8px;
            color: #617084;
            font-size: 12px;
            line-height: 1.35;
        }

        .assistant-widget {
            position: fixed;
            right: 22px;
            bottom: 22px;
            z-index: 30;
            width: min(350px, calc(100vw - 28px));
            filter: drop-shadow(0 24px 42px rgba(16, 25, 44, .24));
        }

        .assistant-card {
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(132, 151, 176, .34);
            border-radius: 8px;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, .96), rgba(255, 255, 255, .92)),
                linear-gradient(135deg, rgba(21, 184, 166, .14), rgba(66, 87, 232, .10), rgba(255, 184, 77, .12));
        }

        .assistant-card::before {
            content: "";
            position: absolute;
            inset: 0 0 auto;
            height: 5px;
            background: linear-gradient(90deg, var(--teal), var(--cyan), var(--indigo), var(--rose), var(--amber));
        }

        .assistant-head {
            display: grid;
            grid-template-columns: 44px 1fr 30px;
            gap: 10px;
            align-items: center;
            padding: 16px 14px 10px;
        }

        .assistant-avatar {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 44px;
            height: 44px;
            border-radius: 8px;
            color: #fff;
            background: linear-gradient(135deg, var(--navy), var(--indigo), var(--teal));
            box-shadow: 0 12px 24px rgba(66, 87, 232, .20);
        }

        .assistant-title strong {
            display: block;
            color: #111827;
            font-size: 14px;
            font-weight: 900;
        }

        .assistant-title span {
            display: block;
            margin-top: 3px;
            color: #667085;
            font-size: 12px;
            line-height: 1.35;
        }

        .assistant-close,
        .assistant-launcher {
            border: 0;
            cursor: pointer;
        }

        .assistant-close {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 30px;
            height: 30px;
            border-radius: 8px;
            color: #526070;
            background: rgba(15, 23, 42, .06);
        }

        .assistant-close:hover {
            color: #111827;
            background: rgba(15, 23, 42, .10);
        }

        .assistant-body {
            padding: 0 14px 14px;
        }

        .assistant-thread {
            display: flex;
            flex-direction: column;
            gap: 7px;
            max-height: 184px;
            margin-bottom: 10px;
            padding: 12px 8px;
            border: 1px solid rgba(132, 151, 176, .22);
            border-radius: 8px;
            background:
                linear-gradient(135deg, rgba(21, 184, 166, .08), rgba(66, 87, 232, .06)),
                repeating-linear-gradient(45deg, rgba(255, 255, 255, .48) 0 1px, transparent 1px 14px),
                #edf7f5;
            overflow-y: auto;
        }

        .assistant-message {
            position: relative;
            align-self: flex-start;
            max-width: 84%;
            margin: 0;
            padding: 8px 10px 15px;
            border: 0;
            border-radius: 4px 14px 14px 14px;
            color: #1f2937;
            background: #fff;
            font-size: 12px;
            line-height: 1.45;
            box-shadow: 0 6px 16px rgba(49, 73, 118, .10);
            overflow-wrap: anywhere;
        }

        .assistant-message.is-user {
            align-self: flex-end;
            color: #082f2a;
            border-radius: 14px 4px 14px 14px;
            background: linear-gradient(135deg, #d8fbef, #bff2e9);
        }

        .assistant-message.is-user::after,
        .assistant-message.is-admin::after {
            content: "";
            position: absolute;
            top: 0;
            width: 10px;
            height: 12px;
            background: inherit;
        }

        .assistant-message.is-user::after {
            right: -5px;
            clip-path: polygon(0 0, 100% 0, 0 100%);
        }

        .assistant-message.is-system {
            align-self: center;
            max-width: 92%;
            padding: 6px 9px;
            border-radius: 999px;
            color: #526070;
            background: rgba(255, 255, 255, .72);
            box-shadow: none;
            font-size: 11px;
            text-align: center;
        }

        .assistant-message.is-admin {
            align-self: flex-start;
            color: #172033;
            background: #fff;
        }

        .assistant-message.is-admin::after {
            left: -5px;
            clip-path: polygon(0 0, 100% 0, 100% 100%);
        }

        .assistant-message > span {
            display: block;
            padding-right: 34px;
        }

        .assistant-message.is-system > span {
            padding-right: 0;
        }

        .assistant-message small {
            position: absolute;
            right: 8px;
            bottom: 4px;
            color: #718096;
            font-size: 9px;
            line-height: 1;
            opacity: .9;
        }

        .assistant-message.is-user small {
            color: #0f766e;
        }

        .assistant-contact-form {
            display: grid;
            gap: 9px;
        }

        .assistant-field {
            display: grid;
            gap: 5px;
        }

        .assistant-field label {
            color: #344054;
            font-size: 11px;
            font-weight: 900;
        }

        .assistant-contact-form input,
        .assistant-contact-form textarea {
            width: 100%;
            min-height: 38px;
            padding: 0 10px;
            border: 1px solid #d7e2f0;
            border-radius: 8px;
            color: #142033;
            background: #fff;
            font-size: 12px;
            outline: 0;
            transition: border-color .18s ease, box-shadow .18s ease;
        }

        .assistant-contact-form textarea {
            min-height: 78px;
            padding-top: 10px;
            resize: vertical;
        }

        .assistant-contact-form input:focus,
        .assistant-contact-form textarea:focus {
            border-color: rgba(66, 87, 232, .55);
            box-shadow: 0 0 0 3px rgba(66, 87, 232, .10);
        }

        .assistant-submit {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            min-height: 40px;
            border: 0;
            border-radius: 8px;
            color: #fff;
            background: linear-gradient(135deg, var(--navy), var(--indigo), var(--teal));
            box-shadow: 0 14px 28px rgba(66, 87, 232, .20);
            font-size: 12px;
            font-weight: 900;
            cursor: pointer;
        }

        .assistant-submit:disabled {
            cursor: wait;
            opacity: .74;
        }

        .assistant-note {
            margin: 0;
            color: #667085;
            font-size: 11px;
            line-height: 1.35;
        }

        .assistant-status {
            min-height: 0;
            color: #667085;
            font-size: 11px;
            font-weight: 850;
        }

        .assistant-launcher {
            display: none;
            align-items: center;
            justify-content: center;
            gap: 9px;
            margin-left: auto;
            min-height: 50px;
            padding: 0 15px;
            border-radius: 999px;
            color: #fff;
            background: linear-gradient(135deg, var(--navy), var(--indigo), var(--teal));
            box-shadow: 0 18px 36px rgba(66, 87, 232, .24);
            font-weight: 900;
            white-space: nowrap;
        }

        .assistant-widget.is-collapsed .assistant-card {
            display: none;
        }

        .assistant-widget.is-collapsed .assistant-launcher {
            display: inline-flex;
        }

        @@media (prefers-reduced-motion: reduce) {
            .showcase-track {
                animation: none;
            }
        }

        @@media (max-width: 1080px) {
            .entry-main {
                grid-template-columns: 1fr;
                gap: 28px;
            }

            .side-column {
                order: -1;
                width: min(560px, 100%);
                margin-top: 0;
            }

            .access-panel {
                width: 100%;
            }

            .product-board {
                width: 100%;
                max-width: 100%;
            }

            .product-feature-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @@media (max-width: 760px) {
            .entry-shell {
                width: min(100% - 22px, 1180px);
                padding-top: 16px;
            }

            .entry-main,
            .story-panel,
            .side-column,
            .access-panel {
                width: 100%;
                max-width: 100%;
                min-width: 0;
            }

            .entry-nav {
                align-items: flex-start;
                flex-direction: column;
            }

            .brand-lockup {
                max-width: 100%;
                padding: 9px 13px 9px 11px;
                gap: 10px;
                border-radius: 16px;
            }

            .brand-mark,
            .brand-logo-sketch {
                flex-basis: 58px;
                width: 58px;
                height: 44px;
            }

            .brand-copy strong {
                font-size: 28px;
            }

            .brand-copy span {
                font-size: 12px;
            }

            .nav-actions {
                width: 100%;
                justify-content: flex-start;
            }

            .nav-link-btn,
            .primary-top {
                width: 100%;
            }

            .hero-title {
                font-size: 38px;
            }

            .hero-text {
                font-size: 16px;
            }

            .confidence-row,
            .trust-ribbon,
            .company-proof,
            .product-feature-grid,
            .trust-center-grid,
            .preview-body,
            .field-grid,
            .panel-footer,
            .captcha-box {
                grid-template-columns: 1fr;
            }

            .panel-trust-strip {
                grid-template-columns: 34px minmax(0, 1fr);
            }

            .panel-trust-strip > span,
            .panel-trust-strip span {
                min-width: 0;
            }

            .company-proof-details {
                grid-template-columns: 1fr;
            }

            .product-board-head {
                align-items: stretch;
                flex-direction: column;
            }

            .product-score {
                place-items: start;
                min-height: auto;
                padding: 10px;
                text-align: left;
            }

            .side-shot-stack {
                min-height: 156px;
            }

            .side-shot {
                height: 98px;
            }

            .studio-preview {
                margin-top: 22px;
            }

            .app-showcase {
                padding: 10px;
                min-height: auto;
            }

            .showcase-head {
                align-items: stretch;
                flex-direction: column;
            }

            .showcase-count {
                place-items: start;
                min-height: auto;
                padding: 10px;
                text-align: left;
            }

            .showcase-track {
                padding-right: 0;
            }

            .report-shot {
                flex-basis: 224px;
                min-height: 250px;
            }

            .report-visual {
                min-height: 144px;
                padding: 40px 10px 10px;
            }

            .assistant-widget {
                right: 12px;
                bottom: 12px;
                width: auto;
            }

            .assistant-card {
                width: min(340px, calc(100vw - 24px));
            }

            .assistant-widget.is-collapsed .assistant-launcher {
                width: 50px;
                min-height: 50px;
                padding: 0;
                border-radius: 50%;
                font-size: 0;
                gap: 0;
            }

            .assistant-widget.is-collapsed .assistant-launcher i {
                font-size: 18px;
            }
        }

        @@media (max-width: 560px) {
            .panel-head {
                padding: 14px 14px 0;
            }

            .mode-tabs {
                display: grid;
                grid-template-columns: repeat(2, minmax(0, 1fr));
                gap: 4px;
                padding: 4px;
            }

            .mode-tabs button {
                width: 100%;
                min-height: 38px;
                gap: 5px;
                font-size: 12px;
            }

            .mode-tabs button i {
                font-size: 14px;
            }

            .showcase-track {
                width: 100%;
                padding-right: 0;
                padding-bottom: 7px;
                overflow-x: auto;
                scroll-snap-type: x mandatory;
                animation: none;
            }

            .report-shot {
                flex-basis: 230px;
                scroll-snap-align: start;
            }

            .donut-chart {
                grid-template-columns: 1fr;
            }

            .donut-ring {
                width: 72px;
                height: 72px;
            }
        }
    </style>
    @if (recaptchaAktif)
    {
        <script src="https://www.google.com/recaptcha/api.js?onload=onLoginRecaptchaReady&render=explicit" defer></script>
    }
</head>

