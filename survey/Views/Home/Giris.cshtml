@model survey.Models.Personel
@{
    ViewBag.Title = "Survey by Aslana Teknoloji";
    Layout = null;

    var activePanel = (ViewBag.ActiveAuthPanel as string) ?? "login";
    var registerActive = string.Equals(activePanel, "register", StringComparison.OrdinalIgnoreCase);
    var verifyActive = string.Equals(activePanel, "verify", StringComparison.OrdinalIgnoreCase);
    var participantActive = string.Equals(activePanel, "participant", StringComparison.OrdinalIgnoreCase);
    var loginActive = !registerActive && !verifyActive && !participantActive;
    var captchaSoru = (ViewBag.CaptchaSoru as string) ?? "?";
    var verifyEmail = (ViewBag.VerifyEmail as string) ?? string.Empty;
    var recaptchaAktif = ViewBag.RecaptchaAktif is bool recaptchaValue && recaptchaValue;
    var captchaAtlandi = ViewBag.CaptchaAtlandi is bool captchaAtlandiValue && captchaAtlandiValue;
    var recaptchaSiteKey = (ViewBag.RecaptchaSiteKey as string) ?? string.Empty;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <title>Survey by Aslana Teknoloji | Sınav, Anket ve Sertifika Platformu</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=0, minimal-ui">
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="description" content="Sınav, anket, eğitim ve sertifika yayınlama platformu">
    <link rel="icon" href="~/Content/img/aslana-favicon.png" type="image/png">
    <link rel="stylesheet" type="text/css" href="~/files/bower_components/bootstrap/dist/css/bootstrap.min.css">
    <link rel="stylesheet" type="text/css" href="~/files/assets/icon/themify-icons/themify-icons.css">
    <link rel="stylesheet" type="text/css" href="~/files/assets/icon/icofont/css/icofont.css">
    <style>
        :root {
            --ink: #152033;
            --muted: #667085;
            --soft: #f4f8ff;
            --line: #dce6f2;
            --panel: #ffffff;
            --teal: #15b8a6;
            --cyan: #28c7d9;
            --indigo: #4257e8;
            --violet: #7c3aed;
            --amber: #ffb84d;
            --coral: #ff6b5d;
            --rose: #ff4f8b;
            --green: #22c55e;
            --navy: #10192c;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            color: var(--ink);
            font-family: "Segoe UI", Arial, sans-serif;
            background: #f6faff;
        }

        a,
        a:hover {
            text-decoration: none;
        }

        .studio-entry {
            position: relative;
            min-height: 100vh;
            overflow: hidden;
            background:
                linear-gradient(132deg, rgba(21, 184, 166, .22) 0 17%, transparent 17% 100%),
                linear-gradient(151deg, transparent 0 48%, rgba(66, 87, 232, .11) 48% 70%, rgba(255, 184, 77, .18) 70% 100%),
                linear-gradient(22deg, transparent 0 62%, rgba(255, 79, 139, .12) 62% 100%),
                repeating-linear-gradient(90deg, rgba(16, 25, 44, .04) 0 1px, transparent 1px 76px),
                repeating-linear-gradient(0deg, rgba(16, 25, 44, .035) 0 1px, transparent 1px 76px),
                linear-gradient(180deg, #ffffff 0%, #f7fbff 46%, #eef7ff 100%);
        }

        .studio-entry::before {
            content: "";
            position: absolute;
            inset: auto 0 0;
            height: 12px;
            background: linear-gradient(90deg, var(--teal), var(--cyan), var(--indigo), var(--violet), var(--rose), var(--amber));
        }

        .studio-entry::after {
            content: "";
            position: absolute;
            top: 86px;
            right: -16%;
            width: 72%;
            height: 78%;
            clip-path: polygon(20% 0, 100% 13%, 84% 100%, 0 78%);
            background:
                linear-gradient(135deg, rgba(40, 199, 217, .16), rgba(124, 58, 237, .10) 42%, rgba(255, 184, 77, .16)),
                repeating-linear-gradient(90deg, rgba(66, 87, 232, .06) 0 1px, transparent 1px 58px);
            pointer-events: none;
        }

        .entry-shell {
            position: relative;
            z-index: 1;
            width: min(1180px, calc(100% - 36px));
            min-height: 100vh;
            margin: 0 auto;
            display: grid;
            grid-template-rows: auto 1fr;
            gap: 28px;
            padding: 24px 0 42px;
        }

        .entry-shell::before {
            content: "";
            position: absolute;
            top: 84px;
            left: -96px;
            width: 390px;
            height: 300px;
            clip-path: polygon(0 14%, 88% 0, 100% 64%, 23% 100%);
            background: linear-gradient(135deg, rgba(125, 244, 199, .38), rgba(56, 189, 248, .18), rgba(255, 107, 93, .10));
            filter: blur(1px);
            pointer-events: none;
            z-index: -1;
        }

        .entry-nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 18px;
        }

        .brand-lockup {
            display: inline-flex;
            align-items: center;
            gap: 14px;
            min-width: 0;
            padding: 10px 18px 10px 14px;
            color: #fff;
            border: 1px solid rgba(255, 255, 255, .16);
            border-radius: 18px;
            background:
                linear-gradient(135deg, rgba(255, 255, 255, .12), transparent 38%),
                linear-gradient(135deg, #121a2b 0%, #26384f 54%, #24325f 100%);
            box-shadow: 0 18px 42px rgba(21, 32, 51, .22), inset 0 0 0 1px rgba(125, 244, 199, .08);
            transition: transform .16s ease, box-shadow .16s ease, border-color .16s ease;
        }

        .brand-lockup:hover {
            color: #fff;
            border-color: rgba(125, 244, 199, .38);
            box-shadow: 0 22px 50px rgba(21, 32, 51, .24);
            transform: translateY(-1px);
        }

        .brand-mark {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex: 0 0 72px;
            width: 72px;
            height: 54px;
        }

        .brand-logo-sketch {
            display: block;
            width: 72px;
            height: 54px;
            overflow: visible;
            filter: drop-shadow(0 10px 18px rgba(0, 0, 0, .2));
        }

        .brand-logo-sketch path,
        .brand-logo-sketch line,
        .brand-logo-sketch rect {
            fill: none;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .brand-logo-sketch .survey-sheet,
        .brand-logo-sketch .survey-fold {
            stroke: rgba(255, 255, 255, .94);
            stroke-width: 3.2;
        }

        .brand-logo-sketch .survey-form-line {
            stroke: rgba(255, 255, 255, .82);
            stroke-width: 2.5;
        }

        .brand-logo-sketch .survey-box.mint {
            stroke: #7df4c7;
        }

        .brand-logo-sketch .survey-box.blue {
            stroke: #38bdf8;
        }

        .brand-logo-sketch .survey-box.coral {
            stroke: #fb7185;
        }

        .brand-logo-sketch .survey-check-shadow {
            stroke: rgba(251, 113, 133, .26);
            stroke-width: 7;
        }

        .brand-logo-sketch .survey-check {
            stroke: url(#entrySurveyCheckGradient);
            stroke-width: 4.5;
        }

        .brand-copy {
            min-width: 0;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            justify-content: center;
            line-height: 1;
            text-align: left;
        }

        .brand-copy strong {
            display: block;
            margin: 0;
            color: #fff;
            font-size: 36px;
            font-weight: 850;
            letter-spacing: 0;
            text-transform: lowercase;
            white-space: nowrap;
        }

        .brand-copy span {
            display: block;
            margin: 3px 0 0;
            color: rgba(255, 255, 255, .76);
            font-size: 15px;
            font-weight: 600;
            letter-spacing: 0;
            white-space: nowrap;
        }

        .brand-lockup img {
            width: 226px;
            max-width: 64vw;
            height: auto;
            display: block;
        }

        .nav-actions {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 10px;
            flex-wrap: wrap;
        }

        .nav-link-btn,
        .primary-top,
        .text-btn,
        .submit-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            border-radius: 8px;
            font-weight: 800;
            transition: transform .16s ease, box-shadow .16s ease, background .16s ease, border-color .16s ease;
        }

        .nav-link-btn {
            min-height: 42px;
            padding: 0 15px;
            color: #1f2d44;
            border: 1px solid rgba(151, 167, 195, .42);
            background: rgba(255, 255, 255, .82);
            box-shadow: 0 12px 26px rgba(49, 73, 118, .08);
        }

        .nav-link-btn:hover {
            color: #142033;
            border-color: rgba(66, 87, 232, .36);
            background: #fff;
            transform: translateY(-1px);
        }

        .primary-top {
            min-height: 42px;
            padding: 0 16px;
            border: 0;
            color: #fff;
            background: linear-gradient(135deg, var(--navy), #2d3be8 58%, #16b8a6);
            box-shadow: 0 14px 30px rgba(66, 87, 232, .24);
            cursor: pointer;
        }

        .primary-top:hover {
            transform: translateY(-1px);
            box-shadow: 0 16px 32px rgba(21, 32, 51, .22);
        }

        .entry-main {
            display: grid;
            grid-template-columns: minmax(0, 1fr) 430px;
            align-items: start;
            gap: 44px;
        }

        .story-panel {
            min-width: 0;
        }

        .eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 9px;
            margin-bottom: 18px;
            padding: 8px 12px;
            color: #0c4a45;
            border: 1px solid rgba(21, 184, 166, .34);
            border-radius: 999px;
            background: linear-gradient(90deg, rgba(21, 184, 166, .14), rgba(56, 189, 248, .12), rgba(255, 184, 77, .13));
            font-size: 13px;
            font-weight: 800;
            box-shadow: 0 12px 28px rgba(21, 184, 166, .10);
        }

        .eyebrow i {
            color: var(--teal);
        }

        .hero-title {
            max-width: 720px;
            margin: 0;
            color: #121b2d;
            font-size: 52px;
            line-height: 1.04;
            font-weight: 900;
            letter-spacing: 0;
        }

        .hero-title span {
            color: transparent;
            background: linear-gradient(90deg, var(--indigo), var(--violet), var(--teal), var(--coral));
            -webkit-background-clip: text;
            background-clip: text;
        }

        .hero-text {
            max-width: 620px;
            margin: 18px 0 0;
            color: #536174;
            font-size: 17px;
            line-height: 1.72;
            font-weight: 500;
        }

        .trust-ribbon {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 10px;
            max-width: 760px;
            margin-top: 22px;
        }

        .trust-item {
            display: grid;
            grid-template-columns: 38px 1fr;
            gap: 10px;
            min-height: 88px;
            padding: 13px;
            border: 1px solid rgba(132, 151, 176, .28);
            border-radius: 8px;
            background:
                linear-gradient(135deg, rgba(255, 255, 255, .88), rgba(255, 255, 255, .68)),
                linear-gradient(135deg, rgba(21, 184, 166, .12), rgba(66, 87, 232, .10));
            box-shadow: 0 16px 36px rgba(49, 73, 118, .10);
        }

        .trust-item:nth-child(2) {
            background:
                linear-gradient(135deg, rgba(255, 255, 255, .88), rgba(255, 255, 255, .68)),
                linear-gradient(135deg, rgba(124, 58, 237, .12), rgba(255, 184, 77, .13));
        }

        .trust-item:nth-child(3) {
            background:
                linear-gradient(135deg, rgba(255, 255, 255, .88), rgba(255, 255, 255, .68)),
                linear-gradient(135deg, rgba(255, 107, 93, .12), rgba(21, 184, 166, .12));
        }

        .trust-mark {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 38px;
            height: 38px;
            border-radius: 8px;
            color: #fff;
            background: linear-gradient(135deg, var(--teal), var(--cyan));
            box-shadow: 0 12px 24px rgba(21, 184, 166, .22);
        }

        .trust-item:nth-child(2) .trust-mark {
            background: linear-gradient(135deg, #4c2f91, var(--violet));
            box-shadow: 0 12px 24px rgba(124, 58, 237, .22);
        }

        .trust-item:nth-child(3) .trust-mark {
            background: linear-gradient(135deg, var(--coral), var(--amber));
            box-shadow: 0 12px 24px rgba(255, 107, 93, .20);
        }

        .trust-copy strong {
            display: block;
            color: #142033;
            font-size: 13px;
            font-weight: 900;
        }

        .trust-copy span {
            display: block;
            margin-top: 4px;
            color: #637288;
            font-size: 12px;
            line-height: 1.42;
        }

        .legal-dock {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            max-width: 760px;
            margin-top: 14px;
        }

        .legal-chip {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            min-height: 30px;
            padding: 0 10px;
            border: 1px solid rgba(132, 151, 176, .28);
            border-radius: 999px;
            color: #314057;
            background: rgba(255, 255, 255, .78);
            box-shadow: 0 10px 24px rgba(49, 73, 118, .08);
            font-size: 11px;
            font-weight: 900;
            white-space: nowrap;
        }

        .legal-chip i {
            color: var(--teal);
        }

        .app-showcase {
            max-width: 760px;
            margin-top: 18px;
            padding: 12px;
            border: 1px solid rgba(132, 151, 176, .26);
            border-radius: 8px;
            background:
                linear-gradient(135deg, rgba(255, 255, 255, .84), rgba(255, 255, 255, .58)),
                linear-gradient(90deg, rgba(21, 184, 166, .12), rgba(66, 87, 232, .10), rgba(255, 184, 77, .12));
            box-shadow: 0 20px 54px rgba(49, 73, 118, .12);
            overflow: hidden;
        }

        .showcase-track {
            display: flex;
            gap: 12px;
            width: max-content;
            animation: showcaseGlide 18s ease-in-out infinite;
        }

        .app-showcase:hover .showcase-track {
            animation-play-state: paused;
        }

        .app-shot {
            flex: 0 0 214px;
            min-height: 124px;
            padding: 10px;
            border: 1px solid rgba(132, 151, 176, .30);
            border-radius: 8px;
            background: #fff;
            box-shadow: 0 12px 30px rgba(49, 73, 118, .10);
        }

        .shot-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
            margin-bottom: 10px;
        }

        .shot-title {
            display: flex;
            align-items: center;
            gap: 7px;
            min-width: 0;
            color: #172033;
            font-size: 12px;
            font-weight: 900;
        }

        .shot-title i {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 26px;
            height: 26px;
            flex: 0 0 26px;
            border-radius: 8px;
            color: #fff;
            background: linear-gradient(135deg, var(--teal), var(--cyan));
        }

        .app-shot:nth-child(2) .shot-title i,
        .app-shot:nth-child(6) .shot-title i {
            background: linear-gradient(135deg, var(--indigo), var(--violet));
        }

        .app-shot:nth-child(3) .shot-title i,
        .app-shot:nth-child(7) .shot-title i {
            background: linear-gradient(135deg, var(--coral), var(--amber));
        }

        .app-shot:nth-child(4) .shot-title i,
        .app-shot:nth-child(8) .shot-title i {
            background: linear-gradient(135deg, var(--rose), var(--violet));
        }

        .shot-pill {
            flex: 0 0 auto;
            min-height: 22px;
            padding: 0 8px;
            border-radius: 999px;
            color: #0f766e;
            background: rgba(21, 184, 166, .11);
            font-size: 10px;
            font-weight: 900;
            line-height: 22px;
        }

        .shot-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
        }

        .shot-cell {
            min-height: 48px;
            padding: 8px;
            border: 1px solid #e2eaf5;
            border-radius: 8px;
            background: linear-gradient(135deg, #fbfdff, #f5f8ff);
        }

        .shot-cell strong {
            display: block;
            color: #1d2a41;
            font-size: 11px;
            font-weight: 900;
        }

        .shot-bar {
            display: block;
            width: var(--shot-bar, 72%);
            height: 6px;
            margin-top: 9px;
            border-radius: 999px;
            background: linear-gradient(90deg, var(--teal), var(--amber));
        }

        .shot-list {
            display: grid;
            gap: 7px;
        }

        .shot-list span {
            display: block;
            height: 9px;
            border-radius: 999px;
            background: linear-gradient(90deg, rgba(66, 87, 232, .20), rgba(21, 184, 166, .20));
        }

        .shot-list span:nth-child(2) {
            width: 78%;
        }

        .shot-list span:nth-child(3) {
            width: 62%;
        }

        @@keyframes showcaseGlide {
            0%, 14% {
                transform: translateX(0);
            }

            50% {
                transform: translateX(-256px);
            }

            86%, 100% {
                transform: translateX(0);
            }
        }

        .hero-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 11px;
            margin-top: 28px;
        }

        .hero-actions .primary-top,
        .hero-actions .nav-link-btn {
            min-height: 50px;
            padding: 0 20px;
            font-size: 14px;
        }

        .confidence-row {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 10px;
            max-width: 660px;
            margin-top: 30px;
        }

        .confidence-item {
            position: relative;
            overflow: hidden;
            min-height: 78px;
            padding: 14px;
            border: 1px solid rgba(132, 151, 176, .26);
            border-radius: 8px;
            background: rgba(255, 255, 255, .82);
            box-shadow: 0 14px 34px rgba(49, 73, 118, .08);
        }

        .confidence-item::before {
            content: "";
            position: absolute;
            inset: 0 0 auto;
            height: 4px;
            background: linear-gradient(90deg, var(--teal), var(--cyan));
        }

        .confidence-item:nth-child(2)::before {
            background: linear-gradient(90deg, var(--indigo), var(--violet));
        }

        .confidence-item:nth-child(3)::before {
            background: linear-gradient(90deg, var(--coral), var(--amber));
        }

        .confidence-item i {
            color: var(--indigo);
            font-size: 18px;
        }

        .confidence-item strong {
            display: block;
            margin-top: 8px;
            color: #19253a;
            font-size: 13px;
        }

        .confidence-item span {
            display: block;
            margin-top: 4px;
            color: #69778b;
            font-size: 12px;
            line-height: 1.35;
        }

        .studio-preview {
            max-width: 650px;
            margin-top: 30px;
            border: 1px solid transparent;
            border-radius: 8px;
            background:
                linear-gradient(#ffffff, #ffffff) padding-box,
                linear-gradient(135deg, rgba(21, 184, 166, .58), rgba(66, 87, 232, .44), rgba(255, 184, 77, .52)) border-box;
            box-shadow: 0 24px 70px rgba(49, 73, 118, .17);
            overflow: hidden;
        }

        .preview-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 14px 16px;
            border-bottom: 1px solid #e5edf7;
            background:
                linear-gradient(90deg, rgba(21, 184, 166, .10), rgba(66, 87, 232, .08), rgba(255, 184, 77, .10)),
                #fff;
        }

        .preview-title {
            display: flex;
            align-items: center;
            gap: 10px;
            min-width: 0;
            color: #182338;
            font-weight: 900;
        }

        .preview-title i {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 30px;
            height: 30px;
            flex: 0 0 30px;
            border-radius: 8px;
            color: #fff;
            background: linear-gradient(135deg, var(--teal), var(--cyan));
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            min-height: 30px;
            padding: 0 11px;
            color: #17663b;
            border-radius: 999px;
            background: rgba(34, 197, 94, .12);
            font-size: 12px;
            font-weight: 900;
            white-space: nowrap;
        }

        .preview-body {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
            padding: 16px;
        }

        .workflow-list,
        .report-list {
            display: grid;
            gap: 10px;
        }

        .workflow-step,
        .report-line {
            min-height: 54px;
            padding: 12px;
            border: 1px solid #e3ebf6;
            border-radius: 8px;
            background: linear-gradient(135deg, #ffffff, #f7fbff);
            box-shadow: inset 0 0 0 1px rgba(255, 255, 255, .52);
        }

        .workflow-step {
            display: grid;
            grid-template-columns: 34px 1fr;
            align-items: center;
            gap: 10px;
        }

        .step-no {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 34px;
            height: 34px;
            border-radius: 8px;
            color: #fff;
            background: linear-gradient(135deg, var(--indigo), var(--violet));
            font-weight: 900;
        }

        .workflow-step:nth-child(2) .step-no {
            background: linear-gradient(135deg, var(--teal), var(--cyan));
        }

        .workflow-step:nth-child(3) .step-no {
            background: linear-gradient(135deg, var(--coral), var(--amber));
        }

        .workflow-step strong,
        .report-line strong {
            display: block;
            color: #1c2840;
            font-size: 13px;
        }

        .workflow-step span,
        .report-line span {
            display: block;
            margin-top: 3px;
            color: #6b7789;
            font-size: 12px;
        }

        .report-line {
            position: relative;
            overflow: hidden;
        }

        .report-line::after {
            content: "";
            display: block;
            width: var(--bar, 70%);
            height: 6px;
            margin-top: 10px;
            border-radius: 999px;
            background: linear-gradient(90deg, var(--teal), var(--amber));
        }

        .trust-center {
            max-width: 650px;
            margin-top: 14px;
            padding: 14px;
            border: 1px solid rgba(132, 151, 176, .28);
            border-radius: 8px;
            background:
                linear-gradient(135deg, rgba(16, 25, 44, .94), rgba(36, 50, 95, .94)),
                linear-gradient(90deg, var(--teal), var(--indigo), var(--amber));
            color: #fff;
            box-shadow: 0 22px 60px rgba(16, 25, 44, .20);
        }

        .trust-center-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 12px;
        }

        .trust-center-head strong {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            font-weight: 900;
        }

        .trust-center-head span {
            display: inline-flex;
            align-items: center;
            min-height: 26px;
            padding: 0 10px;
            border: 1px solid rgba(125, 244, 199, .30);
            border-radius: 999px;
            color: #7df4c7;
            background: rgba(125, 244, 199, .10);
            font-size: 11px;
            font-weight: 900;
            white-space: nowrap;
        }

        .trust-center-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 8px;
        }

        .trust-center-item {
            min-height: 74px;
            padding: 10px;
            border: 1px solid rgba(255, 255, 255, .14);
            border-radius: 8px;
            background: rgba(255, 255, 255, .08);
        }

        .trust-center-item i {
            color: #7df4c7;
        }

        .trust-center-item strong {
            display: block;
            margin-top: 7px;
            color: #fff;
            font-size: 12px;
            font-weight: 900;
        }

        .trust-center-item span {
            display: block;
            margin-top: 3px;
            color: rgba(255, 255, 255, .72);
            font-size: 11px;
            line-height: 1.35;
        }

        .access-panel {
            position: relative;
            align-self: start;
            margin-top: 92px;
            border: 1px solid rgba(132, 151, 176, .34);
            border-radius: 8px;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, .96), rgba(255, 255, 255, .90)),
                linear-gradient(145deg, rgba(21, 184, 166, .10), rgba(66, 87, 232, .10), rgba(255, 184, 77, .10));
            box-shadow: 0 30px 90px rgba(49, 73, 118, .22);
            overflow: hidden;
        }

        .access-panel::before {
            content: "";
            position: absolute;
            inset: 0 0 auto;
            height: 5px;
            background: linear-gradient(90deg, var(--teal), var(--cyan), var(--indigo), var(--violet), var(--rose), var(--amber));
        }

        .panel-head {
            padding: 18px 18px 0;
        }

        .panel-trust-strip {
            display: grid;
            grid-template-columns: 38px 1fr;
            gap: 10px;
            margin-bottom: 12px;
            padding: 12px;
            border: 1px solid rgba(21, 184, 166, .22);
            border-radius: 8px;
            background:
                linear-gradient(135deg, rgba(21, 184, 166, .10), rgba(66, 87, 232, .08), rgba(255, 184, 77, .10)),
                rgba(255, 255, 255, .88);
        }

        .panel-trust-strip i {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 38px;
            height: 38px;
            border-radius: 8px;
            color: #fff;
            background: linear-gradient(135deg, var(--teal), var(--indigo));
        }

        .panel-trust-strip strong {
            display: block;
            color: #142033;
            font-size: 13px;
            font-weight: 900;
        }

        .panel-trust-strip span {
            display: block;
            margin-top: 4px;
            color: #64748b;
            font-size: 12px;
            line-height: 1.35;
        }

        .mode-tabs {
            display: flex;
            gap: 6px;
            padding: 5px;
            border: 1px solid #e2eaf5;
            border-radius: 8px;
            background: #f5f8fc;
        }

        .mode-tabs button {
            flex: 1 1 0;
            min-width: 0;
            min-height: 42px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            border: 0;
            border-radius: 6px;
            color: #667085;
            background: transparent;
            font-size: 13px;
            font-weight: 900;
            line-height: 1;
            white-space: nowrap;
            cursor: pointer;
            transition: background .16s ease, color .16s ease, box-shadow .16s ease;
        }

        .mode-tabs button i {
            font-size: 15px;
            line-height: 1;
        }

        .mode-tabs button.is-active {
            color: #fff;
            background: linear-gradient(135deg, var(--navy), var(--indigo));
            box-shadow: 0 10px 22px rgba(66, 87, 232, .22);
        }

        .auth-form {
            display: none;
            padding: 20px;
        }

        .auth-form.is-active {
            display: block;
        }

        .auth-title {
            margin: 0 0 5px;
            color: #142033;
            font-size: 24px;
            font-weight: 900;
        }

        .auth-copy {
            margin: 0 0 18px;
            color: #687789;
            line-height: 1.55;
            font-size: 13px;
        }

        .field-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .form-field {
            margin-bottom: 12px;
        }

        .form-field label {
            display: block;
            margin-bottom: 7px;
            color: #344054;
            font-size: 12px;
            font-weight: 900;
        }

        .form-field input {
            width: 100%;
            min-height: 46px;
            border: 1px solid #d8e4f2;
            border-radius: 8px;
            outline: none;
            padding: 0 13px;
            color: #172033;
            background: rgba(255, 255, 255, .86);
            transition: border-color .16s ease, background .16s ease, box-shadow .16s ease;
        }

        .form-field input:focus {
            border-color: rgba(66, 87, 232, .68);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(66, 87, 232, .11);
        }

        .form-field input::placeholder {
            color: #9aa8ba;
        }

        .password-field {
            position: relative;
        }

        .password-field input {
            padding-right: 48px;
        }

        .password-toggle {
            position: absolute;
            right: 8px;
            bottom: 8px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 32px;
            height: 32px;
            border: 0;
            border-radius: 6px;
            color: #5b667a;
            background: transparent;
            cursor: pointer;
        }

        .password-toggle:hover,
        .password-toggle.is-visible {
            color: var(--indigo);
            background: rgba(66, 87, 232, .08);
        }

        .google-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            width: 100%;
            min-height: 48px;
            margin: 4px 0 14px;
            border: 1px solid #d9e3f0;
            border-radius: 8px;
            color: #182338;
            background: #fff;
            font-weight: 900;
            box-shadow: 0 10px 24px rgba(49, 73, 118, .08);
            transition: transform .16s ease, border-color .16s ease, box-shadow .16s ease;
        }

        .google-btn:hover {
            color: #182338;
            border-color: rgba(66, 87, 232, .36);
            transform: translateY(-1px);
            box-shadow: 0 14px 28px rgba(49, 73, 118, .12);
        }

        .google-mark {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 24px;
            height: 24px;
            border-radius: 50%;
            color: #fff;
            background: linear-gradient(135deg, #4285f4, #34a853 46%, #fbbc05 72%, #ea4335);
            font-weight: 900;
            font-family: Arial, sans-serif;
        }

        .or-line {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            align-items: center;
            gap: 10px;
            margin: 2px 0 14px;
            color: #98a2b3;
            font-size: 11px;
            font-weight: 900;
            text-transform: uppercase;
        }

        .or-line::before,
        .or-line::after {
            content: "";
            height: 1px;
            background: #e5edf7;
        }

        .captcha-box {
            display: grid;
            grid-template-columns: 112px minmax(0, 1fr);
            gap: 10px;
            align-items: end;
            margin-bottom: 12px;
        }

        .captcha-question {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 46px;
            border: 1px solid rgba(21, 184, 166, .26);
            border-radius: 8px;
            color: #126b62;
            background: rgba(21, 184, 166, .10);
            font-weight: 900;
        }

        .recaptcha-box {
            display: flex;
            justify-content: center;
            min-height: 78px;
            margin: 4px 0 12px;
            padding: 8px;
            border: 1px solid var(--line);
            border-radius: 8px;
            background: #fbfdff;
            overflow: hidden;
        }

        .submit-btn {
            width: 100%;
            min-height: 50px;
            margin-top: 4px;
            border: 0;
            color: #fff;
            background: linear-gradient(135deg, var(--navy), var(--indigo) 48%, var(--teal));
            box-shadow: 0 18px 38px rgba(66, 87, 232, .24);
            cursor: pointer;
        }

        .submit-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 20px 40px rgba(66, 87, 232, .24);
        }

        .submit-btn:disabled {
            opacity: .58;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        .form-foot {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin-top: 14px;
            color: #687789;
            font-size: 12px;
            flex-wrap: wrap;
        }

        .form-foot a {
            color: var(--indigo);
            font-weight: 900;
        }

        .legal-note {
            margin: 12px 0 0;
            color: #667085;
            font-size: 11px;
            line-height: 1.45;
        }

        .legal-note strong {
            color: #26354d;
        }

        .text-btn {
            min-height: 36px;
            padding: 0 12px;
            color: var(--indigo);
            border: 1px solid rgba(66, 87, 232, .18);
            background: rgba(66, 87, 232, .07);
            cursor: pointer;
            font-size: 12px;
        }

        .text-btn:hover {
            background: rgba(66, 87, 232, .12);
        }

        .alert-line {
            margin-bottom: 14px;
            padding: 11px 12px;
            border: 1px solid rgba(255, 107, 93, .30);
            border-radius: 8px;
            color: #9c2f25;
            background: rgba(255, 107, 93, .10);
            font-size: 13px;
            font-weight: 800;
        }

        .alert-line.success {
            border-color: rgba(34, 197, 94, .30);
            color: #17663b;
            background: rgba(34, 197, 94, .10);
        }

        .panel-footer {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 1px;
            border-top: 1px solid #e5edf7;
            background: #e5edf7;
        }

        .mini-proof {
            min-height: 76px;
            padding: 13px;
            background: rgba(255, 255, 255, .88);
        }

        .mini-proof i {
            color: var(--teal);
            font-size: 18px;
        }

        .mini-proof:nth-child(2) i {
            color: var(--violet);
        }

        .mini-proof:nth-child(3) i {
            color: var(--coral);
        }

        .mini-proof span {
            display: block;
            margin-top: 8px;
            color: #617084;
            font-size: 12px;
            line-height: 1.35;
        }

        .assistant-widget {
            position: fixed;
            right: 22px;
            bottom: 22px;
            z-index: 30;
            width: min(350px, calc(100vw - 28px));
            filter: drop-shadow(0 24px 42px rgba(16, 25, 44, .24));
        }

        .assistant-card {
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(132, 151, 176, .34);
            border-radius: 8px;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, .96), rgba(255, 255, 255, .92)),
                linear-gradient(135deg, rgba(21, 184, 166, .14), rgba(66, 87, 232, .10), rgba(255, 184, 77, .12));
        }

        .assistant-card::before {
            content: "";
            position: absolute;
            inset: 0 0 auto;
            height: 5px;
            background: linear-gradient(90deg, var(--teal), var(--cyan), var(--indigo), var(--rose), var(--amber));
        }

        .assistant-head {
            display: grid;
            grid-template-columns: 44px 1fr 30px;
            gap: 10px;
            align-items: center;
            padding: 16px 14px 10px;
        }

        .assistant-avatar {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 44px;
            height: 44px;
            border-radius: 8px;
            color: #fff;
            background: linear-gradient(135deg, var(--navy), var(--indigo), var(--teal));
            box-shadow: 0 12px 24px rgba(66, 87, 232, .20);
        }

        .assistant-title strong {
            display: block;
            color: #111827;
            font-size: 14px;
            font-weight: 900;
        }

        .assistant-title span {
            display: block;
            margin-top: 3px;
            color: #667085;
            font-size: 12px;
            line-height: 1.35;
        }

        .assistant-close,
        .assistant-launcher {
            border: 0;
            cursor: pointer;
        }

        .assistant-close {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 30px;
            height: 30px;
            border-radius: 8px;
            color: #526070;
            background: rgba(15, 23, 42, .06);
        }

        .assistant-close:hover {
            color: #111827;
            background: rgba(15, 23, 42, .10);
        }

        .assistant-body {
            padding: 0 14px 14px;
        }

        .assistant-message {
            margin: 0;
            padding: 11px 12px;
            border: 1px solid rgba(21, 184, 166, .22);
            border-radius: 8px;
            color: #334155;
            background: rgba(255, 255, 255, .78);
            font-size: 12px;
            line-height: 1.45;
        }

        .assistant-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
            margin-top: 10px;
        }

        .assistant-actions button {
            min-height: 38px;
            border: 1px solid #dbe6f4;
            border-radius: 8px;
            color: #142033;
            background: #fff;
            font-size: 12px;
            font-weight: 900;
            cursor: pointer;
        }

        .assistant-actions button:first-child {
            grid-column: 1 / -1;
            color: #fff;
            border-color: transparent;
            background: linear-gradient(135deg, var(--navy), var(--indigo), var(--teal));
        }

        .assistant-launcher {
            display: none;
            align-items: center;
            justify-content: center;
            gap: 9px;
            margin-left: auto;
            min-height: 50px;
            padding: 0 15px;
            border-radius: 999px;
            color: #fff;
            background: linear-gradient(135deg, var(--navy), var(--indigo), var(--teal));
            box-shadow: 0 18px 36px rgba(66, 87, 232, .24);
            font-weight: 900;
            white-space: nowrap;
        }

        .assistant-widget.is-collapsed .assistant-card {
            display: none;
        }

        .assistant-widget.is-collapsed .assistant-launcher {
            display: inline-flex;
        }

        @@media (prefers-reduced-motion: reduce) {
            .showcase-track {
                animation: none;
            }
        }

        @@media (max-width: 1080px) {
            .entry-main {
                grid-template-columns: 1fr;
                gap: 28px;
            }

            .access-panel {
                order: -1;
                width: min(560px, 100%);
                margin-top: 0;
            }
        }

        @@media (max-width: 760px) {
            .entry-shell {
                width: min(100% - 22px, 1180px);
                padding-top: 16px;
            }

            .entry-main,
            .story-panel,
            .access-panel {
                width: 100%;
                max-width: 100%;
                min-width: 0;
            }

            .entry-nav {
                align-items: flex-start;
                flex-direction: column;
            }

            .brand-lockup {
                max-width: 100%;
                padding: 9px 13px 9px 11px;
                gap: 10px;
                border-radius: 16px;
            }

            .brand-mark,
            .brand-logo-sketch {
                flex-basis: 58px;
                width: 58px;
                height: 44px;
            }

            .brand-copy strong {
                font-size: 28px;
            }

            .brand-copy span {
                font-size: 12px;
            }

            .nav-actions {
                width: 100%;
                justify-content: flex-start;
            }

            .nav-link-btn,
            .primary-top {
                width: 100%;
            }

            .hero-title {
                font-size: 38px;
            }

            .hero-text {
                font-size: 16px;
            }

            .confidence-row,
            .trust-ribbon,
            .trust-center-grid,
            .preview-body,
            .field-grid,
            .panel-footer,
            .captcha-box {
                grid-template-columns: 1fr;
            }

            .panel-trust-strip {
                grid-template-columns: 34px minmax(0, 1fr);
            }

            .panel-trust-strip > span,
            .panel-trust-strip span {
                min-width: 0;
            }

            .studio-preview {
                margin-top: 22px;
            }

            .app-showcase {
                padding: 10px;
            }

            .app-shot {
                flex-basis: 204px;
            }

            .assistant-widget {
                right: 12px;
                bottom: 12px;
            }
        }

        @@media (max-width: 560px) {
            .panel-head {
                padding: 14px 14px 0;
            }

            .mode-tabs {
                display: grid;
                grid-template-columns: repeat(2, minmax(0, 1fr));
                gap: 4px;
                padding: 4px;
            }

            .mode-tabs button {
                width: 100%;
                min-height: 38px;
                gap: 5px;
                font-size: 12px;
            }

            .mode-tabs button i {
                font-size: 14px;
            }
        }
    </style>
    @if (recaptchaAktif)
    {
        <script src="https://www.google.com/recaptcha/api.js?onload=onLoginRecaptchaReady&render=explicit" defer></script>
    }
</head>

<body>
    <main class="studio-entry" data-active-panel="@activePanel">
        <div class="entry-shell">
            <nav class="entry-nav">
                <a class="brand-lockup" href="@Url.Action("Giris", "Home")" aria-label="Survey by Aslana Teknoloji ana sayfa">
                    <span class="brand-mark" aria-hidden="true">
                        <svg class="brand-logo-sketch" viewBox="0 0 88 64" focusable="false">
                            <defs>
                                <linearGradient id="entrySurveyCheckGradient" x1="56" y1="50" x2="84" y2="29" gradientUnits="userSpaceOnUse">
                                    <stop stop-color="#ff8a7a" />
                                    <stop offset=".58" stop-color="#ff6b6b" />
                                    <stop offset="1" stop-color="#fb7185" />
                                </linearGradient>
                            </defs>
                            <path class="survey-sheet" d="M16.7 7.2 C20.8 4.3 39.7 4.5 49.8 5.5 C54.1 5.9 65.6 18.6 68.5 25.2 C70.5 29.6 69.5 49.6 67.4 55 C66.1 58.6 61.5 60.2 52.1 59.8 C40.6 59.4 23.5 60.1 17.5 58.4 C12.4 56.9 10.8 52.6 11 46.2 C11.3 34.1 10.6 14.9 16.7 7.2 Z" />
                            <path class="survey-fold" d="M50.2 6.5 C49.8 12.5 49.9 21.2 52.8 24 C55.7 26.8 63 26.4 68.4 25.8" />
                            <rect class="survey-box mint" x="24" y="18.2" width="8" height="8" rx="1.5" />
                            <line class="survey-form-line" x1="40.3" y1="22.2" x2="54.8" y2="22.2" />
                            <rect class="survey-box blue" x="24" y="31.4" width="8" height="8" rx="1.5" />
                            <line class="survey-form-line" x1="40.3" y1="35.4" x2="53.3" y2="35.4" />
                            <rect class="survey-box coral" x="24" y="44.6" width="8" height="8" rx="1.5" />
                            <line class="survey-form-line" x1="40.3" y1="48.6" x2="49.7" y2="48.6" />
                            <path class="survey-check-shadow" d="M55.7 49.1 C59.2 52.5 62.3 55.2 64.8 58 C69.2 49.9 74.6 40.7 83.2 32" />
                            <path class="survey-check" d="M55.7 49.1 C59.2 52.5 62.3 55.2 64.8 58 C69.2 49.9 74.6 40.7 83.2 32" />
                        </svg>
                    </span>
                    <span class="brand-copy">
                        <strong>survey</strong>
                        <span>by Aslana Teknoloji</span>
                    </span>
                </a>
                <div class="nav-actions">
                    <button type="button" class="nav-link-btn" data-open-panel="participant">
                        <i class="ti-user"></i>
                        Katılımcı Girişi
                    </button>
                    <button type="button" class="nav-link-btn" data-open-panel="participant">
                        <i class="ti-search"></i>
                        Katılım Kodum Var
                    </button>
                    <button type="button" class="primary-top" data-open-panel="register">
                        <i class="ti-plus"></i>
                        Ücretsiz Başla
                    </button>
                </div>
            </nav>

            <section class="entry-main">
                <div class="story-panel">
                    <div class="eyebrow">
                        <i class="ti-shield"></i>
                        Güvenli sınav, anket ve sertifika stüdyosu
                    </div>
                    <h1 class="hero-title">
                        Değerlendirme süreçlerinizi <span>güvenli, kurumsal ve tek</span> bir ekrandan yönetin.
                    </h1>
                    <p class="hero-text">
                        Survey by Aslana Teknoloji; İK, eğitim, kalite ve işe alım ekipleri için sınav oluşturma, anket yayınlama, sonuç izleme ve sertifika süreçlerini renkli ama kontrollü bir çalışma alanında toplar.
                    </p>

                    <div class="trust-ribbon" aria-label="Kurumsal güven bilgileri">
                        <div class="trust-item">
                            <span class="trust-mark"><i class="ti-briefcase"></i></span>
                            <span class="trust-copy">
                                <strong>Aslana Teknoloji Ltd. Şti.</strong>
                                <span>Kurumsal şirket yapısı, doğrulanmış yönetim paneli ve kayıtlı çalışma alanı.</span>
                            </span>
                        </div>
                        <div class="trust-item">
                            <span class="trust-mark"><i class="ti-credit-card"></i></span>
                            <span class="trust-copy">
                                <strong>Tami ile güvenli ödeme</strong>
