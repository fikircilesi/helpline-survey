@model survey.Models.Anket

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    ViewData["DeleteEyebrow"] = "Çalışma silme";
    ViewData["DeleteTitle"] = "Çalışma silinsin mi?";
    ViewData["DeleteDescription"] = "Bu çalışma listeden kaldırılacak. Çalışmaya bağlı soru grubu veya katılım verisi varsa sistem veri kaybını önlemek için silmeyi durdurur.";
    ViewData["DeleteItemLabel"] = "Çalışma adı";
    ViewData["DeleteItemName"] = Model?.AnketAdi;
    ViewData["DeleteWarning"] = "Bu işlem geri alınamaz. Silme engellenirse önce bağlı soru gruplarını veya katılım kayıtlarını temizleyin.";
    ViewData["DeleteBackUrl"] = Url.Action("AnketAdIndex", "Home");
    ViewData["DeleteSubmitText"] = "Çalışmayı sil";
}

@await Html.PartialAsync("_DeleteConfirm")
