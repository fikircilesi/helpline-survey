@model survey.Models.Anket
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Yeni Kayıt</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="form-group">
            <div class="col-md-10">
                <b>Anket ya da sınav başlığını yazın</b>
                @Html.TextBoxFor(model => model.AnketAdi, new { @class = "form-control", @maxlength = "50", @Required = "" })
                @Html.ValidationMessageFor(model => model.AnketAdi, "", new { @class = "text-danger" })
            </div>
            <hr />
            <div class="col-md-10">
                <div class="checkbox-color checkbox-primary">
                    <input name="Sinav" value="True" id="checkbox1" type="checkbox" unchecked="">
                    <label class="form-label" for="checkbox1"> Sınav yapılacak ise işaretleyin.</label>
                </div>
            </div>

            <div class="col-md-10">
                <b>Eğitim için youtube video linkini buraya yapıştırın</b>
                <b>ensondaki / işaretinden sonraki kodu</b>
                @Html.TextBoxFor(model => model.Link, new { @class = "form-control", @maxlength = "450" })
                @Html.ValidationMessageFor(model => model.Link, "", new { @class = "text-danger" })
            </div>
            <div class="col-md-10">
                <b>Sınav için zaman belirleyin dakika cinsinden</b>
                @Html.TextBoxFor(model => model.Zaman, new { @class = "form-control", @maxlength = "3" })
                @Html.ValidationMessageFor(model => model.Zaman, "", new { @class = "text-danger" })
            </div>
            <div class="col-md-10">
                <b>Katilim baslangici</b>
                <input type="datetime-local" name="YayinBaslangicTarihi" class="form-control" value="@ViewBag.YayinBaslangicLocal" />
                <small class="text-muted">Bos birakilirsa link hemen kullanilabilir.</small>
                @Html.ValidationMessage("YayinBaslangicTarihi", "", new { @class = "text-danger" })
            </div>
            <div class="col-md-10">
                <b>Katilim bitisi</b>
                <input type="datetime-local" name="YayinBitisTarihi" class="form-control" value="@ViewBag.YayinBitisLocal" />
                <small class="text-muted">Bos birakilirsa belirli bir yayin bitisi uygulanmaz.</small>
                @Html.ValidationMessage("YayinBitisTarihi", "", new { @class = "text-danger" })
            </div>

        </div>
        <a class="btn btn-primary btn-outline-primary fa fa-backward" href="@Url.Action("AnketAdIndex", "Home")"> Geri</a>
        <input type="submit" class="btn btn-primary btn-outline-primary fa fa-check" value=" Kayıt" />
    </div>
}