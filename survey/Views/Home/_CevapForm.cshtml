@model survey.Models.Cevap
@using Microsoft.AspNetCore.Mvc.Rendering
@using System.Globalization
@using System.Text.RegularExpressions

@functions {
    public (string Metin, string Gorsel) GorselliMetniCoz(string value)
    {
        var text = value ?? string.Empty;
        var match = Regex.Match(
            text,
            @"\s*\[\[gorsel:(?<file>[^\]]+)\]\]\s*$",
            RegexOptions.IgnoreCase | RegexOptions.CultureInvariant);

        if (!match.Success)
        {
            return (text.Trim(), string.Empty);
        }

        var cleanText = Regex.Replace(text, @"\s*\[\[gorsel:[^\]]+\]\]\s*$", "", RegexOptions.IgnoreCase).Trim();
        var fileName = System.IO.Path.GetFileName((match.Groups["file"].Value ?? string.Empty).Trim());
        return string.Equals(System.IO.Path.GetExtension(fileName), ".webp", StringComparison.OrdinalIgnoreCase)
            ? (cleanText, fileName)
            : (cleanText, string.Empty);
    }
}

@{
    var baslik = Convert.ToString(ViewData["CevapFormBaslik"] ?? "Seçenek");
    var altBaslik = Convert.ToString(ViewData["CevapFormAltBaslik"] ?? "Seçenek metni, görseli, puanı ve sınavdaki doğru cevap bilgisi");
    var aksiyon = Convert.ToString(ViewData["CevapFormAksiyon"] ?? ViewContext.RouteData.Values["action"]);
    var gruplar = ViewBag.Gur as List<SelectListItem> ?? new List<SelectListItem>();
    var gorselli = GorselliMetniCoz(Model?.CevapAdi);
    var imageBaseUrl = Url.Content("~/Content/AnketGorsel/");
    var imageUploadUrl = Url.Action("AssessmentWizardImageUpload", "Home");
    var geriUrl = Url.Action("CevapIndex", "Home");
    var puan = (Model?.CevapPuan ?? 0).ToString("0.##", CultureInfo.InvariantCulture);
    Func<string, string> imageUrl = file =>
    {
        file = (file ?? string.Empty).Trim();
        return string.IsNullOrWhiteSpace(file) ? string.Empty : imageBaseUrl + Uri.EscapeDataString(file);
    };
}

<div class="answer-editor">
    @using (Html.BeginForm(aksiyon, "Home", FormMethod.Post, new { @class = "answer-form", id = "answerBankForm" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(model => model.CevapId)
        <input type="hidden" id="CevapGorsel" value="@gorselli.Gorsel" />

        <section class="answer-hero">
            <div>
                <span class="answer-eyebrow">Seçenek Bankası</span>
                <h1>@baslik</h1>
                <p>@altBaslik</p>
            </div>
            <div class="answer-actions">
                <a class="answer-btn ghost" href="@geriUrl">
                    <i class="fa fa-arrow-left"></i> Geri
                </a>
                <button class="answer-btn primary" type="submit">
                    <i class="fa fa-check"></i> Kaydet
                </button>
            </div>
        </section>

        @Html.ValidationSummary(true, "", new { @class = "answer-validation" })
        <div class="answer-validation" id="clientAnswerError" hidden></div>

        <div class="answer-layout">
            <main class="answer-main">
                <section class="answer-section">
                    <div class="answer-section-head">
                        <span>01</span>
                        <h2>Seçenek</h2>
                    </div>

                    <label class="answer-field">
                        <span>Seçenek metni</span>
                        <input class="answer-input"
                               id="CevapAdi"
                               name="CevapAdi"
                               type="text"
                               value="@gorselli.Metin"
                               maxlength="250"
                               autofocus
                               placeholder="Seçenek metnini yazın" />
                        @Html.ValidationMessageFor(model => model.CevapAdi, "", new { @class = "answer-error" })
                    </label>

                    <div class="answer-image-editor">
                        <div class="answer-image-thumb" data-image-preview>
                            @if (!string.IsNullOrWhiteSpace(gorselli.Gorsel))
                            {
                                <img src="@imageUrl(gorselli.Gorsel)" alt="" loading="lazy" />
                            }
                            else
                            {
                                <i class="fa fa-image"></i>
                            }
                        </div>
                        <div class="answer-image-copy">
                            <strong>Seçenek görseli</strong>
                            <span data-image-name>@(string.IsNullOrWhiteSpace(gorselli.Gorsel) ? "Görsel yok" : gorselli.Gorsel)</span>
                        </div>
                        <div class="answer-image-actions">
                            <button class="answer-btn compact" type="button" data-upload-image>
                                <i class="fa fa-image"></i> Görsel Ekle
                            </button>
                            <button class="answer-icon-btn" type="button" data-remove-image title="Görseli kaldır" @(string.IsNullOrWhiteSpace(gorselli.Gorsel) ? "hidden" : "")>
                                <i class="fa fa-times"></i>
                            </button>
                        </div>
                    </div>
                </section>

                <section class="answer-section">
                    <div class="answer-section-head">
                        <span>02</span>
                        <h2>Puanlama</h2>
                    </div>

                    <div class="answer-grid">
                        <label class="answer-field">
                            <span>Anket puanı</span>
                            <input class="answer-input"
                                   id="CevapPuan"
                                   name="CevapPuan"
                                   type="number"
                                   min="0"
                                   max="1000"
                                   step="0.5"
                                   value="@puan"
                                   placeholder="Örn: 5" />
                            @Html.ValidationMessageFor(model => model.CevapPuan, "", new { @class = "answer-error" })
                        </label>

                        <label class="answer-switch">
                            <input type="checkbox" id="Dogru" name="Dogru" value="true" @(Model != null && Model.Dogru == true ? "checked" : "") />
                            <input type="hidden" name="Dogru" value="false" />
                            <span><i class="fa fa-check"></i></span>
                            <strong>Sınavlarda doğru cevap kabul edilsin</strong>
                        </label>
                    </div>
                </section>
            </main>

            <aside class="answer-side">
                <section class="answer-section">
                    <div class="answer-section-head compact">
                        <span>03</span>
                        <h2>Bağlantı</h2>
                    </div>

                    <label class="answer-field">
                        <span>Seçenek grubu</span>
                        @Html.DropDownListFor(m => m.CevapGrupId, gruplar, "Seçim", new { @class = "answer-select", required = "required" })
                        @Html.ValidationMessageFor(model => model.CevapGrupId, "", new { @class = "answer-error" })
                    </label>
                </section>

                <section class="answer-save-panel">
                    <button class="answer-btn primary wide" type="submit">
                        <i class="fa fa-check"></i> Kaydet
                    </button>
                    <a class="answer-btn ghost wide" href="@geriUrl">
                        <i class="fa fa-arrow-left"></i> Geri
                    </a>
                </section>
            </aside>
        </div>
    }
</div>

<style>
    .answer-editor { width: min(1500px, calc(100% - 48px)); margin: 34px auto 64px; color: #071832; }
    .answer-editor * { box-sizing: border-box; }
    .answer-hero, .answer-section, .answer-save-panel { border: 1px solid #d6e2f3; border-radius: 12px; background: rgba(255,255,255,.98); box-shadow: 0 20px 48px rgba(24,45,83,.08); }
    .answer-hero { display: flex; justify-content: space-between; gap: 28px; align-items: flex-start; padding: 32px 34px; background: linear-gradient(130deg, rgba(228,253,247,.96), rgba(247,249,255,.94) 56%, rgba(255,248,228,.78)), #fff; }
    .answer-eyebrow { display: inline-block; color: #255ef5; font-size: 12px; font-weight: 950; letter-spacing: .08em; text-transform: uppercase; }
    .answer-hero h1 { margin: 10px 0 8px; font-size: 40px; line-height: 1.1; font-weight: 950; letter-spacing: 0; }
    .answer-hero p { max-width: 740px; margin: 0; color: #526176; font-size: 15px; line-height: 1.6; font-weight: 700; }
    .answer-actions { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: 10px; min-width: 250px; }
    .answer-layout { display: grid; grid-template-columns: minmax(0, 1fr) 360px; gap: 18px; margin-top: 18px; align-items: start; }
    .answer-main, .answer-side { display: grid; gap: 18px; }
    .answer-section { padding: 22px; }
    .answer-save-panel { display: grid; gap: 10px; padding: 14px; }
    .answer-section-head { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; }
    .answer-section-head span { width: 34px; height: 34px; display: inline-grid; place-items: center; border-radius: 10px; color: #0b4b77; background: #eef9ff; font-size: 12px; font-weight: 950; }
    .answer-section-head h2 { margin: 0; font-size: 20px; line-height: 1.2; font-weight: 950; letter-spacing: 0; }
    .answer-section-head.compact h2 { font-size: 17px; }
    .answer-field { display: grid; gap: 8px; margin: 0 0 14px; }
    .answer-field > span { color: #253755; font-size: 13px; font-weight: 950; }
    .answer-input, .answer-select { width: 100%; min-height: 46px; border: 1px solid #cfdbec; border-radius: 10px; background: #fff; color: #071832; font-size: 14px; font-weight: 750; outline: none; padding: 0 13px; }
    .answer-input:focus, .answer-select:focus { border-color: #3562f4; box-shadow: 0 0 0 3px rgba(53,98,244,.12); }
    .answer-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(260px, .8fr); gap: 14px; align-items: end; }
    .answer-image-editor { display: grid; grid-template-columns: 104px minmax(0, 1fr) auto; gap: 14px; align-items: center; padding: 14px; border: 1px solid #d6e2f3; border-radius: 12px; background: #f8fbff; }
    .answer-image-thumb { width: 104px; aspect-ratio: 4 / 3; display: grid; place-items: center; overflow: hidden; border: 1px solid #d6e2f3; border-radius: 10px; background: #fff; color: #8aa0bf; }
    .answer-image-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .answer-image-copy { min-width: 0; display: grid; gap: 4px; }
    .answer-image-copy strong { font-size: 14px; font-weight: 950; }
    .answer-image-copy span { color: #64748b; font-size: 12px; font-weight: 800; overflow-wrap: anywhere; }
    .answer-image-actions { display: flex; gap: 8px; align-items: center; }
    .answer-btn, .answer-icon-btn { display: inline-flex; align-items: center; justify-content: center; gap: 8px; border: 1px solid #cfe0f6; border-radius: 10px; background: #fff; color: #071832; font-weight: 950; text-decoration: none; cursor: pointer; transition: transform .16s ease, box-shadow .16s ease; }
    .answer-btn { min-height: 42px; padding: 0 16px; }
    .answer-btn.compact { min-height: 38px; padding: 0 13px; font-size: 13px; }
    .answer-btn.primary { border-color: #22b8a6; color: #fff; background: linear-gradient(135deg, #16bca9, #3562f4); box-shadow: 0 16px 32px rgba(34,105,244,.18); }
    .answer-btn.wide { width: 100%; }
    .answer-btn:hover, .answer-icon-btn:hover { transform: translateY(-2px); box-shadow: 0 16px 34px rgba(19,42,80,.12); text-decoration: none; }
    .answer-icon-btn { width: 38px; min-width: 38px; min-height: 38px; padding: 0; color: #1763df; }
    .answer-switch { min-height: 46px; display: flex; align-items: center; gap: 10px; margin: 0; padding: 0 13px; border: 1px solid #d6e2f3; border-radius: 10px; background: #fff; color: #344054; cursor: pointer; }
    .answer-switch input { position: absolute; opacity: 0; pointer-events: none; }
    .answer-switch span { width: 30px; height: 30px; min-width: 30px; display: inline-grid; place-items: center; border-radius: 9px; color: #9aa8bd; border: 1px solid #d6e2f3; background: #fff; }
    .answer-switch input:checked + input + span { color: #fff; border-color: #10b981; background: #10b981; }
    .answer-switch strong { font-size: 13px; line-height: 1.3; }
    .answer-validation { margin: 16px 0 0; padding: 12px 14px; border: 1px solid #fecaca; border-radius: 10px; color: #991b1b; background: #fff1f2; font-weight: 800; }
    .answer-validation.validation-summary-valid, .answer-validation[hidden] { display: none; }
    .answer-error { color: #b42318; font-size: 12px; font-weight: 800; }
    @@media (max-width: 1100px) { .answer-layout { grid-template-columns: 1fr; } .answer-side { grid-template-columns: 1fr 1fr; } }
    @@media (max-width: 760px) { .answer-editor { width: min(100% - 22px, 1500px); margin-top: 18px; } .answer-hero { display: grid; padding: 24px; } .answer-actions { justify-content: flex-start; min-width: 0; } .answer-hero h1 { font-size: 32px; } .answer-side, .answer-grid { grid-template-columns: 1fr; } .answer-image-editor { grid-template-columns: 82px 1fr; } .answer-image-thumb { width: 82px; } .answer-image-actions { grid-column: 1 / -1; } }
</style>

<script>
    (function () {
        const form = document.getElementById("answerBankForm");
        if (!form) return;

        const uploadUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(imageUploadUrl));
        const imageBaseUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(imageBaseUrl));
        const textInput = document.getElementById("CevapAdi");
        const imageInput = document.getElementById("CevapGorsel");
        const preview = form.querySelector("[data-image-preview]");
        const imageName = form.querySelector("[data-image-name]");
        const removeButton = form.querySelector("[data-remove-image]");
        const clientError = document.getElementById("clientAnswerError");

        function cleanImageName(value) {
            return String(value || "").split(/[\\/]/).pop().trim();
        }

        function cleanText(value) {
            return String(value || "").replace(/\s*\[\[gorsel:[^\]]+\]\]\s*$/i, "").trim();
        }

        function imageUrl(fileName) {
            const cleanName = cleanImageName(fileName);
            return cleanName ? imageBaseUrl + encodeURIComponent(cleanName) : "";
        }

        function renderImage(fileName) {
            const cleanName = cleanImageName(fileName);
            const url = imageUrl(cleanName);
            imageInput.value = cleanName;
            preview.innerHTML = url ? `<img src="${url}" alt="" loading="lazy" />` : `<i class="fa fa-image"></i>`;
            imageName.textContent = cleanName || "Görsel yok";
            if (removeButton) removeButton.hidden = !cleanName;
        }

        function showClientError(message) {
            if (!clientError) return;
            clientError.textContent = message;
            clientError.hidden = !message;
        }

        function pickImageFile() {
            return new Promise(resolve => {
                const input = document.createElement("input");
                input.type = "file";
                input.accept = "image/jpeg,image/png,image/webp,image/gif";
                input.addEventListener("change", () => resolve(input.files && input.files[0] ? input.files[0] : null), { once: true });
                input.click();
            });
        }

        async function uploadImage() {
            const file = await pickImageFile();
            if (!file) return "";

            const token = form.querySelector("input[name='__RequestVerificationToken']")?.value || "";
            const body = new FormData();
            body.append("__RequestVerificationToken", token);
            body.append("file", file);

            const response = await fetch(uploadUrl, { method: "POST", body });
            const result = await response.json();
            if (!result.success) {
                window.alert(result.message || "Görsel yüklenemedi.");
                return "";
            }

            return result.fileName || "";
        }

        form.addEventListener("click", async event => {
            if (event.target.closest("[data-upload-image]")) {
                const fileName = await uploadImage();
                if (fileName) renderImage(fileName);
                return;
            }

            if (event.target.closest("[data-remove-image]")) {
                renderImage("");
            }
        });

        form.addEventListener("submit", event => {
            showClientError("");
            const text = cleanText(textInput.value);
            const image = cleanImageName(imageInput.value);

            if (!text && !image) {
                event.preventDefault();
                showClientError("Seçenek metni veya görseli zorunlu.");
                textInput.focus();
                return;
            }

            if (!image) {
                textInput.value = text.slice(0, 250);
                return;
            }

            const marker = `[[gorsel:${image}]]`;
            const room = Math.max(0, 250 - marker.length - 1);
            const clippedText = text.slice(0, room).trimEnd();
            textInput.value = clippedText ? `${clippedText} ${marker}` : marker;
        });
    })();
</script>
