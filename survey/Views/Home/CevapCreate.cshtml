@model survey.Models.Cevap
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="panel card shadow-sm p-3">
    <h4 class="fw-bold text-primary">Yeni Seçenek</h4>
    <p class="text-muted mb-3">Anketlerde puan, sınavlarda doğru cevap mantığı burada tanımlanır.</p>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="form-group mb-3">
            <h5>Seçenek Metni</h5>
            @Html.EditorFor(model => model.CevapAdi, new { htmlAttributes = new { @class = "form-control", @Required = "", autofocus = "", @maxlength = "250" } })
            @Html.ValidationMessageFor(model => model.CevapAdi, "", new { @class = "text-danger" })
        </div>

        <div class="form-group mb-3">
            <h5>Seçenek Grubu</h5>
            @Html.DropDownListFor(m => m.CevapGrupId, (List<SelectListItem>)ViewBag.Gur, "Seçim", new { @class = "form-control", @Required = "" })
            @Html.ValidationMessageFor(model => model.CevapGrupId, "", new { @class = "text-danger" })
        </div>

        <div class="form-group mb-3">
            <h5>Anket Puanı</h5>
            @Html.EditorFor(model => model.CevapPuan, new { htmlAttributes = new { @class = "form-control", @Required = "", @maxlength = "6", placeholder = "Örn: 5" } })
            @Html.ValidationMessageFor(model => model.CevapPuan, "", new { @class = "text-danger" })
            <small class="text-muted">Anketlerde 1-5 gibi ölçek puanı için kullanılır. Sınav puanı soru üzerinden hesaplanır.</small>
        </div>

        <div class="form-check mb-4">
            <input class="form-check-input" type="checkbox" id="Dogru" name="Dogru" value="true" @(Model != null && Model.Dogru == true ? "checked" : "") />
            <input type="hidden" name="Dogru" value="false" />
            <label class="form-check-label fw-bold" for="Dogru">Sınavlarda doğru cevap kabul edilsin</label>
        </div>

        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" href="@Url.Action("CevapIndex", "Home")">
                <i class="fa fa-backward"></i> Geri
            </a>
            <button type="submit" class="btn btn-primary">
                <i class="fa fa-check"></i> Kaydet
            </button>
        </div>
    }
</div>
