            @if (grup.Cinsiyet.Any() || grup.Egitim.Any() || grup.Yas.Any())
            {
                <div class="two-col" style="margin-top:18px;">
                    @if (grup.Cinsiyet.Any())
                    {
                        <div class="section-card">
