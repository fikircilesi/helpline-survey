                                        <div class="bar-label">@row.Ad</div>
                                        <div class="score-bar"><span style="width:@PercentWidth(row.Puan)"></span></div>
                                        <div class="bar-value">@PercentText(row.Puan)%</div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="page-footer">
                <span>Soru Grubu Bazlı Değerlendirme</span>
                <span>@grup.Kisi katılımcı</span>
            </div>
        </section>
