                <div class="big-score-number">@PercentText(grup.Puan)%</div>
                <div class="score-bar"><span style="width:@PercentWidth(grup.Puan)"></span></div>
            </div>

            <div class="section-card">
                <h3 class="section-title">Bu Gruptaki Sorular</h3>
