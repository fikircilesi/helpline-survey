                                    </div>
                                }
                            </div>
                        </div>
                    }
                    @if (grup.Egitim.Any())
                    {
                        <div class="section-card">
                            <h3 class="section-title">Eğitim Durumuna Göre</h3>
                            <div class="bar-list">
                                @foreach (var row in grup.Egitim)
                                {
                                    <div class="bar-row">
                                        <div class="bar-label">@row.Ad</div>
                                        <div class="score-bar"><span style="width:@PercentWidth(row.Puan)"></span></div>
                                        <div class="bar-value">@PercentText(row.Puan)%</div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    @if (grup.Yas.Any())
                    {
                        <div class="section-card">
                            <h3 class="section-title">Yaşa Göre</h3>
                            <div class="bar-list">
                                @foreach (var row in grup.Yas)
