@model survey.Models.AnketGrup
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="text-uppercase">Soru Grubu Ekle</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

<div class="form-horizontal">
    <hr />
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <div class="form-group">
        <div hidden class="col-md-10">
            @Html.TextBoxFor(model => model.AnketId, new { @Value = ViewBag.id })
            @Html.ValidationMessageFor(model => model.AnketId, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-10">
            <h5>Soru Grup Adı</h5>
            @Html.DropDownListFor(m => m.SoruGrupId, (List<SelectListItem>)ViewBag.Sor, "Seçim", new { @class = "form-control", @Required = "" })
            @Html.ValidationMessageFor(model => model.SoruGrupId, "", new { @class = "text-danger" })
        </div>

    </div>
    <a class="btn btn-primary btn-outline-primary fa fa-backward" href="@Url.Action("AnketGrupIndex", "Home", new {id = ViewBag.id, adi = ViewBag.adi})"> Geri</a>
    <input hidden name="adi" value="@ViewBag.adi" />
    <input type="submit" class="btn btn-primary btn-outline-primary fa fa-check" value=" Kayıt" />
</div>
}
