@model survey.Models.Cevap

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    ViewData["DeleteEyebrow"] = "Seçenek bankası";
    ViewData["DeleteTitle"] = "Seçenek silinsin mi?";
    ViewData["DeleteDescription"] = "Bu cevap seçeneği bankadan kaldırılacak. Sorular veya katılım cevapları tarafından kullanılıyorsa silme işlemi engellenir.";
    ViewData["DeleteItemLabel"] = "Seçenek";
    ViewData["DeleteItemName"] = Model?.CevapAdi;
    ViewData["DeleteWarning"] = "Bu işlem geri alınamaz. Kullanımda olan seçenekleri silmeden önce bağlı kayıtları temizleyin.";
    ViewData["DeleteBackUrl"] = Url.Action("CevapIndex", "Home");
    ViewData["DeleteSubmitText"] = "Seçeneği sil";
}

@await Html.PartialAsync("_DeleteConfirm")
