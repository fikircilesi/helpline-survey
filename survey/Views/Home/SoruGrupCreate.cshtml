@model survey.Models.SoruGrup
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Yeni Bölüm / Kategori</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="form-group">
            <div class="col-md-10">
                <h5>Bölüm / Kategori Adı</h5>
                @Html.EditorFor(model => model.SoruGrupAdi, new { htmlAttributes = new { @class = "form-control", @Required = "", @maxlength = "50" } })
                @Html.ValidationMessageFor(model => model.SoruGrupAdi, "", new { @class = "text-danger" })
            </div>
            <div class="col-md-10">
                <h5>Toplam Puan</h5>
                @Html.EditorFor(model => model.SoruGrupPuan, new { htmlAttributes = new { @class = "form-control", @Required = "", @maxlength = "2" } })
                @Html.ValidationMessageFor(model => model.SoruGrupPuan, "", new { @class = "text-danger" })
            </div>
            <div class="col-md-10">
                <h5>Sıra</h5>
                @Html.EditorFor(model => model.SoruGrupSira, new { htmlAttributes = new { @class = "form-control", @Required = "", @maxlength = "3" } })
                @Html.ValidationMessageFor(model => model.SoruGrupSira, "", new { @class = "text-danger" })
            </div>

        </div>
        <a class="btn btn-primary btn-outline-primary fa fa-backward" href="@Url.Action("SoruGrupIndex", "Home")"> Geri</a>
        <input type="submit" class="btn btn-primary btn-outline-primary fa fa-check" value=" Kayıt" />
    </div>
}
