@model IEnumerable<survey.Models.Anket>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var toplamMap = ViewBag.ZamanToplam as System.Collections.Generic.Dictionary<int, int>
        ?? new System.Collections.Generic.Dictionary<int, int>();
    var devamMap = ViewBag.ZamanDevam as System.Collections.Generic.Dictionary<int, int>
        ?? new System.Collections.Generic.Dictionary<int, int>();
    var bittiMap = ViewBag.ZamanBitti as System.Collections.Generic.Dictionary<int, int>
        ?? new System.Collections.Generic.Dictionary<int, int>();
    var cevapliKatilimMap = ViewBag.ZamanCevapliKatilim as System.Collections.Generic.Dictionary<int, int>
        ?? new System.Collections.Generic.Dictionary<int, int>();
}

<style>
    .time-reset-shell {
        background: #fff;
        border: 1px solid #e3eaf4;
        border-radius: 8px;
        box-shadow: 0 18px 44px rgba(15, 23, 42, .07);
        overflow: hidden;
    }

    .time-reset-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        padding: 22px 24px;
        background: linear-gradient(135deg, #f4fbff, #f8f7ff);
        border-bottom: 1px solid #e3eaf4;
    }

    .time-reset-head h2 {
        margin: 0;
        color: #111827;
        font-size: 24px;
        font-weight: 900;
    }

    .time-reset-head p {
        margin: 6px 0 0;
        color: #64748b;
        font-size: 14px;
    }

    .time-reset-body {
        padding: 22px 24px 26px;
    }

    .time-table {
        width: 100%;
        border-collapse: collapse;
    }

    .time-table th,
    .time-table td {
        padding: 14px 12px;
        border-bottom: 1px solid #edf2f7;
        color: #1f2937;
        vertical-align: middle;
    }

    .time-table th {
        color: #64748b;
        font-size: 12px;
        font-weight: 900;
        letter-spacing: .06em;
        text-transform: uppercase;
        background: #f8fafc;
    }

    .time-name {
        font-weight: 900;
        color: #0f172a;
    }

    .time-pill {
        display: inline-flex;
        align-items: center;
        min-height: 30px;
        padding: 6px 10px;
        border-radius: 999px;
        background: #edf2ff;
        color: #3651d4;
        font-size: 12px;
        font-weight: 900;
    }

    .time-pill.done {
        background: #fff0f0;
        color: #c53030;
    }

    .time-pill.live {
        background: #e9fbf3;
        color: #08724f;
    }

    .time-action {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 36px;
        padding: 0 12px;
        border: 1px solid #c7d7ea;
        border-radius: 8px;
        color: #163b64;
        background: #fff;
        font-weight: 900;
    }

    .empty-time-state {
        padding: 34px;
        border: 1px dashed #cbd5e1;
        border-radius: 8px;
        color: #64748b;
        background: #f8fafc;
        text-align: center;
        font-weight: 800;
    }
</style>

<div class="time-reset-shell">
    <div class="time-reset-head">
        <div>
            <h2>Süre Kayıtları</h2>
            <p>Bu liste cevap katılımını değil, sınav zaman takibini gösterir. Kişi çalışmayı açınca süre kaydı oluşabilir.</p>
        </div>
        <a class="time-action" href="@Url.Action("Indexgosterge", "Home")">Geri</a>
    </div>

    <div class="time-reset-body">
        @if (!Model.Any())
        {
            <div class="empty-time-state">
                Bu çalışma alanında sıfırlanabilecek süre kaydı yok.
            </div>
        }
        else
        {
            <table class="time-table">
                <thead>
                    <tr>
                        <th>Çalışma</th>
                        <th>Sınav süresi</th>
                        <th>Süre kaydı</th>
                        <th>Cevaplı katılım</th>
                        <th>Devam eden</th>
                        <th>Süresi dolan</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var toplam = toplamMap.ContainsKey(item.AnketId) ? toplamMap[item.AnketId] : 0;
                        var cevapliKatilim = cevapliKatilimMap.ContainsKey(item.AnketId) ? cevapliKatilimMap[item.AnketId] : 0;
                        var devam = devamMap.ContainsKey(item.AnketId) ? devamMap[item.AnketId] : 0;
                        var bitti = bittiMap.ContainsKey(item.AnketId) ? bittiMap[item.AnketId] : 0;
                        <tr>
                            <td class="time-name">@item.AnketAdi</td>
                            <td>@(item.Zaman.HasValue && item.Zaman.Value > 0 ? item.Zaman + " dk" : "Sınırsız")</td>
                            <td><span class="time-pill">@toplam süre kaydı</span></td>
                            <td><span class="time-pill">@cevapliKatilim cevaplı</span></td>
                            <td><span class="time-pill live">@devam</span></td>
                            <td><span class="time-pill done">@bitti</span></td>
                            <td>
                                <a class="time-action" href="@Url.Action("AnketZamanIndex1", "Home", new { id = item.AnketId })">
                                    Süre kayıtlarını gör
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
