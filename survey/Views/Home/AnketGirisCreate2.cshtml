@model survey.Models.Tumcontroller
@{
    Layout = "~/Views/Shared/_AnketLayout.cshtml";

    var sorular = (Model.Sor ?? Enumerable.Empty<survey.Models.Soru>())
        .OrderBy(x => x.SoruSira)
        .ThenBy(x => x.SoruId)
        .ToList();
    var cevaplar = (Model.Cev ?? Enumerable.Empty<survey.Models.Cevap>()).ToList();
    var havuz = (Model.Hav ?? Enumerable.Empty<survey.Models.Havuz>()).ToList();

    int? sessionUserId = null;
    if (Session["id"] != null)
    {
        sessionUserId = Convert.ToInt32(Session["id"]);
    }

    int? katilimKodu = null;
    if (ViewBag.kod != null)
    {
        katilimKodu = Convert.ToInt32(ViewBag.kod);
    }

    int? linkUserId = null;
    if (ViewBag.user != null)
    {
        linkUserId = Convert.ToInt32(ViewBag.user);
    }

    Func<survey.Models.Soru, survey.Models.Havuz> seciliBul = soru => havuz.FirstOrDefault(h =>
        h.SoruID == soru.SoruId &&
        (
            (katilimKodu.HasValue && h.Isimsiz == katilimKodu.Value) ||
            (!katilimKodu.HasValue && sessionUserId.HasValue && h.UserId == sessionUserId.Value) ||
            (!katilimKodu.HasValue && linkUserId.HasValue && h.UserId == linkUserId.Value)
        ));

    var ilkCevapsizIndex = sorular.FindIndex(x => seciliBul(x) == null);
    if (ilkCevapsizIndex < 0)
    {
        ilkCevapsizIndex = 0;
    }

    var cevaplananSayisi = sorular.Count(x => seciliBul(x) != null);
    var calismaTuru = Convert.ToString(ViewBag.calismaTuru ?? (ViewBag.sinav == true ? "Sınav" : "Anket"));
    var calismaTuruKucuk = calismaTuru.ToLower(new System.Globalization.CultureInfo("tr-TR"));
    var bitirMetni = calismaTuru == "Anket" ? "Anketi Bitir" : (calismaTuru == "Eğitim" ? "Eğitimi Bitir" : "Sınavı Bitir");
    var tamamlandiBaslik = calismaTuru + " tamamlandı";
    var katilimciAdi = Convert.ToString(ViewBag.katilimciAdi ?? Session["adi"] ?? string.Empty);
    var katilimciResim = Convert.ToString(ViewBag.katilimciResim ?? string.Empty);
    var katilimciCinsiyet = Convert.ToString(ViewBag.katilimciCinsiyet ?? string.Empty);
    var karsilamaMetni = !string.IsNullOrWhiteSpace(katilimciAdi)
        ? "Sayın " + katilimciAdi + ", hoş geldiniz"
        : "Hoş geldiniz";
}

@functions {
    private sealed class GorselliMetin
    {
        public string Metin { get; set; }
        public string GorselUrl { get; set; }
    }

    private GorselliMetin GorselliMetniCoz(string value)
    {
        var text = value ?? string.Empty;
        var match = System.Text.RegularExpressions.Regex.Match(
            text,
            @"\s*\[\[gorsel:(?<file>[^\]]+)\]\]\s*$",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);

        if (!match.Success)
        {
            return new GorselliMetin { Metin = text, GorselUrl = string.Empty };
        }

        var fileName = System.IO.Path.GetFileName(match.Groups["file"].Value.Trim());
        var cleanText = text.Substring(0, match.Index).Trim();
        var url = string.IsNullOrWhiteSpace(fileName)
            ? string.Empty
            : Url.Content("~/Content/AnketGorsel/" + System.Uri.EscapeDataString(fileName));

        return new GorselliMetin { Metin = cleanText, GorselUrl = url };
    }
}

