@{
    Layout = null;
    var sayfa = (ViewBag.YasalSayfa as string) ?? "kurumsal";
    var baslik = (ViewBag.YasalBaslik as string) ?? "Survey by Aslana Teknoloji";
    var ozet = (ViewBag.YasalOzet as string) ?? "Kurumsal bilgilendirme";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <title>@baslik | Survey by Aslana Teknoloji</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=0, minimal-ui">
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="description" content="@ozet">
    <link rel="icon" href="~/Content/img/aslana-favicon.png" type="image/png">
    <link rel="stylesheet" type="text/css" href="~/files/bower_components/bootstrap/dist/css/bootstrap.min.css">
    <link rel="stylesheet" type="text/css" href="~/files/assets/icon/themify-icons/themify-icons.css">
    <style>
        :root {
            --ink: #152033;
            --muted: #64748b;
            --line: #dbe6f4;
            --teal: #15b8a6;
            --cyan: #28c7d9;
            --indigo: #4257e8;
            --violet: #7c3aed;
            --amber: #ffb84d;
            --coral: #ff6b5d;
            --navy: #10192c;
        }

        * {
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            margin: 0;
            color: var(--ink);
            font-family: "Segoe UI", Arial, sans-serif;
            background:
                linear-gradient(128deg, rgba(21, 184, 166, .20) 0 19%, transparent 19% 100%),
                linear-gradient(28deg, transparent 0 56%, rgba(255, 184, 77, .16) 56% 100%),
                repeating-linear-gradient(90deg, rgba(16, 25, 44, .045) 0 1px, transparent 1px 74px),
                repeating-linear-gradient(0deg, rgba(16, 25, 44, .035) 0 1px, transparent 1px 74px),
                linear-gradient(180deg, #ffffff 0%, #f7fbff 100%);
        }

        a,
        a:hover {
            text-decoration: none;
        }

        .legal-shell {
            width: min(1120px, calc(100% - 32px));
            min-height: 100vh;
            margin: 0 auto;
            padding: 26px 0 52px;
        }

        .legal-nav,
        .legal-hero,
        .legal-card {
            border-radius: 8px;
        }

        .legal-nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            margin-bottom: 22px;
        }

        .brand-lockup {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            min-height: 56px;
            padding: 8px 15px 8px 12px;
            color: #fff;
            border: 1px solid rgba(255, 255, 255, .16);
            border-radius: 8px;
            background: linear-gradient(135deg, #121a2b 0%, #26384f 58%, #24325f 100%);
            box-shadow: 0 18px 42px rgba(21, 32, 51, .18);
        }

        .brand-mark {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            border-radius: 8px;
            color: #fff;
            background: linear-gradient(135deg, var(--teal), var(--indigo));
        }

        .brand-copy strong,
        .brand-copy span {
            display: block;
            line-height: 1;
        }

        .brand-copy strong {
            color: #fff;
            font-size: 24px;
            font-weight: 900;
            text-transform: lowercase;
        }

        .brand-copy span {
            margin-top: 4px;
            color: rgba(255, 255, 255, .74);
            font-size: 12px;
            font-weight: 700;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            min-height: 42px;
            padding: 0 14px;
            border: 1px solid rgba(132, 151, 176, .38);
            border-radius: 8px;
            color: #26344c;
            background: rgba(255, 255, 255, .82);
            font-weight: 850;
            box-shadow: 0 12px 28px rgba(49, 73, 118, .08);
        }

        .legal-hero {
            position: relative;
            overflow: hidden;
            padding: 32px;
            border: 1px solid rgba(132, 151, 176, .26);
            background:
                linear-gradient(135deg, rgba(255, 255, 255, .94), rgba(255, 255, 255, .72)),
                linear-gradient(90deg, rgba(21, 184, 166, .16), rgba(66, 87, 232, .12), rgba(255, 184, 77, .15));
            box-shadow: 0 24px 70px rgba(49, 73, 118, .14);
        }

        .legal-hero::before {
            position: absolute;
            inset: 0 0 auto;
            height: 5px;
            background: linear-gradient(90deg, var(--teal), var(--cyan), var(--indigo), var(--violet), var(--coral), var(--amber));
            content: "";
        }

        .legal-kicker {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            min-height: 30px;
            padding: 0 11px;
            border-radius: 999px;
            color: #0f766e;
            background: rgba(21, 184, 166, .12);
            font-size: 11px;
            font-weight: 900;
            text-transform: uppercase;
        }

        h1 {
            max-width: 780px;
            margin: 14px 0 0;
            color: #111827;
            font-size: 42px;
            line-height: 1.08;
            font-weight: 900;
            letter-spacing: 0;
        }

        .hero-copy {
            max-width: 720px;
            margin: 12px 0 0;
            color: #536174;
            font-size: 16px;
            line-height: 1.65;
            font-weight: 550;
        }

        .legal-tabs {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 22px;
        }

        .legal-tabs a {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            min-height: 38px;
            padding: 0 13px;
            border: 1px solid rgba(132, 151, 176, .28);
            border-radius: 8px;
            color: #314057;
            background: rgba(255, 255, 255, .78);
            font-size: 12px;
            font-weight: 900;
        }

        .legal-tabs a.is-active {
            color: #fff;
            border-color: transparent;
            background: linear-gradient(135deg, var(--navy), var(--indigo), var(--teal));
            box-shadow: 0 14px 28px rgba(66, 87, 232, .18);
        }

        .legal-grid {
            display: grid;
            grid-template-columns: minmax(0, 1.15fr) minmax(300px, .85fr);
            gap: 16px;
            margin-top: 18px;
        }

        .legal-card {
            padding: 22px;
            border: 1px solid rgba(132, 151, 176, .28);
            background: rgba(255, 255, 255, .88);
            box-shadow: 0 18px 48px rgba(49, 73, 118, .10);
        }

        .legal-card h2 {
            margin: 0 0 12px;
            color: #142033;
            font-size: 22px;
            line-height: 1.18;
            font-weight: 900;
        }

        .legal-card h3 {
            margin: 20px 0 8px;
            color: #172033;
            font-size: 16px;
            font-weight: 900;
        }

        .legal-card p,
        .legal-card li {
            color: #5f6f86;
            font-size: 14px;
            line-height: 1.68;
        }

        .legal-card ul {
            margin: 10px 0 0;
            padding-left: 18px;
        }

        .info-list {
            display: grid;
            gap: 10px;
        }

        .info-item {
            display: grid;
            gap: 4px;
            padding: 12px;
            border: 1px solid rgba(132, 151, 176, .24);
            border-radius: 8px;
            background: linear-gradient(135deg, #ffffff, #f7fbff);
        }

        .info-item small {
            color: #667085;
            font-size: 11px;
            font-weight: 900;
            text-transform: uppercase;
        }

        .info-item strong,
        .info-item span {
            color: #162137;
            font-size: 13px;
            font-weight: 850;
            overflow-wrap: anywhere;
        }

        .trust-band {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 10px;
            margin-top: 16px;
        }

        .trust-band div {
            min-height: 88px;
            padding: 14px;
            border: 1px solid rgba(132, 151, 176, .26);
            border-radius: 8px;
            background:
                linear-gradient(135deg, rgba(255, 255, 255, .88), rgba(255, 255, 255, .68)),
                linear-gradient(135deg, rgba(21, 184, 166, .12), rgba(66, 87, 232, .09));
        }

        .trust-band i {
            color: var(--teal);
            font-size: 18px;
        }

        .trust-band strong {
            display: block;
            margin-top: 8px;
            color: #172033;
            font-size: 13px;
            font-weight: 900;
        }

        .trust-band span {
            display: block;
            margin-top: 4px;
            color: #64748b;
            font-size: 12px;
            line-height: 1.42;
        }

        @@media (max-width: 820px) {
            .legal-nav,
            .legal-grid {
                grid-template-columns: 1fr;
                flex-direction: column;
                align-items: stretch;
            }

            .back-link {
                width: 100%;
            }

            .legal-hero {
                padding: 24px 18px;
            }

            h1 {
                font-size: 34px;
            }

            .trust-band {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <main class="legal-shell">
        <nav class="legal-nav">
            <a class="brand-lockup" href="@Url.Action("Giris", "Home")" aria-label="Survey ana sayfa">
                <span class="brand-mark"><i class="ti-check-box"></i></span>
                <span class="brand-copy">
                    <strong>survey</strong>
                    <span>by Aslana Teknoloji</span>
                </span>
            </a>
            <a class="back-link" href="@Url.Action("Giris", "Home")"><i class="ti-arrow-left"></i> Giriş ekranına dön</a>
        </nav>

        <section class="legal-hero">
            <span class="legal-kicker"><i class="ti-shield"></i> Survey güven merkezi</span>
            <h1>@baslik</h1>
            <p class="hero-copy">@ozet</p>
            <div class="legal-tabs" aria-label="Yasal ve kurumsal sayfalar">
                <a class="@(sayfa == "kurumsal" ? "is-active" : "")" href="@Url.Action("Kurumsal", "Home")"><i class="ti-building"></i> Kurumsal</a>
                <a class="@(sayfa == "gizlilik" ? "is-active" : "")" href="@Url.Action("GizlilikPolitikasi", "Home")"><i class="ti-lock"></i> Gizlilik ve KVKK</a>
                <a class="@(sayfa == "iade" ? "is-active" : "")" href="@Url.Action("IadePolitikasi", "Home")"><i class="ti-receipt"></i> İade ve satış</a>
            </div>
        </section>

        @if (sayfa == "kurumsal")
        {
            <section class="legal-grid">
                <article class="legal-card">
                    <h2>Aslana Teknoloji ve E-Ticaret Ltd. Şti.</h2>
                    <p>
                        Survey; sınav, anket, eğitim katılımı, sertifika ve raporlama süreçlerini tek çalışma alanında toplamak için Aslana Teknoloji tarafından geliştirilen yerli yazılım platformudur.
                    </p>
                    <p>
                        Platformda ödeme adımları Tami ortak ödeme sayfasında tamamlanır; kart bilgileri Survey panelinde saklanmaz. Katılımcı, soru ve sonuç verileri çalışma alanı yetkileriyle sınırlandırılır.
                    </p>
                    <div class="trust-band">
                        <div><i class="ti-server"></i><strong>Yerli altyapı</strong><span>Ürün ve destek süreçleri Türkiye merkezli yürütülür.</span></div>
                        <div><i class="ti-credit-card"></i><strong>Güvenli ödeme</strong><span>Paket ödemeleri Tami ödeme altyapısı ile ilerler.</span></div>
                        <div><i class="ti-lock"></i><strong>Yetki kontrolü</strong><span>Çalışma alanı, kullanıcı ve katılımcı erişimleri ayrıştırılır.</span></div>
                    </div>
                </article>
                <aside class="legal-card">
                    <h2>Resmi bilgiler</h2>
                    <div class="info-list">
                        <div class="info-item"><small>Unvan</small><strong>Aslana Teknoloji ve E-Ticaret Ltd. Şti.</strong></div>
                        <div class="info-item"><small>MERSİS</small><span>0089146437500001</span></div>
                        <div class="info-item"><small>Adres</small><span>Balat Mah. Hızır Çavuş Mescidi Sk. No:40A Fatih / İstanbul</span></div>
                        <div class="info-item"><small>İletişim</small><span>+90 212 916 18 58<br>info@aslana.com.tr</span></div>
                        <div class="info-item"><small>KEP</small><span>aslanateknoloji@hs09.kep.tr</span></div>
                        <div class="info-item"><small>ETBİS</small><span>ETBİS'e kayıtlıdır.</span></div>
                    </div>
                </aside>
            </section>
        }
        else if (sayfa == "gizlilik")
        {
            <section class="legal-grid">
                <article class="legal-card" id="kvkk">
                    <h2>Gizlilik ve KVKK yaklaşımı</h2>
                    <p>
                        Survey'de hesap, çalışma alanı, katılımcı, sınav, anket, cevap, rapor ve sertifika bilgileri hizmetin yürütülmesi için işlenir. Veriler yetkili kullanıcı rolleriyle sınırlandırılır ve iş amacı dışında paylaşılmaz.
                    </p>
                    <h3>İşlenen veri grupları</h3>
                    <ul>
                        <li>Yönetici hesabı için ad soyad, e-posta, telefon, firma ve kullanıcı bilgileri.</li>
                        <li>Katılımcı süreçleri için katılım kodu, cevaplar, puanlar, tamamlama durumu ve sertifika bilgileri.</li>
                        <li>Güvenlik ve kalite için oturum, işlem tarihi ve sistem kayıtları.</li>
                    </ul>
                    <h3>Temel ilkeler</h3>
                    <ul>
                        <li>Veriler ölçme, raporlama, sertifika üretimi, destek ve güvenlik amaçlarıyla kullanılır.</li>
                        <li>Çalışma alanı verilerine erişim ilgili hesap ve yetkilerle sınırlandırılır.</li>
                        <li>Silme, düzeltme ve bilgi talepleri için info@aslana.com.tr adresinden iletişim kurulabilir.</li>
                    </ul>
                </article>
                <aside class="legal-card">
                    <h2>Güvenlik başlıkları</h2>
                    <div class="info-list">
                        <div class="info-item"><small>Erişim</small><span>Panel, üyelik ve katılım kodu akışları ayrı tutulur.</span></div>
                        <div class="info-item"><small>Ödeme</small><span>Kart bilgileri Survey panelinde saklanmaz.</span></div>
                        <div class="info-item"><small>Çerez</small><span>Oturum, güvenlik ve kullanım sürekliliği için zorunlu çerezler kullanılabilir.</span></div>
                        <div class="info-item"><small>İletişim</small><span>info@aslana.com.tr<br>+90 212 916 18 58</span></div>
                    </div>
                </aside>
            </section>
        }
        else
        {
            <section class="legal-grid">
                <article class="legal-card" id="mesafeli-satis">
                    <h2>İade ve satış koşulları</h2>
                    <p>
                        Survey paketleri; sınav, anket, katılımcı, rapor, sertifika ve çalışma alanı kullanım limitlerine göre sunulan dijital hizmetlerdir. Paket yükseltme ve ödeme adımları kullanıcı onayıyla başlatılır.
                    </p>
                    <h3>Ödeme süreci</h3>
                    <ul>
                        <li>Ücretli paket ödemeleri Tami ödeme altyapısı üzerinden tamamlanır.</li>
                        <li>Kart bilgileri Survey uygulaması içinde tutulmaz.</li>
                        <li>Satın alma sonrası paket hakkı ilgili çalışma alanına tanımlanır.</li>
                    </ul>
                    <h3>İade değerlendirmesi</h3>
                    <ul>
                        <li>İade talepleri hizmetin kullanımı, paket aktivasyonu ve mevzuat koşulları birlikte değerlendirilerek sonuçlandırılır.</li>
                        <li>Hatalı veya mükerrer ödeme durumlarında destek ekibi ödeme kaydını inceleyerek yönlendirme yapar.</li>
                        <li>İade ve fatura talepleri için info@aslana.com.tr adresine ödeme bilgisiyle başvurulabilir.</li>
                    </ul>
                </article>
                <aside class="legal-card">
                    <h2>Satış özeti</h2>
                    <div class="info-list">
                        <div class="info-item"><small>Satıcı</small><strong>Aslana Teknoloji ve E-Ticaret Ltd. Şti.</strong></div>
                        <div class="info-item"><small>Hizmet</small><span>Survey dijital sınav, anket, sertifika ve raporlama platformu.</span></div>
                        <div class="info-item"><small>Ödeme altyapısı</small><span>Tami ortak ödeme sayfası.</span></div>
                        <div class="info-item"><small>Destek</small><span>info@aslana.com.tr<br>+90 212 916 18 58</span></div>
                    </div>
                </aside>
            </section>
        }
    </main>
</body>
</html>
