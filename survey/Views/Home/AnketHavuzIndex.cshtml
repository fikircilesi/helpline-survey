@model IEnumerable<survey.Models.Havuz>
@using System
@using System.Globalization
@using System.Linq

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var culture = new CultureInfo("tr-TR");
    var kayitlar = (Model ?? Enumerable.Empty<survey.Models.Havuz>())
        .Where(x => x.AnketId.HasValue)
        .ToList();

    var calismalar = kayitlar
        .GroupBy(x => x.AnketId.Value)
        .Select(g =>
        {
            var anketAdi = g.Select(x => x.Anket != null ? x.Anket.AnketAdi : null)
                .FirstOrDefault(x => !string.IsNullOrWhiteSpace(x)) ?? ("Çalışma #" + g.Key);
            var tanimli = g.Where(x => x.UserId.HasValue && x.UserId.Value != 1)
                .Select(x => x.UserId.Value)
                .Distinct()
                .Count();
            var tanimsiz = g.Where(x => x.Isimsiz.HasValue)
                .Select(x => x.Isimsiz.Value)
                .Distinct()
                .Count();
            var sonKayit = g.Where(x => x.KayitTar.HasValue)
                .Select(x => x.KayitTar.Value)
                .DefaultIfEmpty()
                .Max();

            return new
            {
                AnketId = g.Key,
                AnketAdi = anketAdi,
                KayitSayisi = g.Count(),
                KatilimciSayisi = tanimli + tanimsiz,
                Tanimli = tanimli,
                Tanimsiz = tanimsiz,
                SonKayit = sonKayit == default(DateTime) ? (DateTime?)null : sonKayit
            };
        })
        .OrderByDescending(x => x.SonKayit ?? DateTime.MinValue)
        .ThenBy(x => x.AnketAdi)
        .ToList();

    var toplamKatilimci = calismalar.Sum(x => x.KatilimciSayisi);
    Func<DateTime?, string> tarih = value => value.HasValue ? value.Value.ToString("dd.MM.yyyy HH:mm", culture) : "Henüz tarih yok";
}

<div class="reset-page">
    <section class="reset-hero">
        <div>
            <span class="reset-eyebrow">Veri temizliği</span>
            <h1>Katılım Verilerini Sıfırla</h1>
            <p>Bu bölüm yalnızca sizin çalışma alanınızda katılım verisi oluşmuş anket, sınav ve eğitimleri listeler. Soru bankası, çalışma ayarları ve tanımlar korunur.</p>
            <div class="reset-chip-row">
                <span><i class="fa fa-clipboard"></i> @calismalar.Count çalışma</span>
                <span><i class="fa fa-users"></i> @toplamKatilimci katılımcı</span>
                <span><i class="fa fa-database"></i> @kayitlar.Count cevap kaydı</span>
            </div>
        </div>
        <a class="reset-btn" href="@Url.Action("Indexgosterge", "Home", new { idi = Session["id"] })">
            <i class="fa fa-th-large"></i> Panele dön
        </a>
    </section>

    <section class="reset-warning">
        <div class="warning-icon"><i class="fa fa-exclamation-triangle"></i></div>
        <div>
            <strong>Dikkat isteyen işlem</strong>
            <span>Bir çalışmanın katılım verilerini sildiğinizde katılımcı cevapları, puanları ve ilgili rapor kayıtları temizlenir. Çalışmanın kendisi silinmez.</span>
        </div>
    </section>

    <section class="reset-toolbar">
        <div class="reset-search">
            <i class="fa fa-search"></i>
            <input id="resetSearch" type="search" placeholder="Çalışma adı ara" autocomplete="off" />
        </div>
    </section>

    @if (calismalar.Any())
    {
        <section class="reset-list">
            @foreach (var item in calismalar)
            {
                var arama = item.AnketAdi.ToLower(culture);
                <article class="reset-card" data-reset-row data-search="@arama">
                    <div class="reset-card-main">
                        <div class="reset-mark"><i class="fa fa-file-text-o"></i></div>
                        <div>
                            <h2>@item.AnketAdi</h2>
                            <div class="reset-meta">
                                <span><i class="fa fa-users"></i> @item.KatilimciSayisi katılımcı</span>
                                <span><i class="fa fa-user"></i> @item.Tanimli tanımlı</span>
                                <span><i class="fa fa-user-secret"></i> @item.Tanimsiz tanımsız</span>
                                <span><i class="fa fa-database"></i> @item.KayitSayisi cevap kaydı</span>
                                <span><i class="fa fa-clock-o"></i> @tarih(item.SonKayit)</span>
                            </div>
                        </div>
                    </div>
                    <div class="reset-card-actions">
                        <a class="reset-btn subtle" href="@Url.Action("AnketHavuzIndex2", "Home", new { id = item.AnketId })">
                            <i class="fa fa-list"></i> Kayıtları gör
                        </a>
                        <a class="reset-btn danger" title="@item.AnketAdi katılım verilerini sil" href="@Url.Action("AnketHavuzDelete", "Home", new { id = item.AnketId })">
                            <i class="fa fa-trash-o"></i> Verileri sıfırla
                        </a>
                    </div>
                </article>
            }
        </section>
    }
    else
    {
        <section class="reset-empty">
            <i class="fa fa-check-circle-o"></i>
            <strong>Sıfırlanacak katılım verisi yok</strong>
            <span>Bu çalışma alanındaki anket, sınav veya eğitimlerde henüz katılım cevabı oluşmamış.</span>
        </section>
    }

    <section class="reset-empty" id="resetEmpty" hidden>
        <i class="fa fa-search"></i>
        <strong>Sonuç bulunamadı</strong>
        <span>Arama metnini değiştirerek tekrar deneyin.</span>
    </section>
</div>

<style>
    .reset-page { width: min(1580px, calc(100% - 48px)); margin: 34px auto 60px; color: #061a35; }
    .reset-page * { box-sizing: border-box; }
    .reset-hero, .reset-warning, .reset-toolbar, .reset-card, .reset-empty { border: 1px solid #d6e2f3; border-radius: 12px; background: rgba(255,255,255,.96); box-shadow: 0 20px 48px rgba(24,45,83,.08); }
    .reset-hero { display: flex; justify-content: space-between; align-items: flex-start; gap: 24px; padding: 34px; background: linear-gradient(130deg, rgba(225,253,246,.96), rgba(244,247,255,.9) 58%, rgba(255,248,229,.72)), #fff; }
    .reset-eyebrow { color: #255ef5; font-size: 12px; font-weight: 900; letter-spacing: .08em; text-transform: uppercase; }
    .reset-hero h1 { margin: 10px 0 8px; font-size: 40px; line-height: 1.12; font-weight: 950; letter-spacing: 0; }
    .reset-hero p { max-width: 820px; margin: 0; color: #53627a; font-size: 15px; line-height: 1.7; font-weight: 650; }
    .reset-chip-row, .reset-meta, .reset-card-actions { display: flex; flex-wrap: wrap; gap: 10px; }
    .reset-chip-row { margin-top: 20px; }
    .reset-chip-row span, .reset-meta span { display: inline-flex; align-items: center; gap: 7px; border-radius: 999px; background: #eef5ff; color: #24436d; font-size: 12px; font-weight: 850; padding: 8px 11px; }
    .reset-chip-row i, .reset-meta i { color: #11a99b; }
    .reset-btn { min-height: 42px; display: inline-flex; align-items: center; justify-content: center; gap: 8px; border: 1px solid #cfe0f6; border-radius: 10px; background: #fff; color: #071832; font-weight: 900; text-decoration: none; padding: 0 16px; transition: transform .16s ease, box-shadow .16s ease; white-space: nowrap; }
    .reset-btn:hover, .reset-card:hover { transform: translateY(-2px); box-shadow: 0 18px 38px rgba(19,42,80,.12); text-decoration: none; }
    .reset-btn.subtle { background: #f8fbff; color: #1763df; }
    .reset-btn.danger { border-color: #ffd1d8; background: linear-gradient(135deg, #fff7f8, #fff); color: #d9364f; }
    .reset-warning { display: grid; grid-template-columns: 48px 1fr; gap: 14px; align-items: center; margin-top: 18px; padding: 18px; border-color: #ffd7a7; background: #fffaf1; }
    .warning-icon { display: grid; place-items: center; width: 42px; height: 42px; border-radius: 12px; background: #fff1cf; color: #c57600; font-size: 20px; }
    .reset-warning strong { display: block; color: #7a4300; font-size: 15px; font-weight: 950; }
    .reset-warning span { display: block; margin-top: 3px; color: #7d5b25; font-weight: 700; line-height: 1.55; }
    .reset-toolbar { margin-top: 18px; padding: 16px; }
    .reset-search { position: relative; max-width: 560px; }
    .reset-search i { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #7890b0; }
    .reset-search input { width: 100%; min-height: 44px; border: 1px solid #d3dfef; border-radius: 10px; padding: 0 14px 0 40px; color: #071832; font-weight: 750; outline: none; }
    .reset-search input:focus { border-color: #3562f4; box-shadow: 0 0 0 3px rgba(53,98,244,.12); }
    .reset-list { display: grid; gap: 14px; margin-top: 18px; }
    .reset-card { display: flex; justify-content: space-between; gap: 22px; padding: 18px; transition: transform .16s ease, box-shadow .16s ease; }
    .reset-card-main { display: grid; grid-template-columns: 58px minmax(0, 1fr); gap: 16px; min-width: 0; }
    .reset-mark { display: grid; place-items: center; width: 56px; height: 56px; border-radius: 16px; background: linear-gradient(135deg, #18b7a4, #5065f6); color: #fff; font-size: 22px; box-shadow: 0 14px 28px rgba(80,101,246,.20); }
    .reset-card h2 { margin: 2px 0 12px; color: #071832; font-size: 20px; line-height: 1.3; font-weight: 950; letter-spacing: 0; }
    .reset-card-actions { justify-content: flex-end; align-content: center; min-width: 330px; }
    .reset-empty { display: grid; place-items: center; gap: 6px; margin-top: 18px; padding: 42px; color: #64748b; text-align: center; }
    .reset-empty i { color: #11a99b; font-size: 32px; }
    @@media (max-width: 1000px) { .reset-page { width: min(100% - 22px, 1580px); } .reset-hero, .reset-card { display: grid; grid-template-columns: 1fr; } .reset-card-actions { min-width: 0; justify-content: flex-start; } }
</style>

<script>
    (function () {
        const input = document.getElementById('resetSearch');
        const rows = document.querySelectorAll('[data-reset-row]');
        const empty = document.getElementById('resetEmpty');
        function normalize(value) { return (value || '').toLocaleLowerCase('tr-TR').trim(); }
        function applySearch() {
            const term = normalize(input ? input.value : '');
            let visible = 0;
            rows.forEach(function (row) {
                const show = !term || normalize(row.dataset.search).indexOf(term) > -1;
                row.hidden = !show;
                if (show) visible += 1;
            });
            if (empty) empty.hidden = visible !== 0;
        }
        if (input) input.addEventListener('input', applySearch);
        applySearch();
    })();
</script>
