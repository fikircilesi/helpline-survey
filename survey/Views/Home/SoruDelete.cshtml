@model survey.Models.Soru

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    ViewData["DeleteEyebrow"] = "Soru bankası";
    ViewData["DeleteTitle"] = "Soru silinsin mi?";
    ViewData["DeleteDescription"] = "Soru bankasındaki bu kayıt kaldırılacak. Bir çalışmada kullanılıyorsa sistem silme işlemini güvenlik için engeller.";
    ViewData["DeleteItemLabel"] = "Soru metni";
    ViewData["DeleteItemName"] = Model?.SoruAdi;
    ViewData["DeleteWarning"] = "Bu işlem geri alınamaz. Soruyu kullanan çalışma veya cevap kaydı varsa önce o bağlantıları kaldırın.";
    ViewData["DeleteBackUrl"] = Url.Action("SoruIndex", "Home");
    ViewData["DeleteSubmitText"] = "Soruyu sil";
}

@await Html.PartialAsync("_DeleteConfirm")
