@model IEnumerable<survey.Models.Havuz>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Sadece CDN DataTables -->
<script src="~/Scripts/jquery-3.7.1.min.js"></script>

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/jquery.dataTables.min.css" />
<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>

<link href="~/Content/yazdir.css" rel="stylesheet" />

<!-- jQuery yüklendikten sonra DataTables -->
<script src="~/files/assets/js/jquery.dataTables.min.js"></script>
<!-- Chart.js ve eklentiler -->
<script src="~/Scripts/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.9.2/html2pdf.bundle.min.js"></script>


<div class="panel">
    <div>
        <h4 class="text-uppercase">
            <a class="btn btn-primary btn-outline-primary fa fa-backward"
               href="@Url.Action("AnketIndex1", "Home", new { id = ViewBag.ank })"></a>
            @ViewBag.adi (@ViewBag.anketadi)
        </h4>
    </div>

    <div class="panel-body">
        <table class="table">
            <tr>
                <th>
                    @{
                        var item3 = Model.Where(x => x.UserId != null);
                        var item4 = Model.Where(x => x.Isimsiz != null);

                        var tanimli = item3.GroupBy(x => x.UserId).Count();
                        var tanimsiz = item4.Count();
                    }
                    <b style="color:green">@tanimli Tanımlı </b>
                    <b style="color:orangered">@tanimsiz Tanımsız Katılım</b>
                </th>
            </tr>
        </table>
    </div>

    <div class="card-block">
        <div class="row">
            <div class="col-lg-12 col-xl-12">

                <!-- Nav tabs -->
                <ul class="nav nav-tabs tabs" role="tablist">
                    <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#Rapor">Rapor</a></li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#Genel">Genel</a></li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#Departman">Departman</a></li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#Cinsiyet">Cinsiyet</a></li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#Egitim">Eğitim</a></li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#Yas">Yaş</a></li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#Sehir">Şehir</a></li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#Sube">Şube</a></li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#Unvani">Ünvan</a></li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#Yaka">Yaka</a></li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#Yonetici">Yönetici</a></li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#Soru">Soru</a></li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#Sorugrup">Soru Grup</a></li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#Kisi">Kişiye Göre</a></li>
                </ul>

                <!-- Tab content -->
                <div class="tab-content card-block">
                    <!-- Rapor Sekmesi -->
                    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.9.2/html2pdf.bundle.min.js"></script>

                    <div class="tab-pane active" id="Rapor">
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <h3>Genel Rapor</h3>
                            <button class="btn btn-danger" onclick="downloadPDF()">PDF İndir</button>

                        </div>
                        <p>Departman, Cinsiyet, Eğitim, Yaş, Şehir, Şube, Ünvan, Yaka, Yönetici, Soru ve Soru Grup analizleri tek sayfada özetlenmiştir.</p>
                        <div id="raporContainer"></div>
                    </div>


                    <!-- Genel -->
                    <div class="tab-pane" id="Genel"><canvas id="myChart1" style="width:100%; height:100%"></canvas></div>
                    <div class="tab-pane" id="Departman"><canvas id="myChart2" style="width:100%; height:100%"></canvas></div>
                    <div class="tab-pane" id="Cinsiyet"><canvas id="myChart3" style="width:100%; height:100%"></canvas></div>
                    <div class="tab-pane" id="Egitim"><canvas id="myChart4" style="width:100%; height:100%"></canvas></div>
                    <div class="tab-pane" id="Yas"><canvas id="myChart5" style="width:100%; height:100%"></canvas></div>
                    <div class="tab-pane" id="Sehir"><canvas id="myChart6" style="width:100%; height:100%"></canvas></div>
                    <div class="tab-pane" id="Sube"><canvas id="myChart7" style="width:100%; height:100%"></canvas></div>
                    <div class="tab-pane" id="Unvani"><canvas id="myChart8" style="width:100%; height:100%"></canvas></div>
                    <div class="tab-pane" id="Yaka"><canvas id="myChart9" style="width:100%; height:100%"></canvas></div>
                    <div class="tab-pane" id="Yonetici"><canvas id="myChart10" style="width:100%; height:100%"></canvas></div>
                    <div class="tab-pane" id="Soru"><canvas id="myChart11" style="width:100%; height:100%"></canvas></div>
                    <div class="tab-pane" id="Sorugrup"><canvas id="myChart12" style="width:100%; height:100%"></canvas></div>

                    <!-- Kişi Tablosu -->
                    <div class="tab-pane" id="Kisi">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover" id="Grid">
                                <thead>
                                    <!-- Başlık satırı -->
                                    <tr class="table-dark">
                                        <th>Adı Soyadı</th>
                                        <th>Departman</th>
                                        <th>Cinsiyet</th>
                                        <th>Eğitim</th>
                                        <th>Yaş</th>
                                        <th>Şehir</th>
                                        <th>Şube</th>
                                        <th>Ünvan</th>
                                        <th>Yaka</th>
                                        <th>Yönetici</th>
                                        <th>Puan</th>
                                    </tr>
                                    <!-- Arama satırı (Id için input yok) -->
                                    <tr>
                                        <th><input type="text" placeholder="Ara Adı Soyadı" /></th>
                                        <th><input type="text" placeholder="Ara Departman" /></th>
                                        <th><input type="text" placeholder="Ara Cinsiyet" /></th>
                                        <th><input type="text" placeholder="Ara Eğitim" /></th>
                                        <th><input type="text" placeholder="Ara Yaş" /></th>
                                        <th><input type="text" placeholder="Ara Şehir" /></th>
                                        <th><input type="text" placeholder="Ara Şube" /></th>
                                        <th><input type="text" placeholder="Ara Ünvan" /></th>
                                        <th><input type="text" placeholder="Ara Yaka" /></th>
                                        <th><input type="text" placeholder="Ara Yönetici" /></th>
                                        <th><input type="text" placeholder="Ara Puan" /></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.GroupBy(x => x.UserId))
                                    {
                                        <tr>
                                            <!-- ID gizli olacak -->

                                            <td>
                                                <a href="@Url.Action("AnketUserIndex", "Home", new { id = item.Key, ank = ViewBag.id })">
                                                    @item.First().User.UserAdi
                                                </a>
                                            </td>
                                            <td>@item.First().User.Departman.DepartmanAdi</td>
                                            <td>@item.First().User.Cinsiyet.CinsiyetAdi</td>
                                            <td>@item.First().User.Egitim.EgitimAdi</td>
                                            <td>
                                                @{
                                                    var dogumTarihi = item.First().User.UserDogumTar;
                                                    if (dogumTarihi != null)
                                                    {
                                                        var yas = DateTime.Today.Year - dogumTarihi.Value.Year;
                                                        if (DateTime.Today < dogumTarihi.Value.AddYears(yas)) { yas--; }
                                                        @yas
                                                    }
                                                }
                                            </td>
                                            <td>@item.First().User.Sehir.SehiarAdi</td>
                                            <td>@item.First().User.Sube.SubeAdi</td>
                                            <td>@item.First().User.Unvan.UnvanAdi</td>
                                            <td>@item.First().User.Yaka.YakaAdi</td>
                                            <td>@item.First().User.Yonetici.YoneticiAdi</td>
                                            <td>
                                                @if (ViewBag.sinav != true)
                                                {
                                                    var soru = item.Count();
                                                    var c5 = item.Count(x => x.CevapPuan == 5);
                                                    var c4 = item.Count(x => x.CevapPuan == 4);
                                                    var c3 = item.Count(x => x.CevapPuan == 3);
                                                    var c2 = item.Count(x => x.CevapPuan == 2);
                                                    var c1 = item.Count(x => x.CevapPuan == 1);

                                                    var d5 = (float)c5 * 5 / 5 * 100;
                                                    var d4 = (float)c4 * 4 / 5 * 100;
                                                    var d3 = (float)c3 * 3 / 5 * 100;
                                                    var d2 = (float)c2 * 2 / 5 * 100;
                                                    var d1 = (float)c1 * 1 / 5 * 100;

                                                    var p2 = d1 + d2 + d3 + d4 + d5;
                                                    var p1 = p2 / soru;
                                                    @String.Format("{0:n2}", p1)
                                                }
                                                else
                                                {
                                                    var cx = item.Where(x => x.CevapPuan == 5);
                                                    var tp = cx.Sum(x => x.SoruPuan);
                                                    @String.Format("{0:n2}", tp)
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div> <!-- tab-content -->
            </div>
        </div>
    </div>
</div>
@using Newtonsoft.Json
<script>
    // Column olması istenen grafikler
    const columnCharts = ["Genel", "Cinsiyet", "Şehir", "Şube", "Yaka", "Soru", "Soru Grup", "Eğitim"];

    function createChart(ctxId, label, labels, data, type = 'bar', adet = null) {
        // temel input kontrolü
        if (!labels || !data || labels.length === 0 || data.length === 0) return;

        const isColumn = columnCharts.includes(label);
        const indexAxis = isColumn ? 'x' : 'y';
        const canvas = document.getElementById(ctxId);

        if (!canvas) {
            console.warn('Canvas bulunamadı:', ctxId);
            return;
        }

        // Eğer özel olarak yüksekliği zorlamak istiyorsan canvas'a data-force-height="true" ekle
        const forceHeight = canvas.dataset && canvas.dataset.forceHeight === 'true';
        const maintainAspect = !forceHeight; // forceHeight ise maintainAspectRatio = false

        // Sol padding (özellikle "Soru" grafiği için ayarlanabilir)
        let leftPadding = 10;

        // "Soru" yatay grafikse dinamik boyutlandır
        if (indexAxis === 'y' && label === 'Soru') {
            const heightPerItem = 40;
            const totalHeight = Math.max(200, labels.length * heightPerItem); // minimum yüksekliği koru

            // etiket uzunluğuna göre genişlik hesapla
            const maxLabelLength = Math.max(...labels.map(l => (l ? String(l).length : 0)));
            const extraWidth = maxLabelLength * 8; // karakter başına yaklaşık genişlik (küçük azaltma)
            const baseWidth = 1200;
            const totalWidth = Math.min(2500, baseWidth + extraWidth);

            // inline height/width ekle (forceHeight kullanılıyorsa burada etkili olacak)
            canvas.style.height = totalHeight + 'px';
            canvas.style.width = totalWidth + 'px';
        }

        if (isColumn) {
            canvas.classList.add("column-chart");
        }

        // Chart oluştur
        const chart = new Chart(canvas, {
            type: type,
            data: {
                labels: labels,
                datasets: [{
                    label: label,
                    data: data,
                    backgroundColor: [
                        'rgba(0,123,255,0.7)',
                        'rgba(232,62,140,0.7)',
                        'rgba(40,167,69,0.7)',
                        'rgba(255,193,7,0.7)',
                        'rgba(220,53,69,0.7)',
                        'rgba(23,162,184,0.7)',
                        'rgba(111,66,193,0.7)',
                        'rgba(52,58,64,0.7)',
                    ],
                    borderColor: 'white',
                    borderWidth: 1,
                    adet: adet
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: maintainAspect,
                aspectRatio: 2,
                indexAxis: indexAxis,
                layout: {
                    padding: {
                        top: 100,
                        right: 100,
                        left: leftPadding,
                        bottom: 10
                    }
                },
                plugins: {
                    legend: { display: false },
                    datalabels: {
                        anchor: 'end',
                        align: 'end',
                        rotation: -90,
                        offset: 6,
                        clamp: true,
                        color: '#000',
                        font: { weight: 'bold', size: 9 },
                        formatter: function (value, context) {
                            const adetVal = context.dataset.adet
                                ? context.dataset.adet[context.dataIndex]
                                : null;
                            return adetVal
                                ? `${value.toFixed(2)} % (${adetVal} kişi)`
                                : `${value.toFixed(2)} %`;
                        }
                    }
                },
                scales: {
                    y: {
                        barPercentage: 1,
                        categoryPercentage: 1.2,
                        afterFit: (axis) => {
                            if (label === "Soru") {
                                axis.width = 400;
                            }
                        },
                        ticks: {
                            autoSkip: false,
                            callback(value) {
                                const txt = this.getLabelForValue(value) || '';
                                return txt.length > 100 ? txt.match(/.{1,30}/g) : txt;
                            },
                            font: { size: label === "Soru" ? 8 : 10 },
                            mirror: false,
                            padding: 4
                        }
                    },
                    x: {
                        ticks: {
                            font: { size: 10 }
                        }
                    }
                }
            },
            plugins: [ChartDataLabels]
        });

        return chart;
    }

    // Razor'dan JSON veriler
    var baslik1  = @Html.Raw(JsonConvert.SerializeObject(ViewBag.baslik1));
    var puan1    = @Html.Raw(JsonConvert.SerializeObject(ViewBag.puan1));
    var adet1    = @Html.Raw(JsonConvert.SerializeObject(ViewBag.adet1));
    var baslik2  = @Html.Raw(JsonConvert.SerializeObject(ViewBag.baslik2));
    var puan2    = @Html.Raw(JsonConvert.SerializeObject(ViewBag.puan2));
    var adet2    = @Html.Raw(JsonConvert.SerializeObject(ViewBag.adet2));
    var baslik3  = @Html.Raw(JsonConvert.SerializeObject(ViewBag.baslik3));
    var puan3    = @Html.Raw(JsonConvert.SerializeObject(ViewBag.puan3));
    var adet3    = @Html.Raw(JsonConvert.SerializeObject(ViewBag.adet3));
    var baslik4  = @Html.Raw(JsonConvert.SerializeObject(ViewBag.baslik4));
    var puan4    = @Html.Raw(JsonConvert.SerializeObject(ViewBag.puan4));
    var adet4    = @Html.Raw(JsonConvert.SerializeObject(ViewBag.adet4));
    var baslik5  = @Html.Raw(JsonConvert.SerializeObject(ViewBag.baslik5));
    var puan5    = @Html.Raw(JsonConvert.SerializeObject(ViewBag.puan5));
    var adet5    = @Html.Raw(JsonConvert.SerializeObject(ViewBag.adet5));
    var baslik6  = @Html.Raw(JsonConvert.SerializeObject(ViewBag.baslik6));
    var puan6    = @Html.Raw(JsonConvert.SerializeObject(ViewBag.puan6));
    var adet6    = @Html.Raw(JsonConvert.SerializeObject(ViewBag.adet6));
    var baslik7  = @Html.Raw(JsonConvert.SerializeObject(ViewBag.baslik7));
    var puan7    = @Html.Raw(JsonConvert.SerializeObject(ViewBag.puan7));
    var adet7    = @Html.Raw(JsonConvert.SerializeObject(ViewBag.adet7));
    var baslik8  = @Html.Raw(JsonConvert.SerializeObject(ViewBag.baslik8));
    var puan8    = @Html.Raw(JsonConvert.SerializeObject(ViewBag.puan8));
    var adet8    = @Html.Raw(JsonConvert.SerializeObject(ViewBag.adet8));
    var baslik9  = @Html.Raw(JsonConvert.SerializeObject(ViewBag.baslik9));
    var puan9    = @Html.Raw(JsonConvert.SerializeObject(ViewBag.puan9));
    var adet9    = @Html.Raw(JsonConvert.SerializeObject(ViewBag.adet9));
    var baslik10 = @Html.Raw(JsonConvert.SerializeObject(ViewBag.baslik10));
    var puan10   = @Html.Raw(JsonConvert.SerializeObject(ViewBag.puan10));
    var adet10   = @Html.Raw(JsonConvert.SerializeObject(ViewBag.adet10));
    var baslik11 = @Html.Raw(JsonConvert.SerializeObject(ViewBag.baslik11));
    var baslik11   = @Html.Raw(JsonConvert.SerializeObject(ViewBag.baslik11));
    var puan11     = @Html.Raw(JsonConvert.SerializeObject(ViewBag.puan11));
    var adet11     = @Html.Raw(JsonConvert.SerializeObject(ViewBag.adet11));
    var soruGrup11 = @Html.Raw(JsonConvert.SerializeObject(ViewBag.soruGrup11));
    var baslik12 = @Html.Raw(JsonConvert.SerializeObject(ViewBag.baslik12));
    var puan12   = @Html.Raw(JsonConvert.SerializeObject(ViewBag.puan12));
    var adet12 = @Html.Raw(JsonConvert.SerializeObject(ViewBag.adet12));


    // Genel grafik çağrıları
    createChart("myChart1", "Genel", baslik1, puan1, "bar", adet1);
    createChart("myChart2", "Departman", baslik2, puan2, "bar", adet2);
    createChart("myChart3", "Cinsiyet", baslik3, puan3, "bar", adet3);
    createChart("myChart4", "Eğitim", baslik4, puan4, "bar", adet4);
    createChart("myChart5", "Yaş", baslik5, puan5, "bar", adet5);
    createChart("myChart6", "Şehir", baslik6, puan6, "bar", adet6);
    createChart("myChart7", "Şube", baslik7, puan7, "bar", adet7);
    createChart("myChart8", "Ünvan", baslik8, puan8, "bar", adet8);
    createChart("myChart9", "Yaka", baslik9, puan9, "bar", adet9);
    createChart("myChart10", "Yönetici", baslik10, puan10, "bar", adet10);
    createChart("myChart11", "Soru", baslik11, puan11, "bar", adet11);
    createChart("myChart12", "Soru Grup", baslik12, puan12, "bar", adet12);

    // Dinamik rapor verileri
    const raporData = [
        { id: 2, baslik: baslik2, puan: puan2, adet: adet2, label: "Departman", type: "bar" },
        { id: 3, baslik: baslik3, puan: puan3, adet: adet3, label: "Cinsiyet", type: "bar" },
        { id: 4, baslik: baslik4, puan: puan4, adet: adet4, label: "Eğitim", type: "bar" },
        { id: 5, baslik: baslik5, puan: puan5, adet: adet5, label: "Yaş", type: "bar" },
        { id: 6, baslik: baslik6, puan: puan6, adet: adet6, label: "Şehir", type: "bar" },
        { id: 7, baslik: baslik7, puan: puan7, adet: adet7, label: "Şube", type: "bar" },
        { id: 8, baslik: baslik8, puan: puan8, adet: adet8, label: "Ünvan", type: "bar" },
        { id: 9, baslik: baslik9, puan: puan9, adet: adet9, label: "Yaka", type: "bar" },
        { id: 10, baslik: baslik10, puan: puan10, adet: adet10, label: "Yönetici", type: "bar" },
        { id: 11, baslik: baslik11, puan: puan11, adet: adet11, label: "Soru", type: "bar", soruGrup: soruGrup11 },
        { id: 12, baslik: baslik12, puan: puan12, adet: adet12, label: "Soru Grup", type: "bar" }
    ];

    // 🔹 sadece buradan çağırıyoruz
    document.addEventListener("DOMContentLoaded", function () {
        const container = document.getElementById("raporContainer");

        // küçük stil ekleri (sayfayı bozmadan)
        const style = document.createElement('style');
        style.textContent = `
        .soru-grup-section { margin-bottom: 28px; border-bottom: 1px solid #e9ecef; padding-bottom: 12px; }
        .soru-grup-section h5 { margin-top:10px; margin-bottom:8px; font-weight:700; }
        .soru-grup-chart { height: 300px; width: 100%; margin-bottom: 8px; }
        .soru-grup-table { margin-top: 6px; }
    `;
        document.head.appendChild(style);

        raporData.forEach((grp) => {
            if (grp.baslik && grp.baslik.length > 0) {
                // parent section - birden fazla grup varsa içeriği alt bölümlere ayıracağız
                let section = document.createElement("div");
                section.classList.add("page-break", "mb-3");
                if (grp.label === "Soru") section.classList.add("full-width");

                // Eğer Soru grupları varsa: her grup için ayrı grafik + tablo oluştur
                if (grp.label === "Soru" && grp.soruGrup && grp.soruGrup.length > 0) {
                    // Grupla
                    const groupedData = {};
                    grp.soruGrup.forEach((grupAdi, i) => {
                        if (!groupedData[grupAdi]) groupedData[grupAdi] = [];
                        groupedData[grupAdi].push({
                            soru: grp.baslik[i],
                            puan: grp.puan[i],
                            adet: grp.adet[i]
                        });
                    });

                    // Başlık genel (isteğe bağlı)
                    const sectionTitle = document.createElement("h4");
                    sectionTitle.textContent = grp.label;
                    section.appendChild(sectionTitle);

                    // Her grup için bölüm oluştur
                    Object.entries(groupedData).forEach(([grupAdi, sorular], idx) => {
                        const groupDiv = document.createElement("div");
                        groupDiv.classList.add("soru-grup-section");

                        // Grup başlığı
                        const grpHead = document.createElement("h5");
                        grpHead.textContent = grupAdi;
                        groupDiv.appendChild(grpHead);

                        // Grafik alanı (her grup için ayrı canvas)
                        const chartBox = document.createElement("div");
                        chartBox.classList.add("soru-grup-chart", "chart-box");
                        const chartId = `soru_grup_chart_${grp.id}_${idx}`;
                        chartBox.innerHTML = `<canvas id="${chartId}" data-force-height="true" style="width:100%; height:200px;"></canvas>`;
                            groupDiv.appendChild(chartBox);

                        // Tablo
                        const table = document.createElement("table");
                        table.className = "table table-bordered soru-grup-table";
                        let tableHTML = `
                        <thead>
                            <tr>
                                <th>Soru</th>
                                <th style="width:140px">Ortalama Puan</th>
                                <th style="width:110px">Kişi Sayısı</th>
                            </tr>
                        </thead>
                        <tbody>
                    `;
                        const labels = [];
                        const puanlar = [];
                        const adetler = [];

                        sorular.forEach(s => {
                            labels.push(s.soru);
                            puanlar.push(s.puan ?? 0);
                            adetler.push(s.adet ?? 0);

                            const puanText = s.puan != null ? `${s.puan.toFixed(2)} %` : "-";
                            const adetText = s.adet ?? "-";
                            tableHTML += `
                            <tr>
                                <td style="padding-left:12px">${s.soru}</td>
                                <td>${puanText}</td>
                                <td>${adetText}</td>
                            </tr>
                        `;
                        });

                        tableHTML += "</tbody>";
                        table.innerHTML = tableHTML;
                        groupDiv.appendChild(table);

                        // DOM'a ekle
                        section.appendChild(groupDiv);
                        container.appendChild(section);

                        // Grafik oluşturma (canvas DOM'a eklendikten sonra)
                        // requestAnimationFrame ile garanti ediyoruz.
                        requestAnimationFrame(() => {
                            // createChart fonksiyonunuz zaten var; buna uygun parametreler veriyoruz.
                            // Grafik tipi column (yani dikey sütun). label olarak grup adı verilebilir.
                            createChart(chartId, grupAdi, labels, puanlar, "bar", adetler);
                        });
                    });

                } else {
                    // Diğer grafikler için (Soru olmayanlar) - sade tablo + tek canvas
                    let html = `
                    <h4>${grp.label}</h4>
                    <div class="chart-box">
                        <canvas id="raporChart${grp.id}" style="width:100%; height:300px;"></canvas>
                    </div>
                    <table class="table table-bordered mt-3">
                        <thead>
                            <tr>
                                <th>${grp.label}</th>
                                <th style="width:140px">Ortalama Puan</th>
                                <th style="width:110px">Kişi Sayısı</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${grp.baslik.map((b, i) => {
                        const puanText = grp.puan[i] != null ? `${grp.puan[i].toFixed(2)} %` : '-';
                        const adetText = grp.adet[i] ?? '-';
                        return `<tr><td>${b}</td><td>${puanText}</td><td>${adetText}</td></tr>`;
                    }).join("")}
                        </tbody>
                    </table>
                `;
                    section.innerHTML = html;
                    container.appendChild(section);

                    // Bu tek canvas'ı hemen oluştur
                    createChart(`raporChart${grp.id}`, grp.label, grp.baslik, grp.puan, grp.type, grp.adet);
                }
            }
        });
    });
</script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.9.2/html2pdf.bundle.min.js"></script>
<script>
function downloadPDF() {
    const container = document.getElementById("raporContainer");
    const sections  = Array.from(container.querySelectorAll(":scope > div")); // her kutu

    // Başlık
    const header = document.createElement("div");
    header.innerHTML = `
        <div style="display:flex; justify-content:center; align-items:center; height:600px;">
            <h1 style="font-size:48px; font-weight:bold; text-align:center;">
                ${`@ViewBag.adi (@ViewBag.anketadi)`}
            </h1>
        </div>
    `;

    // Chart animasyonlarını kapat (PDF'e yakalamada daha stabil)
    const oldAnim = Chart.defaults.animation;
    Chart.defaults.animation = false;

    const opt = {
        margin: 10,
        filename: 'Rapor.pdf',
        image: { type: 'jpeg', quality: 0.98 },
        html2canvas: { scale: 2, useCORS: true, backgroundColor: '#fff' },
        jsPDF: { unit: 'mm', format: 'a4', orientation: 'landscape' },
        pagebreak: { mode: ['css'] }
    };

    // Tek worker, içerikleri sırayla ekle (HER BÖLÜM 1 KEZ!)
    let worker = html2pdf().set(opt);

    // 1) Başlık sayfasını ekle ve sayfa aç
    worker = worker
        .from(header).toContainer().toCanvas().toPdf()
        .get('pdf').then(pdf => { pdf.addPage(); });

    // 2) Bölümleri sırayla ekle; her birinden sonra (son hariç) sayfa aç
    sections.forEach((section, i) => {
        worker = worker
            .from(section).toContainer().toCanvas().toPdf()
            .get('pdf').then(pdf => {
                if (i < sections.length - 1) pdf.addPage();
            });
    });

    // 3) Kaydet ve animasyonu geri al
    worker.save().then(() => {
        Chart.defaults.animation = oldAnim;
    });
}

</script>


@section Scripts {
    <script>
$(function () {
    // Dil değerini Session'dan al (yoksa 'tr')
    var dil = '@(Session["Dil"] as string ?? "tr")'.toLowerCase();

    var table = $('#Grid').DataTable({
        responsive: true,
        orderCellsTop: true,
        fixedHeader: true,
        pageLength: 10,
        lengthMenu: [
            [10, 25, 50, 100, 500, -1],
            [10, 25, 50, 100, 500, dil === 'en' ? 'All' : 'Tümü']
        ],
        // İstersen varsayılan sıralamayı kapat:
        // order: [],
        // veya bir kolona göre sırala:
        // order: [[0, 'asc']],
        language: {
            url: dil === 'en'
                ? '@Url.Content("~/Scripts/en.json")'
                : '@Url.Content("~/Scripts/tr.json")'
        },
        drawCallback: function () {
            var api = this.api();
            if (api.rows({ page: 'current' }).data().length === 0) {
                $('#Grid tbody td')
                    .addClass('text-light text-center fst-italic')
                    .css('background-color', '#1a1a1a')
                    .text(dil === 'en' ? 'No data available in table' : 'Tabloda veri yok');
            }
        }
    });

    // Kolon bazlı arama – ikinci header satırındaki inputlarla birebir
    $('#Grid thead tr:eq(1) th').each(function (i) {
        var $input = $('input', this);
        if (!$input.length) return;

        $input.on('keyup change', function () {
            if (table.column(i).search() !== this.value) {
                table.column(i).search(this.value).draw();
            }
        });
    });
});
    </script>
}
