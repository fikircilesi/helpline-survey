@model IEnumerable<survey.Models.Havuz>
@using System
@using System.Globalization
@using System.Linq

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var culture = new CultureInfo("tr-TR");
    var kayitlar = (Model ?? Enumerable.Empty<survey.Models.Havuz>()).ToList();
    var anketAdi = Convert.ToString(ViewBag.ankadi);
    if (string.IsNullOrWhiteSpace(anketAdi))
    {
        anketAdi = kayitlar.Select(x => x.Anket != null ? x.Anket.AnketAdi : null).FirstOrDefault(x => !string.IsNullOrWhiteSpace(x)) ?? "Çalışma";
    }

    var gruplar = kayitlar
        .GroupBy(x => x.SoruGrupId)
        .Select(g =>
        {
            var grupAdi = g.Select(x => x.SoruGrup != null ? x.SoruGrup.SoruGrupAdi : null).FirstOrDefault(x => !string.IsNullOrWhiteSpace(x)) ?? "Grupsuz kayıt";
            var tanimli = g.Where(x => x.UserId.HasValue && x.UserId.Value != 1).Select(x => x.UserId.Value).Distinct().Count();
            var tanimsiz = g.Where(x => x.Isimsiz.HasValue).Select(x => x.Isimsiz.Value).Distinct().Count();
            return new
            {
                GrupId = g.Key,
                GrupAdi = grupAdi,
                KayitSayisi = g.Count(),
                SoruSayisi = g.Where(x => x.SoruID.HasValue).Select(x => x.SoruID.Value).Distinct().Count(),
                KatilimciSayisi = tanimli + tanimsiz,
                SonKayit = g.Max(x => x.KayitTar)
            };
        })
        .OrderBy(x => x.GrupAdi)
        .ToList();

    Func<DateTime?, string> tarih = value => value.HasValue ? value.Value.ToString("dd.MM.yyyy HH:mm", culture) : "Tarih yok";
}

<div class="drill-page">
    <section class="drill-hero">
        <div>
            <span class="drill-eyebrow">Katılım verileri</span>
            <h1>@anketAdi</h1>
            <p>Bu çalışmadaki katılım kayıtları soru gruplarına göre özetlenir. Bir gruba girerek tekil cevap kayıtlarını görebilir veya sadece o grubun verilerini sıfırlayabilirsiniz.</p>
            <div class="drill-chip-row">
                <span><i class="fa fa-layer-group"></i> @gruplar.Count grup</span>
                <span><i class="fa fa-question-circle"></i> @gruplar.Sum(x => x.SoruSayisi) soru</span>
                <span><i class="fa fa-users"></i> @gruplar.Sum(x => x.KatilimciSayisi) katılımcı</span>
                <span><i class="fa fa-database"></i> @kayitlar.Count cevap kaydı</span>
            </div>
        </div>
        <a class="drill-btn" href="@Url.Action("AnketHavuzIndex", "Home", new { id = Session["id"] })">
            <i class="fa fa-arrow-left"></i> Listeye dön
        </a>
    </section>

    <section class="drill-toolbar">
        <div class="drill-search">
            <i class="fa fa-search"></i>
            <input id="drillSearch" type="search" placeholder="Soru grubu ara" autocomplete="off" />
        </div>
    </section>

    @if (gruplar.Any())
    {
        <section class="drill-grid">
            @foreach (var item in gruplar)
            {
                var search = item.GrupAdi.ToLower(culture);
                <article class="drill-card" data-drill-row data-search="@search">
                    <div class="drill-card-main">
                        <div class="drill-mark"><i class="fa fa-folder-open-o"></i></div>
                        <div>
                            <h2>@item.GrupAdi</h2>
                            <div class="drill-meta">
                                <span><i class="fa fa-question-circle"></i> @item.SoruSayisi soru</span>
                                <span><i class="fa fa-users"></i> @item.KatilimciSayisi katılımcı</span>
                                <span><i class="fa fa-database"></i> @item.KayitSayisi kayıt</span>
                                <span><i class="fa fa-clock-o"></i> @tarih(item.SonKayit)</span>
                            </div>
                        </div>
                    </div>
                    <div class="drill-actions">
                        @if (item.GrupId.HasValue)
                        {
                            <a class="drill-btn subtle" href="@Url.Action("AnketHavuzIndex1", "Home", new { id = item.GrupId.Value, ank = ViewBag.id })">
                                <i class="fa fa-list"></i> Kayıtları gör
                            </a>
                            <a class="drill-btn danger" href="@Url.Action("AnketHavuzDelete2", "Home", new { id = item.GrupId.Value, ank = ViewBag.id })">
                                <i class="fa fa-trash-o"></i> Grubu sıfırla
                            </a>
                        }
                        else
                        {
                            <span class="drill-passive">Grup bilgisi yok</span>
                        }
                    </div>
                </article>
            }
        </section>
    }
    else
    {
        <section class="drill-empty">
            <i class="fa fa-check-circle-o"></i>
            <strong>Bu çalışma için cevap kaydı yok</strong>
            <span>Katılım oluştuğunda soru grupları burada listelenecek.</span>
        </section>
    }

    <section class="drill-empty" id="drillEmpty" hidden>
        <i class="fa fa-search"></i>
        <strong>Sonuç bulunamadı</strong>
        <span>Arama metnini değiştirerek tekrar deneyin.</span>
    </section>
</div>

<style>
    .drill-page { width: min(1580px, calc(100% - 48px)); margin: 34px auto 60px; color: #061a35; }
    .drill-page * { box-sizing: border-box; }
    .drill-hero, .drill-toolbar, .drill-card, .drill-empty { border: 1px solid #d6e2f3; border-radius: 12px; background: rgba(255,255,255,.96); box-shadow: 0 20px 48px rgba(24,45,83,.08); }
    .drill-hero { display: flex; justify-content: space-between; align-items: flex-start; gap: 24px; padding: 34px; background: linear-gradient(130deg, rgba(225,253,246,.96), rgba(244,247,255,.9) 58%, rgba(255,248,229,.72)), #fff; }
    .drill-eyebrow { color: #255ef5; font-size: 12px; font-weight: 900; letter-spacing: .08em; text-transform: uppercase; }
    .drill-hero h1 { margin: 10px 0 8px; font-size: 38px; line-height: 1.14; font-weight: 950; letter-spacing: 0; }
    .drill-hero p { max-width: 820px; margin: 0; color: #53627a; font-size: 15px; line-height: 1.7; font-weight: 650; }
    .drill-chip-row, .drill-meta, .drill-actions { display: flex; flex-wrap: wrap; gap: 10px; }
    .drill-chip-row { margin-top: 20px; }
    .drill-chip-row span, .drill-meta span, .drill-passive { display: inline-flex; align-items: center; gap: 7px; border-radius: 999px; background: #eef5ff; color: #24436d; font-size: 12px; font-weight: 850; padding: 8px 11px; }
    .drill-chip-row i, .drill-meta i { color: #11a99b; }
    .drill-btn { min-height: 42px; display: inline-flex; align-items: center; justify-content: center; gap: 8px; border: 1px solid #cfe0f6; border-radius: 10px; background: #fff; color: #071832; font-weight: 900; text-decoration: none; padding: 0 16px; transition: transform .16s ease, box-shadow .16s ease; white-space: nowrap; }
    .drill-btn:hover, .drill-card:hover { transform: translateY(-2px); box-shadow: 0 18px 38px rgba(19,42,80,.12); text-decoration: none; }
    .drill-btn.subtle { background: #f8fbff; color: #1763df; }
    .drill-btn.danger { border-color: #ffd1d8; background: #fff7f8; color: #d9364f; }
    .drill-toolbar { margin-top: 18px; padding: 16px; }
    .drill-search { position: relative; max-width: 560px; }
    .drill-search i { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #7890b0; }
    .drill-search input { width: 100%; min-height: 44px; border: 1px solid #d3dfef; border-radius: 10px; padding: 0 14px 0 40px; color: #071832; font-weight: 750; outline: none; }
    .drill-search input:focus { border-color: #3562f4; box-shadow: 0 0 0 3px rgba(53,98,244,.12); }
    .drill-grid { display: grid; gap: 14px; margin-top: 18px; }
    .drill-card { display: flex; justify-content: space-between; gap: 22px; padding: 18px; transition: transform .16s ease, box-shadow .16s ease; }
    .drill-card-main { display: grid; grid-template-columns: 58px minmax(0, 1fr); gap: 16px; min-width: 0; }
    .drill-mark { display: grid; place-items: center; width: 56px; height: 56px; border-radius: 16px; background: linear-gradient(135deg, #18b7a4, #5065f6); color: #fff; font-size: 22px; box-shadow: 0 14px 28px rgba(80,101,246,.20); }
    .drill-card h2 { margin: 2px 0 12px; color: #071832; font-size: 20px; line-height: 1.3; font-weight: 950; letter-spacing: 0; }
    .drill-actions { justify-content: flex-end; align-content: center; min-width: 300px; }
    .drill-passive { background: #f2f5fa; color: #687790; }
    .drill-empty { display: grid; place-items: center; gap: 6px; margin-top: 18px; padding: 42px; color: #64748b; text-align: center; }
    .drill-empty i { color: #11a99b; font-size: 32px; }
    @@media (max-width: 1000px) { .drill-page { width: min(100% - 22px, 1580px); } .drill-hero, .drill-card { display: grid; grid-template-columns: 1fr; } .drill-actions { min-width: 0; justify-content: flex-start; } }
</style>

<script>
    (function () {
        const input = document.getElementById('drillSearch');
        const rows = document.querySelectorAll('[data-drill-row]');
        const empty = document.getElementById('drillEmpty');
        function normalize(value) { return (value || '').toLocaleLowerCase('tr-TR').trim(); }
        function applySearch() {
            const term = normalize(input ? input.value : '');
            let visible = 0;
            rows.forEach(function (row) {
                const show = !term || normalize(row.dataset.search).indexOf(term) > -1;
                row.hidden = !show;
                if (show) visible += 1;
            });
            if (empty) empty.hidden = visible !== 0;
        }
        if (input) input.addEventListener('input', applySearch);
        applySearch();
    })();
</script>
