@model survey.Models.Havuz

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var soruAdi = Model != null && Model.Soru != null && !string.IsNullOrWhiteSpace(Model.Soru.SoruAdi)
        ? Model.Soru.SoruAdi
        : "Silinmiş veya bulunamayan soru";
    var cevapAdi = Model != null && Model.Cevap != null && !string.IsNullOrWhiteSpace(Model.Cevap.CevapAdi)
        ? Model.Cevap.CevapAdi
        : "Cevap bilgisi yok";
    var katilimci = "Tanımsız katılımcı";
    if (Model != null && Model.User != null && !string.IsNullOrWhiteSpace(Model.User.UserAdi))
    {
        katilimci = Model.User.UserAdi;
    }
    else if (Model != null && Model.Isimsiz.HasValue)
    {
        katilimci = "Katılımcı #" + Model.Isimsiz.Value;
    }
}

<div class="confirm-page">
    <section class="confirm-card">
        <div class="confirm-icon"><i class="fa fa-trash-o"></i></div>
        <span class="confirm-eyebrow">Tek cevap kaydı silme</span>
        <h1>@soruAdi</h1>
        <p>Bu ekranda yalnızca seçili cevap kaydı silinir. Aynı soruya veya aynı katılımcıya ait diğer cevaplar korunur.</p>

        <div class="confirm-details">
            <div>
                <span>Verilen cevap</span>
                <strong>@cevapAdi</strong>
            </div>
            <div>
                <span>Katılımcı</span>
                <strong>@katilimci</strong>
            </div>
        </div>

        <div class="confirm-warning">
            <i class="fa fa-lock"></i>
            <span>Bu işlem geri alınamaz.</span>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@ViewBag.id" />
            <input type="hidden" name="ank" value="@ViewBag.ank" />
            <input type="hidden" name="sor" value="@ViewBag.sor" />

            <div class="confirm-actions">
                <a class="confirm-btn" href="@Url.Action("AnketHavuzIndex1", "Home", new { id = ViewBag.sor, ank = ViewBag.ank })">
                    <i class="fa fa-arrow-left"></i> Vazgeç
                </a>
                <button type="submit" class="confirm-btn danger">
                    <i class="fa fa-trash-o"></i> Kaydı sil
                </button>
            </div>
        }
    </section>
</div>

<style>
    .confirm-page { width: min(760px, calc(100% - 32px)); margin: 58px auto; color: #061a35; }
    .confirm-page * { box-sizing: border-box; }
    .confirm-card { border: 1px solid #ffd1d8; border-radius: 14px; background: linear-gradient(135deg, #fff, #fff8f9); box-shadow: 0 24px 60px rgba(154, 38, 62, .12); padding: 34px; }
    .confirm-icon { display: grid; place-items: center; width: 64px; height: 64px; border-radius: 18px; background: #fff0f2; color: #d9364f; font-size: 28px; margin-bottom: 18px; }
    .confirm-eyebrow { color: #d9364f; font-size: 12px; font-weight: 950; letter-spacing: .08em; text-transform: uppercase; }
    .confirm-card h1 { margin: 8px 0 10px; font-size: 30px; line-height: 1.25; font-weight: 950; letter-spacing: 0; }
    .confirm-card p { margin: 0; color: #53627a; font-size: 15px; line-height: 1.7; font-weight: 700; }
    .confirm-details { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; margin: 24px 0; }
    .confirm-details div { border: 1px solid #dce7f6; border-radius: 12px; background: #fff; padding: 14px; }
    .confirm-details span { display: block; color: #64748b; font-size: 12px; font-weight: 950; text-transform: uppercase; letter-spacing: .05em; }
    .confirm-details strong { display: block; margin-top: 7px; color: #071832; font-size: 16px; line-height: 1.45; }
    .confirm-warning { display: flex; gap: 10px; align-items: center; border: 1px solid #ffd7a7; border-radius: 12px; background: #fffaf1; color: #7a4300; padding: 14px; font-weight: 850; }
    .confirm-actions { display: flex; justify-content: flex-end; gap: 12px; margin-top: 24px; }
    .confirm-btn { min-height: 44px; display: inline-flex; align-items: center; justify-content: center; gap: 8px; border: 1px solid #cfe0f6; border-radius: 10px; background: #fff; color: #071832; font-weight: 950; text-decoration: none; padding: 0 18px; }
    .confirm-btn.danger { border-color: #d9364f; background: #d9364f; color: #fff; }
    @@media (max-width: 720px) { .confirm-details { grid-template-columns: 1fr; } .confirm-actions { display: grid; } }
</style>
