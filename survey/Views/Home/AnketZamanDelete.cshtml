@model survey.Models.Izledim

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    var anketAdi = (ViewBag.ank as string) ?? Model?.Anket?.AnketAdi ?? "Çalışma";
    var fallbackId = Model == null ? "-" : (Model.UseId?.ToString() ?? Model.IzleId.ToString());
    var kullaniciAdi = (ViewBag.adi as string) ?? Model?.User?.UserAdi ?? ("Katılımcı #" + fallbackId);
    var mevcutAralik = (Model?.IzTarih?.ToString("dd.MM.yyyy HH:mm") ?? "-")
        + " - "
        + (Model?.BitisZaman?.ToString("dd.MM.yyyy HH:mm") ?? "sınırsız");

    ViewData["DeleteEyebrow"] = "Süre kaydı";
    ViewData["DeleteTitle"] = "Süre kaydı sıfırlansın mı?";
    ViewData["DeleteDescription"] = "Bu işlem katılımcının mevcut zaman kaydını siler. Kişi çalışmaya tekrar girdiğinde süre yeniden başlatılır.";
    ViewData["DeleteItemLabel"] = "Katılımcı / çalışma";
    ViewData["DeleteItemName"] = kullaniciAdi + " - " + anketAdi + " (" + mevcutAralik + ")";
    ViewData["DeleteWarning"] = "Bu işlem mevcut süre takibini geri alınamaz şekilde sıfırlar; cevap kayıtları silinmez.";
    ViewData["DeleteBackUrl"] = Url.Action("AnketZamanIndex1", "Home", new { id = ViewBag.ankid });
    ViewData["DeleteSubmitText"] = "Süreyi sıfırla";
    ViewData["DeleteIcon"] = "fa fa-clock-o";
    ViewData["DeleteHiddenFields"] = new[]
    {
        new System.Collections.Generic.KeyValuePair<string, string>("id", Convert.ToString(ViewBag.id)),
        new System.Collections.Generic.KeyValuePair<string, string>("ank", Convert.ToString(ViewBag.ankid))
    };
}

@await Html.PartialAsync("_DeleteConfirm")
