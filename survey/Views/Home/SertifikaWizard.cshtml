        box-shadow: inset 0 0 0 2px #0f3f5f;
    }

    .frame-guilloche {
        border: 3px double #163a75;
        background:
            repeating-radial-gradient(ellipse at center, rgba(22,58,117,.42) 0 2px, transparent 2px 7px),
