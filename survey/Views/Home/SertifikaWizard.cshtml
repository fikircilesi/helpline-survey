        font-weight: 700;
    }

    .cert-name-help {
        display: block;
        margin-top: -6px;
        margin-bottom: 10px;
        color: #667085;
        font-size: 11px;
        font-weight: 750;
    }

    .cert-preview p {
        color: #526071;
        font-size: clamp(11px, calc(var(--cert-text-size, 17) * .76px), 22px);
