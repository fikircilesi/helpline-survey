                                        <input type="radio" name="SertifikaVerilisZamani" value="SureBitince" @(zaman == "SureBitince" ? "checked" : "") />
                                        <strong>Süre kapanınca</strong>
                                        <span>Sınav süresi tamamlanmadan sertifika açılmaz. Sınavlar için önerilir.</span>
                                    </label>
                                    <label class="cert-radio">
                                        <input type="radio" name="SertifikaVerilisZamani" value="Tamamlayinca" @(zaman == "Tamamlayinca" ? "checked" : "") />
                                        <strong>Tamamlayınca</strong>
                                        <span>Tüm sorular cevaplanır ve puan yeterliyse sertifika hemen hazır olur.</span>
                                    </label>
                                    <label class="cert-radio">
                                        <input type="radio" name="SertifikaVerilisZamani" value="YayinBitince" @(zaman == "YayinBitince" ? "checked" : "") />
