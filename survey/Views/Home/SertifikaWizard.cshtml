    .cert-preview-signature img {
        display: block;
        width: 92px;
        height: 42px;
        margin: 0 0 7px auto;
        object-fit: contain;
        mix-blend-mode: multiply;
    }

    .cert-preview-signature img[hidden] {
        display: none;
    }

    .cert-footer {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 22px;
    }

    @@media (max-width: 980px) {
        .cert-head,
        .cert-grid {
            grid-template-columns: 1fr;
        }

        .cert-grid,
        .cert-head {
            display: block;
