<div class="cert-wizard">
    <div class="cert-shell">
        <div class="cert-head">
            <div>
                <p class="cert-kicker">Aslana Survey Studio</p>
                <h1 class="cert-title">Sertifika Sihirbazı</h1>
                <p class="cert-subtitle">
                    @Model.AnketAdi için sertifikanın kimlere, ne zaman ve hangi koşulla verileceğini buradan yönetin.
                </p>
            </div>
            <div class="cert-actions">
                <a class="cert-btn" href="@Url.Action("Indexgosterge", "Home")">Geri</a>
            </div>
        </div>

        <div class="cert-body">
            @using (Html.BeginForm("SertifikaWizard", "Home", FormMethod.Post, new { enctype = "multipart/form-data", @class = "certificate-wizard-form" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(x => x.AnketId)
                <input type="hidden" name="SertifikaLogo" value="@Model.SertifikaLogo" />
                <input type="hidden" name="SertifikaTema" value="Modern" />

                if (!ViewData.ModelState.IsValid)
                {
                    <div class="cert-validation">
                        @Html.ValidationSummary(false)
                    </div>
                }

                <div class="cert-grid">
                    <div>
                        <section class="cert-panel">
                            <div class="cert-panel-head">
