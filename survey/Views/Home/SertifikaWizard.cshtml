    }

    .cert-form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .cert-field.full {
        grid-column: 1 / -1;
    }

    .cert-design-grid {
        align-items: start;
    }

    .cert-type-settings {
        margin-top: 16px;
        padding: 14px;
        border: 1px solid #e2eaf6;
        border-radius: 8px;
        background: #fbfdff;
    }

    .cert-type-head {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: baseline;
        margin-bottom: 12px;
    }

    .cert-type-head strong {
        color: #0f1f35;
        font-size: 14px;
        font-weight: 950;
    }

    .cert-type-head span {
        color: #667085;
        font-size: 12px;
        line-height: 1.45;
        font-weight: 650;
        text-align: right;
    }

    .cert-field label {
        display: block;
        margin-bottom: 7px;
        color: #344054;
        font-size: 12px;
        font-weight: 900;
        letter-spacing: .06em;
        text-transform: uppercase;
    }

    .cert-input,
    .cert-textarea {
        width: 100%;
        border: 1px solid #cddbf0;
        border-radius: 8px;
        background: #fff;
        color: #0f1f35;
        font-size: 15px;
        font-weight: 650;
    }

    .cert-input {
