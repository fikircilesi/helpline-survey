@model survey.Controllers.HomeController.SertifikaWizardForm
@{
    ViewBag.Title = "Sertifika Sihirbazı";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var zaman = string.IsNullOrWhiteSpace(Model.SertifikaVerilisZamani) ? "SureBitince" : Model.SertifikaVerilisZamani;
    var vurgu = string.IsNullOrWhiteSpace(Model.SertifikaVurguRengi) ? "#2563eb" : Model.SertifikaVurguRengi;
    var cerceve = string.IsNullOrWhiteSpace(Model.SertifikaCerceve) ? "Classic" : Model.SertifikaCerceve;
    var font = string.IsNullOrWhiteSpace(Model.SertifikaFont) ? "Georgia" : Model.SertifikaFont;
    var yaziPunto = Model.SertifikaYaziPunto.HasValue ? Model.SertifikaYaziPunto.Value : 17;
    var baslikPunto = Model.SertifikaBaslikPunto.HasValue ? Model.SertifikaBaslikPunto.Value : 44;
    var logo = Model.SertifikaLogo;
    var imza = Model.Imza;
    var fontOptions = new[]
    {
        new SelectListItem { Value = "Georgia", Text = "Georgia", Selected = font == "Georgia" },
        new SelectListItem { Value = "Garamond", Text = "Garamond", Selected = font == "Garamond" },
        new SelectListItem { Value = "Playfair", Text = "Playfair", Selected = font == "Playfair" },
        new SelectListItem { Value = "Merriweather", Text = "Merriweather", Selected = font == "Merriweather" },
        new SelectListItem { Value = "Cambria", Text = "Cambria", Selected = font == "Cambria" },
        new SelectListItem { Value = "Times", Text = "Times New Roman", Selected = font == "Times" },
        new SelectListItem { Value = "Arial", Text = "Arial", Selected = font == "Arial" },
        new SelectListItem { Value = "Verdana", Text = "Verdana", Selected = font == "Verdana" },
        new SelectListItem { Value = "OpenSans", Text = "Open Sans", Selected = font == "OpenSans" }
    };
    var onizlemeMetni = string.IsNullOrWhiteSpace(Model.SertifikaMetni)
        ? "Başarı koşullarını sağlayan katılımcılar için sertifika bu görsel dilde hazırlanır. Yetki ve zamanlama kuralları katılım portalında otomatik uygulanır."
        : Model.SertifikaMetni
            .Replace("{adSoyad}", "Katılımcı")
            .Replace("{egitim}", Model.AnketAdi)
            .Replace("{tarih}", DateTime.Now.ToString("dd.MM.yyyy"))
            .Replace("{egitimVeren}", string.IsNullOrWhiteSpace(Model.EgitimVeren) ? "Düzenleyen" : Model.EgitimVeren);
}

<style>
    .cert-wizard {
        max-width: 1180px;
        margin: 24px auto;
        color: #0f1f35;
    }

    .cert-shell {
        overflow: hidden;
        border: 1px solid #d9e3f2;
        border-radius: 8px;
        background: #fff;
        box-shadow: 0 22px 60px rgba(24, 38, 66, .10);
    }

    .cert-head {
        display: flex;
        justify-content: space-between;
        gap: 18px;
        padding: 28px 32px;
        background: linear-gradient(135deg, rgba(24,183,164,.12), rgba(67,97,238,.10));
        border-bottom: 1px solid #d9e3f2;
    }

    .cert-kicker {
        margin: 0 0 8px;
        color: #3157ff;
        font-size: 12px;
        font-weight: 900;
        letter-spacing: .16em;
        text-transform: uppercase;
    }

    .cert-title {
        margin: 0;
        font-size: clamp(26px, 3vw, 38px);
        font-weight: 950;
        letter-spacing: 0;
    }

    .cert-subtitle {
        max-width: 720px;
        margin: 10px 0 0;
        color: #55657d;
        font-size: 15px;
        line-height: 1.6;
        font-weight: 650;
    }

    .cert-actions {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        flex-shrink: 0;
    }

    .cert-btn {
        min-height: 42px;
        padding: 0 18px;
        border: 1px solid #cddbf0;
        border-radius: 8px;
        background: #fff;
        color: #102238;
        font-weight: 900;
        text-decoration: none;
        cursor: pointer;
    }

    .cert-btn.primary {
        border-color: #2563eb;
        color: #fff;
        background: #2563eb;
    }

    .cert-body {
        padding: 30px 32px 34px;
    }

    .cert-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(320px, 420px);
        gap: 24px;
        align-items: start;
    }

    .cert-panel {
        border: 1px solid #d9e3f2;
        border-radius: 8px;
        background: #fff;
    }

    .cert-panel + .cert-panel {
        margin-top: 18px;
    }

    .cert-panel-head {
        padding: 18px 20px;
        border-bottom: 1px solid #e8eef7;
        background: #f8fbff;
    }

    .cert-panel-head h3 {
        margin: 0;
        font-size: 17px;
        font-weight: 950;
    }

    .cert-panel-head p {
        margin: 7px 0 0;
        color: #667085;
        font-size: 13px;
        line-height: 1.5;
        font-weight: 650;
    }

    .cert-panel-body {
        padding: 20px;
    }

    .cert-switch-row,
    .cert-check-row {
        display: flex;
        gap: 14px;
        align-items: flex-start;
        padding: 14px;
        border: 1px solid #d9e3f2;
        border-radius: 8px;
        background: #fbfdff;
    }

    .cert-check-row + .cert-check-row {
        margin-top: 12px;
    }

    .cert-switch-row input,
    .cert-check-row input {
        width: 20px;
        height: 20px;
        margin-top: 2px;
        accent-color: #18b7a4;
    }

    .cert-switch-row strong,
    .cert-check-row strong {
        display: block;
        font-size: 15px;
        font-weight: 950;
    }

    .cert-switch-row span,
    .cert-check-row span {
        display: block;
        margin-top: 5px;
        color: #667085;
        font-size: 13px;
        line-height: 1.5;
        font-weight: 650;
    }

    .cert-radio-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
    }

    .cert-radio {
        display: block;
        min-height: 138px;
        padding: 14px;
        border: 1px solid #d9e3f2;
        border-radius: 8px;
        background: #fbfdff;
        cursor: pointer;
    }

    .cert-radio input {
        width: 18px;
        height: 18px;
        accent-color: #4361ee;
    }

    .cert-radio strong {
        display: block;
        margin-top: 12px;
        font-size: 14px;
        font-weight: 950;
    }

    .cert-radio span {
        display: block;
        margin-top: 7px;
        color: #667085;
        font-size: 12px;
        line-height: 1.45;
        font-weight: 650;
    }

    .cert-radio:has(input:checked) {
        border-color: #4361ee;
        background: #eef3ff;
        box-shadow: inset 0 0 0 1px #4361ee;
    }

    .cert-frame-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 10px;
        margin-top: 16px;
    }

    .cert-frame-option {
        display: grid;
        gap: 8px;
        min-height: 108px;
        padding: 10px;
        border: 1px solid #d9e3f2;
        border-radius: 8px;
        background: #fbfdff;
        cursor: pointer;
    }

    .cert-frame-option input {
        position: absolute;
        opacity: 0;
        pointer-events: none;
    }

    .cert-frame-option strong {
        font-size: 12px;
        font-weight: 950;
    }

    .cert-frame-option:has(input:checked) {
        border-color: #4361ee;
        background: #eef3ff;
        box-shadow: inset 0 0 0 1px #4361ee;
    }

    .frame-swatch {
        display: block;
        position: relative;
        height: 46px;
        border-radius: 5px;
        background: #fffdf8;
        overflow: hidden;
    }

    .frame-classic {
        border: 2px solid var(--theme-color, #4361ee);
    }

    .frame-doublegold {
        border: 5px double #d6b25e;
    }

    .frame-ribbon {
        border: 1px solid #cddbf0;
        border-top: 8px solid var(--theme-color, #4361ee);
    }

    .frame-cornerseal {
        border: 2px solid #cddbf0;
    }

    .frame-cornerseal::before,
    .frame-cornerseal::after {
        content: "";
        position: absolute;
        width: 18px;
        height: 18px;
        border: 4px solid var(--theme-color, #4361ee);
    }

    .frame-cornerseal::before {
        top: 0;
        left: 0;
        border-right: 0;
        border-bottom: 0;
    }

    .frame-cornerseal::after {
        right: 0;
        bottom: 0;
        border-left: 0;
        border-top: 0;
    }

    .frame-gradientwash {
        border: 1px solid #cddbf0;
        background: linear-gradient(135deg, rgba(24,183,164,.20), rgba(67,97,238,.15), #fffdf8);
    }

    .frame-royal {
        border: 3px solid #172554;
        box-shadow: inset 0 0 0 4px rgba(214,178,94,.45);
    }

    .frame-sidestripe {
        border: 1px solid #cddbf0;
        border-left: 9px solid var(--theme-color, #4361ee);
    }

    .frame-topband {
        border: 1px solid #cddbf0;
        background: linear-gradient(180deg, var(--theme-color, #4361ee) 0 18%, #fffdf8 18%);
    }

    .frame-minimalline {
        border: 0;
        border-bottom: 5px solid var(--theme-color, #4361ee);
        background: #fff;
    }

    .frame-artdeco {
        border: 2px solid #111827;
        background:
            linear-gradient(135deg, transparent 0 34%, rgba(214,178,94,.45) 34% 42%, transparent 42%),
            linear-gradient(315deg, transparent 0 34%, rgba(214,178,94,.45) 34% 42%, transparent 42%),
            #fffdf8;
    }

    .frame-blueclassic {
        border: 5px double #163a75;
        background:
            repeating-linear-gradient(90deg, #163a75 0 7px, #f7f4e6 7px 11px),
            #fffdf8;
        box-shadow: inset 0 0 0 8px #f7f4e6;
    }

    .frame-lacecolor {
        border: 5px solid transparent;
        background:
            linear-gradient(#fffdf8, #fffdf8) padding-box,
            repeating-linear-gradient(90deg, #18b7a4 0 9px, #e879f9 9px 18px, #f4c430 18px 27px, #111827 27px 36px) border-box;
        box-shadow: inset 0 0 0 2px #fff;
    }

    .frame-goldornate {
        border: 6px solid #c4972f;
        background:
            repeating-linear-gradient(45deg, rgba(196,151,47,.65) 0 4px, transparent 4px 8px),
            #fffdf8;
        box-shadow: inset 0 0 0 7px #fff7dd, inset 0 0 0 10px #c4972f;
    }

    .frame-sealribbon {
        border: 3px solid #d6b25e;
        background:
            radial-gradient(circle at 16% 78%, #b91c1c 0 13px, transparent 14px),
            linear-gradient(135deg, rgba(214,178,94,.24), transparent 42%),
            #fffdf8;
    }

    .frame-formalaward {
        border: 4px double #1f2937;
        background:
            linear-gradient(90deg, #1f2937 0 9px, transparent 9px calc(100% - 9px), #1f2937 calc(100% - 9px)),
