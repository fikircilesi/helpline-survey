                                    </label>
                                    <label class="cert-frame-option" style="--theme-color:@vurgu">
                                        <input type="radio" name="SertifikaCerceve" value="FormalAward" @(cerceve == "FormalAward" ? "checked" : "") />
                                        <span class="frame-swatch frame-formalaward"></span>
                                        <strong>Resmi Belge</strong>
                                    </label>
                                    <label class="cert-frame-option" style="--theme-color:@vurgu">
                                        <input type="radio" name="SertifikaCerceve" value="FloralGold" @(cerceve == "FloralGold" ? "checked" : "") />
                                        <span class="frame-swatch frame-floralgold"></span>
                                        <strong>Çiçekli Altın</strong>
                                    </label>
                                    <label class="cert-frame-option" style="--theme-color:@vurgu">
                                        <input type="radio" name="SertifikaCerceve" value="Ottoman" @(cerceve == "Ottoman" ? "checked" : "") />
                                        <span class="frame-swatch frame-ottoman"></span>
                                        <strong>Osmanlı Motif</strong>
                                    </label>
                                    <label class="cert-frame-option" style="--theme-color:@vurgu">
                                        <input type="radio" name="SertifikaCerceve" value="AofTurquoise" @(cerceve == "AofTurquoise" ? "checked" : "") />
                                        <span class="frame-swatch frame-aofturquoise"></span>
                                        <strong>AÖF Turkuaz</strong>
                                    </label>
                                    <label class="cert-frame-option" style="--theme-color:@vurgu">
                                        <input type="radio" name="SertifikaCerceve" value="Guilloche" @(cerceve == "Guilloche" ? "checked" : "") />
