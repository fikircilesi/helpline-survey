            #fffdf8;
    }

    .frame-floralgold {
        border: 4px double #c4972f;
        background:
            repeating-linear-gradient(90deg, rgba(196,151,47,.70) 0 6px, transparent 6px 12px),
            #fffdf8;
    }

    .frame-ottoman {
        border: 5px solid transparent;
        background:
            linear-gradient(#fffdf8, #fffdf8) padding-box,
