        background:
            radial-gradient(circle at 14% 80%, rgba(185,28,28,.92) 0 23px, transparent 24px),
            linear-gradient(135deg, rgba(214,178,94,.20), transparent 46%),
            #fffdf8;
    }

    .cert-preview.frame-formalaward {
        border: 6px double #1f2937;
        background:
