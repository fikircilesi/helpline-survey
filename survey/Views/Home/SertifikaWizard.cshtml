                                </div>
                            </div>
                        </section>

                        <div class="cert-footer">
                            <a class="cert-btn" href="@Url.Action("Indexgosterge", "Home")">Vazgeç</a>
                            <button class="cert-btn primary" type="submit">Kaydet</button>
                        </div>
                    </div>

                    <aside class="cert-preview frame-@cerceve.ToLowerInvariant() font-@font.ToLowerInvariant()" style="--cert-accent:@vurgu; --cert-text-size:@yaziPunto; --cert-title-size:@baslikPunto">
                        <div data-cert-logo-area>
                            @if (!string.IsNullOrWhiteSpace(logo))
                            {
                                <div class="cert-preview-logo">
                                    <img src="@logo" alt="Sertifika logosu" />
                                </div>
                            }
                            else
                            {
                                <div class="cert-preview-mark">E</div>
                            }
                        </div>
                        <h3 data-cert-title>@(string.IsNullOrWhiteSpace(Model.SertifikaBaslik) ? "Katılım Sertifikası" : Model.SertifikaBaslik)</h3>
                        <div class="cert-preview-course">@Model.AnketAdi</div>
                        <div class="cert-preview-name">Sn. Katılımcı</div>
                        <span class="cert-name-help">Gerçek sertifikada katılımcı adı otomatik gelir.</span>
                        <p data-cert-text>@onizlemeMetni</p>
                        <div class="cert-preview-footer">
                            <div>
                                <strong>Düzenleme Tarihi</strong>
                                <span>@DateTime.Now.ToString("dd.MM.yyyy")</span>
                            </div>
                            <div class="cert-preview-signature">
                                <img data-cert-signature-img src="@(string.IsNullOrWhiteSpace(imza) ? "" : Url.Content(imza))" alt="Eğitici imzası" @(string.IsNullOrWhiteSpace(imza) ? "hidden" : "") />
                                <strong>Eğitimi Veren</strong>
                                <span data-cert-organizer>@(string.IsNullOrWhiteSpace(Model.EgitimVeren) ? "Düzenleyen" : Model.EgitimVeren)</span>
                            </div>
                        </div>
                        <template>
                            Başarı koşullarını sağlayan katılımcılar için sertifika bu görsel dilde hazırlanır.
                            Yetki ve zamanlama kuralları katılım portalında otomatik uygulanır.
                        </template>
                    </aside>
                </div>
            }
        </div>
    </div>
</div>

<script>
    (function () {
        var preview = document.querySelector(".cert-preview");
        if (!preview) return;

        var colorInput = document.getElementById("SertifikaVurguRengi");
        var titleInput = document.getElementById("SertifikaBaslik");
        var titleTarget = document.querySelector("[data-cert-title]");
        var logoInput = document.getElementById("LogoDosyasi");
        var logoArea = document.querySelector("[data-cert-logo-area]");
        var textInput = document.getElementById("SertifikaMetni");
        var textTarget = document.querySelector("[data-cert-text]");
        var fontInput = document.getElementById("SertifikaFont");
        var textSizeInput = document.getElementById("SertifikaYaziPunto");
        var titleSizeInput = document.getElementById("SertifikaBaslikPunto");
        var organizerInput = document.getElementById("EgitimVeren");
        var organizerTarget = document.querySelector("[data-cert-organizer]");
        var signatureInput = document.getElementById("ImzaDosyasi");
        var signatureFieldPreview = document.querySelector("[data-signature-field-preview]");
        var signatureFieldImg = document.querySelector("[data-signature-field-img]");
        var signatureFieldText = document.querySelector("[data-signature-field-text]");
        var signaturePreviewImg = document.querySelector("[data-cert-signature-img]");
        var courseName = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AnketAdi ?? "Eğitim"));
        var fallbackText = "Başarı koşullarını sağlayan katılımcılar için sertifika bu görsel dilde hazırlanır. Yetki ve zamanlama kuralları katılım portalında otomatik uygulanır.";

        function updateFrame() {
            var selected = document.querySelector("input[name='SertifikaCerceve']:checked");
            var frame = selected ? selected.value.toLowerCase() : "classic";
            preview.classList.remove(
                "frame-classic",
                "frame-doublegold",
                "frame-ribbon",
                "frame-cornerseal",
                "frame-gradientwash",
                "frame-royal",
                "frame-sidestripe",
                "frame-topband",
                "frame-minimalline",
                "frame-artdeco",
                "frame-blueclassic",
                "frame-lacecolor",
                "frame-goldornate",
                "frame-sealribbon",
                "frame-formalaward",
                "frame-floralgold",
                "frame-ottoman",
                "frame-aofturquoise",
                "frame-guilloche",
                "frame-victorian",
                "frame-laurel",
                "frame-cornerflourish",
                "frame-finelace",
                "frame-antique"
            );
            preview.classList.add("frame-" + frame);
        }

        function updateFont() {
            var font = fontInput && fontInput.value ? fontInput.value.toLowerCase() : "georgia";
            preview.classList.remove("font-georgia", "font-garamond", "font-playfair", "font-merriweather", "font-cambria", "font-times", "font-arial", "font-verdana", "font-opensans");
            preview.classList.add("font-" + font);
        }

        function updateSizes() {
            if (textSizeInput && textSizeInput.value) {
                preview.style.setProperty("--cert-text-size", textSizeInput.value);
            }
            if (titleSizeInput && titleSizeInput.value) {
                preview.style.setProperty("--cert-title-size", titleSizeInput.value);
            }
        }

        function updateColor() {
            if (colorInput && colorInput.value) {
                preview.style.setProperty("--cert-accent", colorInput.value);
                document.querySelectorAll(".cert-frame-option").forEach(function (item) {
                    item.style.setProperty("--theme-color", colorInput.value);
                });
            }
        }

        function updateTitle() {
            if (titleTarget && titleInput) {
                titleTarget.textContent = titleInput.value.trim() || "Katılım Sertifikası";
            }
        }

        function formatCertificateText(value) {
            var text = value && value.trim() ? value : fallbackText;
            var organizer = organizerInput && organizerInput.value.trim() ? organizerInput.value.trim() : "Düzenleyen";
            return text
                .replaceAll("{adSoyad}", "Katılımcı")
                .replaceAll("{egitim}", courseName || "Eğitim")
                .replaceAll("{tarih}", new Date().toLocaleDateString("tr-TR"))
                .replaceAll("{egitimVeren}", organizer);
        }

        function updateText() {
            if (textTarget) {
                textTarget.textContent = formatCertificateText(textInput ? textInput.value : "");
            }
        }

        function updateOrganizer() {
            if (organizerTarget && organizerInput) {
                organizerTarget.textContent = organizerInput.value.trim() || "Düzenleyen";
            }
            updateText();
        }

        function updateSignaturePreview(url) {
            if (signatureFieldPreview && signatureFieldImg) {
                signatureFieldImg.src = url;
                signatureFieldPreview.hidden = false;
            }
            if (signatureFieldText) {
                signatureFieldText.textContent = "Yeni imza önizlemesi";
            }
            if (signaturePreviewImg) {
                signaturePreviewImg.src = url;
                signaturePreviewImg.hidden = false;
            }
        }

        document.querySelectorAll("input[name='SertifikaCerceve']").forEach(function (item) {
            item.addEventListener("change", updateFrame);
        });

        if (colorInput) colorInput.addEventListener("input", updateColor);
        if (titleInput) titleInput.addEventListener("input", updateTitle);
        if (textInput) textInput.addEventListener("input", updateText);
        if (fontInput) fontInput.addEventListener("change", updateFont);
        if (textSizeInput) textSizeInput.addEventListener("input", updateSizes);
        if (titleSizeInput) titleSizeInput.addEventListener("input", updateSizes);
        if (organizerInput) organizerInput.addEventListener("input", updateOrganizer);
        if (logoInput && logoArea) {
            logoInput.addEventListener("change", function () {
                var file = logoInput.files && logoInput.files[0];
                if (!file) return;
                var url = URL.createObjectURL(file);
                logoArea.innerHTML = '<div class="cert-preview-logo"><img src="' + url + '" alt="Sertifika logosu" /></div>';
            });
        }
        if (signatureInput) {
            signatureInput.addEventListener("change", function () {
                var file = signatureInput.files && signatureInput.files[0];
                if (!file) return;
                updateSignaturePreview(URL.createObjectURL(file));
            });
        }

        updateFrame();
        updateColor();
        updateFont();
        updateSizes();
        updateTitle();
        updateOrganizer();
    })();
</script>
