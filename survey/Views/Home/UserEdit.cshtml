@model survey.Models.Personel

@{
    ViewBag.Title = "Hesap Ayarları";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var personelAdi = string.IsNullOrWhiteSpace(Model?.PersonelAdi) ? "Kullanıcı" : Model.PersonelAdi;
    var kullaniciAdi = Model?.KullaniciAdi ?? "";
    var mail = Model?.Mail ?? "";
    var profilResmi = string.IsNullOrWhiteSpace(Model?.Resim) ? "avatar.png" : Model.Resim;
    var profilResmiUrl = Url.Content("~/Content/Personel/" + profilResmi);
    var geriId = ViewBag.id ?? Model?.PersonelId;
}

<style>
    .studio-profile-page {
        max-width: 1544px;
        margin: 0 auto;
        padding: 38px 42px 64px;
    }

    .studio-profile-hero {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        min-height: 190px;
        padding: 34px 38px;
        color: #ffffff;
        background: linear-gradient(135deg, #172333 0%, #1d3a45 100%);
        border: 1px solid rgba(255,255,255,.10);
        border-radius: 8px;
        box-shadow: 0 24px 60px rgba(15, 29, 45, .14);
    }

    .studio-profile-kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 13px;
        margin-bottom: 18px;
        color: #b8ffe9;
        font-size: 13px;
        font-weight: 700;
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(255,255,255,.18);
        border-radius: 999px;
    }

    .studio-profile-hero h1 {
        margin: 0;
        color: #ffffff;
        font-size: 34px;
        line-height: 1.18;
        font-weight: 800;
    }

    .studio-profile-hero p {
        max-width: 720px;
        margin: 12px 0 0;
        color: rgba(255,255,255,.78);
        font-size: 15px;
        line-height: 1.7;
    }

    .studio-profile-badge {
        flex: 0 0 auto;
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 230px;
        padding: 16px;
        background: rgba(255,255,255,.09);
        border: 1px solid rgba(255,255,255,.16);
        border-radius: 8px;
    }

    .studio-profile-badge img {
        width: 54px;
        height: 54px;
        object-fit: cover;
        border-radius: 8px;
        border: 2px solid rgba(255,255,255,.28);
        background: rgba(255,255,255,.16);
    }

    .studio-profile-badge strong,
    .studio-profile-badge span {
        display: block;
        max-width: 150px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .studio-profile-badge span {
        margin-top: 3px;
        color: rgba(255,255,255,.68);
        font-size: 12px;
    }

    .studio-profile-shell {
        display: grid;
        grid-template-columns: minmax(260px, 360px) minmax(0, 1fr);
        gap: 18px;
        margin-top: 22px;
    }

    .studio-profile-side,
    .studio-profile-form {
        background: #ffffff;
        border: 1px solid #e4eaf1;
        border-radius: 8px;
        box-shadow: 0 18px 48px rgba(21, 39, 61, .08);
    }

    .studio-profile-side {
        padding: 24px;
    }

    .studio-avatar-frame {
        display: grid;
        place-items: center;
        width: 142px;
        height: 142px;
        margin: 0 auto 18px;
        background: #eef4fa;
        border: 1px solid #dce5ee;
        border-radius: 8px;
        overflow: hidden;
    }

    .studio-avatar-frame img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .studio-person-summary {
        text-align: center;
    }

    .studio-person-summary h2 {
        margin: 0;
        color: #0f1f31;
        font-size: 21px;
        line-height: 1.3;
        font-weight: 800;
    }

    .studio-person-summary p {
        margin: 7px 0 0;
        color: #5c6c80;
        font-size: 14px;
        overflow-wrap: anywhere;
    }

    .studio-upload-control {
        display: block;
        margin-top: 22px;
    }

    .studio-upload-control input {
        position: absolute;
        width: 1px;
        height: 1px;
        opacity: 0;
        pointer-events: none;
    }

    .studio-upload-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
        width: 100%;
        min-height: 46px;
        padding: 11px 14px;
        color: #102035;
        font-weight: 800;
        background: #eef5fb;
        border: 1px solid #dce6ef;
        border-radius: 8px;
        cursor: pointer;
    }

    .studio-upload-name {
        display: block;
        min-height: 20px;
        margin-top: 10px;
        color: #617187;
        font-size: 13px;
        overflow-wrap: anywhere;
    }

    .studio-profile-form {
        padding: 0;
        overflow: hidden;
    }

    .studio-form-head,
    .studio-form-actions {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        padding: 22px 26px;
        background: #fbfcfe;
        border-bottom: 1px solid #e4eaf1;
    }

    .studio-form-head h2 {
        margin: 0;
        color: #0f1f31;
        font-size: 20px;
        font-weight: 800;
    }

    .studio-form-head p {
        margin: 5px 0 0;
        color: #627187;
        font-size: 13px;
    }

    .studio-form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 18px;
        padding: 26px;
    }

    .studio-field {
        min-width: 0;
    }

    .studio-field-full {
        grid-column: 1 / -1;
    }

    .studio-field label,
    .studio-field .studio-label {
        display: block;
        margin-bottom: 8px;
        color: #203047;
        font-size: 13px;
        font-weight: 800;
    }

    .studio-input,
    .studio-profile-form select,
    .studio-profile-form input[type="text"],
    .studio-profile-form input[type="password"],
    .studio-profile-form input[type="email"] {
        width: 100%;
        min-height: 46px;
        padding: 11px 13px;
        color: #172333;
        background: #ffffff;
        border: 1px solid #d4dde8;
        border-radius: 8px;
        box-shadow: none;
        outline: none;
        transition: border-color .15s ease, box-shadow .15s ease, background .15s ease;
    }

    .studio-profile-form input:disabled {
        color: #6b788a;
        background: #f2f5f8;
        cursor: not-allowed;
    }

    .studio-profile-form select:focus,
    .studio-profile-form input:focus {
        border-color: #5be4bd;
        box-shadow: 0 0 0 4px rgba(91, 228, 189, .18);
    }

    .studio-password-wrap {
        position: relative;
    }

    .studio-password-wrap input {
        padding-right: 50px;
    }

    .studio-password-toggle {
        position: absolute;
        right: 6px;
        top: 6px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        color: #43536a;
        background: #eef3f8;
        border: 0;
        border-radius: 8px;
        cursor: pointer;
    }

    .studio-validation {
        padding: 0 26px;
    }

    .studio-form-actions {
        justify-content: flex-end;
        border-top: 1px solid #e4eaf1;
        border-bottom: 0;
    }

    .studio-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        min-height: 44px;
        padding: 11px 18px;
        color: #102035;
        font-weight: 800;
        border: 1px solid transparent;
        border-radius: 8px;
        cursor: pointer;
        text-decoration: none;
    }

    .studio-btn:hover,
    .studio-btn:focus {
        color: #102035;
        text-decoration: none;
    }

    .studio-btn-secondary {
        background: #eef3f8;
        border-color: #d8e1eb;
    }

    .studio-btn-primary {
        background: #86efca;
        border-color: #86efca;
        box-shadow: 0 16px 30px rgba(71, 209, 165, .22);
    }

    @@media (max-width: 1180px) {
        .studio-profile-page {
            padding: 28px 24px 54px;
        }

        .studio-profile-hero {
            align-items: flex-start;
            flex-direction: column;
        }

        .studio-profile-badge {
            width: 100%;
        }
    }

    @@media (max-width: 900px) {
        .studio-profile-shell,
        .studio-form-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 640px) {
        .studio-profile-page {
            padding: 20px 14px 42px;
        }

        .studio-profile-hero {
            padding: 24px 20px;
        }

        .studio-profile-hero h1 {
            font-size: 27px;
        }

        .studio-form-head,
        .studio-form-actions,
        .studio-form-grid {
            padding-left: 18px;
            padding-right: 18px;
        }

        .studio-form-actions {
            flex-direction: column-reverse;
        }

        .studio-btn {
            width: 100%;
        }
    }
</style>

@using (Html.BeginForm("UserEdit", "Home", FormMethod.Post, new { enctype = "multipart/form-data", @class = "studio-profile-page" }))
{
    @Html.AntiForgeryToken()

    @Html.HiddenFor(model => model.PersonelId)
    @Html.HiddenFor(model => model.PersonelAdi)
    @Html.HiddenFor(model => model.KullaniciAdi)
    @Html.HiddenFor(model => model.KayitTarihi)
    @Html.HiddenFor(model => model.Pasif)
    @Html.HiddenFor(model => model.Tc)
    @Html.HiddenFor(model => model.Telefon)
    @Html.HiddenFor(model => model.Adres)
    @Html.HiddenFor(model => model.Admin)
    @Html.HiddenFor(model => model.Mail)
    @Html.HiddenFor(model => model.Resim)

    <section class="studio-profile-hero">
        <div>
            <span class="studio-profile-kicker"><i class="ti-user"></i> Survey by Aslana Teknoloji hesabı</span>
            <h1>Hesap ayarlarını zarifçe toparlayalım.</h1>
            <p>Profil görünümü ve giriş şifresi bu ekrandan güncellenir. Kullanıcı adı ve mail adresi hesap kimliği olduğu için sabit tutulur.</p>
        </div>
        <div class="studio-profile-badge">
            <img id="profilHeroOnizleme" src="@profilResmiUrl" alt="@personelAdi" onerror="this.onerror=null;this.src='@Url.Content("~/Content/Personel/avatar.png")';" />
            <div>
                <strong>@personelAdi</strong>
                <span>@kullaniciAdi</span>
            </div>
        </div>
    </section>

    <section class="studio-profile-shell">
        <aside class="studio-profile-side">
            <div class="studio-avatar-frame">
                <img id="profilOnizleme" src="@profilResmiUrl" alt="@personelAdi" onerror="this.onerror=null;this.src='@Url.Content("~/Content/Personel/avatar.png")';" />
            </div>

            <div class="studio-person-summary">
                <h2>@personelAdi</h2>
                <p>@mail</p>
            </div>

            <label class="studio-upload-control" for="uploadfile">
                <input type="file" name="uploadfile" id="uploadfile" accept="image/*" />
                <span class="studio-upload-button"><i class="ti-image"></i> Profil Resmi Seç</span>
                <span class="studio-upload-name" id="dosyaAdi">Mevcut görsel: @profilResmi</span>
            </label>
        </aside>

        <div class="studio-profile-form">
            <div class="studio-form-head">
                <div>
                    <h2>Personel Bilgileri</h2>
                    <p>Hesap bilgilerini güncelle, sonra kaydet.</p>
                </div>
                <i class="ti-settings"></i>
            </div>

            <div class="studio-validation">
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            </div>

            <div class="studio-form-grid">
                <div class="studio-field">
                    <label for="KullaniciAdiGorunum">Kullanıcı Adı</label>
                    <input id="KullaniciAdiGorunum" class="studio-input" maxlength="15" value="@kullaniciAdi" disabled />
                </div>

                <div class="studio-field">
                    <label for="Sifre">Şifre</label>
                    <div class="studio-password-wrap">
                        @Html.TextBoxFor(m => m.Sifre, new { @class = "studio-input", maxlength = "15", type = "password", autocomplete = "new-password" })
                        <button type="button" class="studio-password-toggle" id="sifreGoster" aria-label="Şifreyi göster veya gizle">
                            <i class="ti-eye"></i>
                        </button>
                    </div>
                    @Html.ValidationMessageFor(model => model.Sifre, "", new { @class = "text-danger" })
                </div>

                <div class="studio-field studio-field-full">
                    <label for="MailGorunum">Mail</label>
                    <input id="MailGorunum" class="studio-input" type="email" value="@mail" disabled />
                </div>
            </div>

            <div class="studio-form-actions">
                <a class="studio-btn studio-btn-secondary" href="@Url.Action("Indexgosterge", "Home", new { id = geriId })">
                    <i class="ti-arrow-left"></i> Geri
                </a>
                <input type="hidden" name="id" value="@geriId">
                <input type="hidden" name="mgz" value="@ViewBag.mgz">
                <button type="submit" class="studio-btn studio-btn-primary">
                    <i class="ti-check"></i> Kaydet
                </button>
            </div>
        </div>
    </section>
}

<script>
    (function () {
        var upload = document.getElementById('uploadfile');
        var preview = document.getElementById('profilOnizleme');
        var heroPreview = document.getElementById('profilHeroOnizleme');
        var sidebarPreview = document.querySelector('.sidebar-user-main img');
        var fileName = document.getElementById('dosyaAdi');
        var password = document.getElementById('Sifre');
        var passwordToggle = document.getElementById('sifreGoster');

        if (upload && preview && fileName) {
            upload.addEventListener('change', function () {
                var file = upload.files && upload.files[0];
                if (!file) {
                    return;
                }

                fileName.textContent = file.name;

                if (file.type && file.type.indexOf('image/') === 0) {
                    var previewUrl = URL.createObjectURL(file);
                    preview.src = previewUrl;
                    if (heroPreview) {
                        heroPreview.src = previewUrl;
                    }
                    if (sidebarPreview) {
                        sidebarPreview.src = previewUrl;
                    }
                }
            });
        }

        if (password && passwordToggle) {
            passwordToggle.addEventListener('click', function () {
                var isPassword = password.type === 'password';
                password.type = isPassword ? 'text' : 'password';
                passwordToggle.innerHTML = isPassword ? '<i class="ti-lock"></i>' : '<i class="ti-eye"></i>';
            });
        }
    })();
</script>
