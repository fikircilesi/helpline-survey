@model survey.Models.Tumcontroller
@{
    Layout = "~/Views/Shared/_AnketLayout.cshtml";

    var katilimciAdi = Convert.ToString(ViewBag.katilimciAdi ?? Session["adi"] ?? string.Empty);
    var katilimciResim = Convert.ToString(ViewBag.katilimciResim ?? string.Empty);
    var katilimciCinsiyet = Convert.ToString(ViewBag.katilimciCinsiyet ?? string.Empty);
    var calismaAdi = Convert.ToString(ViewBag.ankadi ?? "Çalışma");
    var calismaTuru = Convert.ToString(ViewBag.calismaTuru ?? (ViewBag.sinav == true ? "Sınav" : "Çalışma"));
    var egitimVeren = Convert.ToString(ViewBag.egitimVeren ?? string.Empty);
    var katilimKodu = Convert.ToString(ViewBag.kod ?? string.Empty);
    var userValue = Convert.ToString(ViewBag.user ?? Session["id"] ?? 1);
    var videoKodu = Convert.ToString(ViewBag.link ?? string.Empty).Trim();
    if (!string.IsNullOrWhiteSpace(videoKodu))
    {
        string hamVideo = videoKodu;
        Uri videoUri;
        if (Uri.TryCreate(hamVideo, UriKind.Absolute, out videoUri))
        {
            string[] pathSegments = videoUri.AbsolutePath
                .Split(new[] { '/' }, StringSplitOptions.RemoveEmptyEntries);
            string[] queryPairs = videoUri.Query.TrimStart('?')
                .Split(new[] { '&' }, StringSplitOptions.RemoveEmptyEntries);
            string vParam = string.Empty;

            foreach (var queryPair in queryPairs)
            {
                var queryParts = queryPair.Split(new[] { '=' }, 2);
                if (queryParts.Length == 2 && string.Equals(queryParts[0], "v", StringComparison.OrdinalIgnoreCase))
                {
                    vParam = queryParts[1];
                    break;
                }
            }

            if (!string.IsNullOrWhiteSpace(vParam))
            {
                videoKodu = vParam;
            }
            else if (pathSegments.Length > 0)
            {
                videoKodu = pathSegments[pathSegments.Length - 1];
            }
        }
        else
        {
            string[] videoParcalari = hamVideo.Split(new[] { '?', '&' }, StringSplitOptions.RemoveEmptyEntries);
            videoKodu = videoParcalari.Length > 0 ? videoParcalari[0] : string.Empty;
        }

        var videoEslesme = System.Text.RegularExpressions.Regex.Match(videoKodu, @"[A-Za-z0-9_-]{6,}");
        videoKodu = videoEslesme.Success ? videoEslesme.Value : string.Empty;
    }
    var sinavMi = ViewBag.sinav == true;
    var videoVar = sinavMi && !string.IsNullOrWhiteSpace(videoKodu);
    var izledi = ViewBag.izledi == true;
    var sonucAcik = ViewBag.sonucAcik == true;

    int? sureDakika = null;
    int sureDegeri = 0;
    if (ViewBag.zaman != null && int.TryParse(Convert.ToString(ViewBag.zaman), out sureDegeri) && sureDegeri > 0)
    {
        sureDakika = sureDegeri;
    }

    int soruSayisi = 0;
    if (ViewBag.soruSayisi != null)
    {
        int.TryParse(Convert.ToString(ViewBag.soruSayisi), out soruSayisi);
    }

    int grupSayisi = 0;
    if (ViewBag.grupSayisi != null)
    {
        int.TryParse(Convert.ToString(ViewBag.grupSayisi), out grupSayisi);
    }

    double toplamPuan = 0;
    if (ViewBag.toplamPuan != null)
    {
        double.TryParse(Convert.ToString(ViewBag.toplamPuan), out toplamPuan);
    }

    int? gecmeNotu = null;
    int notDegeri = 0;
    if (ViewBag.sertifikaNotu != null && int.TryParse(Convert.ToString(ViewBag.sertifikaNotu), out notDegeri))
    {
        gecmeNotu = notDegeri;
    }

    var karsilamaMetni = !string.IsNullOrWhiteSpace(katilimciAdi)
        ? "Sayın " + katilimciAdi + ", giriş alanınız hazır."
        : "Giriş alanınız hazır.";
    var baslatMetni = izledi
        ? "Sınava Devam Et"
        : videoVar
            ? "Videoyu İzledim, Sınava Başla"
            : "Çalışmaya Başla";
}

<style>
    :root {
        --portal-ink: #101828;
        --portal-muted: #667085;
        --portal-line: #d9e4f2;
        --portal-blue: #3255e8;
        --portal-teal: #18b7a5;
        --portal-amber: #f5a524;
        --portal-rose: #ee5b74;
        --portal-bg: #eef4f8;
    }

    body {
        background:
            linear-gradient(115deg, rgba(50, 85, 232, .08), transparent 28%),
            linear-gradient(245deg, rgba(24, 183, 165, .10), transparent 34%),
            var(--portal-bg);
    }

    .main-body,
    .page-wrapper {
        background: transparent !important;
    }

    .page-wrapper {
        padding: 22px 24px 30px !important;
    }

    .participant-gateway {
        width: min(1480px, 100%);
        margin: 0 auto;
        color: var(--portal-ink);
    }

    .gateway-hero {
        position: relative;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 22px;
        align-items: center;
        padding: 26px;
        border: 1px solid rgba(255, 255, 255, .28);
        border-radius: 8px;
        background:
            linear-gradient(130deg, rgba(9, 18, 32, .98), rgba(16, 54, 65, .96) 54%, rgba(12, 26, 44, .98)),
            #0b1220;
        color: #fff;
        box-shadow: 0 24px 68px rgba(16, 24, 40, .20);
        overflow: hidden;
        isolation: isolate;
    }

    .gateway-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
            linear-gradient(106deg, transparent 0 25%, rgba(24, 183, 165, .22) 33%, transparent 43%),
            linear-gradient(76deg, transparent 0 58%, rgba(245, 165, 36, .18) 65%, transparent 73%),
            linear-gradient(145deg, transparent 0 78%, rgba(238, 91, 116, .17) 84%, transparent 91%);
        background-size: 520px 100%, 420px 100%, 460px 100%;
        animation: portalLightTracks 11s linear infinite;
        z-index: -2;
    }

    .gateway-hero::after {
        content: "";
        position: absolute;
        inset: 0;
        background-image:
            repeating-linear-gradient(90deg, rgba(255, 255, 255, .055) 0 1px, transparent 1px 46px),
            repeating-linear-gradient(0deg, rgba(255, 255, 255, .04) 0 1px, transparent 1px 38px);
        opacity: .5;
        z-index: -1;
    }

    @@keyframes portalLightTracks {
        from { background-position: -520px 0, 420px 0, -460px 0; }
        to { background-position: 520px 0, -420px 0, 460px 0; }
    }

    .gateway-brand {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        min-height: 32px;
        padding: 0 12px;
        border: 1px solid rgba(255, 255, 255, .22);
        border-radius: 999px;
        color: rgba(255, 255, 255, .78);
        background: rgba(255, 255, 255, .08);
        font-size: 12px;
        font-weight: 800;
    }

    .gateway-title {
        max-width: 900px;
        margin: 16px 0 8px;
        color: #fff;
        font-size: clamp(30px, 4vw, 54px);
        line-height: 1.04;
        font-weight: 950;
        letter-spacing: 0;
    }

    .gateway-subtitle {
        max-width: 760px;
        margin: 0;
        color: rgba(255, 255, 255, .80);
        font-size: 16px;
        line-height: 1.7;
        font-weight: 700;
    }

    .hero-person {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        align-items: center;
        gap: 13px;
        min-width: min(390px, 100%);
        padding: 14px;
        border: 1px solid rgba(255, 255, 255, .18);
        border-radius: 8px;
        background: rgba(255, 255, 255, .09);
        backdrop-filter: blur(16px);
    }

    .hero-person strong {
        display: block;
        color: #fff;
        font-size: 16px;
        font-weight: 900;
        word-break: break-word;
    }

    .hero-person span {
        display: block;
        margin-top: 4px;
        color: rgba(255, 255, 255, .70);
        font-size: 12px;
        font-weight: 800;
    }

    .gateway-strip {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
        margin: 16px 0 0;
    }

    .gateway-stat {
        min-height: 78px;
        padding: 13px 14px;
        border: 1px solid rgba(255, 255, 255, .15);
        border-radius: 8px;
        background: rgba(255, 255, 255, .08);
    }

    .gateway-stat span {
        display: block;
        color: rgba(255, 255, 255, .66);
        font-size: 11px;
        font-weight: 900;
        letter-spacing: .06em;
        text-transform: uppercase;
    }

    .gateway-stat strong {
        display: block;
        margin-top: 7px;
        color: #fff;
        font-size: 22px;
        font-weight: 950;
        line-height: 1.15;
    }

    .gateway-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.55fr) minmax(330px, .75fr);
        gap: 18px;
        margin-top: 18px;
        align-items: start;
    }

    .gateway-panel {
        border: 1px solid var(--portal-line);
        border-radius: 8px;
        background: rgba(255, 255, 255, .92);
        box-shadow: 0 18px 54px rgba(16, 24, 40, .09);
        overflow: hidden;
    }

    .panel-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 18px 20px;
        border-bottom: 1px solid #e7eef8;
        background: linear-gradient(135deg, #fbfdff, #f4f8ff);
    }

    .panel-head h2,
    .panel-head h3 {
        margin: 0;
        color: var(--portal-ink);
        font-size: 18px;
        font-weight: 950;
    }

    .panel-head p {
        margin: 5px 0 0;
        color: var(--portal-muted);
        font-size: 13px;
        font-weight: 700;
    }

    .video-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        min-height: 34px;
        padding: 0 12px;
        border-radius: 999px;
        color: #0b645b;
        background: #e9fbf8;
        border: 1px solid #bdeee5;
        font-weight: 900;
        white-space: nowrap;
    }

    .video-stage {
        padding: 16px;
        background: #0f172a;
    }

    .video-shell {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 9;
        min-height: 360px;
        overflow: hidden;
        border-radius: 8px;
        background:
            linear-gradient(135deg, rgba(24, 183, 165, .22), transparent 38%),
            linear-gradient(225deg, rgba(50, 85, 232, .24), transparent 45%),
            #101828;
    }

    .video-shell iframe {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        border: 0;
    }

    .video-empty {
        display: grid;
        place-items: center;
        min-height: 360px;
        color: #fff;
        text-align: center;
        padding: 34px;
    }

    .video-empty i {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 76px;
        height: 76px;
        border-radius: 8px;
        color: #071420;
        background: #a8ffdf;
        font-size: 30px;
        margin-bottom: 16px;
    }

    .video-empty h2 {
        margin: 0 0 8px;
        color: #fff;
        font-size: 28px;
        font-weight: 950;
    }

    .video-empty p {
        margin: 0;
        color: rgba(255, 255, 255, .72);
        font-weight: 700;
    }

    .status-row {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
        padding: 14px 16px 16px;
        background: #fff;
    }

    .status-step {
        display: grid;
        grid-template-columns: 38px minmax(0, 1fr);
        gap: 10px;
        align-items: center;
        min-height: 62px;
        padding: 10px;
        border: 1px solid #e4ebf5;
        border-radius: 8px;
        background: #f8fafc;
    }

    .status-step i {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 38px;
        height: 38px;
        border-radius: 8px;
        color: #17324d;
        background: #e9f3ff;
    }

    .status-step.is-active {
        border-color: #9de6dc;
        background: #effdfa;
    }

    .status-step.is-active i {
        color: #fff;
        background: linear-gradient(135deg, var(--portal-teal), var(--portal-blue));
    }

    .status-step strong,
    .status-step span {
        display: block;
        overflow-wrap: anywhere;
    }

    .status-step strong {
        color: #101828;
        font-size: 13px;
        font-weight: 950;
    }

    .status-step span {
        margin-top: 2px;
        color: var(--portal-muted);
        font-size: 12px;
        font-weight: 700;
    }

    .side-body {
        padding: 16px;
    }

    .code-panel {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 12px;
        align-items: center;
        margin-bottom: 14px;
        padding: 14px;
        border: 1px solid #bdeee5;
        border-radius: 8px;
        background: #effdfa;
    }

    .code-panel span {
        display: block;
        color: #0b645b;
        font-size: 11px;
        font-weight: 950;
        letter-spacing: .06em;
        text-transform: uppercase;
    }

    .code-panel strong {
        display: block;
        margin-top: 4px;
        color: #101828;
        font-size: 24px;
        font-weight: 950;
        word-break: break-all;
    }

    .copy-code {
        min-width: 42px;
        height: 42px;
        border: 1px solid #91ded3;
        border-radius: 8px;
        color: #0b645b;
        background: #fff;
        font-size: 16px;
        cursor: pointer;
    }

    .start-form {
        margin: 0;
    }

    .start-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        width: 100%;
        min-height: 56px;
        border: 0;
        border-radius: 8px;
        color: #fff;
        background: linear-gradient(135deg, var(--portal-teal), var(--portal-blue));
        box-shadow: 0 18px 34px rgba(50, 85, 232, .26);
        font-size: 16px;
        font-weight: 950;
        cursor: pointer;
        transition: transform .18s ease, box-shadow .18s ease;
    }

    .start-button:hover {
        transform: translateY(-1px);
        color: #fff;
        box-shadow: 0 20px 40px rgba(24, 183, 165, .28);
    }

    .exit-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        min-height: 44px;
        margin-top: 10px;
        border: 1px solid #ffd0d8;
        border-radius: 8px;
        color: #b4233a;
        background: #fff7f8;
        font-weight: 900;
    }

    .prep-list {
        display: grid;
        gap: 10px;
        margin: 14px 0 0;
    }

    .prep-item {
        display: grid;
        grid-template-columns: 34px minmax(0, 1fr);
        gap: 10px;
        align-items: start;
        padding: 12px;
        border: 1px solid #e4ebf5;
        border-radius: 8px;
        background: #fff;
    }

    .prep-item i {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        border-radius: 8px;
        color: #3255e8;
        background: #eef3ff;
    }

    .prep-item strong {
        display: block;
        color: #101828;
        font-weight: 950;
    }

    .prep-item span {
        display: block;
        margin-top: 3px;
        color: var(--portal-muted);
        font-size: 12px;
        font-weight: 700;
        line-height: 1.5;
    }

    .gateway-detail-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
        margin-top: 18px;
    }

    .detail-tile {
        min-height: 110px;
        padding: 16px;
        border: 1px solid var(--portal-line);
        border-radius: 8px;
        background: rgba(255, 255, 255, .92);
        box-shadow: 0 16px 38px rgba(16, 24, 40, .07);
    }

    .detail-tile i {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        margin-bottom: 12px;
        border-radius: 8px;
        color: #fff;
        background: #3255e8;
    }

    .detail-tile:nth-child(2) i {
        background: #18b7a5;
    }

    .detail-tile:nth-child(3) i {
        background: #f5a524;
    }

    .detail-tile:nth-child(4) i {
        background: #ee5b74;
    }

    .detail-tile strong {
        display: block;
        color: #101828;
        font-size: 18px;
        font-weight: 950;
    }

    .detail-tile span {
        display: block;
        margin-top: 4px;
        color: var(--portal-muted);
        font-size: 12px;
        font-weight: 800;
        line-height: 1.45;
    }

    .copy-feedback {
        min-height: 18px;
        margin-top: 8px;
        color: #0b645b;
        font-size: 12px;
        font-weight: 900;
    }

    @@media (max-width: 1180px) {
        .gateway-hero,
        .gateway-grid {
            grid-template-columns: 1fr;
        }

        .hero-person {
            min-width: 0;
        }
    }

    @@media (max-width: 820px) {
        .page-wrapper {
            padding: 14px !important;
        }

        .gateway-hero {
            padding: 20px;
        }

        .gateway-strip,
        .status-row,
        .gateway-detail-grid {
            grid-template-columns: 1fr 1fr;
        }

        .video-shell,
        .video-empty {
            min-height: 250px;
        }
    }

    @@media (max-width: 560px) {
        .gateway-strip,
        .status-row,
        .gateway-detail-grid,
        .hero-person,
        .code-panel {
            grid-template-columns: 1fr;
        }

        .copy-code {
            width: 100%;
        }
    }
</style>

<main class="participant-gateway">
    <section class="gateway-hero">
        <div>
            <span class="gateway-brand"><i class="fa fa-shield"></i> Survey by Aslana Teknoloji</span>
            <h1 class="gateway-title">@calismaAdi</h1>
            <p class="gateway-subtitle">@karsilamaMetni Bu alan size özel açıldı; videonuzu izleyip sınav akışına aynı kodla güvenle devam edebilirsiniz.</p>

            <div class="gateway-strip">
                <div class="gateway-stat">
                    <span>Çalışma türü</span>
                    <strong>@calismaTuru</strong>
                </div>
                <div class="gateway-stat">
                    <span>Süre</span>
                    <strong>@(sureDakika.HasValue ? sureDakika + " dk" : "Sınırsız")</strong>
                </div>
                <div class="gateway-stat">
                    <span>Soru</span>
                    <strong>@soruSayisi</strong>
                </div>
                <div class="gateway-stat">
                    <span>Toplam puan</span>
                    <strong>@toplamPuan.ToString("0.#")</strong>
                </div>
            </div>
        </div>

        <aside class="hero-person">
            @await Html.PartialAsync("_KatilimciAvatar", new survey.Models.KatilimciAvatarModel { Ad = katilimciAdi, Resim = katilimciResim, Cinsiyet = katilimciCinsiyet, Size = "lg" })
            <div>
                <strong>@(string.IsNullOrWhiteSpace(katilimciAdi) ? "Katılımcı" : katilimciAdi)</strong>
                <span>@(string.IsNullOrWhiteSpace(katilimKodu) ? "Kayıtlı giriş" : "Katılım kodu: " + katilimKodu)</span>
            </div>
        </aside>
    </section>

    <section class="gateway-grid">
        <div class="gateway-panel">
            <div class="panel-head">
                <div>
                    <h2>@(videoVar ? "Eğitim Videosu" : "Başlangıç")</h2>
                    <p>@(videoVar ? "Sınava başlamadan önce eğitim videosunu tamamlayın." : "Bu çalışma için video adımı kapalı; doğrudan başlayabilirsiniz.")</p>
                </div>
                <span class="video-badge" id="videoStatus">
                    <i class="fa @(izledi ? "fa-check" : (videoVar ? "fa-play" : "fa-arrow-right"))"></i>
                    @(izledi ? "Video onaylandı" : (videoVar ? "İzleme bekleniyor" : "Başlamaya hazır"))
                </span>
            </div>

            <div class="video-stage">
                @if (videoVar)
                {
                    <div class="video-shell">
                        <iframe id="ytplayer"
                                src="https://www.youtube.com/embed/@videoKodu?enablejsapi=1&rel=0&modestbranding=1"
                                title="@calismaAdi eğitim videosu"
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                allowfullscreen></iframe>
                    </div>
                }
                else
                {
                    <div class="video-empty">
                        <div>
                            <i class="fa fa-rocket"></i>
                            <h2>Hazırsınız</h2>
                            <p>Sınav akışına geçmeden önce bilgileriniz aşağıda özetlendi.</p>
                        </div>
                    </div>
                }
            </div>

            <div class="status-row">
                <div class="status-step @(videoVar && !izledi ? "is-active" : "")" id="videoStep">
                    <i class="fa fa-play-circle"></i>
                    <div>
                        <strong>Video</strong>
                        <span>@(videoVar ? "Eğitim içeriği" : "Video yok")</span>
                    </div>
                </div>
                <div class="status-step @(!videoVar || izledi ? "is-active" : "")" id="examStep">
                    <i class="fa fa-pencil"></i>
                    <div>
                        <strong>Sınav</strong>
                        <span>@soruSayisi soru ile devam</span>
                    </div>
                </div>
                <div class="status-step">
                    <i class="fa fa-trophy"></i>
                    <div>
                        <strong>Sonuç</strong>
                        <span>@(sonucAcik ? "Sonuç takibi açık" : "Sonuç yönetici tarafından izlenir")</span>
                    </div>
                </div>
            </div>
        </div>

        <aside class="gateway-panel">
            <div class="panel-head">
                <div>
                    <h3>Katılım Hazırlığı</h3>
                    <p>Başlamadan önce çalışma bilgileriniz.</p>
                </div>
            </div>
            <div class="side-body">
                @if (!string.IsNullOrWhiteSpace(katilimKodu))
                {
                    <div class="code-panel">
                        <div>
                            <span>Katılım kodunuz</span>
                            <strong id="participantCode">@katilimKodu</strong>
                        </div>
                        <button class="copy-code" type="button" id="copyCodeButton" title="Kodu kopyala">
                            <i class="fa fa-copy"></i>
                        </button>
                    </div>
                    <div class="copy-feedback" id="copyFeedback"></div>
                }

                <form id="examForm" class="start-form" method="post" action="@Url.Action("Izledim", "Home")">
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <input type="hidden" name="UseId" value="@userValue" />
                    <input type="hidden" name="AnketId" value="@ViewBag.id" />
                    <input type="hidden" name="Izledi" value="true" />
                    <input type="hidden" name="IzTarih" value="@DateTime.Now" />
                    <input type="hidden" name="user" value="@userValue" />
                    <input type="hidden" name="kod" value="@ViewBag.kod" />

                    <button type="submit" id="btnStartExam" class="start-button">
                        <i class="fa @(izledi || !videoVar ? "fa-arrow-right" : "fa-check")"></i>
                        <span>@baslatMetni</span>
                    </button>
                </form>

                @if (Session["tc"] != null || ViewBag.kod != null)
                {
                    <a class="exit-link" href="@Url.Action("KatilimciCikis", "Home")">
                        <i class="fa fa-sign-out"></i>
                        Çıkış
                    </a>
                }

                <div class="prep-list">
                    <div class="prep-item">
                        <i class="fa fa-clock-o"></i>
                        <div>
                            <strong>Süre başlangıcı</strong>
                            <span>Süre sınava geçtiğiniz anda takip edilir.</span>
                        </div>
                    </div>
                    <div class="prep-item">
                        <i class="fa fa-check-square-o"></i>
                        <div>
                            <strong>Cevap kaydı</strong>
                            <span>Yanıtlarınızı gönderdikçe kayıt güvenli şekilde güncellenir.</span>
                        </div>
                    </div>
                    <div class="prep-item">
                        <i class="fa fa-certificate"></i>
                        <div>
                            <strong>Sertifika</strong>
                            <span>@(gecmeNotu.HasValue ? "Geçme notu: " + gecmeNotu + " ve üzeri." : "Sertifika koşulu bu çalışma için kapalı.")</span>
                        </div>
                    </div>
                </div>
            </div>
        </aside>
    </section>

    <section class="gateway-detail-grid">
        <div class="detail-tile">
            <i class="fa fa-list-ol"></i>
            <strong>@grupSayisi bölüm</strong>
            <span>Sorular rapor başlıklarına göre düzenlenmiştir.</span>
        </div>
        <div class="detail-tile">
            <i class="fa fa-question-circle"></i>
            <strong>@soruSayisi soru</strong>
            <span>Soru seti yayınlanan çalışma üzerinden takip edilir.</span>
        </div>
        <div class="detail-tile">
            <i class="fa fa-star"></i>
            <strong>@toplamPuan.ToString("0.#") puan</strong>
            <span>Toplam soru ağırlığına göre değerlendirilir.</span>
        </div>
        <div class="detail-tile">
            <i class="fa fa-user-circle"></i>
            <strong>@(string.IsNullOrWhiteSpace(egitimVeren) ? "Aslana" : egitimVeren)</strong>
            <span>Çalışma düzenleyicisi ve rapor sahibi.</span>
        </div>
    </section>
</main>

<script>
    (function () {
        var requiresVideo = @((videoVar && !izledi).ToString().ToLowerInvariant());
        var videoCompleted = @((izledi || !videoVar).ToString().ToLowerInvariant());
        var startButton = document.getElementById("btnStartExam");
        var startButtonText = startButton ? startButton.querySelector("span") : null;
        var videoStatus = document.getElementById("videoStatus");
        var videoStep = document.getElementById("videoStep");
        var examStep = document.getElementById("examStep");
        var form = document.getElementById("examForm");
        var copyButton = document.getElementById("copyCodeButton");
        var codeNode = document.getElementById("participantCode");
        var copyFeedback = document.getElementById("copyFeedback");
        var player;

        function setVideoComplete() {
            videoCompleted = true;
            if (videoStatus) {
                videoStatus.innerHTML = "<i class=\"fa fa-check\"></i> Video tamamlandı";
            }
            if (videoStep) {
                videoStep.classList.remove("is-active");
            }
            if (examStep) {
                examStep.classList.add("is-active");
            }
            if (startButtonText) {
                startButtonText.textContent = "Video Tamamlandı, Sınava Başla";
            }
        }

        window.onYouTubeIframeAPIReady = function () {
            if (!requiresVideo || !document.getElementById("ytplayer")) {
                return;
            }

            player = new YT.Player("ytplayer", {
                events: {
                    onStateChange: function (event) {
                        if (event.data === YT.PlayerState.ENDED) {
                            setVideoComplete();
                        }
                    }
                }
            });
        };

        if (form) {
            form.addEventListener("submit", function (event) {
                if (requiresVideo && !videoCompleted) {
                    var devam = confirm("Video henüz tamamlandı olarak algılanmadı. Yine de sınava geçmek istiyor musunuz?");
                    if (!devam) {
                        event.preventDefault();
                    }
                }
            });
        }

        if (copyButton && codeNode) {
            copyButton.addEventListener("click", function () {
                var code = codeNode.textContent.trim();
                if (!code) return;

                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(code).then(function () {
                        if (copyFeedback) copyFeedback.textContent = "Katılım kodu kopyalandı.";
                    }).catch(function () {
                        if (copyFeedback) copyFeedback.textContent = "Kod: " + code;
                    });
                } else if (copyFeedback) {
                    copyFeedback.textContent = "Kod: " + code;
                }
            });
        }
    })();
</script>

@if (videoVar)
{
    <script src="https://www.youtube.com/iframe_api"></script>
}
