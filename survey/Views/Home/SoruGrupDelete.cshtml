@model survey.Models.SoruGrup

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    ViewData["DeleteEyebrow"] = "Soru grubu";
    ViewData["DeleteTitle"] = "Soru grubu silinsin mi?";
    ViewData["DeleteDescription"] = "Bu grup soru bankasından kaldırılacak. Bir çalışmada veya sonuç kırılımında kullanılıyorsa silme işlemi durdurulur.";
    ViewData["DeleteItemLabel"] = "Soru grubu";
    ViewData["DeleteItemName"] = Model?.SoruGrupAdi;
    ViewData["DeleteWarning"] = "Bu işlem geri alınamaz. Önce bu grubu kullanan çalışma bağlantılarını kaldırmanız gerekebilir.";
    ViewData["DeleteBackUrl"] = Url.Action("SoruGrupIndex", "Home");
    ViewData["DeleteSubmitText"] = "Grubu sil";
}

@await Html.PartialAsync("_DeleteConfirm")
