@model survey.Models.Sube

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    ViewData["DeleteEyebrow"] = "Lokasyon tanımı";
    ViewData["DeleteTitle"] = "Şube silinsin mi?";
    ViewData["DeleteDescription"] = "Bu şube lokasyon tanımlarından kaldırılacak. Katılımcı veya çalışma kayıtlarında kullanılıyorsa silme işlemi durdurulur.";
    ViewData["DeleteItemLabel"] = "Şube";
    ViewData["DeleteItemName"] = Model?.SubeAdi;
    ViewData["DeleteWarning"] = "Bu işlem geri alınamaz. Önce bu şubeye bağlı kayıtları başka şubeye taşıyın.";
    ViewData["DeleteBackUrl"] = Url.Action("SubeIndex", "Ayar");
    ViewData["DeleteSubmitText"] = "Şubeyi sil";
}

@await Html.PartialAsync("_DeleteConfirm")
