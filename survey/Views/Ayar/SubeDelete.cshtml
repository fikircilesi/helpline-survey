@model survey.Models.Sube

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<div class="panel panel-primary">
    <div class="panel-heading panel-head; text-uppercase">
        ŞUBE SİL
    </div>
    <div class="panel-body">

        <div class="col-md-10">
            <h5>Şube Adı</h5>
            @Html.EditorFor(model => model.SubeAdi, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly" } })
        </div>
        <div class="col-lg-9"></div>
        <div class="col-lg-3">
            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                <a style="background-color:green; color:white" class="btn btn-default" href="@Url.Action("SubeIndex", "Ayar")">Geri</a>
                <input type="submit" style="background-color:red; color:white" class="btn btn-default" value="Sil" />
            }
        </div>
    </div>
</div>
