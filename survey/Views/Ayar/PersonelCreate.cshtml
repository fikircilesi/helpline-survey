@model survey.Models.PersonelYonetimForm
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal settings-form-panel settings-personel-form-panel">
        <div class="settings-form-heading">
            <h4>YENİ PERSONEL KAYDI</h4>
        </div>
        <div class="settings-form-body">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            @Html.HiddenFor(model => model.KayitTarihi)
            @Html.HiddenFor(model => model.MailOnaylandi)
            @Html.HiddenFor(model => model.GirisKaynagi)
            @Html.HiddenFor(model => model.GoogleKimlikId)
            @Html.HiddenFor(model => model.Mail)
            @Html.HiddenFor(model => model.Telefon)
            @Html.HiddenFor(model => model.Tc)
            @Html.HiddenFor(model => model.Unvani)
            @Html.HiddenFor(model => model.Adres)
            @Html.HiddenFor(model => model.Resim)
            @Html.HiddenFor(model => model.MailOnayKoduTarihi)
            @Html.HiddenFor(model => model.SonGirisTarihi)

            <div class="form-group">
                <div class="checkbox-color checkbox-primary">
                    @Html.CheckBoxFor(model => model.HesapAktif, new { id = "HesapAktif" })
                    <label class="form-label" for="HesapAktif">Hesap aktif</label>
                </div>
                <div class="checkbox-color checkbox-primary">
                    @Html.CheckBoxFor(model => model.Admin, new { id = "Admin" })
                    <label class="form-label" for="Admin">Yönetici yetkisi</label>
                </div>
                <div class="col-md-10">
                    <h5>Personel Adı</h5>
                    @Html.EditorFor(model => model.PersonelAdi, new { htmlAttributes = new { @class = "form-control", @Required = "", autofocus = "", @maxlength = "50" } })
                    @Html.ValidationMessageFor(model => model.PersonelAdi, "", new { @class = "text-danger" })
                </div>
                <div class="col-md-10">
                    <h5>Giriş Kullanıcı Adı</h5>
                    @Html.EditorFor(model => model.KullaniciAdi, new { htmlAttributes = new { @class = "form-control", @Required = "", @maxlength = "50" } })
                    @Html.ValidationMessageFor(model => model.KullaniciAdi, "", new { @class = "text-danger" })
                </div>
                <div class="col-md-10">
                    <h5>Şifre</h5>
                    @Html.PasswordFor(model => model.Sifre, new { @class = "form-control", @Required = "", @maxlength = "50" })
                    @Html.ValidationMessageFor(model => model.Sifre, "", new { @class = "text-danger" })
                </div>
            </div>
            <div class="settings-form-actions">
                <a style="background-color:green; color:white" class="btn btn-default" href="@Url.Action("PersonelIndex", "Ayar")">Geri</a>
                <input type="submit" style="background-color:blue; color:white" class="btn btn-default" value="Kayıt" />
            </div>
        </div>
    </div>
}
