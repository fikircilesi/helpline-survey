@model survey.Models.Bolge

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    ViewData["DeleteEyebrow"] = "Lokasyon tanımı";
    ViewData["DeleteTitle"] = "Bölge silinsin mi?";
    ViewData["DeleteDescription"] = "Bu bölge lokasyon tanımlarından kaldırılacak. Şehir, şube veya kayıtlarla ilişkisi varsa silme işlemi engellenir.";
    ViewData["DeleteItemLabel"] = "Bölge";
    ViewData["DeleteItemName"] = Model?.BolgeAdi;
    ViewData["DeleteWarning"] = "Bu işlem geri alınamaz. Önce bu bölgeye bağlı şehir, şube veya kişi kayıtlarını düzenleyin.";
    ViewData["DeleteBackUrl"] = Url.Action("BolgeIndex", "Ayar");
    ViewData["DeleteSubmitText"] = "Bölgeyi sil";
}

@await Html.PartialAsync("_DeleteConfirm")
