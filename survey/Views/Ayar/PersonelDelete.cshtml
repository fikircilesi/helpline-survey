@model survey.Models.Personel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    ViewData["DeleteEyebrow"] = "Panel personeli";
    ViewData["DeleteTitle"] = "Personel silinsin mi?";
    ViewData["DeleteDescription"] = "Bu panel personeli hesabı kaldırılacak. Aktif oturum, yetki veya geçmiş işlem bağı varsa sistem silmeyi engelleyebilir.";
    ViewData["DeleteItemLabel"] = "Personel";
    ViewData["DeleteItemName"] = Model?.PersonelAdi;
    ViewData["DeleteWarning"] = "Bu işlem geri alınamaz. Giriş yetkisini kapatmak yeterliyse silmek yerine hesabı pasife almayı tercih edin.";
    ViewData["DeleteBackUrl"] = Url.Action("PersonelIndex", "Ayar");
    ViewData["DeleteSubmitText"] = "Personeli sil";
}

@await Html.PartialAsync("_DeleteConfirm")
