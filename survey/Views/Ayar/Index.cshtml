@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section HeadExtra {
    <style>
        .settings-workspace {
            color: #142033;
        }

        .settings-hero {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            align-items: center;
            gap: 22px;
            padding: 28px;
            margin-bottom: 20px;
            border-radius: 8px;
            color: #fff;
            background: linear-gradient(135deg, rgba(11, 18, 32, .96), rgba(24, 52, 68, .94));
            box-shadow: 0 18px 48px rgba(21, 34, 50, .14);
            overflow: hidden;
        }

        .settings-kicker {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            min-height: 30px;
            padding: 0 11px;
            margin-bottom: 14px;
            border: 1px solid rgba(255, 255, 255, .22);
            border-radius: 999px;
            color: rgba(255, 255, 255, .78);
            background: rgba(255, 255, 255, .08);
            font-weight: 700;
            font-size: 12px;
        }

        .settings-title {
            margin: 0;
            color: #fff;
            font-size: 32px;
            font-weight: 900;
            line-height: 1.18;
            letter-spacing: 0;
        }

        .settings-subtitle {
            max-width: 720px;
            margin: 10px 0 0;
            color: rgba(255, 255, 255, .72);
            font-size: 15px;
            line-height: 1.6;
        }

        .settings-hero-actions {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 10px;
            flex-wrap: wrap;
        }

        .settings-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            min-height: 44px;
            padding: 0 16px;
            border: 1px solid rgba(255, 255, 255, .24);
            border-radius: 8px;
            color: #fff;
            background: rgba(255, 255, 255, .1);
            font-weight: 800;
            font-size: 13px;
            transition: transform .18s ease, background .18s ease;
        }

        .settings-btn:hover {
            color: #fff;
            transform: translateY(-1px);
            background: rgba(255, 255, 255, .18);
            text-decoration: none;
        }

        .settings-btn.primary {
            color: #0b1220;
            border-color: transparent;
            background: #8df0c7;
            box-shadow: 0 16px 34px rgba(56, 211, 159, .24);
        }

        .settings-btn.primary:hover {
            color: #0b1220;
        }

        .settings-overview {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 14px;
            margin-bottom: 24px;
        }

        .settings-stat {
            min-height: 92px;
            padding: 16px;
            border: 1px solid #e8edf5;
            border-radius: 8px;
            background: #fff;
            box-shadow: 0 12px 30px rgba(20, 32, 51, .06);
        }

        .settings-stat i {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 34px;
            height: 34px;
            border-radius: 8px;
            color: #fff;
            font-size: 16px;
            background: #19a7ce;
        }

        .settings-stat:nth-child(2) i { background: #38a169; }
        .settings-stat:nth-child(3) i { background: #f26b4f; }
        .settings-stat:nth-child(4) i { background: #7559d9; }

        .settings-stat strong {
            display: block;
            margin-top: 11px;
            color: #101827;
            font-size: 15px;
            font-weight: 900;
        }

        .settings-stat span {
            display: block;
            margin-top: 3px;
            color: #667085;
            font-size: 12px;
            font-weight: 700;
        }

        .settings-section {
            margin-top: 20px;
        }

        .settings-section-head {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 16px;
            margin-bottom: 12px;
        }

        .settings-section-title {
            margin: 0;
            color: #101827;
            font-size: 20px;
            font-weight: 900;
            letter-spacing: 0;
        }

        .settings-section-note {
            margin: 4px 0 0;
            color: #667085;
            font-size: 13px;
            line-height: 1.45;
        }

        .settings-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 14px;
        }

        .settings-card {
            position: relative;
            min-height: 104px;
            display: grid;
            grid-template-columns: 42px minmax(0, 1fr) 22px;
            align-items: center;
            gap: 12px;
            padding: 16px;
            border: 1px solid #e8edf5;
            border-radius: 8px;
            color: #172033;
            background: #fff;
            box-shadow: 0 12px 28px rgba(20, 32, 51, .06);
            transition: border-color .18s ease, box-shadow .18s ease, transform .18s ease;
        }

        .settings-card:hover,
        .settings-card:focus {
            color: #172033;
            border-color: rgba(141, 240, 199, .9);
            box-shadow: 0 18px 38px rgba(21, 34, 50, .10);
            transform: translateY(-2px);
            text-decoration: none;
        }

        .settings-icon {
            width: 42px;
            height: 42px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            color: #0f766e;
            background: #e9fbf6;
            font-size: 18px;
        }

        .settings-card:nth-child(2) .settings-icon { color: #2563eb; background: #eff6ff; }
        .settings-card:nth-child(3) .settings-icon { color: #c2410c; background: #fff4ed; }
        .settings-card:nth-child(4) .settings-icon { color: #6d4edb; background: #f4f1ff; }

        .settings-card-title {
            display: block;
            color: #101827;
            font-size: 15px;
            font-weight: 900;
            line-height: 1.25;
        }

        .settings-card-meta {
            display: block;
            margin-top: 5px;
            color: #667085;
            font-size: 12px;
            font-weight: 700;
            line-height: 1.35;
        }

        .settings-arrow {
            justify-self: end;
            color: #98a2b3;
            font-size: 17px;
            transition: color .18s ease, transform .18s ease;
        }

        .settings-card:hover .settings-arrow {
            color: #17b996;
            transform: translate(2px, -2px);
        }

        .settings-card-static,
        .settings-card-static:hover,
        .settings-card-static:focus {
            transform: none;
            cursor: default;
            border-color: #e8edf5;
            box-shadow: 0 12px 28px rgba(20, 32, 51, .06);
        }

        .settings-lock {
            justify-self: end;
            min-height: 30px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0 10px;
            border-radius: 999px;
            color: #475569;
            background: #f1f5f9;
            font-size: 11px;
            font-weight: 900;
            white-space: nowrap;
        }

        .settings-default-alert {
            margin: 0 0 18px;
            padding: 12px 14px;
            border: 1px solid #a7f3d0;
            border-radius: 8px;
            color: #065f46;
            background: #ecfdf5;
            font-weight: 800;
        }

        .settings-defaults-panel {
            margin: 0 0 24px;
            border: 1px solid #d9e5f5;
            border-radius: 8px;
            background: #fff;
            box-shadow: 0 14px 34px rgba(20, 32, 51, .06);
            overflow: hidden;
        }

        .settings-defaults-panel summary {
            cursor: pointer;
            padding: 14px 16px;
            color: #10233b;
            font-size: 15px;
            font-weight: 900;
            background: #fbfdff;
            border-bottom: 1px solid #e6edf7;
        }

        .settings-defaults-body {
            padding: 16px;
        }

        .settings-defaults-body p {
            margin: 0 0 14px;
            color: #465a78;
            font-size: 13px;
            line-height: 1.45;
            font-weight: 700;
        }

        .settings-defaults-grid {
            display: grid;
            grid-template-columns: repeat(6, minmax(180px, 1fr));
            gap: 12px;
        }

        .settings-defaults-group {
            border: 1px solid #dce7f7;
            border-radius: 8px;
            padding: 12px;
            background: #fff;
        }

        .settings-defaults-group-head {
            align-items: center;
            display: flex;
            gap: 8px;
            justify-content: space-between;
            margin-bottom: 8px;
        }

        .settings-defaults-group-head strong {
            color: #10233b;
            font-weight: 900;
        }

        .settings-defaults-group-actions {
            display: flex;
            gap: 6px;
        }

        .settings-defaults-mini {
            border: 1px solid #cfe0f6;
            border-radius: 6px;
            background: #f8fbff;
            color: #173a67;
            font-size: 11px;
            font-weight: 900;
            line-height: 1;
            padding: 6px 8px;
            white-space: nowrap;
        }

        .settings-defaults-items {
            display: grid;
            gap: 6px;
            max-height: 220px;
            overflow: auto;
            padding-right: 4px;
        }

        .settings-defaults-items label {
            align-items: center;
            display: flex;
            gap: 8px;
            color: #142033;
            font-weight: 700;
            margin: 0;
        }

        .settings-defaults-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 14px;
        }

        .settings-defaults-button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 42px;
            padding: 0 16px;
            border: 0;
            border-radius: 8px;
            color: #fff;
            font-weight: 900;
            font-size: 13px;
            box-shadow: 0 12px 28px rgba(20, 32, 51, .12);
        }

        .settings-defaults-button.primary { background: #0f766e; }
        .settings-defaults-button.muted { background: #64748b; }
        .settings-defaults-button.secondary { background: #2563eb; }

        .settings-defaults-section {
            margin: 0 0 28px;
        }

        .settings-defaults-heading {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 16px;
            margin-bottom: 12px;
        }

        .settings-defaults-heading h2 {
            margin: 0;
            color: #101827;
            font-size: 20px;
            font-weight: 900;
            letter-spacing: 0;
        }

        .settings-defaults-heading p {
            margin: 4px 0 0;
            color: #667085;
            font-size: 13px;
            line-height: 1.45;
        }

        .settings-defaults-badge {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            min-height: 32px;
            padding: 0 12px;
            border: 1px solid #fde68a;
            border-radius: 8px;
            color: #854d0e;
            background: #fffbeb;
            font-size: 12px;
            font-weight: 900;
            white-space: nowrap;
        }

        .settings-defaults-panel {
            margin: 0;
            border-color: #f3d68d;
            background: #fff;
            box-shadow: 0 18px 42px rgba(20, 32, 51, .08);
        }

        .settings-defaults-panel summary::-webkit-details-marker {
            display: none;
        }

        .settings-defaults-summary {
            display: grid;
            grid-template-columns: 54px minmax(0, 1fr) auto auto;
            align-items: center;
            gap: 14px;
            padding: 18px 20px;
            border-bottom: 0;
            background: linear-gradient(135deg, #fff8e6, #f7fbff);
            list-style: none;
        }

        .settings-defaults-panel[open] .settings-defaults-summary {
            border-bottom: 1px solid #eadfbf;
        }

        .settings-defaults-icon {
            width: 54px;
            height: 54px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 1px solid #fde68a;
            border-radius: 8px;
            color: #a16207;
            background: #fffbeb;
            font-size: 22px;
        }

        .settings-defaults-eyebrow {
            display: block;
            color: #b45309;
            font-size: 11px;
            font-weight: 900;
            letter-spacing: .08em;
            text-transform: uppercase;
        }

        .settings-defaults-copy strong {
            display: block;
            margin-top: 3px;
            color: #0f172a;
            font-size: 18px;
            font-weight: 900;
        }

        .settings-defaults-copy span {
            display: block;
            margin-top: 4px;
            color: #475569;
            font-size: 13px;
            font-weight: 700;
            line-height: 1.45;
        }

        .settings-defaults-summary-tags {
            display: flex;
            flex-wrap: wrap;
            justify-content: flex-end;
            gap: 6px;
            max-width: 460px;
        }

        .settings-defaults-summary-tags span {
            min-height: 28px;
            display: inline-flex;
            align-items: center;
            padding: 0 10px;
            border-radius: 999px;
            color: #173a67;
            background: #eff6ff;
            font-size: 12px;
            font-weight: 900;
        }

        .settings-defaults-toggle {
            min-width: 118px;
            min-height: 42px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            color: #fff;
            background: #0f766e;
            font-size: 13px;
            font-weight: 900;
            box-shadow: 0 12px 24px rgba(15, 118, 110, .18);
        }

        .settings-defaults-toggle::before {
            content: "Sihirbazı aç";
        }

        .settings-defaults-panel[open] .settings-defaults-toggle::before {
            content: "Sihirbazı kapat";
        }

        .settings-defaults-body {
            padding: 18px;
            background: #fff;
        }

        .settings-defaults-body p {
            margin-bottom: 0;
        }

        .settings-defaults-steps {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 10px;
            margin-bottom: 16px;
        }

        .settings-defaults-step {
            display: grid;
            grid-template-columns: 34px minmax(0, 1fr);
            gap: 10px;
            align-items: center;
            min-height: 66px;
            padding: 10px;
            border: 1px solid #e5edf8;
            border-radius: 8px;
            background: #f8fbff;
        }

        .settings-defaults-step em {
            width: 34px;
            height: 34px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            color: #fff;
            background: #2563eb;
            font-style: normal;
            font-weight: 900;
        }

        .settings-defaults-step strong,
        .settings-defaults-step span {
            display: block;
        }

        .settings-defaults-step strong {
            color: #10233b;
            font-size: 13px;
            font-weight: 900;
        }

        .settings-defaults-step span {
            margin-top: 2px;
            color: #667085;
            font-size: 12px;
            font-weight: 700;
            line-height: 1.35;
        }

        .settings-defaults-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
            align-items: stretch;
        }

        .settings-defaults-lane {
            display: flex;
            flex-direction: column;
            min-width: 0;
            border: 1px solid #dbe7f5;
            border-radius: 8px;
            background: #fbfdff;
            overflow: hidden;
        }

        .settings-defaults-lane-head {
            display: grid;
            grid-template-columns: 40px minmax(0, 1fr);
            gap: 10px;
            align-items: center;
            padding: 12px;
            border-bottom: 1px solid #e4ecf7;
            background: #fff;
        }

        .settings-defaults-lane-icon {
            width: 40px;
            height: 40px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            color: #0f766e;
            background: #e9fbf6;
            font-size: 18px;
        }

        .settings-defaults-lane-head strong,
        .settings-defaults-lane-head span {
            display: block;
        }

        .settings-defaults-lane-head strong {
            color: #0f172a;
            font-size: 15px;
            font-weight: 900;
        }

        .settings-defaults-lane-head span {
            margin-top: 3px;
            color: #667085;
            font-size: 12px;
            font-weight: 700;
            line-height: 1.35;
        }

        .settings-defaults-lane-body {
            display: grid;
            gap: 12px;
            padding: 12px;
        }

        .settings-defaults-group {
            border: 0;
            border-radius: 8px;
            padding: 0;
            background: transparent;
        }

        .settings-defaults-group-head {
            margin-bottom: 7px;
        }

        .settings-defaults-items {
            max-height: 170px;
            padding: 9px;
            border: 1px solid #e4ecf7;
            border-radius: 8px;
            background: #fff;
        }

        .settings-defaults-actions {
            align-items: center;
            justify-content: space-between;
            margin-top: 16px;
            padding-top: 14px;
            border-top: 1px solid #e6edf7;
        }

        .settings-defaults-action-note {
            color: #667085;
            font-size: 12px;
            font-weight: 800;
        }

        .settings-defaults-action-buttons {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        @@media (max-width: 1399px) {
            .settings-grid,
            .settings-overview {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .settings-defaults-grid {
                grid-template-columns: 1fr;
            }

            .settings-defaults-summary {
                grid-template-columns: 54px minmax(0, 1fr);
            }

            .settings-defaults-summary-tags,
            .settings-defaults-toggle {
                justify-self: start;
            }
        }

        @@media (max-width: 767px) {
            .settings-hero {
                grid-template-columns: 1fr;
                padding: 22px;
            }

            .settings-title {
                font-size: 27px;
            }

            .settings-hero-actions {
                justify-content: flex-start;
            }

            .settings-btn {
                width: 100%;
            }

            .settings-grid,
            .settings-overview {
                grid-template-columns: 1fr;
            }

            .settings-defaults-grid {
                grid-template-columns: 1fr;
            }

            .settings-defaults-heading,
            .settings-defaults-group-head {
                align-items: flex-start;
                flex-direction: column;
            }

            .settings-defaults-heading {
                display: flex;
            }

            .settings-defaults-summary {
                grid-template-columns: 1fr;
                padding: 16px;
            }

            .settings-defaults-summary-tags {
                justify-content: flex-start;
            }

            .settings-defaults-steps {
                grid-template-columns: 1fr;
            }

            .settings-defaults-button {
                width: 100%;
            }

            .settings-defaults-action-buttons {
                width: 100%;
            }
        }
    </style>
}

<div class="page-body settings-workspace">
    <section class="settings-hero">
        <div>
            <span class="settings-kicker">
                <i class="feather icon-settings"></i>
                Survey by Aslana Teknoloji yönetim alanı
            </span>
            <h1 class="settings-title">Ayarlar</h1>
            <p class="settings-subtitle">Personel, katılımcı, organizasyon ve sistem tanımlarını tek ekranda düzenleyin.</p>
        </div>
        <div class="settings-hero-actions">
            <a class="settings-btn" href="@Url.Action("Indexgosterge", "Home", new { idi = Session["id"] })">
                <i class="feather icon-grid"></i>
                Gösterge Paneli
            </a>
            <a class="settings-btn primary" href="@Url.Action("UserIndex", "Ayar", new { id = Session["id"] })">
                <i class="feather icon-users"></i>
                Katılımcılar
            </a>
        </div>
    </section>

    <div class="settings-overview">
        <div class="settings-stat">
            <i class="feather icon-users"></i>
            <strong>Erişim</strong>
            <span>Panel personeli ve katılımcı kayıtları</span>
        </div>
        <div class="settings-stat">
            <i class="feather icon-briefcase"></i>
            <strong>Organizasyon</strong>
            <span>Rol, birim ve sorumlu yapısı</span>
        </div>
        <div class="settings-stat">
            <i class="feather icon-map-pin"></i>
            <strong>Lokasyon</strong>
            <span>Bölge, şehir ve şube tanımları</span>
        </div>
        <div class="settings-stat">
            <i class="feather icon-cpu"></i>
            <strong>Sistem</strong>
            <span>Studio AI ve platform ayarları</span>
        </div>
    </div>

    @{
        var varsayilanGruplar = (ViewBag.VarsayilanSecenekGruplari as IEnumerable<survey.Controllers.AyarController.VarsayilanSecenekGrubu> ?? new List<survey.Controllers.AyarController.VarsayilanSecenekGrubu>()).ToList();
    }
    @if (TempData["UserImportMesaj"] != null)
    {
        <div class="settings-default-alert">@TempData["UserImportMesaj"]</div>
    }
    @if (varsayilanGruplar.Any())
    {
        var varsayilanBloklar = new[]
        {
            new { Baslik = "Organizasyon", Aciklama = "Ünvan ve departman omurgası", Ikon = "icon-briefcase", Tipler = new[] { "Unvan", "Departman" } },
            new { Baslik = "Profil", Aciklama = "Cinsiyet ve eğitim kırılımları", Ikon = "icon-user-check", Tipler = new[] { "Cinsiyet", "Egitim" } },
            new { Baslik = "Lokasyon", Aciklama = "Bölge ve şehir haritası", Ikon = "icon-map-pin", Tipler = new[] { "Bolge", "Sehir" } }
        };

        <section class="settings-defaults-section">
            <div class="settings-defaults-heading">
                <div>
                    <h2>Hazır Kurulum Sihirbazı</h2>
                    <p>Çalışma alanına başlangıç listelerini seçerek ekleyin; Excel importu bu listeleri akıllı eşleştirme için kullanır.</p>
                </div>
                <span class="settings-defaults-badge"><i class="feather icon-zap"></i> Hızlı başlangıç</span>
            </div>

            <details class="settings-defaults-panel">
                <summary class="settings-defaults-summary">
                    <span class="settings-defaults-icon"><i class="feather icon-star"></i></span>
                    <span class="settings-defaults-copy">
                        <span class="settings-defaults-eyebrow">Hazır veri kütüphanesi</span>
                        <strong>Ünvan, departman, profil ve lokasyon listelerini tek akışta kurun</strong>
                        <span>İstemediğiniz seçenekleri çıkarın; kalanlar mevcut çalışma alanına temiz biçimde eklenir.</span>
                    </span>
                    <span class="settings-defaults-summary-tags">
                        <span>Ünvan</span>
                        <span>Departman</span>
                        <span>Eğitim</span>
                        <span>Cinsiyet</span>
                        <span>Bölge</span>
                        <span>Şehir</span>
                    </span>
                    <span class="settings-defaults-toggle" aria-hidden="true"></span>
                </summary>
                <div class="settings-defaults-body">
                    <div class="settings-defaults-steps">
                        <div class="settings-defaults-step">
                            <em>1</em>
                            <span>
                                <strong>İlgili listeleri açın</strong>
                                <span>Organizasyon, profil ve lokasyon ayrı ayrı seçilir.</span>
                            </span>
                    </div>
                    <div class="settings-defaults-step">
                        <em>2</em>
                        <span>
                            <strong>Gereksizleri çıkarın</strong>
                            <span>Her blokta tümünü seçme ve temizleme var.</span>
                        </span>
                    </div>
                    <div class="settings-defaults-step">
                        <em>3</em>
                        <span>
                            <strong>Çalışma alanına ekleyin</strong>
                            <span>Excel importu yakın yazımları bu havuza göre düzeltir.</span>
                        </span>
                    </div>
                </div>
                @using (Html.BeginForm("VarsayilanSecenekleriEkle", "Ayar", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="donus" value="Index" />
                    <div class="settings-defaults-grid">
                        @foreach (var blok in varsayilanBloklar)
                        {
                            var blokGruplari = varsayilanGruplar.Where(g => blok.Tipler.Contains(g.Tip)).ToList();
                            if (blokGruplari.Any())
                            {
                                <div class="settings-defaults-lane">
                                    <div class="settings-defaults-lane-head">
                                        <span class="settings-defaults-lane-icon"><i class="feather @blok.Ikon"></i></span>
                                        <span>
                                            <strong>@blok.Baslik</strong>
                                            <span>@blok.Aciklama</span>
                                        </span>
                                    </div>
                                    <div class="settings-defaults-lane-body">
                                        @foreach (var grup in blokGruplari)
                                        {
                                            <div class="settings-defaults-group">
                                                <div class="settings-defaults-group-head">
                                                    <strong>@grup.Baslik</strong>
                                                    <div class="settings-defaults-group-actions">
                                                        <button class="settings-defaults-mini" type="button" data-settings-defaults-group-all>Tümünü seç</button>
                                                        <button class="settings-defaults-mini" type="button" data-settings-defaults-group-clear>Temizle</button>
                                                    </div>
                                                </div>
                                                <div class="settings-defaults-items">
                                                    @foreach (var secenek in grup.Secenekler)
                                                    {
                                                        <label>
                                                            <input type="checkbox" name="secenekler" value="@($"{grup.Tip}|{secenek}")" checked />
                                                            <span>@secenek</span>
                                                        </label>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    </div>
                    <div class="settings-defaults-actions">
                        <span class="settings-defaults-action-note">Seçili olanlar eklenir; mevcut kayıtlar yeniden oluşturulmaz.</span>
                        <span class="settings-defaults-action-buttons">
                            <button class="settings-defaults-button muted" type="button" data-settings-defaults-clear>Seçimleri temizle</button>
                            <button class="settings-defaults-button secondary" type="button" data-settings-defaults-all>Tümünü seç</button>
                            <button class="settings-defaults-button primary" type="submit">Sihirbazı çalıştır</button>
                        </span>
                    </div>
                }
            </div>
        </details>
        </section>
    }

