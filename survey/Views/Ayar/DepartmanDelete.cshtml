@model survey.Models.Departman

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    ViewData["DeleteEyebrow"] = "Organizasyon tanımı";
    ViewData["DeleteTitle"] = "Departman silinsin mi?";
    ViewData["DeleteDescription"] = "Bu departman organizasyon tanımlarından kaldırılacak. Bağlı personel, katılımcı veya bölüm varsa sistem silmeyi durdurur.";
    ViewData["DeleteItemLabel"] = "Departman";
    ViewData["DeleteItemName"] = Model?.DepartmanAdi;
    ViewData["DeleteWarning"] = "Bu işlem geri alınamaz. Önce bu departmanı kullanan kayıtları başka departmana taşıyın.";
    ViewData["DeleteBackUrl"] = Url.Action("DepartmanIndex", "Ayar");
    ViewData["DeleteSubmitText"] = "Departmanı sil";
}

@await Html.PartialAsync("_DeleteConfirm")
