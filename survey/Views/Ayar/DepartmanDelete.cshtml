@model survey.Models.Departman

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<div class="panel">
    <h4>DEPARTMAN SİL</h4>
    </div>
    <div class="panel-body">

        <div class="col-md-10">
            <h5>Departman Adı</h5>
            @Html.EditorFor(model => model.DepartmanAdi, new { htmlAttributes = new { @class = "form-control", @readonly = "readonly" } })
        </div>
        <div class="col-lg-9"></div>
        <div class="col-lg-3">
            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                <a style="background-color:green; color:white" class="btn btn-default" href="@Url.Action("DepartmanIndex", "Ayar")">Geri</a>
                <input type="submit" style="background-color:red; color:white" class="btn btn-default" value="Sil" />
            }
        </div>
    </div>
</div>
