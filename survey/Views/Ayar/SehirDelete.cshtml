@model survey.Models.Sehir

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    ViewData["DeleteEyebrow"] = "Lokasyon tanımı";
    ViewData["DeleteTitle"] = "Şehir silinsin mi?";
    ViewData["DeleteDescription"] = "Bu şehir lokasyon tanımlarından kaldırılacak. Şube veya katılımcı kayıtlarında kullanılıyorsa silme işlemi engellenir.";
    ViewData["DeleteItemLabel"] = "Şehir";
    ViewData["DeleteItemName"] = Model?.SehiarAdi;
    ViewData["DeleteWarning"] = "Bu işlem geri alınamaz. Önce bu şehre bağlı kayıtları güncelleyin.";
    ViewData["DeleteBackUrl"] = Url.Action("SehirIndex", "Ayar");
    ViewData["DeleteSubmitText"] = "Şehri sil";
}

@await Html.PartialAsync("_DeleteConfirm")
