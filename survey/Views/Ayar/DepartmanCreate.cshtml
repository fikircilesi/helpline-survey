@model survey.Models.Departman
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Yeni Kayıt</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="form-group">
            <div class="col-md-10">
                @Html.TextBoxFor(model => model.DepartmanAdi, new { @class = "form-control", @maxlength = "50", @Required = "" })
                @Html.ValidationMessageFor(model => model.DepartmanAdi, "", new { @class = "text-danger" })
            </div>

        </div>
            <a style="background-color:green; color:white" class="btn btn-default" href="@Url.Action("DepartmanIndex", "Ayar")">Geri</a>
            <input type="submit" style="background-color:blue; color:white" class="btn btn-default" value="Kayıt" />
    </div>
}
