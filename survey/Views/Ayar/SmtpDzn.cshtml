@model survey.Models.smtpayar

@{
    /**/

    ViewBag.Title = "SmtpDzn";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@using (Html.BeginForm("SmtpDzn", "Ayar", FormMethod.Post, new { enctype = "multipart/form-data" }))
{

    @Html.AntiForgeryToken()

    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    @Html.HiddenFor(model => model.MailId)
    <div class="panel panel-primary">
        <div class="panel-heading panel-head; text-uppercase">
            SMTP DÜZENLE
        </div>
        <div class="panel-body">

            <table class="table" style="background-color:white">
                <tr>
                    <th>
                        Sunucu Adresi
                    </th>
                    <th>
                        Giden Port
                    </th>
                    <th>
                        Kullanıcı Adı
                    </th>
                    <th>
                        Şifre
                    </th>
                    <th>
                        Ssl Düzenle
                    </th>
                    <th>
                        Gönderen
                    </th>
                </tr>

                <tr>
                    <td>@Html.EditorFor(model => model.Sunucu, new { htmlAttributes = new { @class = "form-control" } })</td>
                    <td>@Html.EditorFor(model => model.Portu, new { htmlAttributes = new { @class = "form-control" } })</td>
                    <td>@Html.EditorFor(model => model.UserName, new { htmlAttributes = new { @class = "form-control" } })</td>
                    <td>@Html.EditorFor(model => model.Password, new { htmlAttributes = new { @type = "password", @class = "form-control" } })</td>
                    <td>@Html.DropDownListFor(model => model.Ssli, new List<SelectListItem> { new SelectListItem { Text = "Evet", Value = "True" }, new SelectListItem { Text = "Hayır", Value = "False" } }, new { @class = "form-control" })</td>
                    <td>@Html.EditorFor(model => model.Gonderen, new { htmlAttributes = new { @class = "form-control" } })</td>
                </tr>
            </table>
            <div class="col-lg-9"></div>
            <div class="col-lg-3">
                <a style="background-color:green; color:white" class="btn btn-default" href="@Url.Action("Index", "Ayar")">Geri</a>
                <button type="submit" class="btn btn-primary">Kayıt</button>
            </div>
        </div>

    </div>
}
