@model survey.Models.User
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal settings-form-panel settings-user-form-panel">
        <div class="settings-form-heading">
            <h4>YENİ KATILIMCI KAYDI</h4>
        </div>
        <div class="settings-form-body">
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <div class="form-group">
        <div hidden class="col-md-10">
            <b>Kayıt Tarihi</b>
            @Html.TextBoxFor(model => model.KayitTarihi, new { @Value = ViewBag.KayitTar })
            @Html.ValidationMessageFor(model => model.KayitTarihi, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-10">
            <b>Katılımcı Adı</b>
            @Html.EditorFor(model => model.UserAdi, new { htmlAttributes = new { @class = "form-control", @Required = "", autofocus = "", @maxlength = "50" } })
            @Html.ValidationMessageFor(model => model.UserAdi, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-10">
            <b>Tc</b>
            @Html.EditorFor(model => model.UserTc, new { htmlAttributes = new { @class = "form-control", @Required = "", autofocus = "", @maxlength = "50" } })
            @Html.ValidationMessageFor(model => model.UserTc, "", new { @class = "text-danger" })
        </div>
        <div>
            <b>Unvan</b>
            @Html.DropDownListFor(m => m.UserUnvan, (List<SelectListItem>)ViewBag.Unv, "Seçim", new { @class = "form-control", @Required = "" })
            @Html.ValidationMessageFor(model => model.UserUnvan, "", new { @class = "text-danger" })
        </div>
        <div>
            <b>Cinsiyet</b>
            @Html.DropDownListFor(m => m.UserCinsiyet, (List<SelectListItem>)ViewBag.Cin, "Seçim", new { @class = "form-control", @Required = "" })
            @Html.ValidationMessageFor(model => model.UserCinsiyet, "", new { @class = "text-danger" })
        </div>
        <div>
            <b>Eğitim</b>
            @Html.DropDownListFor(m => m.UserEgitim, (List<SelectListItem>)ViewBag.Egi, "Seçim", new { @class = "form-control", @Required = "" })
            @Html.ValidationMessageFor(model => model.UserEgitim, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-10">
            <b>Yaşı</b>
            @Html.EditorFor(model => model.UserDogumTar, new { htmlAttributes = new { @type = "date", @class = "form-control", @Required = "", @maxlength = "50" } })
            @Html.ValidationMessageFor(model => model.UserDogumTar, "", new { @class = "text-danger" })
        </div>

        <div>
            <b>Bölüm</b>
            @Html.DropDownListFor(m => m.UserBolumu, (List<SelectListItem>)ViewBag.Bol, "Seçim", new { @class = "form-control", @Required = "" })
            @Html.ValidationMessageFor(model => model.UserBolumu, "", new { @class = "text-danger" })
        </div>
        <div>
            <b>Şube Adı</b>
            @Html.DropDownListFor(m => m.UserSube, (List<SelectListItem>)ViewBag.Sub, "Seçim", new { @class = "form-control", @Required = "" })
            @Html.ValidationMessageFor(model => model.UserBolge, "", new { @class = "text-danger" })
        </div>
        <div>
            <b>Bölge Adı</b>
            @Html.DropDownListFor(m => m.UserBolge, (List<SelectListItem>)ViewBag.Blg, "Seçim", new { @class = "form-control", @Required = "" })
            @Html.ValidationMessageFor(model => model.UserSube, "", new { @class = "text-danger" })
        </div>
        <div>
            <b>Departman Adı</b>
            @Html.DropDownListFor(m => m.UserDepartman, (List<SelectListItem>)ViewBag.Dep, "Seçim", new { @class = "form-control", @Required = "" })
            @Html.ValidationMessageFor(model => model.UserDepartman, "", new { @class = "text-danger" })
        </div>
        <div>
            <b>Yönetici Adı</b>
            @Html.DropDownListFor(m => m.UserYoneticisi, (List<SelectListItem>)ViewBag.Yon, "Seçim", new { @class = "form-control", @Required = "" })
            @Html.ValidationMessageFor(model => model.UserYoneticisi, "", new { @class = "text-danger" })
        </div>

        <div>
            <b>Yaka Adı</b>
            @Html.DropDownListFor(m => m.UserYaka, (List<SelectListItem>)ViewBag.Yak, "Seçim", new { @class = "form-control", @Required = "" })
            @Html.ValidationMessageFor(model => model.UserYaka, "", new { @class = "text-danger" })
        </div>
        <div>
            <b>Şehir Adı</b>
            @Html.DropDownListFor(m => m.UserSehir, (List<SelectListItem>)ViewBag.Seh, "Seçim", new { @class = "form-control", @Required = "" })
            @Html.ValidationMessageFor(model => model.UserSehir, "", new { @class = "text-danger" })
        </div>
        <div class="checkbox-color checkbox-primary">
            <input name="Pasif" value="True" id="checkbox1" type="checkbox" unchecked="">
            <label class="form-label" for="checkbox1"> Pasif</label>
        </div>


        </div>
        <div class="settings-form-actions">
            <a style="background-color:green; color:white" class="btn btn-default" href="@Url.Action("UserIndex", "Ayar")">Geri</a>
            <input type="submit" style="background-color:blue; color:white" class="btn btn-default" value="Kayıt" />
        </div>
        </div>
    </div>
}
