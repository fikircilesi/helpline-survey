@model survey.Models.Yonetici

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    ViewData["DeleteEyebrow"] = "Sorumlu kişi tanımı";
    ViewData["DeleteTitle"] = "Yönetici tanımı silinsin mi?";
    ViewData["DeleteDescription"] = "Bu yönetici tanımı kaldırılacak. Çalışma veya kişi kayıtlarında kullanılıyorsa silme işlemi engellenir.";
    ViewData["DeleteItemLabel"] = "Yönetici";
    ViewData["DeleteItemName"] = Model?.YoneticiAdi;
    ViewData["DeleteWarning"] = "Bu işlem geri alınamaz. Önce bu yöneticiyi kullanan kayıtları güncelleyin.";
    ViewData["DeleteBackUrl"] = Url.Action("YoneticiIndex", "Ayar");
    ViewData["DeleteSubmitText"] = "Tanımı sil";
}

@await Html.PartialAsync("_DeleteConfirm")
