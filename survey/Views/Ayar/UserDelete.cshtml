@model survey.Models.User

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    ViewData["DeleteEyebrow"] = "Katılımcı kaydı";
    ViewData["DeleteTitle"] = "Katılımcı silinsin mi?";
    ViewData["DeleteDescription"] = "Bu katılımcı kartı kaldırılacak. Katılım, cevap veya sonuç verisi varsa sistem kayıt bütünlüğü için silmeyi engeller.";
    ViewData["DeleteItemLabel"] = "Katılımcı";
    ViewData["DeleteItemName"] = Model?.UserAdi;
    ViewData["DeleteWarning"] = "Bu işlem geri alınamaz. Katılımcının geçmiş cevapları varsa önce ilgili çalışma verilerini kontrol edin.";
    ViewData["DeleteBackUrl"] = Url.Action("UserIndex", "Ayar");
    ViewData["DeleteSubmitText"] = "Katılımcıyı sil";
}

@await Html.PartialAsync("_DeleteConfirm")
