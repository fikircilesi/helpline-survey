@model survey.Models.Bolum

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    ViewData["DeleteEyebrow"] = "Organizasyon tanımı";
    ViewData["DeleteTitle"] = "Bölüm silinsin mi?";
    ViewData["DeleteDescription"] = "Bu bölüm organizasyon tanımlarından kaldırılacak. Kişi veya çalışma kayıtlarında kullanılıyorsa silme işlemi engellenir.";
    ViewData["DeleteItemLabel"] = "Bölüm";
    ViewData["DeleteItemName"] = Model?.BolumAdi;
    ViewData["DeleteWarning"] = "Bu işlem geri alınamaz. Önce bu bölüme bağlı kayıtları güncelleyin.";
    ViewData["DeleteBackUrl"] = Url.Action("BolumIndex", "Ayar");
    ViewData["DeleteSubmitText"] = "Bölümü sil";
}

@await Html.PartialAsync("_DeleteConfirm")
