@model survey.Models.Unvan

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    ViewData["DeleteEyebrow"] = "Organizasyon tanımı";
    ViewData["DeleteTitle"] = "Ünvan silinsin mi?";
    ViewData["DeleteDescription"] = "Bu ünvan organizasyon tanımlarından kaldırılacak. Personel veya katılımcı kayıtlarında kullanılıyorsa silme işlemi engellenir.";
    ViewData["DeleteItemLabel"] = "Ünvan";
    ViewData["DeleteItemName"] = Model?.UnvanAdi;
    ViewData["DeleteWarning"] = "Bu işlem geri alınamaz. Kullanımda olan ünvanları silmeden önce bağlı kayıtları güncelleyin.";
    ViewData["DeleteBackUrl"] = Url.Action("UnvanIndex", "Ayar");
    ViewData["DeleteSubmitText"] = "Ünvanı sil";
}

@await Html.PartialAsync("_DeleteConfirm")
