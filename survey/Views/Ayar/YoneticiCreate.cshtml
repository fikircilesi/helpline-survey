@model survey.Models.Yonetici
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Yeni Kayıt</h2>

@using (Html.BeginForm("YoneticiCreate", "Ayar", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="form-group">
            <div class="col-md-10">
                <h5>Yönetici Adı</h5>
                @Html.TextBoxFor(model => model.YoneticiAdi, new { @class = "form-control", @maxlength = "50", @Required = "" })
                @Html.ValidationMessageFor(model => model.YoneticiAdi, "", new { @class = "text-danger" })
            </div>
            <div class="col-md-10">
                <h5>Yönetici Fotoğrafı</h5>
                @await Html.PartialAsync("_ResimKirpici")
                <small class="text-muted">Fotoğraf yoksa yönetici avatar ile gösterilir.</small>
            </div>

        </div>
            <a style="background-color:green; color:white" class="btn btn-default" href="@Url.Action("YoneticiIndex", "Ayar")">Geri</a>
            <input type="submit" style="background-color:blue; color:white" class="btn btn-default" value="Kayıt" />
    </div>
}
