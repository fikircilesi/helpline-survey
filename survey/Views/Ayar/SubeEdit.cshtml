@model survey.Models.Sube

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    @Html.HiddenFor(model => model.SubeId)

    <div class="panel panel-primary">
        <div>
            <h4>ŞUBE LİSTESİ</h4>
        </div>
        <div class="panel-body">

            <div class="col-md-10">
                <h5>Şube Adı</h5>
                @Html.EditorFor(model => model.SubeAdi, new { htmlAttributes = new { @class = "form-control", @Required = "", autofocus = "", @maxlength = "50" } })
                @Html.ValidationMessageFor(model => model.SubeAdi, "", new { @class = "text-danger" })
            </div>

            <div class="col-lg-9"></div>
            <div class="col-lg-3">
                <a style="background-color:green; color:white" class="btn btn-default" href="@Url.Action("SubeIndex", "Ayar")">Geri</a>
                <input type="submit" style="background-color:blue; color:white" class="btn btn-default" value="Kayıt" />
            </div>
        </div>
    </div>
}
