@model IEnumerable<survey.Models.User>
@using System
@using System.Globalization
@using System.Linq

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var kullanicilar = (Model ?? Enumerable.Empty<survey.Models.User>()).ToList();
    var anketId = ViewBag.AnketId;
    var anketAdi = Convert.ToString(ViewBag.AnketAdi ?? "Çalışma");
    var aktif = kullanicilar.Count(x => x.Pasif != true);
    var pasif = kullanicilar.Count(x => x.Pasif == true);
    Func<string, string> safe = value => string.IsNullOrWhiteSpace(value) ? "Tanımsız" : value;
}

<div class="watch-center">
    <section class="watch-hero">
        <div>
            <span class="eyebrow">Katılım takibi</span>
            <h1>Katılmayanlar</h1>
            <p>@anketAdi çalışmasına henüz cevap kaydı oluşturmayan kullanıcılar burada listelenir.</p>
            <div class="hero-chips">
                <span><i class="fa fa-users"></i> @kullanicilar.Count kişi</span>
                <span><i class="fa fa-check-circle"></i> @aktif aktif</span>
                <span><i class="fa fa-ban"></i> @pasif pasif</span>
            </div>
        </div>
        <div class="hero-actions">
            <a class="center-btn primary" href="@Url.Action("AnketIndex1", "Home", new { id = anketId })">
                <i class="fa fa-pie-chart"></i> Rapor Panosu
            </a>
            <a class="center-btn" href="@Url.Action("AnketIndex", "Home", new { id = anketId })">
                <i class="fa fa-th-large"></i> Rapor Merkezi
            </a>
        </div>
    </section>

    @if (kullanicilar.Any())
    {
        <div class="people-tools">
            <input type="search" class="person-search" data-watch-person-search placeholder="Katılımcı ara" />
            <span>@kullanicilar.Count kayıt</span>
        </div>
        <section class="people-grid">
            @foreach (var item in kullanicilar)
            {
                var ad = safe(item.UserAdi);
                var profil = string.Join(" / ", new[]
                {
                    item.Departman?.DepartmanAdi,
                    item.Unvan?.UnvanAdi,
                    item.Sehir?.SehiarAdi
                }.Where(x => !string.IsNullOrWhiteSpace(x)).DefaultIfEmpty("Profil bilgisi yok"));
                var arama = string.Join(" ", new[] { ad, item.UserTc, profil, item.Cinsiyet?.CinsiyetAdi, item.Egitim?.EgitimAdi, item.Sube?.SubeAdi, item.Yonetici?.YoneticiAdi }.Where(x => !string.IsNullOrWhiteSpace(x)));

                <article class="person-card" data-watch-person-card data-search="@arama">
                    @await Html.PartialAsync("_KatilimciAvatar", new survey.Models.KatilimciAvatarModel { Ad = ad, Resim = item.UserResim, Cinsiyet = item.Cinsiyet?.CinsiyetAdi, Size = "lg" })
                    <div class="person-main">
                        <div class="person-head">
                            <div>
                                <h2>@ad</h2>
                                <p>@profil</p>
                            </div>
                            <span class="status-chip @(item.Pasif == true ? "passive" : "active")">
                                @(item.Pasif == true ? "Pasif" : "Aktif")
                            </span>
                        </div>
                        <div class="person-meta">
                            <span><i class="fa fa-id-card"></i> @(string.IsNullOrWhiteSpace(item.UserTc) ? "-" : item.UserTc)</span>
                            <span><i class="fa fa-venus-mars"></i> @safe(item.Cinsiyet?.CinsiyetAdi)</span>
                            <span><i class="fa fa-graduation-cap"></i> @safe(item.Egitim?.EgitimAdi)</span>
                            <span><i class="fa fa-sitemap"></i> @safe(item.Sube?.SubeAdi)</span>
                            <span><i class="fa fa-user-tie"></i> @safe(item.Yonetici?.YoneticiAdi)</span>
                            <span><i class="fa fa-layer-group"></i> @safe(item.Yaka?.YakaAdi)</span>
                        </div>
                    </div>
                </article>
            }
        </section>
    }
    else
    {
        <section class="empty-center">
            <i class="fa fa-check-circle"></i>
            <h2>Katılmayan kullanıcı yok</h2>
            <p>Bu çalışma için bekleyen kullanıcı görünmüyor.</p>
            <a class="center-btn primary" href="@Url.Action("AnketIndex1", "Home", new { id = anketId })">
                Rapor Panosuna Dön
            </a>
        </section>
    }
</div>

<style>
    .watch-center {
        width: min(1500px, calc(100% - 48px));
        margin: 32px auto 56px;
        color: #061a35;
    }

    .watch-hero,
    .person-card,
    .empty-center {
        border: 1px solid #d3e1f4;
        border-radius: 14px;
        background: rgba(255, 255, 255, .96);
        box-shadow: 0 22px 55px rgba(24, 48, 88, .10);
    }

    .watch-hero {
        display: flex;
        justify-content: space-between;
        gap: 28px;
        padding: 34px;
        background: linear-gradient(130deg, rgba(225, 253, 246, .96), rgba(244, 247, 255, .9) 58%, rgba(255, 248, 229, .72)), #fff;
    }

    .eyebrow {
        display: inline-flex;
        color: #255ef5;
        font-size: 12px;
        font-weight: 900;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .watch-hero h1 {
        margin: 10px 0 8px;
        font-size: 38px;
        font-weight: 950;
        letter-spacing: 0;
    }

    .watch-hero p {
        max-width: 760px;
        margin: 0;
        color: #53627a;
        font-size: 15px;
        line-height: 1.7;
    }

    .hero-chips,
    .person-meta,
    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .hero-chips {
        margin-top: 20px;
    }

    .hero-chips span,
    .person-meta span {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        border-radius: 999px;
        background: #eef5ff;
        color: #24436d;
        font-size: 12px;
        font-weight: 850;
        padding: 8px 11px;
    }

    .hero-chips i {
        color: #11a99b;
    }

    .hero-actions {
        align-items: flex-start;
        justify-content: flex-end;
        min-width: 280px;
    }

    .people-tools {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 18px;
    }

    .people-tools span {
        border-radius: 999px;
        background: #eef5ff;
        color: #24436d;
        font-size: 12px;
        font-weight: 850;
        padding: 8px 11px;
    }

    .person-search {
        width: min(280px, 100%);
        min-height: 40px;
        border: 1px solid #cfe0f6;
        border-radius: 10px;
        padding: 0 12px;
        color: #071832;
        background: #fff;
        font-weight: 850;
        outline: none;
    }

    .person-search:focus {
        border-color: #3562f4;
        box-shadow: 0 0 0 3px rgba(53, 98, 244, .12);
    }

    .center-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        min-height: 42px;
        border: 1px solid #cfe0f6;
        border-radius: 10px;
        background: #fff;
        color: #071832;
        font-weight: 900;
        text-decoration: none;
        padding: 0 16px;
        transition: transform .16s ease, box-shadow .16s ease;
    }

    .center-btn.primary {
        border-color: #22b8a6;
        background: linear-gradient(135deg, #16bca9, #3562f4);
        color: #fff;
        box-shadow: 0 16px 32px rgba(34, 105, 244, .18);
    }

    .center-btn:hover,
    .person-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 18px 38px rgba(19, 42, 80, .12);
        text-decoration: none;
    }

    .people-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
        max-height: 640px;
        margin-top: 12px;
        overflow-y: auto;
        padding-right: 6px;
    }

    .person-card {
        display: grid;
        grid-template-columns: 58px minmax(0, 1fr);
        gap: 16px;
        padding: 20px;
        transition: transform .16s ease, box-shadow .16s ease;
    }

    .person-avatar {
        display: grid;
        place-items: center;
        width: 56px;
        height: 56px;
        border-radius: 17px;
        background: linear-gradient(135deg, #18b7a4, #5065f6);
        color: #fff;
        font-size: 21px;
        font-weight: 950;
        box-shadow: 0 14px 28px rgba(80, 101, 246, .20);
    }

    .person-head {
        display: flex;
        justify-content: space-between;
        gap: 14px;
    }

    .person-head h2 {
        margin: 0;
        font-size: 20px;
        font-weight: 950;
    }

    .person-head p {
        margin: 6px 0 12px;
        color: #64748b;
        font-weight: 750;
    }

    .status-chip {
        align-self: flex-start;
        border-radius: 999px;
        padding: 8px 11px;
        font-size: 12px;
        font-weight: 900;
        white-space: nowrap;
    }

    .status-chip.active {
        background: #e6fff7;
        color: #047864;
    }

    .status-chip.passive {
        background: #eef2f7;
        color: #64748b;
    }

    .empty-center {
        display: grid;
        place-items: center;
        gap: 10px;
        margin-top: 18px;
        padding: 48px 24px;
        text-align: center;
    }

    .empty-center i {
        display: grid;
        place-items: center;
        width: 72px;
        height: 72px;
        border-radius: 22px;
        background: #e6fff7;
        color: #047864;
        font-size: 28px;
    }

    .empty-center h2 {
        margin: 8px 0 0;
        font-size: 24px;
        font-weight: 950;
    }

    .empty-center p {
        margin: 0 0 10px;
        color: #64748b;
        font-weight: 700;
    }

    @@media (max-width: 900px) {
        .watch-hero,
        .people-grid,
        .person-card {
            display: grid;
            grid-template-columns: 1fr;
        }

        .hero-actions {
            min-width: 0;
            justify-content: stretch;
        }

        .center-btn {
            flex: 1 1 100%;
        }
    }
</style>

<script>
    (() => {
        const search = document.querySelector("[data-watch-person-search]");
        const cards = Array.from(document.querySelectorAll("[data-watch-person-card]"));
        if (!search || cards.length === 0) {
            return;
        }

        search.addEventListener("input", () => {
            const query = search.value.toLocaleLowerCase("tr-TR").trim();
            cards.forEach(card => {
                const haystack = (card.dataset.search || "").toLocaleLowerCase("tr-TR");
                card.hidden = query.length > 0 && !haystack.includes(query);
            });
        });
    })();
</script>
